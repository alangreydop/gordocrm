{
  "name": "grande-gordo",
  "version": "0.1.0",
  "description": "Grande&Gordo CRM API on Cloudflare Workers + D1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --project tsconfig.build.json",
    "build:portal": "npm --prefix portal run build",
    "check:portal": "npm --prefix portal run check",
    "deploy": "npm run build:portal && wrangler deploy --env production",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:migrate": "wrangler d1 migrations apply gordocrm --local",
    "db:migrate:remote": "wrangler d1 migrations apply gordocrm --remote",
    "db:seed": "node --import tsx db/seed.ts --local",
    "db:seed:remote": "node --import tsx db/seed.ts --remote"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@fal-ai/client": "^1.0.0",
    "airtable": "^0.12.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.9.2",
    "ioredis": "^5.0.0",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "resend": "^3.0.0",
    "stripe": "^14.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "wrangler": "^4.27.0"
  }
}
