---
import BaseLayout from './BaseLayout.astro';
import { siteLinks } from '../lib/site-links';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
    { href: '/client', label: 'Resumen' },
    { href: '/client/assets', label: 'Assets' },
    { href: '/client/history', label: 'Historial' },
    { href: '/client/profile', label: 'Perfil' },
];
---

<BaseLayout title={title}>
    <div class="crm-body min-h-screen">
        <div class="flex min-h-screen flex-col lg:flex-row">
            <!-- Skip navigation -->
             <a href="#client-main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-crm-accent focus:text-white focus:rounded-lg">
                 saltar al contenido
             </a>

             <!-- Mobile overlay -->
             <div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/40 backdrop-blur-sm hidden lg:hidden"></div>

             <!-- Dark Sidebar -->
             <aside id="main-sidebar" role="navigation" aria-label="Área de cliente" class="crm-sidebar w-full px-5 py-6 lg:w-72 lg:py-8 transition-all duration-300 ease-in-out -translate-x-full lg:translate-x-0 fixed lg:static z-40 h-full overflow-y-auto lg:border-r lg:border-b-0 border-b" style="border-color: var(--crm-sidebar-border);">
                 <!-- Brand Block -->
                 <div class="mb-6">
                     <div class="flex items-center gap-3">
                         <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2813.19 1671.88" class="h-9 w-auto" aria-hidden="true">
                             <path d="M1177.85 429.55c11.51 0 20.72-3.89 27.63-11.66s11.22-20.87 12.95-39.29c2.88-27.06 11.37-47.06 25.47-60.01 14.1-12.95 32.09-19.43 53.97-19.43 24.18 0 43.61 8.63 58.29 25.9 14.68 17.27 22.02 42.6 22.02 75.99v35.4l-134.7 64.76c-17.27 8.06-31.66 15.83-43.18 23.31-11.51 7.48-20.72 15.11-27.63 22.88s-11.8 15.97-14.68 24.61c-2.88 8.63-4.32 18.42-4.32 29.36 0 25.33 8.78 45.91 26.34 61.74 17.56 15.83 40.73 23.75 69.51 23.75 25.9 0 49.79-6.33 71.67-19 21.87-12.66 40.87-31.66 56.99-56.99 1.73 23.6 8.01 65.63 102.99 65.63h183.52V363.91c23.03-34.54 53.4-51.81 92.55-51.81 23.6 0 42.6 7.63 56.99 22.88s21.59 38.42 21.59 69.51v223.64c0 5.18-.86 9.07-2.59 11.66s-5.47 4.46-11.23 5.61l-41.45 5.18v25.9h193.42v-25.9l-43.18-5.18c-5.76-1.15-9.5-3.02-11.22-5.61-1.73-2.59-2.59-6.48-2.59-11.66V398.44c0-42.02-11.8-74.55-35.4-97.57-23.6-23.03-54.4-34.54-92.39-34.54-26.48 0-50.51 5.9-72.1 17.7-21.59 11.8-38.58 28.93-52.4 51.38V264.6l-138 35.4v12.09l43.18 18.13c5.76 2.88 9.35 5.61 10.79 8.2 1.44 2.59 2.16 7.05 2.16 13.38v266.36c-13.82-16.69-31.09-29.5-51.81-38.42-20.72-8.92-43.46-13.38-68.21-13.38s-50.23 5.18-72.97 15.54c-22.74 10.36-42.6 25.04-59.58 44.04-16.98 19-30.36 41.88-40.15 68.65-9.79 26.77-14.68 56.27-14.68 88.51s4.61 60.01 13.82 85.05 21.73 46.34 37.56 63.9Zm38.86-227.1c6.04-21.01 14.68-38.71 25.9-53.1 11.22-14.39 24.32-25.47 39.29-33.24 14.97-7.77 31.66-11.66 50.08-11.66 21.87 0 41.45 4.46 58.72 13.38 17.27 8.92 31.66 21.73 43.17 38.42v224.51c-13.24 17.27-28.35 30.51-45.33 39.72-16.98 9.21-36.41 13.82-58.29 13.82-16.69 0-32.38-3.74-47.06-11.22s-27.63-18.28-38.86-32.38c-11.22-14.1-20.15-31.09-26.77-50.95-6.62-19.86-9.93-42.17-9.93-66.92s3.02-49.36 9.07-70.37Z" fill="currentColor" class="text-crm-accent"/>
                         </svg>
                         <div>
                             <p class="text-[0.65rem] font-bold uppercase tracking-[0.28em]" style="color: var(--crm-accent-light);">Grande &amp; Gordo</p>
                             <h1 class="mt-0.5 text-lg font-black tracking-tight" style="color: var(--crm-sidebar-text-active);">área de cliente</h1>
                         </div>
                     </div>
                     <p class="mt-2 text-xs leading-relaxed" style="color: var(--crm-sidebar-text);">
                        tu proyecto, aquí.
                     </p>
                 </div>

                 <!-- Navigation -->
                 <nav class="grid gap-1">
                     {navItems.map((item) => {
                        const active =
                            item.href === '/client'
                                 ? pathname === '/client'
                                 : pathname.startsWith(item.href);

                        return (
                             <a
                                href={item.href}
                                aria-current={active ? 'page' : undefined}
                                class:list={[
                                     'crm-sidebar-link block rounded-xl px-4 py-2.5 text-sm transition',
                                    active ? 'crm-sidebar-link--active font-semibold' : '',
                                 ]}
                                style={active ? '' : ''}
                             >
                                 {item.label.toLowerCase()}
                             </a>
                         );
                     })}
                 </nav>

                 <!-- Connected Resources -->
                 <div class="mt-6 pt-6" style="border-top: 1px solid var(--crm-sidebar-border);">
                     <p class="text-[0.65rem] font-bold tracking-[0.06em] mb-3" style="color: var(--crm-sidebar-text);">recursos</p>
                     <div class="space-y-0.5 text-sm">
                         <a href={siteLinks.portalHub} target="_blank" rel="noreferrer" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              Centro de cliente
                         </a>
                         <a href="/client/pricing" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              Planes y precios
                         </a>
                         <a href={siteLinks.cases} target="_blank" rel="noreferrer" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              Casos de éxito
                         </a>
                         <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              Brief de proyecto
                         </a>
                         <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              Onboarding
                         </a>
                         <a href="/client/faq" class="crm-sidebar-link block rounded-lg px-3 py-2 transition">
                              FAQ
                         </a>
                     </div>
                 </div>

                 <!-- User block at bottom -->
                 <div class="mt-auto pt-6" style="border-top: 1px solid var(--crm-sidebar-border); margin-top: auto;">
                     <p class="text-[0.65rem] font-bold tracking-[0.06em] mb-1" style="color: var(--crm-sidebar-text);">soporte</p>
                     <p class="text-sm font-medium" style="color: var(--crm-sidebar-text-active);">{siteLinks.supportEmail}</p>
                     <p id="sidebar-user-name" class="mt-3 text-sm font-semibold" style="color: var(--crm-sidebar-text-active);">cargando...</p>
                     <p id="sidebar-user-email" class="text-xs" style="color: var(--crm-sidebar-text);"></p>
                     <button type="button" id="logout-button" class="mt-3 text-sm cursor-pointer transition" style="color: var(--crm-sidebar-text);">
                          Cerrar sesion
                     </button>
                 </div>

                 <div class="mt-4 flex flex-wrap gap-4 text-xs" style="color: var(--crm-sidebar-text);">
                     <a href="/client/legal/terms" class="hover:underline transition">Términos</a>
                     <a href="/client/legal/privacy" class="hover:underline transition">Privacidad</a>
                 </div>
             </aside>

             <!-- Light Content Area -->
             <main id="client-main" class="crm-main flex-1 min-h-screen" style="background: var(--crm-bg);" role="main" aria-label="Contenido del área de cliente">
                 <div class="mx-auto max-w-7xl px-6 py-8">
                     <!-- Mobile header -->
                     <div class="flex items-center justify-between mb-6">
                         <div class="flex items-center gap-4">
                             <button id="sidebar-toggle" class="p-2 rounded-xl crm-button crm-button-secondary" aria-label="Abrir menú de navegación" style="min-height: 44px; min-width: 44px;">
                                 <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                             </button>
                             <nav id="breadcrumbs" class="text-sm" aria-label="Breadcrumbs">
                                 <ol class="flex items-center gap-2" style="color: var(--crm-muted);">
                                     <li><a href="/client" class="transition" style="color: var(--crm-muted);">Resumen</a></li>
                                 </ol>
                             </nav>
                         </div>
                         <div class="relative">
                             <button id="notifications-btn" class="relative rounded-full p-2 crm-button crm-button-secondary" aria-label="Notificaciones" aria-expanded="false" aria-controls="notifications-dropdown" style="min-height: 44px; min-width: 44px;">
                                 <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                                 </svg>
                                 <span id="notifications-badge" class="absolute top-1 right-1 w-2.5 h-2.5 rounded-full hidden" style="background: var(--crm-accent);"></span>
                             </button>
                             <!-- Notifications Dropdown -->
                             <div id="notifications-dropdown" class="hidden absolute right-0 mt-2 w-80 rounded-2xl shadow-2xl z-50 crm-panel" role="menu" aria-label="Notificaciones">
                                 <div class="p-4" style="border-bottom: 1px solid var(--crm-border);">
                                     <div class="flex items-center justify-between">
                                         <h3 class="font-semibold" style="color: var(--crm-text);">Notificaciones</h3>
                                         <button id="mark-all-read-btn" class="text-sm crm-button crm-button-secondary" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;" role="menuitem">Marcar todas como leídas</button>
                                     </div>
                                 </div>
                                 <div id="notifications-list" class="max-h-96 overflow-y-auto" role="list"></div>
                             </div>
                         </div>
                     </div>
                     <slot />
                 </div>
             </main>
         </div>
     </div>

     <script>
         (async () => {
        const { logout, requireRole } = await import('../lib/api-client');

        const user = await requireRole('client');
        if (user) {
            const name = document.getElementById('sidebar-user-name');
            const email = document.getElementById('sidebar-user-email');

            if (name) name.textContent = user.name;
            if (email) email.textContent = user.email;
         }

        document.getElementById('logout-button')?.addEventListener('click', async () => {
            await logout();
            window.location.href = '/login';
         });

         // Notificaciones
        const notificationsBtn = document.getElementById('notifications-btn');
        const notificationsDropdown = document.getElementById('notifications-dropdown');
        const notificationsList = document.getElementById('notifications-list');
        const notificationsBadge = document.getElementById('notifications-badge');
        const markAllReadBtn = document.getElementById('mark-all-read-btn');

        const formatNotificationTime = (dateString) => {
            const date = new Date(dateString);
            const now = new Date();
            const diffMs = now.getTime() - date.getTime();
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMins / 60);
            const diffDays = Math.floor(diffHours / 24);

            if (diffMins < 1) return 'Ahora mismo';
            if (diffMins < 60) return `Hace ${diffMins}m`;
            if (diffHours < 24) return `Hace ${diffHours}h`;
            if (diffDays < 7) return `Hace ${diffDays}d`;
            return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
         };

        const getNotificationIcon = (type) => {
            switch (type) {
                case 'job_completed': return 'listo';
                case 'job_updated': return 'actualizado';
                case 'feedback_received': return 'feedback';
                case 'message': return 'mensaje';
                case 'reminder': return 'recordatorio';
                default: return 'notificacion';
             }
         };

        let notificationsData = [];

        const loadNotifications = async () => {
            try {
                const { api } = await import('../lib/api-client');
                const data = await api('/api/portal/notifications');
                notificationsData = data.notifications || [];

                if (notificationsBadge) {
                    if (data.unreadCount > 0) {
                        notificationsBadge.classList.remove('hidden');
                     } else {
                        notificationsBadge.classList.add('hidden');
                     }
                 }

                if (notificationsList) {
                    if (notificationsData.length === 0) {
                        notificationsList.innerHTML = '<p class="p-4 text-sm text-center" style="color: var(--crm-muted);">No hay notificaciones</p>';
                     } else {
                        notificationsList.innerHTML = notificationsData.map((notif) => `
                             <div class="p-4 transition" style="border-bottom: 1px solid var(--crm-border); ${!notif.read ? 'background: var(--crm-accent-soft);' : ''}" role="listitem">
                                 <div class="flex items-start gap-3">
                                     <span class="text-lg">${getNotificationIcon(notif.type)}</span>
                                     <div class="flex-1 min-w-0">
                                         <p class="text-sm font-medium truncate" style="color: var(--crm-text);">${notif.title}</p>
                                         <p class="text-xs mt-0.5" style="color: var(--crm-muted);">${notif.message}</p>
                                         <p class="text-xs mt-2" style="color: var(--crm-subtle);">${formatNotificationTime(notif.createdAt)}</p>
                                     </div>
                                     ${!notif.read ? '<span class="w-2 h-2 rounded-full flex-shrink-0 mt-1" style="background: var(--crm-info);"></span>' : ''}
                                 </div>
                             </div>
                         `).join('');
                     }
                 }
             } catch (error) {
                console.error('Failed to load notifications:', error);
                if (notificationsList) {
                    notificationsList.innerHTML = '<p class="p-4 text-sm text-center" style="color: var(--crm-muted);">No se pudieron cargar las notificaciones</p>';
                 }
             }
         };

        const markAllAsRead = async () => {
            try {
                const { api } = await import('../lib/api-client');
                await api('/api/portal/notifications/mark-all-read', { method: 'POST' });
                await loadNotifications();
             } catch (error) {
                console.error('Failed to mark notifications as read:', error);
             }
         };

        notificationsBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            const isHidden = notificationsDropdown?.classList.contains('hidden');
            if (isHidden) {
                notificationsBtn.setAttribute('aria-expanded', 'true');
                loadNotifications();
             } else {
                notificationsBtn.setAttribute('aria-expanded', 'false');
             }
            notificationsDropdown?.classList.toggle('hidden');
         });

        document.addEventListener('click', (e) => {
            if (notificationsDropdown && !notificationsDropdown.contains(e.target) && !notificationsBtn?.contains(e.target)) {
                notificationsDropdown.classList.add('hidden');
                notificationsBtn?.setAttribute('aria-expanded', 'false');
             }
         });

        markAllReadBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            markAllAsRead();
         });

         // Reduce polling from 30s to 60s (performance fix)
        setInterval(loadNotifications, 60000);

         // Close dropdown on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && notificationsDropdown && !notificationsDropdown.classList.contains('hidden')) {
                notificationsDropdown.classList.add('hidden');
                notificationsBtn?.setAttribute('aria-expanded', 'false');
             }
         });

         // Breadcrumbs
        const breadcrumbs = document.getElementById('breadcrumbs');
        if (breadcrumbs) {
            const path = window.location.pathname;
            const pages = {
                 '/client/assets': { label: 'Assets', href: '/client/assets' },
                 '/client/history': { label: 'Historial', href: '/client/history' },
                 '/client/profile': { label: 'Perfil', href: '/client/profile' },
                 '/client/jobs': { label: 'Trabajos', href: '/client/jobs' },
                 '/client/jobs/detail': { label: 'Trabajos', href: '/client/jobs' },
                 '/client/onboarding': { label: 'Onboarding', href: '/client/onboarding' },
                 '/client/hub': { label: 'Centro de cliente', href: '/client/hub' },
            };

            const currentPage = Object.entries(pages).find(([key]) => path.startsWith(key));
            if (currentPage && (path !== '/client' && path !== '/client/')) {
                const ol = breadcrumbs.querySelector('ol');
                const li = document.createElement('li');
                li.className = 'flex items-center gap-2';
                li.innerHTML = `
                     <svg class="w-3.5 h-3.5" style="color: var(--crm-subtle);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                     ${currentPage[1].href ? `<a href="${currentPage[1].href}" class="transition" style="color: var(--crm-muted);">${currentPage[1].label}</a>` : `<span style="color: var(--crm-text);">${currentPage[1].label}</span>`}
                 `;
                if (path.includes('/detail')) {
                    li.innerHTML += `
                         <span class="flex items-center gap-2">
                             <svg class="w-3.5 h-3.5" style="color: var(--crm-subtle);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                             <span style="color: var(--crm-text);">Detalle</span>
                         </span>
                     `;
                 }
                ol.appendChild(li);
             }
         }

         // Sidebar Mobile Toggle
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const mainSidebar = document.getElementById('main-sidebar');
        const sidebarOverlay = document.getElementById('sidebar-overlay');

        const toggleSidebar = (open) => {
            if (open) {
                mainSidebar?.classList.remove('-translate-x-full');
                sidebarOverlay?.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
             } else {
                mainSidebar?.classList.add('-translate-x-full');
                sidebarOverlay?.classList.add('hidden');
                document.body.style.overflow = '';
             }
         };

        sidebarToggle?.addEventListener('click', () => toggleSidebar(true));
        sidebarOverlay?.addEventListener('click', () => toggleSidebar(false));

         // Close sidebar on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mainSidebar && !mainSidebar.classList.contains('-translate-x-full')) {
                toggleSidebar(false);
             }
         });

         // Welcome Modal
        const welcomeModal = document.getElementById('welcome-modal');
        const welcomeTourBtn = document.getElementById('welcome-tour-btn');
        const welcomeStartBtn = document.getElementById('welcome-start-btn');
        const hasSeenWelcome = localStorage.getItem('gordo_welcome_seen');

        if (!hasSeenWelcome && welcomeModal) {
            welcomeModal.classList.remove('hidden');
            welcomeModal.classList.add('flex');
            document.body.style.overflow = 'hidden';

            const closeWelcome = () => {
                localStorage.setItem('gordo_welcome_seen', 'true');
                welcomeModal.classList.add('hidden');
                welcomeModal.classList.remove('flex');
                document.body.style.overflow = '';
             };

            welcomeStartBtn?.addEventListener('click', closeWelcome);
            welcomeTourBtn?.addEventListener('click', () => {
                closeWelcome();
             });
            welcomeModal.addEventListener('click', (e) => {
                if (e.target === welcomeModal) closeWelcome();
             });
        }
         // Close modal on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && welcomeModal && !welcomeModal.classList.contains('hidden')) {
                welcomeModal.classList.add('hidden');
                welcomeModal.classList.remove('flex');
                document.body.style.overflow = '';
             }
         });
         // Close modal on overlay click
         if (welcomeModal) {
            welcomeModal.addEventListener('click', (e) => {
                if (e.target === welcomeModal) {
                    welcomeModal.classList.add('hidden');
                    welcomeModal.classList.remove('flex');
                    document.body.style.overflow = '';
                 }
             });
         }
         })();
     </script>
</BaseLayout>
