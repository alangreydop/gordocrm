---
import BaseLayout from './BaseLayout.astro';
import { siteLinks } from '../lib/site-links';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/client', label: 'Resumen' },
  { href: '/client/assets', label: 'Assets' },
  { href: '/client/history', label: 'Historial' },
  { href: '/client/profile', label: 'Perfil' },
];
---

<BaseLayout title={title}>
  <div class="min-h-screen bg-black text-white">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <aside class="w-full border-b border-zinc-900 bg-black px-6 py-6 lg:w-80 lg:border-b-0 lg:border-r lg:px-6 lg:py-8">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2813.19 1671.88" class="h-8 w-auto" aria-hidden="true">
              <path d="M1177.85 429.55c11.51 0 20.72-3.89 27.63-11.66s11.22-20.87 12.95-39.29c2.88-27.06 11.37-47.06 25.47-60.01 14.1-12.95 32.09-19.43 53.97-19.43 24.18 0 43.61 8.63 58.29 25.9 14.68 17.27 22.02 42.6 22.02 75.99v35.4l-134.7 64.76c-17.27 8.06-31.66 15.83-43.18 23.31-11.51 7.48-20.72 15.11-27.63 22.88s-11.8 15.97-14.68 24.61c-2.88 8.63-4.32 18.42-4.32 29.36 0 25.33 8.78 45.91 26.34 61.74 17.56 15.83 40.73 23.75 69.51 23.75 25.9 0 49.79-6.33 71.67-19 21.87-12.66 40.87-31.66 56.99-56.99 1.73 23.6 8.01 65.63 102.99 65.63h183.52V363.91c23.03-34.54 53.4-51.81 92.55-51.81 23.6 0 42.6 7.63 56.99 22.88s21.59 38.42 21.59 69.51v223.64c0 5.18-.86 9.07-2.59 11.66s-5.47 4.46-11.23 5.61l-41.45 5.18v25.9h193.42v-25.9l-43.18-5.18c-5.76-1.15-9.5-3.02-11.22-5.61-1.73-2.59-2.59-6.48-2.59-11.66V398.44c0-42.02-11.8-74.55-35.4-97.57-23.6-23.03-54.4-34.54-92.39-34.54-26.48 0-50.51 5.9-72.1 17.7-21.59 11.8-38.58 28.93-52.4 51.38V264.6l-138 35.4v12.09l43.18 18.13c5.76 2.88 9.35 5.61 10.79 8.2 1.44 2.59 2.16 7.05 2.16 13.38v276.31c0 5.18-.86 9.07-2.59 11.66s-8.39 8.21-14.15 9.36h-57.56c-44.61-5.76-50.89-38.86-50.89-53.83V414.83c.57-48.93-12.09-85.92-37.99-110.96-25.91-25.04-64.19-37.56-114.84-37.56-22.45 0-43.61 3.45-63.47 10.36-19.86 6.91-37.13 15.97-51.81 27.2-14.68 11.23-26.34 15.97-34.97 38.86-8.63 14.68-12.95 29.79-12.95 45.33 0 13.24 3.45 23.46 10.36 30.65 6.91 7.2 15.54 10.79 25.9 10.79Zm200.33 156.29c-24.18 33.39-52.67 50.08-85.48 50.08-17.27 0-31.09-4.75-41.45-14.25-10.36-9.5-15.54-22.88-15.54-40.15 0-15.54 4.17-28.93 12.52-40.15 8.35-11.23 23.46-22.59 45.33-34.11l84.62-44.04v122.61ZM2020.15 632.04c15.83 17.56 34.39 31.09 55.69 40.58 21.3 9.5 44.04 14.25 68.21 14.25 26.48 0 51.38-6.62 74.69-19.86 23.31-13.24 41.84-31.37 56.81-53.82v92.1l82.03-28.78.61-675.95L2220.03 0v12.08l43.17 18.13c5.76 2.88 9.35 5.61 10.79 8.2 1.44 2.59 2.16 7.05 2.16 13.38v266.36c-13.82-16.69-31.09-29.5-51.81-38.42-20.72-8.92-43.46-13.38-68.21-13.38s-50.23 5.18-72.97 15.54c-22.74 10.36-42.6 25.04-59.58 44.04-16.98 19-30.36 41.88-40.15 68.65-9.79 26.77-14.68 56.27-14.68 88.51s4.61 60.01 13.82 85.05 21.73 46.34 37.56 63.9Zm38.86-227.1c6.04-21.01 14.68-38.71 25.9-53.1 11.22-14.39 24.32-25.47 39.29-33.24 14.97-7.77 31.66-11.66 50.08-11.66 21.87 0 41.45 4.46 58.72 13.38 17.27 8.92 31.66 21.73 43.17 38.42v224.51c-13.24 17.27-28.35 30.51-45.33 39.72-16.98 9.21-36.41 13.82-58.29 13.82-16.69 0-32.38-3.74-47.06-11.22s-27.63-18.28-38.86-32.38c-11.22-14.1-20.15-31.09-26.77-50.95-6.62-19.86-9.93-42.17-9.93-66.92s3.02-49.36 9.07-70.37Z" fill="#fff"/>
            </svg>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Grande &amp; Gordo</p>
              <h1 class="mt-1 text-xl font-black tracking-tight text-white">Portal cliente</h1>
            </div>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Tu operativa vive aqui. La web te acompana con contexto; el CRM te da
            seguimiento, entregables y visibilidad de cuenta.
          </p>
        </div>

        <nav class="mt-6 grid gap-2">
          {navItems.map((item) => {
            const active =
              item.href === '/client'
                ? pathname === '/client'
                : pathname.startsWith(item.href);

            return (
              <a
                href={item.href}
                class:list={[
                  'block rounded-2xl px-4 py-3 text-sm transition',
                  active
                    ? 'bg-white text-black font-semibold'
                    : 'text-zinc-400 hover:bg-zinc-900 hover:text-white',
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="mt-6 rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Recursos conectados</p>
          <div class="mt-4 space-y-2 text-sm">
            <a href={siteLinks.portalHub} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-zinc-400 transition hover:bg-zinc-900 hover:text-white">
              Centro de cliente
            </a>
            <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-zinc-400 transition hover:bg-zinc-900 hover:text-white">
              Brief de proyecto
            </a>
            <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-zinc-400 transition hover:bg-zinc-900 hover:text-white">
              Onboarding
            </a>
            <a href={siteLinks.home} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-zinc-400 transition hover:bg-zinc-900 hover:text-white">
              Web publica
            </a>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-zinc-800 bg-zinc-950 p-5 lg:mt-auto">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Soporte</p>
          <p class="mt-3 text-sm font-medium text-white">{siteLinks.supportEmail}</p>
          <p id="sidebar-user-name" class="mt-5 text-sm font-semibold text-white">Cargando...</p>
          <p id="sidebar-user-email" class="mt-1 text-xs text-zinc-500"></p>
          <button type="button" id="logout-button" class="mt-4 text-sm text-zinc-400 hover:text-white cursor-pointer">
            Cerrar sesion
          </button>
        </div>
      </aside>

      <main class="flex-1 px-6 py-10">
        <div class="mx-auto max-w-7xl">
          <slot />
        </div>
      </main>
    </div>
  </div>

  <script>
    (async () => {
    const { logout, requireRole } = await import('../lib/api-client');

    const user = await requireRole('client');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });
    })();
  </script>
</BaseLayout>
