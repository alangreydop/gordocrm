---
import BaseLayout from './BaseLayout.astro';
import { siteLinks } from '../lib/site-links';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/client', label: 'Resumen' },
  { href: '/client/profile', label: 'Perfil' },
];
---

<BaseLayout title={title}>
  <div class="crm-shell flex min-h-screen flex-col lg:flex-row">
    <aside class="crm-sidebar crm-sidebar--client w-full p-5 text-white lg:w-80 lg:p-7">
      <div class="crm-panel-soft p-5">
        <p class="crm-kicker">Grande &amp; Gordo</p>
        <h1 class="mt-3 text-2xl font-black tracking-tight text-white">Portal cliente</h1>
        <p class="mt-3 text-sm leading-relaxed text-slate-300">
          Tu operativa vive aqui. La web te acompana con contexto; el CRM te da
          seguimiento, entregables y visibilidad de cuenta.
        </p>
      </div>

      <nav class="mt-6 grid gap-2">
        {navItems.map((item) => {
          const active =
            item.href === '/client'
              ? pathname === '/client'
              : pathname.startsWith(item.href);

          return (
            <a
              href={item.href}
              class:list={[
                'block rounded-2xl px-4 py-3 text-sm transition',
                active
                  ? 'bg-white text-slate-950 font-semibold shadow-lg shadow-black/20'
                  : 'text-blue-50 hover:bg-white/6 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="crm-panel-soft mt-6 p-5">
        <p class="crm-kicker">Recursos conectados</p>
        <div class="mt-4 space-y-2 text-sm">
          <a href={siteLinks.portalHub} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-slate-200 transition hover:bg-white/6 hover:text-white">
            Centro de cliente
          </a>
          <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-slate-200 transition hover:bg-white/6 hover:text-white">
            Brief de proyecto
          </a>
          <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-slate-200 transition hover:bg-white/6 hover:text-white">
            Onboarding
          </a>
          <a href={siteLinks.home} target="_blank" rel="noreferrer" class="block rounded-xl px-3 py-2 text-slate-200 transition hover:bg-white/6 hover:text-white">
            Web publica
          </a>
        </div>
      </div>

      <div class="crm-panel-soft mt-6 p-5 lg:mt-auto">
        <p class="crm-kicker">Soporte</p>
        <p class="mt-3 text-sm font-medium text-white">{siteLinks.supportEmail}</p>
        <p id="sidebar-user-name" class="mt-5 text-sm font-semibold text-slate-100">Cargando...</p>
        <p id="sidebar-user-email" class="mt-1 text-xs text-slate-400"></p>
        <button type="button" id="logout-button" class="mt-4 text-sm font-medium text-slate-300 hover:text-white cursor-pointer">
          Cerrar sesion
        </button>
      </div>
    </aside>

    <main class="crm-main">
      <div class="mx-auto max-w-7xl">
        <slot />
      </div>
    </main>
  </div>

  <script>
    (async () => {
    const { logout, requireRole } = await import('../lib/api-client');

    const user = await requireRole('client');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });
    })();
  </script>
</BaseLayout>
