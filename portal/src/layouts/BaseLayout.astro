---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Grande & Gordo</title>
    <meta name="theme-color" content="#05070b" />
    <link
      rel="preload"
      href="/Satoshi-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="crm-body min-h-screen">
    <slot />
  </body>
</html>
