---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <aside class="w-64 bg-gray-900 text-white p-6">
      <h1 class="text-xl font-bold mb-8">Grande&Gordo</h1>
      <nav class="space-y-2">
        <a href="/admin" class="block px-3 py-2 rounded hover:bg-gray-800">Dashboard</a>
        <a href="/admin/clients" class="block px-3 py-2 rounded hover:bg-gray-800">Clientes</a>
        <a href="/admin/jobs" class="block px-3 py-2 rounded hover:bg-gray-800">Trabajos</a>
      </nav>
      <div class="mt-auto pt-8 border-t border-gray-700 mt-8">
        <p id="sidebar-user-name" class="text-sm text-gray-400">Cargando...</p>
        <p id="sidebar-user-email" class="text-xs text-gray-500"></p>
        <button type="button" id="logout-button" class="text-sm text-gray-400 hover:text-white mt-2 cursor-pointer">
          Cerrar sesion
        </button>
      </div>
    </aside>
    <main class="flex-1 p-8">
      <slot />
    </main>
  </div>

  <script>
    (async () => {
    const { logout, requireRole } = await import('../lib/api-client');

    const user = await requireRole('admin');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });
    })();
  </script>
</BaseLayout>
