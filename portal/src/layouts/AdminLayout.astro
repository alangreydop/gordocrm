---
import BaseLayout from './BaseLayout.astro';
import { siteLinks } from '../lib/site-links';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const primaryNavItems = [
    { href: '/admin', label: 'operaciones' },
    { href: '/admin/clients', label: 'clientes' },
    { href: '/admin/briefs', label: 'briefs' },
    { href: '/admin/jobs', label: 'trabajos' },
    { href: '/admin/invoices', label: 'facturas' },
];
const secondaryNavItems = [
    { href: '/admin/pipeline-mappings', label: 'pipelines' },
    { href: '/admin/brand-graphs', label: 'brand graphs' },
    { href: '/admin/settings', label: 'cuenta interna' },
];
---

<BaseLayout title={title}>
    <div class="crm-shell">
        <a href="#admin-main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-crm-accent focus:text-white focus:rounded-lg">
            saltar al contenido
        </a>

        <div id="sidebar-overlay" class="crm-overlay fixed inset-0 z-30 hidden lg:hidden"></div>

        <div class="flex min-h-screen flex-col lg:flex-row">
            <aside id="main-sidebar" role="navigation" aria-label="Panel de control" class="crm-sidebar fixed z-40 flex h-full w-full flex-col overflow-y-auto px-5 py-6 transition-transform duration-300 ease-in-out -translate-x-full lg:static lg:w-72 lg:translate-x-0 lg:px-6 lg:py-8">
                <div class="crm-sidebar__section crm-sidebar__brand" style="padding-bottom: 1.75rem; margin-bottom: 1.75rem;">
                    <a href="/admin" aria-label="Grande&Gordo — Operaciones">
                        <img
                            src="https://logos.grandeandgordo.com/logoggblanco.png"
                            alt="Grande&Gordo"
                            width="160"
                            height="60"
                            style="width: 30%; height: auto; display: block; margin: 0 auto 1.25rem;"
                            loading="eager"
                            decoding="async"
                        />
                    </a>
                    <h1 class="crm-sidebar__title">consola operativa</h1>
                    <p class="crm-sidebar__copy">clientes, briefs, trabajos y facturas dentro de una sola capa interna, sin ruido comercial.</p>
                </div>

                <div class="crm-sidebar__section crm-sidebar__search">
                    <p class="crm-sidebar__nav-title" style="margin-bottom: 0.75rem;">búsqueda global</p>
                    <svg class="crm-sidebar__search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
                    <input
                        id="global-search"
                        type="text"
                        placeholder="buscar cliente, brief, trabajo o factura..."
                        aria-label="Buscar en el panel"
                        class="crm-sidebar__search-input"
                    />
                    <div id="search-results" class="absolute z-50 mt-2 hidden max-h-80 w-full overflow-y-auto rounded-2xl shadow-strong" style="background: var(--crm-panel); border: 1px solid var(--crm-border);"></div>
                </div>

                <nav class="crm-sidebar__section" aria-label="Navegación principal">
                    <div class="grid gap-3">
                        <p class="crm-sidebar__nav-title">operaciones</p>
                        <div class="crm-sidebar__nav">
                            {primaryNavItems.map((item) => {
                                const active =
                                    item.href === '/admin'
                                        ? pathname === '/admin'
                                        : pathname.startsWith(item.href);

                                return (
                                    <a
                                        href={item.href}
                                        aria-current={active ? 'page' : undefined}
                                        class:list={['crm-sidebar-link', active && 'crm-sidebar-link--active']}
                                    >
                                        {item.label}
                                    </a>
                                );
                            })}
                        </div>
                    </div>

                    <div class="grid gap-3">
                        <p class="crm-sidebar__nav-title">sistema</p>
                        <div class="crm-sidebar__nav">
                            {secondaryNavItems.map((item) => {
                                const active = pathname.startsWith(item.href);

                                return (
                                    <a
                                        href={item.href}
                                        aria-current={active ? 'page' : undefined}
                                        class:list={['crm-sidebar-link', active && 'crm-sidebar-link--active']}
                                    >
                                        {item.label}
                                    </a>
                                );
                            })}
                        </div>
                    </div>
                </nav>

                <div class="crm-sidebar__section crm-sidebar__meta">
                    <p class="crm-sidebar__meta-label">soporte</p>
                    <p class="crm-sidebar__meta-value">{siteLinks.supportEmail}</p>
                    <p id="sidebar-user-name" class="crm-sidebar__meta-value mt-3">cargando...</p>
                    <p id="sidebar-user-email" class="text-xs" style="color: var(--crm-sidebar-text);"></p>
                    <button type="button" id="logout-button" class="text-sm transition" style="color: var(--crm-sidebar-text); width: fit-content;">
                        cerrar sesión
                    </button>
                </div>

                <div class="crm-sidebar__legal">
                    <a href={siteLinks.home}>web principal</a>
                    <a href="/client">portal cliente</a>
                </div>
            </aside>

            <main id="admin-main" class="crm-main flex-1 min-h-screen" role="main" aria-label="Contenido principal">
                <div class="crm-main-frame">
                    <div class="crm-topbar">
                        <div class="crm-topbar__context">
                            <button id="sidebar-toggle" class="crm-topbar-button lg:hidden" aria-label="Abrir menú de navegación">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                            </button>
                            <div class="grid gap-1">
                                <p class="crm-topbar__eyebrow">admin</p>
                                <span id="admin-topbar-path" class="crm-topbar__path">consola operativa</span>
                            </div>
                        </div>
                    </div>

                    <div class="crm-main-content">
                        <slot />
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        (async () => {
        const { logout, requireRole, search, escapeHtml } = await import('../lib/api-client');

        const user = await requireRole('admin');
        if (user) {
            const name = document.getElementById('sidebar-user-name');
            const email = document.getElementById('sidebar-user-email');

            if (name) name.textContent = user.name;
            if (email) email.textContent = user.email;
        }

        document.getElementById('logout-button')?.addEventListener('click', async () => {
            await logout();
            window.location.href = '/login';
        });

        const formatSegment = (segment) =>
            segment
                .split('-')
                .filter(Boolean)
                .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
                .join(' ');

        const topbarPath = document.getElementById('admin-topbar-path');
        if (topbarPath) {
            const path = window.location.pathname.replace(/\/+$/, '');
            const segments = path.split('/').filter(Boolean).slice(1);
            topbarPath.textContent = segments.length > 0
                ? segments.map(formatSegment).join(' / ')
                : 'consola operativa';
        }

        // Global search
        const searchInput = document.getElementById('global-search');
        const searchResults = document.getElementById('search-results');
        let debounceTimer = null;

        searchInput?.addEventListener('input', () => {
            if (debounceTimer) clearTimeout(debounceTimer);
            debounceTimer = setTimeout(async () => {
                const q = searchInput.value.trim();
                if (!q || !searchResults) {
                    searchResults?.classList.add('hidden');
                    return;
                }
                try {
                    const data = await search(q);
                    let html = '';
                    if (data.clients.length > 0) {
                        html += '<div class="px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.2em]" style="color: var(--crm-muted); border-bottom: 1px solid var(--crm-border);">Clientes</div>';
                        for (const c of data.clients) {
                            html += `<a href="/admin/clients/detail?id=${encodeURIComponent(c.id)}" class="block px-4 py-3 text-sm transition" style="color: var(--crm-text-secondary);"><span class="font-medium" style="color: var(--crm-text);">${escapeHtml(c.name)}</span>${c.company ? ` <span style="color: var(--crm-muted);">— ${escapeHtml(c.company)}</span>` : ''}</a>`;
                        }
                    }
                    if (data.briefs.length > 0) {
                        html += '<div class="px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.2em]" style="color: var(--crm-muted); border-bottom: 1px solid var(--crm-border);">Briefs</div>';
                        for (const b of data.briefs) {
                            html += `<a href="/admin/briefs" class="block px-4 py-3 text-sm transition" style="color: var(--crm-text-secondary);"><span class="font-medium" style="color: var(--crm-text);">${escapeHtml(b.clientName ?? b.email)}</span> <span style="color: var(--crm-muted);">— ${escapeHtml(b.tipo)}</span></a>`;
                        }
                    }
                    if (data.jobs.length > 0) {
                        html += '<div class="px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.2em]" style="color: var(--crm-muted); border-bottom: 1px solid var(--crm-border);">Trabajos</div>';
                        for (const j of data.jobs) {
                            html += `<a href="/admin/jobs/detail?id=${encodeURIComponent(j.id)}" class="block px-4 py-3 text-sm transition" style="color: var(--crm-text-secondary);"><span class="font-medium" style="color: var(--crm-text);">${escapeHtml(j.briefText ?? '(sin brief)')}</span> <span style="color: var(--crm-muted);">— ${escapeHtml(j.clientName)}</span></a>`;
                        }
                    }
                    if (data.invoices.length > 0) {
                        html += '<div class="px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.2em]" style="color: var(--crm-muted); border-bottom: 1px solid var(--crm-border);">Facturas</div>';
                        for (const invoice of data.invoices) {
                            html += `<a href="/admin/invoices/detail?id=${encodeURIComponent(invoice.id)}" class="block px-4 py-3 text-sm transition" style="color: var(--crm-text-secondary);"><span class="font-medium" style="color: var(--crm-text);">${escapeHtml(invoice.invoiceNumber)}</span> <span style="color: var(--crm-muted);">— ${escapeHtml(invoice.clientLegalName)}</span></a>`;
                        }
                    }
                    if (!html) {
                        html = '<div class="px-4 py-3 text-sm" style="color: var(--crm-muted);">Sin resultados</div>';
                    }
                    searchResults.innerHTML = html;
                    searchResults.classList.remove('hidden');
                } catch {
                    searchResults?.classList.add('hidden');
                }
            }, 300);
        });

        document.addEventListener('click', (e) => {
            if (searchResults && !searchResults.contains(e.target) && e.target !== searchInput) {
                searchResults.classList.add('hidden');
            }
        });

        // Sidebar Mobile Toggle
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const mainSidebar = document.getElementById('main-sidebar');
        const sidebarOverlay = document.getElementById('sidebar-overlay');

        const toggleSidebar = (open) => {
            if (open) {
                mainSidebar?.classList.remove('-translate-x-full');
                sidebarOverlay?.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                mainSidebar?.classList.add('-translate-x-full');
                sidebarOverlay?.classList.add('hidden');
                document.body.style.overflow = '';
            }
        };

        sidebarToggle?.addEventListener('click', () => toggleSidebar(true));
        sidebarOverlay?.addEventListener('click', () => toggleSidebar(false));
        // Close sidebar on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mainSidebar && !mainSidebar.classList.contains('-translate-x-full')) {
                toggleSidebar(false);
            }
        });
        })();
    </script>
</BaseLayout>
