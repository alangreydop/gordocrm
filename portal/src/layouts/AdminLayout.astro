---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/clients', label: 'Clientes' },
  { href: '/admin/jobs', label: 'Trabajos' },
  { href: '/admin/briefs', label: 'Briefs' },
  { href: '/admin/settings', label: 'Configuracion' },
];
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <aside class="flex w-72 flex-col bg-gray-950 text-white p-6">
      <div class="mb-8">
        <p class="text-xs uppercase tracking-[0.3em] text-gray-500">Grande&Gordo</p>
        <h1 class="text-xl font-bold mt-2">CRM operativo</h1>
        <p class="text-sm text-gray-400 mt-2">Pipeline, produccion, margen y seguimiento en un solo sitio.</p>
      </div>
      <div class="relative mb-4">
        <div class="relative">
          <svg class="absolute left-2.5 top-2.5 h-4 w-4 text-gray-500 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
          <input
            id="global-search"
            type="text"
            placeholder="Buscar clientes, trabajos o briefs..."
            class="w-full rounded-lg bg-gray-900 border border-gray-800 py-2 pl-9 pr-3 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-gray-600"
          />
        </div>
        <div id="search-results" class="absolute z-50 mt-1 w-full rounded-lg bg-gray-900 border border-gray-800 shadow-lg hidden max-h-80 overflow-y-auto"></div>
      </div>
      <nav class="space-y-2">
        {navItems.map((item) => {
          const active =
            item.href === '/admin'
              ? pathname === '/admin'
              : pathname.startsWith(item.href);

          return (
            <a
              href={item.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition',
                active
                  ? 'bg-white text-gray-950 font-medium'
                  : 'text-gray-300 hover:bg-gray-900 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
      <div class="mt-auto pt-8 border-t border-gray-800 mt-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Operacion</p>
        <p class="text-sm text-gray-300 mt-2">hola@grandeandgordo.com</p>
        <p id="sidebar-user-name" class="text-sm text-gray-400">Cargando...</p>
        <p id="sidebar-user-email" class="text-xs text-gray-500"></p>
        <button type="button" id="logout-button" class="text-sm text-gray-400 hover:text-white mt-2 cursor-pointer">
          Cerrar sesion
        </button>
      </div>
    </aside>
    <main class="flex-1 p-6 md:p-8">
      <slot />
    </main>
  </div>

  <script>
    (async () => {
    const { logout, requireRole, search, escapeHtml } = await import('../lib/api-client');

    const user = await requireRole('admin');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });

    // Global search
    const searchInput = document.getElementById('global-search') as HTMLInputElement | null;
    const searchResults = document.getElementById('search-results');
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    searchInput?.addEventListener('input', () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const q = searchInput.value.trim();
        if (!q || !searchResults) {
          searchResults?.classList.add('hidden');
          return;
        }
        try {
          const data = await search(q);
          let html = '';
          if (data.clients.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs uppercase tracking-wider text-gray-500 border-b border-gray-800">Clientes</div>';
            for (const c of data.clients) {
              html += `<a href="/admin/clients/detail?id=${encodeURIComponent(c.id)}" class="block px-3 py-2 text-sm text-gray-200 hover:bg-gray-800 transition"><span class="font-medium">${escapeHtml(c.name)}</span>${c.company ? ` <span class="text-gray-500">— ${escapeHtml(c.company)}</span>` : ''}</a>`;
            }
          }
          if (data.jobs.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs uppercase tracking-wider text-gray-500 border-b border-gray-800">Trabajos</div>';
            for (const j of data.jobs) {
              html += `<a href="/admin/jobs/detail?id=${encodeURIComponent(j.id)}" class="block px-3 py-2 text-sm text-gray-200 hover:bg-gray-800 transition"><span class="font-medium">${escapeHtml(j.briefText ?? '(sin brief)')}</span> <span class="text-gray-500">— ${escapeHtml(j.clientName)}</span></a>`;
            }
          }
          if (data.briefs.length > 0) {
            html += '<div class="px-3 py-1.5 text-xs uppercase tracking-wider text-gray-500 border-b border-gray-800">Briefs</div>';
            for (const b of data.briefs) {
              html += `<a href="/admin/briefs" class="block px-3 py-2 text-sm text-gray-200 hover:bg-gray-800 transition"><span class="font-medium">${escapeHtml(b.email)}</span> <span class="text-gray-500">— ${escapeHtml(b.clientName ?? b.tipo)}</span></a>`;
            }
          }
          if (!html) {
            html = '<div class="px-3 py-2 text-sm text-gray-500">Sin resultados</div>';
          }
          searchResults.innerHTML = html;
          searchResults.classList.remove('hidden');
        } catch {
          searchResults?.classList.add('hidden');
        }
      }, 300);
    });

    document.addEventListener('click', (e) => {
      if (searchResults && !searchResults.contains(e.target as Node) && e.target !== searchInput) {
        searchResults.classList.add('hidden');
      }
    });
    })();
  </script>
</BaseLayout>
