---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/clients', label: 'Clientes' },
  { href: '/admin/jobs', label: 'Trabajos' },
  { href: '/admin/briefs', label: 'Briefs' },
  { href: '/admin/settings', label: 'Configuracion' },
];
---

<BaseLayout title={title}>
  <div class="min-h-screen bg-black text-white">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <aside class="w-full border-b border-zinc-900 bg-black px-6 py-6 lg:w-80 lg:border-b-0 lg:border-r lg:px-6 lg:py-8">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Grande &amp; Gordo</p>
          <h1 class="mt-3 text-2xl font-black tracking-tight text-white">CRM operativo</h1>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Pipeline, produccion, margen y seguimiento con una capa visual mas
            alineada con la marca y el customer journey.
          </p>
        </div>

        <div class="relative mt-6">
          <div class="relative">
            <svg class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-600 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
            <input
              id="global-search"
              type="text"
              placeholder="Buscar clientes, trabajos o briefs..."
              class="w-full rounded-xl border border-zinc-800 bg-black py-3 pl-11 pr-4 text-sm text-white placeholder-zinc-600 transition focus:border-zinc-600 focus:outline-none"
            />
          </div>
          <div id="search-results" class="absolute z-50 mt-2 hidden max-h-80 w-full overflow-y-auto rounded-2xl border border-zinc-800 bg-zinc-950 shadow-2xl shadow-black/40 backdrop-blur-xl"></div>
        </div>

        <nav class="mt-6 grid gap-2">
          {navItems.map((item) => {
            const active =
              item.href === '/admin'
                ? pathname === '/admin'
                : pathname.startsWith(item.href);

            return (
              <a
                href={item.href}
                class:list={[
                  'block rounded-2xl px-4 py-3 text-sm transition',
                  active
                    ? 'bg-white text-black font-semibold'
                    : 'text-zinc-400 hover:bg-zinc-900 hover:text-white',
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="mt-6 rounded-2xl border border-zinc-800 bg-zinc-950 p-5 lg:mt-auto">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Operacion</p>
          <p class="mt-3 text-sm font-medium text-white">hola@grandeandgordo.com</p>
          <p id="sidebar-user-name" class="mt-5 text-sm font-semibold text-white">Cargando...</p>
          <p id="sidebar-user-email" class="mt-1 text-xs text-zinc-500"></p>
          <button type="button" id="logout-button" class="mt-4 text-sm text-zinc-400 hover:text-white cursor-pointer">
            Cerrar sesion
          </button>
        </div>
      </aside>

      <main class="flex-1 px-6 py-10">
        <div class="mx-auto max-w-7xl">
          <slot />
        </div>
      </main>
    </div>
  </div>

  <script>
    (async () => {
    const { logout, requireRole, search, escapeHtml } = await import('../lib/api-client');

    const user = await requireRole('admin');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });

    // Global search
    const searchInput = document.getElementById('global-search');
    const searchResults = document.getElementById('search-results');
    let debounceTimer = null;

    searchInput?.addEventListener('input', () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const q = searchInput.value.trim();
        if (!q || !searchResults) {
          searchResults?.classList.add('hidden');
          return;
        }
        try {
          const data = await search(q);
          let html = '';
          if (data.clients.length > 0) {
            html += '<div class="border-b border-zinc-800 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-500">Clientes</div>';
            for (const c of data.clients) {
              html += `<a href="/admin/clients/detail?id=${encodeURIComponent(c.id)}" class="block px-4 py-3 text-sm text-zinc-300 transition hover:bg-zinc-900"><span class="font-medium text-white">${escapeHtml(c.name)}</span>${c.company ? ` <span class="text-zinc-500">— ${escapeHtml(c.company)}</span>` : ''}</a>`;
            }
          }
          if (data.jobs.length > 0) {
            html += '<div class="border-b border-zinc-800 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-500">Trabajos</div>';
            for (const j of data.jobs) {
              html += `<a href="/admin/jobs/detail?id=${encodeURIComponent(j.id)}" class="block px-4 py-3 text-sm text-zinc-300 transition hover:bg-zinc-900"><span class="font-medium text-white">${escapeHtml(j.briefText ?? '(sin brief)')}</span> <span class="text-zinc-500">— ${escapeHtml(j.clientName)}</span></a>`;
            }
          }
          if (data.briefs.length > 0) {
            html += '<div class="border-b border-zinc-800 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-500">Briefs</div>';
            for (const b of data.briefs) {
              html += `<a href="/admin/briefs" class="block px-4 py-3 text-sm text-zinc-300 transition hover:bg-zinc-900"><span class="font-medium text-white">${escapeHtml(b.email)}</span> <span class="text-zinc-500">— ${escapeHtml(b.clientName ?? b.tipo)}</span></a>`;
            }
          }
          if (!html) {
            html = '<div class="px-4 py-3 text-sm text-zinc-500">Sin resultados</div>';
          }
          searchResults.innerHTML = html;
          searchResults.classList.remove('hidden');
        } catch {
          searchResults?.classList.add('hidden');
        }
      }, 300);
    });

    document.addEventListener('click', (e) => {
      if (searchResults && !searchResults.contains(e.target) && e.target !== searchInput) {
        searchResults.classList.add('hidden');
      }
    });
    })();
  </script>
</BaseLayout>
