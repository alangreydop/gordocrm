---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/clients', label: 'Clientes' },
  { href: '/admin/jobs', label: 'Trabajos' },
  { href: '/admin/settings', label: 'Configuracion' },
];
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <aside class="flex w-72 flex-col bg-gray-950 text-white p-6">
      <div class="mb-8">
        <p class="text-xs uppercase tracking-[0.3em] text-gray-500">Grande&Gordo</p>
        <h1 class="text-xl font-bold mt-2">CRM operativo</h1>
        <p class="text-sm text-gray-400 mt-2">Pipeline, produccion, margen y seguimiento en un solo sitio.</p>
      </div>
      <nav class="space-y-2">
        {navItems.map((item) => {
          const active =
            item.href === '/admin'
              ? pathname === '/admin'
              : pathname.startsWith(item.href);

          return (
            <a
              href={item.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition',
                active
                  ? 'bg-white text-gray-950 font-medium'
                  : 'text-gray-300 hover:bg-gray-900 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
      <div class="mt-auto pt-8 border-t border-gray-800 mt-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Operacion</p>
        <p class="text-sm text-gray-300 mt-2">hola@grandeandgordo.com</p>
        <p id="sidebar-user-name" class="text-sm text-gray-400">Cargando...</p>
        <p id="sidebar-user-email" class="text-xs text-gray-500"></p>
        <button type="button" id="logout-button" class="text-sm text-gray-400 hover:text-white mt-2 cursor-pointer">
          Cerrar sesion
        </button>
      </div>
    </aside>
    <main class="flex-1 p-6 md:p-8">
      <slot />
    </main>
  </div>

  <script>
    (async () => {
    const { logout, requireRole } = await import('../lib/api-client');

    const user = await requireRole('admin');
    if (user) {
      const name = document.getElementById('sidebar-user-name');
      const email = document.getElementById('sidebar-user-email');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
    }

    document.getElementById('logout-button')?.addEventListener('click', async () => {
      await logout();
      window.location.href = '/login';
    });
    })();
  </script>
</BaseLayout>
