---
import BaseLayout from './BaseLayout.astro';
import { CLIENT_AREA_NAV, isActiveNav } from '../lib/client-area/nav';

interface Props {
  title: string;
  section?: string;
}

const { title, section } = Astro.props;
const pathname = Astro.url.pathname;
---

<BaseLayout title={title}>
  <div class="min-h-screen" style="background: var(--gg-bg); color: var(--gg-text);">
    <!-- Header bar -->
    <header class="fixed top-0 left-0 right-0 z-50" style="height: 3.5rem; background: rgba(247, 240, 243, 0.88); backdrop-filter: blur(18px); border-bottom: 1px solid oklch(88% 0.005 355);">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 h-full flex items-center justify-between">
        <a href="/inicio" class="flex items-center gap-2.5" aria-label="Grande & Gordo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2813.19 1671.88" class="h-6 w-auto" aria-hidden="true">
            <path d="M1177.85 429.55c11.51 0 20.72-3.89 27.63-11.66s11.22-20.87 12.95-39.29c2.88-27.06 11.37-47.06 25.47-60.01 14.1-12.95 32.09-19.43 53.97-19.43 24.18 0 43.61 8.63 58.29 25.9 14.68 17.27 22.02 42.6 22.02 75.99v35.4l-134.7 64.76c-17.27 8.06-31.66 15.83-43.18 23.31-11.51 7.48-20.72 15.11-27.63 22.88s-11.8 15.97-14.68 24.61c-2.88 8.63-4.32 18.42-4.32 29.36 0 25.33 8.78 45.91 26.34 61.74 17.56 15.83 40.73 23.75 69.51 23.75 25.9 0 49.79-6.33 71.67-19 21.87-12.66 40.87-31.66 56.99-56.99 1.73 23.6 8.01 65.63 102.99 65.63h183.52V363.91c23.03-34.54 53.4-51.81 92.55-51.81 23.6 0 42.6 7.63 56.99 22.88s21.59 38.42 21.59 69.51v223.64c0 5.18-.86 9.07-2.59 11.66s-5.47 4.46-11.23 5.61l-41.45 5.18v25.9h193.42v-25.9l-43.18-5.18c-5.76-1.15-9.5-3.02-11.22-5.61-1.73-2.59-2.59-6.48-2.59-11.66V398.44c0-42.02-11.8-74.55-35.4-97.57-23.6-23.03-54.4-34.54-92.39-34.54-26.48 0-50.51 5.9-72.1 17.7-21.59 11.8-38.58 28.93-52.4 51.38V264.6l-138 35.4v12.09l43.18 18.13c5.76 2.88 9.35 5.61 10.79 8.2 1.44 2.59 2.16 7.05 2.16 13.38v276.31c0 5.18-.86 9.07-2.59 11.66s-8.39 8.21-14.15 9.36h-57.56c-44.61-5.76-50.89-38.86-50.89-53.83V414.83c.57-48.93-12.09-85.92-37.99-110.96-25.91-25.04-64.19-37.56-114.84-37.56-22.45 0-43.61 3.45-63.47 10.36-19.86 6.91-37.13 15.97-51.81 27.2-14.68 11.23-26.34 15.97-34.97 38.86-8.63 14.68-12.95 29.79-12.95 45.33 0 13.24 3.45 23.46 10.36 30.65 6.91 7.2 15.54 10.79 25.9 10.79Zm200.33 156.29c-24.18 33.39-52.67 50.08-85.48 50.08-17.27 0-31.09-4.75-41.45-14.25-10.36-9.5-15.54-22.88-15.54-40.15 0-15.54 4.17-28.93 12.52-40.15 8.35-11.23 23.46-22.59 45.33-34.11l84.62-44.04v122.61ZM2020.15 632.04c15.83 17.56 34.39 31.09 55.69 40.58 21.3 9.5 44.04 14.25 68.21 14.25 26.48 0 51.38-6.62 74.69-19.86 23.31-13.24 41.84-31.37 56.81-53.82v92.1l82.03-28.78.61-675.95L2220.03 0v12.08l43.17 18.13c5.76 2.88 9.35 5.61 10.79 8.2 1.44 2.59 2.16 7.05 2.16 13.38v266.36c-13.82-16.69-31.09-29.5-51.81-38.42-20.72-8.92-43.46-13.38-68.21-13.38s-50.23 5.18-72.97 15.54c-22.74 10.36-42.6 25.04-59.58 44.04-16.98 19-30.36 41.88-40.15 68.65-9.79 26.77-14.68 56.27-14.68 88.51s4.61 60.01 13.82 85.05 21.73 46.34 37.56 63.9Zm38.86-227.1c6.04-21.01 14.68-38.71 25.9-53.1 11.22-14.39 24.32-25.47 39.29-33.24 14.97-7.77 31.66-11.66 50.08-11.66 21.87 0 41.45 4.46 58.72 13.38 17.27 8.92 31.66 21.73 43.17 38.42v224.51c-13.24 17.27-28.35 30.51-45.33 39.72-16.98 9.21-36.41 13.82-58.29 13.82-16.69 0-32.38-3.74-47.06-11.22s-27.63-18.28-38.86-32.38c-11.22-14.1-20.15-31.09-26.77-50.95-6.62-19.86-9.93-42.17-9.93-66.92s3.02-49.36 9.07-70.37Z" fill="currentColor" style="color: var(--gg-accent);"/>
          </svg>
          <span class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--gg-text-secondary);">Área de cliente</span>
        </a>

        <nav class="hidden md:flex items-center gap-1">
          {CLIENT_AREA_NAV.map((item) => {
            const active = isActiveNav(item.href, pathname);
            return (
              <a
                href={item.href}
                class:list={[
                  'inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-sm transition-colors duration-150',
                  active ? '' : '',
                ]}
                style={active ? 'background: rgba(196, 22, 90, 0.1); color: var(--gg-accent-dark);' : 'color: var(--gg-text-secondary);'}
                aria-current={active ? 'page' : undefined}
              >
                <span class="w-3.5 text-center">
                  {item.icon === 'home' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>}
                  {item.icon === 'folder' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>}
                  {item.icon === 'eye' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>}
                  {item.icon === 'download' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a2 2 0 002 2h14a2 2 0 002-2v-3"/></svg>}
                  {item.icon === 'message' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.04 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>}
                  {item.icon === 'receipt' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>}
                  {item.icon === 'user' && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>}
                </span>
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="flex items-center gap-3">
          <span id="header-user-name" class="hidden md:inline text-sm" style="color: var(--gg-text-muted);"></span>
          <button type="button" id="user-menu-toggle" class="w-8 h-8 rounded-full flex items-center justify-center" style="background: var(--gg-accent-light); color: var(--gg-accent);" aria-label="Menú de usuario">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </button>
        </div>
      </div>

      <!-- User dropdown -->
      <div id="user-menu" class="hidden absolute right-4 top-[3.5rem] w-56 border z-50" style="background: var(--gg-surface); border-color: var(--gg-border); border-radius: 2px; box-shadow: 0 24px 48px -12px rgba(26, 16, 21, 0.2);">
        <div class="p-4" style="border-bottom: 1px solid var(--gg-border-light);">
          <p id="dropdown-user-name" class="text-sm font-semibold" style="color: var(--gg-text);"></p>
          <p id="dropdown-user-email" class="text-xs mt-0.5" style="color: var(--gg-text-muted);"></p>
        </div>
        <div class="p-2">
          <a href="/perfil" class="flex items-center gap-2 px-3 py-2 text-sm rounded-sm transition-colors duration-150" style="color: var(--gg-text-secondary);" onmouseover="this.style.background='var(--gg-surface-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Mi perfil
          </a>
          <button id="logout-button-dropdown" class="flex items-center gap-2 px-3 py-2 text-sm w-full text-left rounded-sm transition-colors duration-150" style="color: var(--gg-danger);" onmouseover="this.style.background='var(--gg-surface-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Cerrar sesión
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile nav -->
    <div id="mobile-nav-overlay" class="hidden fixed inset-0 z-40" style="background: rgba(26, 16, 21, 0.3); backdrop-filter: blur(4px);"></div>
    <nav id="mobile-nav" class="fixed bottom-0 left-0 right-0 z-50 md:hidden" style="background: var(--gg-surface); border-top: 1px solid oklch(88% 0.005 355); display: none;">
      <div class="flex justify-around py-2">
        {CLIENT_AREA_NAV.slice(0, 5).map((item) => {
          const active = isActiveNav(item.href, pathname);
          return (
            <a
              href={item.href}
              class="flex flex-col items-center gap-0.5 px-2 py-1 text-[0.65rem]"
              style={active ? 'color: var(--gg-accent);' : 'color: var(--gg-text-muted);'}
            >
              {item.icon === 'home' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>}
              {item.icon === 'folder' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>}
              {item.icon === 'eye' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>}
              {item.icon === 'download' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a2 2 0 002 2h14a2 2 0 002-2v-3"/></svg>}
              {item.icon === 'message' && <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.04 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>}
              {item.label}
            </a>
          );
        })}
      </div>
    </nav>

    <!-- Main content -->
    <main class="pt-14">
      <div class="max-w-[1100px] mx-auto px-4 sm:px-6 py-8 md:py-12">
        <slot />
      </div>
    </main>
  </div>

  <script>
    (async () => {
      const { logout, requireRole } = await import('../lib/api-client');
      const user = await requireRole('client');
      if (user) {
        const name = document.getElementById('header-user-name');
        const email = document.getElementById('dropdown-user-email');
        const dName = document.getElementById('dropdown-user-name');
        if (name) { name.textContent = user.name; name.classList.remove('hidden'); }
        if (email) email.textContent = user.email;
        if (dName) dName.textContent = user.name;
      }

      const menuToggle = document.getElementById('user-menu-toggle');
      const menu = document.getElementById('user-menu');
      if (menuToggle && menu) {
        menuToggle.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
        document.addEventListener('click', (e) => {
          if (!menu.contains(e.target as Node) && !menuToggle.contains(e.target as Node)) {
            menu.classList.add('hidden');
          }
        });
      }

      const logoutBtn = document.getElementById('logout-button-dropdown');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          await logout();
          window.location.href = '/login';
        });
      }
    })();
  </script>
</BaseLayout>