---
interface Props {
  kicker: string;
  value?: string;
  subtext?: string;
}

const { kicker, value, subtext } = Astro.props;
---

<div class="crm-metric-card" role="region" aria-label={kicker}>
    <p class="crm-kicker">{kicker}</p>
    {value && <p class="crm-metric-card__value">{value}</p>}
    {subtext && <p class="crm-metric-card__meta">{subtext}</p>}
    <slot />
</div>
