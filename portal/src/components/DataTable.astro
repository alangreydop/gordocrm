---
interface Props {
  headers: string[];
  title?: string;
  description?: string;
}

const { headers, title, description } = Astro.props;
---

{title && (
  <div class="mb-4">
    <h2 class="text-lg font-bold" style="color: var(--crm-text);">{title}</h2>
    {description && <p class="text-sm mt-1" style="color: var(--crm-text-secondary);">{description}</p>}
  </div>
)}
<div class="crm-table-wrap overflow-x-auto">
  <table class="crm-table w-full text-sm">
    <thead>
      <tr>
        {headers.map((h) => (
          <th class="px-4 py-3 text-left font-semibold" style="color: var(--crm-muted);">{h}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      <slot />
    </tbody>
  </table>
</div>