---
interface Props {
  kicker?: string;
  title: string;
  description?: string;
}

const { kicker, title, description } = Astro.props;
---

<section class="crm-page-header" role="region">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
    <div>
      {kicker && <p class="crm-kicker crm-kicker--accent">{kicker}</p>}
      <h1 class="mt-1 text-2xl md:text-3xl font-bold tracking-tight" style="color: var(--crm-text);">{title}</h1>
      {description && <p class="crm-page-header__meta mt-2">{description}</p>}
    </div>
    <div class="flex-shrink-0">
      <slot name="actions" />
    </div>
  </div>
</section>