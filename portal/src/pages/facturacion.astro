---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Facturación" section="facturacion">
  <div id="client-area-root">
    <div class="crm-masthead">
      <p class="crm-kicker">Cobros</p>
      <h1 class="crm-masthead-title">Tus facturas</h1>
      <p class="crm-masthead-deck">Facturas emitidas y estado de cada pago.</p>
    </div>

    <div id="billing-list">
      {[1,2].map(() => `
        <div class="crm-row animate-pulse" style="border-bottom-color: oklch(92% 0.005 355);">
          <div class="flex-1">
            <div class="h-4 w-28 rounded" style="background: var(--gg-border-light);"></div>
            <div class="h-3 w-48 rounded mt-2" style="background: oklch(94% 0.005 355);"></div>
          </div>
          <div class="text-right">
            <div class="h-4 w-20 rounded ml-auto" style="background: var(--gg-border-light);"></div>
            <div class="h-5 w-16 rounded-full mt-1.5 ml-auto" style="background: oklch(94% 0.005 355);"></div>
          </div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toInvoicesViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const invoices = toInvoicesViewModel(snapshot);
      const list = document.getElementById('billing-list');

      if (!list) return;

      if (invoices.length === 0) {
        list.innerHTML = `
          <div class="py-10 text-center">
            <p class="crm-kicker" style="color: oklch(55% 0.008 355);">Sin facturas</p>
            <p class="text-sm mt-2" style="color: var(--gg-text-muted);">Las facturas aparecerán cuando se emitan.</p>
          </div>`;
        return;
      }

      const statusBadge = (status: string): { cls: string; label: string } => {
        switch (status) {
          case 'paid': return { cls: 'crm-badge crm-badge--success', label: 'Pagada' };
          case 'issued': return { cls: 'crm-badge crm-badge--accent', label: 'Pendiente' };
          case 'overdue': return { cls: 'crm-badge crm-badge--danger', label: 'Vencida' };
          case 'draft': return { cls: 'crm-badge crm-badge--muted', label: 'Borrador' };
          default: return { cls: 'crm-badge crm-badge--muted', label: status };
        }
      };

      list.innerHTML = invoices.map((inv, i) => {
        const badge = statusBadge(inv.status);
        return `
        <div class="crm-row ca-card-enter" style="border-bottom-color: oklch(92% 0.005 355); animation-delay: ${i * 40}ms;">
          <div class="flex-1">
            <h3 class="font-semibold" style="color: var(--gg-text);">${inv.invoiceNumber}</h3>
            <p class="text-xs mt-0.5" style="color: oklch(55% 0.008 355);">Emitida: ${new Date(inv.issueDate).toLocaleDateString('es-ES')} · Vence: ${new Date(inv.dueDate).toLocaleDateString('es-ES')}</p>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="font-semibold" style="color: var(--gg-text);">${inv.totalEur}</p>
            <span class="${badge.cls} mt-1">${badge.label}</span>
          </div>
        </div>`;
      }).join('');
    })();
  </script>
</ClientAreaLayout>