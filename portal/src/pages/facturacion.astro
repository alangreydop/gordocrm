---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Facturación" section="facturacion">
  <div id="client-area-root" class="space-y-8">
    <section class="crm-page-header p-6 md:p-7">
      <p class="crm-kicker">Cobros</p>
      <h2 class="mt-4 text-2xl font-bold tracking-tight text-white">Tus facturas</h2>
      <p class="mt-2 text-sm" style="color: var(--gg-text-muted);">Facturas emitidas y estado de cada pago.</p>
    </section>

    <div id="billing-list" class="ca-stagger">
      {[1,2].map(() => `
        <div class="crm-panel-soft p-5 mb-3 animate-pulse">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="h-5 w-28 rounded" style="background: var(--gg-surface-elevated);"></div>
              <div class="h-3 w-48 rounded mt-2" style="background: var(--gg-surface);"></div>
            </div>
            <div class="text-right">
              <div class="h-5 w-20 rounded ml-auto" style="background: var(--gg-surface-elevated);"></div>
              <div class="h-5 w-16 rounded-full mt-2 ml-auto" style="background: var(--gg-surface);"></div>
            </div>
          </div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toInvoicesViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const invoices = toInvoicesViewModel(snapshot);
      const list = document.getElementById('billing-list');

      if (!list) return;

      if (invoices.length === 0) {
        list.innerHTML = `
          <div class="crm-empty">
            <p class="crm-kicker" style="font-size: 0.72rem; color: var(--gg-text-subtle);">Sin facturas</p>
            <p class="text-sm mt-3" style="color: var(--gg-text-muted);">Las facturas aparecerán cuando se emitan.</p>
          </div>`;
        return;
      }

      const statusBadge = (status: string): { style: string; label: string } => {
        switch (status) {
          case 'paid': return { style: 'color: var(--gg-success); background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2);', label: 'Pagada' };
          case 'issued': return { style: 'color: var(--gg-accent-bright); background: var(--gg-accent-soft); border: 1px solid rgba(196,22,90,0.25);', label: 'Pendiente' };
          case 'overdue': return { style: 'color: var(--gg-danger); background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);', label: 'Vencida' };
          case 'draft': return { style: 'color: var(--gg-text-muted); background: rgba(255,255,255,0.04); border: 1px solid var(--gg-border);', label: 'Borrador' };
          default: return { style: 'color: var(--gg-text-muted); background: rgba(255,255,255,0.04); border: 1px solid var(--gg-border);', label: status };
        }
      };

      list.innerHTML = invoices.map((inv, i) => {
        const badge = statusBadge(inv.status);
        return `
        <div class="crm-panel-soft p-5 mb-3 ca-card-enter transition-all duration-200 hover:translate-y-[-1px]" style="animation-delay: ${i * 60}ms;">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-white">${inv.invoiceNumber}</h3>
              <p class="text-xs mt-1" style="color: var(--gg-text-subtle);">Emitida: ${new Date(inv.issueDate).toLocaleDateString('es-ES')} · Vence: ${new Date(inv.dueDate).toLocaleDateString('es-ES')}</p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="font-semibold text-white">${inv.totalEur}</p>
              <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium mt-1" style="${badge.style}">${badge.label}</span>
            </div>
          </div>
        </div>`;
      }).join('');
    })();
  </script>
</ClientAreaLayout>