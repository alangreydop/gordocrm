---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Archivos" section="archivos">
  <div id="client-area-root" class="space-y-6">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
      <div class="border-b border-zinc-800 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Archivos</h2>
        <p class="mt-1 text-sm text-zinc-400">Descarga tus entregables y referencias.</p>
      </div>
      <div id="files-list" class="p-6">
        <p class="text-sm text-zinc-400">Cargando archivos...</p>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toFilesViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const files = toFilesViewModel(snapshot);
      const list = document.getElementById('files-list');

      if (!list) return;

      if (files.length === 0) {
        list.innerHTML = '<p class="text-sm text-zinc-400">No hay archivos disponibles todavía.</p>';
        return;
      }

      list.innerHTML = `<div class="space-y-4">${files.map((f) => `
        <div class="rounded-xl border border-zinc-800 bg-black p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-white">${f.title}</h3>
              <p class="text-xs text-zinc-500 mt-1">${f.category === 'deliverable' ? 'Entregable' : 'Referencia'} · ${f.kind === 'video' ? 'Vídeo' : 'Imagen'}</p>
            </div>
            ${f.href ? `<a href="${f.href}" target="_blank" rel="noreferrer" class="inline-flex rounded-full bg-white px-4 py-2 text-xs font-bold text-black transition hover:bg-zinc-200 flex-shrink-0">Descargar</a>` : ''}
          </div>
        </div>
      `).join('')}</div>`;
    })();
  </script>
</ClientAreaLayout>