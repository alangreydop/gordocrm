---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteLinks } from '../lib/site-links';
---

<BaseLayout title="Login">
  <div class="min-h-screen bg-slate-950 text-white">
    <div class="grid min-h-screen lg:grid-cols-[1.05fr_.95fr]">
      <section class="relative overflow-hidden border-b border-white/10 px-6 py-14 lg:border-b-0 lg:border-r">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(110,71,164,0.28),_transparent_42%),radial-gradient(circle_at_bottom_right,_rgba(122,159,255,0.18),_transparent_38%)]"></div>
        <div class="relative mx-auto flex h-full max-w-2xl flex-col">
          <a href={siteLinks.home} class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 transition hover:text-white">
            <span aria-hidden="true">&larr;</span>
            Volver a grandeandgordo.com
          </a>

          <div class="mt-14 max-w-xl">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-sky-200/70">Portal cliente</p>
            <h1 class="mt-5 text-4xl font-black leading-tight text-white md:text-6xl">
              Misma marca.
              <br />
              Mismo cliente.
              <br />
              Mejor continuidad.
            </h1>
            <p class="mt-6 text-lg leading-relaxed text-slate-300">
              La web publica te acompana con onboarding, brief y recursos. Este CRM
              concentra seguimiento, trabajos, entregables y cuenta. Los dos forman
              parte del mismo journey.
            </p>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-3">
            <a href={siteLinks.portalHub} class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5 shadow-2xl shadow-black/10 transition hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/8">
              <p class="text-sm font-semibold text-white">Centro de cliente</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-300">
                Vista general para moverte entre portal, brief y onboarding.
              </p>
            </a>
            <a href={siteLinks.brief} class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5 shadow-2xl shadow-black/10 transition hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/8">
              <p class="text-sm font-semibold text-white">Brief</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-300">
                Comparte contexto de marca, referencias y necesidades del proyecto.
              </p>
            </a>
            <a href={siteLinks.onboarding} class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5 shadow-2xl shadow-black/10 transition hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/8">
              <p class="text-sm font-semibold text-white">Onboarding</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-300">
                Revisa checklist, preparacion de sesion y preguntas frecuentes.
              </p>
            </a>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-3">
            <div class="rounded-[1.4rem] border border-white/10 bg-black/20 p-5">
              <p class="crm-kicker text-slate-400">Journey</p>
              <p class="mt-3 text-3xl font-black text-white">01</p>
              <p class="mt-2 text-sm text-slate-300">La web captura contexto y reduce friccion.</p>
            </div>
            <div class="rounded-[1.4rem] border border-white/10 bg-black/20 p-5">
              <p class="crm-kicker text-slate-400">Operacion</p>
              <p class="mt-3 text-3xl font-black text-white">02</p>
              <p class="mt-2 text-sm text-slate-300">El CRM concentra trabajos, estados y entregables.</p>
            </div>
            <div class="rounded-[1.4rem] border border-white/10 bg-black/20 p-5">
              <p class="crm-kicker text-slate-400">Continuidad</p>
              <p class="mt-3 text-3xl font-black text-white">03</p>
              <p class="mt-2 text-sm text-slate-300">El cliente se mueve sin notar la frontera entre capas.</p>
            </div>
          </div>

          <div class="mt-auto pt-10 text-sm text-slate-400">
            Si aun no tienes acceso o tu equipo necesita soporte, escribe a
            {' '}
            <a href={siteLinks.supportMailto} class="font-semibold text-white underline decoration-white/30 underline-offset-4 transition hover:decoration-white">
              {siteLinks.supportEmail}
            </a>
            .
          </div>
        </div>
      </section>

      <section class="flex items-center px-6 py-14">
        <div class="mx-auto w-full max-w-md rounded-[2rem] border border-white/12 bg-[rgba(10,14,22,0.88)] p-8 text-white shadow-2xl shadow-black/40 backdrop-blur-xl">
          <div class="mb-8">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-slate-400">Acceso seguro</p>
            <h2 class="mt-3 text-3xl font-black text-white">Entrar al CRM</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">
              Usa el email y la contrasena con los que te dimos acceso. Si vienes desde
              la web, este es el siguiente paso para ver trabajos y entregables.
            </p>
          </div>

          <div id="login-error" class="mb-4 hidden rounded-2xl border border-rose-400/20 bg-rose-400/10 p-3 text-sm text-rose-100"></div>

          <form id="login-form" class="space-y-4">
            <div>
              <label for="email" class="mb-2 block text-sm font-medium text-slate-200">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="crm-input"
                placeholder="cliente@tumarca.com"
              />
            </div>
            <div>
              <label for="password" class="mb-2 block text-sm font-medium text-slate-200">Contrasena</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="crm-input"
              />
            </div>
            <button
              type="submit"
              class="crm-button crm-button-primary w-full"
            >
              Iniciar sesion
            </button>
          </form>

          <div class="mt-6 rounded-[1.4rem] border border-white/10 bg-white/4 p-4 text-sm text-slate-300">
            <p class="font-semibold text-white">Antes o despues de entrar</p>
            <div class="mt-3 flex flex-wrap gap-3">
              <a href={siteLinks.brief} class="font-medium text-slate-200 underline decoration-slate-500 underline-offset-4 transition hover:text-white hover:decoration-white">
                Brief
              </a>
              <a href={siteLinks.onboarding} class="font-medium text-slate-200 underline decoration-slate-500 underline-offset-4 transition hover:text-white hover:decoration-white">
                Onboarding
              </a>
              <a href={siteLinks.portalHub} class="font-medium text-slate-200 underline decoration-slate-500 underline-offset-4 transition hover:text-white hover:decoration-white">
                Centro de cliente
              </a>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    (async () => {
    const { API_BASE, getSessionUser } = await import('../lib/api-client');

    const existingUser = await getSessionUser();
    if (existingUser) {
      window.location.href = existingUser.role === 'admin' ? '/admin' : '/client';
    }

    const form = document.getElementById('login-form');
    const errorDiv = document.getElementById('login-error');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorDiv?.classList.add('hidden');

      const email = document.getElementById('email');
      const password = document.getElementById('password');

      try {
        const res = await fetch(`${API_BASE}/api/portal/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            email: email instanceof HTMLInputElement ? email.value : '',
            password: password instanceof HTMLInputElement ? password.value : '',
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'Login failed');
        }

        const data = await res.json();
        window.location.href = data.user.role === 'admin' ? '/admin' : '/client';
      } catch (error) {
        if (errorDiv instanceof HTMLDivElement) {
          errorDiv.textContent = error instanceof Error ? error.message : 'Login failed';
          errorDiv.classList.remove('hidden');
        }
      }
    });
    })();
  </script>
</BaseLayout>
