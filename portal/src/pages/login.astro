---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteLinks } from '../lib/site-links';
---

<BaseLayout title="Login">
  <div class="login-shell">
    <div class="login-grid">

      <!-- Left: dark panel with logo -->
      <section class="login-intro">
        <a href={siteLinks.home} class="login-back">grandeandgordo.com</a>

        <img
          src="https://logos.grandeandgordo.com/logoggblanco.png"
          alt="Grande&Gordo"
          width="160"
          height="60"
          style="height: 30px; width: auto; display: block;"
          loading="eager"
          decoding="async"
        />

        <p class="crm-kicker crm-kicker--accent" style="margin-top: 0.25rem;">portal operativo</p>
        <h1 class="login-title">entra en tu espacio de trabajo.</h1>
        <p class="login-copy">
          brief, activación, entregables, vault y facturación viven aquí. Sin brochure. Sin ruido.
        </p>

        <div class="login-notes">
          <div class="login-note">
            <span class="login-note__index">01</span>
            <div>
              <p class="login-note__title">cliente</p>
              <p class="login-note__text">sigue briefs, trabajos, activos y billing desde una sola vista.</p>
            </div>
          </div>
          <div class="login-note">
            <span class="login-note__index">02</span>
            <div>
              <p class="login-note__title">admin</p>
              <p class="login-note__text">entra en operaciones, capacidad, briefs y jobs con el mismo acceso.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Right: form panel -->
      <section class="login-panel">
        <div class="login-panel__head">
          <p class="crm-kicker">acceso</p>
          <h2 class="login-panel__title">email y contraseña</h2>
          <p class="login-panel__copy">usa el usuario vinculado a tu cuenta del portal.</p>
        </div>

        <div id="login-error" class="hidden crm-alert crm-alert-danger" role="alert" aria-live="polite"></div>

        <form id="login-form" class="login-form" novalidate>
          <div class="login-field">
            <label for="email">email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="crm-input w-full"
              placeholder="cliente@tumarca.com"
            />
          </div>
          <div class="login-field">
            <label for="password">contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="crm-input w-full"
            />
          </div>
          <button
            type="submit"
            class="crm-button crm-button-primary w-full"
            id="login-submit"
            style="min-height: 3.25rem; font-size: 1rem;"
          >
            entrar
          </button>
        </form>
      </section>

    </div>
  </div>

  <script>
    (async () => {
      const { API_BASE, getSessionUser } = await import('../lib/api-client');

      const existingUser = await getSessionUser();
      if (existingUser) {
        window.location.href = existingUser.role === 'admin' ? '/admin' : '/client';
      }

      const form = document.getElementById('login-form');
      const errorDiv = document.getElementById('login-error');
      const submitBtn = document.getElementById('login-submit');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (errorDiv) errorDiv.classList.add('hidden');
        if (submitBtn) {
          submitBtn.textContent = 'entrando...';
          submitBtn.disabled = true;
        }

        const email = document.getElementById('email');
        const password = document.getElementById('password');

        try {
          const res = await fetch(`${API_BASE}/api/portal/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              email: email instanceof HTMLInputElement ? email.value : '',
              password: password instanceof HTMLInputElement ? password.value : '',
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'login failed');
          }

          const data = await res.json();
          window.location.href = data.user.role === 'admin' ? '/admin' : '/client';
        } catch (error) {
          const msg = error instanceof Error ? error.message : 'error al iniciar sesión';
          if (errorDiv instanceof HTMLDivElement) {
            errorDiv.textContent = msg;
            errorDiv.classList.remove('hidden');
          }
          if (submitBtn) {
            submitBtn.textContent = 'entrar';
            submitBtn.disabled = false;
          }
        }
      });
    })();
  </script>

  <style>
    .login-shell {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 1.5rem;
    }

    .login-grid {
      width: min(100%, 72rem);
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.95fr);
      gap: 1.5rem;
      align-items: stretch;
    }

    .login-intro {
      border-radius: var(--radius-xl);
      padding: clamp(1.75rem, 3vw, 2.5rem);
      background:
        linear-gradient(180deg, rgba(22, 13, 17, 0.96), rgba(11, 6, 8, 1)),
        var(--gg-dark);
      color: var(--gg-text-white);
      box-shadow: var(--shadow-strong);
      display: grid;
      align-content: start;
      gap: 1rem;
    }

    .login-back {
      width: fit-content;
      font-size: var(--text-sm);
      color: rgba(255, 253, 253, 0.55);
      letter-spacing: 0.04em;
      transition: color var(--duration-fast) var(--ease-out);
    }
    .login-back:hover { color: var(--gg-text-white); }

    .login-title {
      font-size: clamp(2.3rem, 5vw, 4.5rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
      max-width: 9ch;
      color: var(--gg-text-white);
    }

    .login-copy {
      color: rgba(255, 253, 253, 0.72);
      max-width: 34ch;
      line-height: 1.75;
      font-size: 0.9375rem;
    }

    .login-notes {
      margin-top: auto;
      display: grid;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .login-note {
      display: grid;
      grid-template-columns: 2.25rem 1fr;
      gap: 0 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      align-items: start;
    }
    .login-note:last-child { border-bottom: 0; }

    .login-note__index {
      font-family: var(--font-serif);
      font-style: italic;
      color: rgba(196, 22, 90, 0.7);
      font-size: 0.85rem;
      padding-top: 0.15rem;
    }

    .login-note__title {
      font-size: 0.9375rem;
      font-weight: 700;
      color: var(--gg-text-white);
      margin: 0 0 0.2rem;
    }

    .login-note__text {
      margin: 0;
      font-size: 0.875rem;
      color: rgba(255, 253, 253, 0.62);
      line-height: 1.6;
    }

    .login-panel {
      border-radius: var(--radius-xl);
      padding: clamp(1.5rem, 3vw, 2.25rem);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.98));
      border: 1px solid var(--gg-border);
      box-shadow: var(--shadow-soft);
      display: grid;
      align-content: center;
      gap: 1.5rem;
    }

    .login-panel__head { display: grid; gap: 0.6rem; }

    .login-panel__title {
      font-size: clamp(1.7rem, 3vw, 2.4rem);
      line-height: 1.04;
      letter-spacing: -0.04em;
      color: var(--gg-text);
      margin: 0;
    }

    .login-panel__copy {
      color: var(--gg-text-muted);
      line-height: 1.65;
      margin: 0;
      font-size: 0.9375rem;
    }

    .login-form { display: grid; gap: 1rem; }

    .login-field { display: grid; gap: 0.45rem; }

    .login-field label {
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--gg-text-muted);
    }

    @media (max-width: 900px) {
      .login-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 640px) {
      .login-shell { padding: 1rem; }
      .login-grid { gap: 1rem; }
    }
  </style>
</BaseLayout>
