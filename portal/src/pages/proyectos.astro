---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Producción" section="proyectos">
  <div id="client-area-root">
    <div class="crm-masthead">
      <p class="crm-kicker">Tus encargos</p>
      <h1 class="crm-masthead-title">Estado de producción</h1>
      <p class="crm-masthead-deck">Seguimiento de cada encargo, de briefing a entrega.</p>
    </div>

    <div id="projects-list">
      {[1,2,3].map(() => `
        <div class="crm-row animate-pulse" style="border-bottom-color: oklch(92% 0.005 355);">
          <div class="flex-1">
            <div class="h-4 w-36 rounded" style="background: var(--gg-border-light);"></div>
            <div class="h-3 w-20 rounded mt-2" style="background: oklch(94% 0.005 355);"></div>
          </div>
          <div class="h-5 w-16 rounded-full" style="background: var(--gg-border-light);"></div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toProjectsViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const projects = toProjectsViewModel(snapshot);
      const list = document.getElementById('projects-list');

      if (!list) return;

      if (projects.length === 0) {
        list.innerHTML = `
          <div class="py-10 text-center">
            <p class="crm-kicker" style="color: oklch(55% 0.008 355);">Sin proyectos</p>
            <p class="text-sm mt-2" style="color: var(--gg-text-muted);">Los proyectos aparecerán cuando se inicien encargos.</p>
          </div>`;
        return;
      }

      const statusBadge = (status: string): { cls: string; label: string } => {
        switch (status) {
          case 'pending': return { cls: 'crm-badge crm-badge--warning', label: 'Pendiente' };
          case 'processing': return { cls: 'crm-badge crm-badge--accent', label: 'En producción' };
          case 'delivered': return { cls: 'crm-badge crm-badge--muted', label: 'Entregado' };
          case 'completed': return { cls: 'crm-badge crm-badge--success', label: 'Completado' };
          case 'failed': return { cls: 'crm-badge crm-badge--danger', label: 'Fallido' };
          default: return { cls: 'crm-badge crm-badge--muted', label: status };
        }
      };

      list.innerHTML = projects.map((p, i) => {
        const badge = statusBadge(p.status);
        return `
        <div class="crm-row crm-row--interactive ca-card-enter" style="border-bottom-color: oklch(92% 0.005 355); animation-delay: ${i * 40}ms;">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold" style="color: var(--gg-text);">${p.title}</h3>
            <p class="text-xs mt-0.5" style="color: oklch(55% 0.008 355);">${[p.platform, p.type].filter(Boolean).map(v => v === 'image' ? 'Imagen' : v === 'video' ? 'Vídeo' : v?.charAt(0).toUpperCase() + v?.slice(1)).join(' · ') || ''}</p>
          </div>
          <div class="text-right flex-shrink-0">
            <span class="${badge.cls}">${badge.label}</span>
            ${p.dueAt ? `<p class="text-xs mt-1" style="color: oklch(55% 0.008 355);">Entrega: ${new Date(p.dueAt).toLocaleDateString('es-ES')}</p>` : ''}
          </div>
        </div>
        ${p.unitsPlanned > 0 ? `
        <div class="px-0 pb-2" style="margin-top: -4px;">
          <div class="flex items-center gap-3">
            <div class="crm-score-track flex-1">
              <div class="crm-score-fill" style="width: ${Math.min(100, (p.unitsConsumed / p.unitsPlanned) * 100)}%; background: ${p.unitsConsumed >= p.unitsPlanned ? 'var(--gg-success)' : p.unitsConsumed > 0 ? 'var(--gg-accent)' : 'oklch(72% 0.008 355)'};"></div>
            </div>
            <span class="text-xs" style="color: oklch(55% 0.008 355);">${p.unitsConsumed}/${p.unitsPlanned}</span>
          </div>
        </div>
        ` : ''}`;
      }).join('');
    })();
  </script>
</ClientAreaLayout>