---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Proyectos" section="proyectos">
  <div id="client-area-root" class="space-y-6">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
      <div class="border-b border-zinc-800 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Tus proyectos</h2>
        <p class="mt-1 text-sm text-zinc-400">Estado de producción y entregas.</p>
      </div>
      <div id="projects-list" class="p-6">
        <div class="space-y-4">
          {[1,2,3].map(() => `
            <div class="rounded-xl border border-zinc-800 bg-black p-5 animate-pulse">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="h-5 w-40 rounded bg-zinc-800"></div>
                  <div class="h-3 w-24 rounded bg-zinc-800/60 mt-2"></div>
                </div>
                <div class="h-6 w-20 rounded-full bg-zinc-800"></div>
              </div>
              <div class="h-3 w-48 rounded bg-zinc-800/40 mt-3"></div>
            </div>
          `).join('')}
        </div>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toProjectsViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const projects = toProjectsViewModel(snapshot);
      const list = document.getElementById('projects-list');

      if (!list) return;

      if (projects.length === 0) {
        list.innerHTML = `
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <svg class="w-12 h-12 text-zinc-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <p class="text-sm text-zinc-400">No tienes proyectos todavía.</p>
            <p class="text-xs text-zinc-600 mt-1">Los proyectos aparecerán cuando se inicien encargos.</p>
          </div>`;
        return;
      }

      const statusBadgeClass = (status: string): string => {
        switch (status) {
          case 'pending': return 'border-amber-300/20 bg-amber-400/10 text-amber-100';
          case 'processing': return 'border-sky-300/20 bg-sky-400/10 text-sky-100';
          case 'delivered': return 'border-fuchsia-300/20 bg-fuchsia-400/10 text-fuchsia-100';
          case 'completed': return 'border-emerald-300/20 bg-emerald-400/10 text-emerald-100';
          case 'failed': return 'border-rose-300/20 bg-rose-400/10 text-rose-100';
          default: return 'border-zinc-700 bg-zinc-900 text-white';
        }
      };

      list.innerHTML = `<div class="space-y-4">${projects.map((p) => `
        <div class="rounded-xl border border-zinc-800 bg-black p-5 transition-all duration-200 hover:border-zinc-700 hover:translate-y-[-1px]">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-white">${p.title}</h3>
              <p class="text-xs text-zinc-500 mt-1">${[p.platform, p.type].filter(Boolean).map(v => v === 'image' ? 'Imagen' : v === 'video' ? 'Vídeo' : v?.charAt(0).toUpperCase() + v?.slice(1)).join(' · ') || ''}</p>
            </div>
            <span class="inline-flex rounded-full border ${statusBadgeClass(p.status)} px-3 py-1 text-xs font-medium flex-shrink-0">${p.statusLabel}</span>
          </div>
          <div class="mt-3 flex items-center gap-4 text-xs text-zinc-400">
            ${p.dueAt ? `<span>Fecha: ${new Date(p.dueAt).toLocaleDateString('es-ES')}</span>` : ''}
            <span>Unidades: ${p.unitsConsumed}/${p.unitsPlanned}</span>
          </div>
          ${p.unitsPlanned > 0 ? `
          <div class="mt-3 w-full rounded-full bg-zinc-900 h-1.5 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500 ${p.unitsConsumed >= p.unitsPlanned ? 'bg-emerald-500' : p.unitsConsumed > 0 ? 'bg-sky-500' : 'bg-zinc-700'}" style="width: ${Math.min(100, (p.unitsConsumed / p.unitsPlanned) * 100)}%"></div>
          </div>
          ` : ''}
        </div>
      `).join('')}</div>`;
    })();
  </script>
</ClientAreaLayout>