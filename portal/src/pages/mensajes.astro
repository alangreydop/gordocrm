---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Mensajes" section="mensajes">
  <div id="client-area-root" class="space-y-6">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
      <div class="border-b border-zinc-800 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Mensajes</h2>
        <p class="mt-1 text-sm text-zinc-400">Conversaciones con tu equipo.</p>
      </div>
      <div id="messages-list" class="p-6">
        <p class="text-sm text-zinc-400">Cargando mensajes...</p>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toMessagesViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const threads = toMessagesViewModel(snapshot);
      const list = document.getElementById('messages-list');

      if (!list) return;

      if (threads.length === 0) {
        list.innerHTML = '<p class="text-sm text-zinc-400">No hay conversaciones todavía.</p>';
        return;
      }

      list.innerHTML = `<div class="space-y-4">${threads.map((t) => `
        <div class="rounded-xl border border-zinc-800 bg-black p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-white">${t.subject}</h3>
              <p class="text-sm text-zinc-400 mt-1">${t.lastMessagePreview}</p>
              <p class="text-xs text-zinc-500 mt-2">${t.participants.join(' · ')} · ${new Date(t.lastMessageAt).toLocaleDateString('es-ES')}</p>
            </div>
            ${t.unreadCount > 0 ? `<span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-sky-500 text-xs font-bold text-white flex-shrink-0">${t.unreadCount}</span>` : ''}
          </div>
        </div>
      `).join('')}</div>`;
    })();
  </script>
</ClientAreaLayout>