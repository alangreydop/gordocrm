---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Mensajes" section="mensajes">
  <div id="client-area-root">
    <div class="crm-masthead">
      <p class="crm-kicker">Conversaciones</p>
      <h1 class="crm-masthead-title">Habla con tu equipo</h1>
      <p class="crm-masthead-deck">Hilos abiertos con el estudio sobre tus encargos.</p>
    </div>

    <div id="messages-list">
      {[1,2].map(() => `
        <div class="crm-row animate-pulse" style="border-bottom-color: oklch(92% 0.005 355);">
          <div class="flex-1">
            <div class="h-4 w-40 rounded" style="background: var(--gg-border-light);"></div>
            <div class="h-3 w-64 rounded mt-2" style="background: oklch(94% 0.005 355);"></div>
          </div>
          <div class="w-5 h-5 rounded-full" style="background: var(--gg-border-light);"></div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toMessagesViewModel } = await import('../lib/client-area/view-models');
      const { api } = await import('../lib/api-client');
      const { invalidateWorkspace } = await import('../lib/client-area/api');

      const snapshot = await bootstrapClientArea();
      const threads = toMessagesViewModel(snapshot);
      const list = document.getElementById('messages-list');

      if (!list) return;

      if (threads.length === 0) {
        list.innerHTML = `
          <div class="py-10 text-center">
            <p class="crm-kicker" style="color: oklch(55% 0.008 355);">Sin conversaciones</p>
            <p class="text-sm mt-2" style="color: var(--gg-text-muted);">Los mensajes aparecerán cuando inicies una conversación.</p>
          </div>`;
        return;
      }

      list.innerHTML = threads.map((t, i) => `
        <div class="crm-row crm-row--interactive" data-thread-id="${t.id}" data-thread-status="${t.status}" style="border-bottom-color: oklch(92% 0.005 355); animation-delay: ${i * 40}ms;">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <h3 class="font-semibold truncate" style="color: var(--gg-text);">${t.subject}</h3>
              ${t.unreadCount > 0 ? `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold text-white flex-shrink-0" style="background: var(--gg-accent); font-family: 'Satoshi', sans-serif;">${t.unreadCount}</span>` : ''}
            </div>
            <p class="text-sm mt-0.5 truncate" style="color: oklch(50% 0.008 355);">${t.lastMessagePreview}</p>
            <p class="text-xs mt-0.5" style="color: oklch(55% 0.008 355);">${t.participants.join(' · ')} · ${new Date(t.lastMessageAt).toLocaleDateString('es-ES')}</p>
          </div>
          <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200" data-chevron="${t.id}" style="color: oklch(55% 0.008 355);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
        <div data-thread-detail="${t.id}" class="hidden" style="border-bottom: 1px solid oklch(92% 0.005 355);">
          <div class="py-4 px-0">
            <div data-messages-history="${t.id}" class="space-y-3">
              <p class="text-sm animate-pulse" style="color: var(--gg-text-muted);">Cargando mensajes...</p>
            </div>
            <div data-reply-area="${t.id}" class="mt-4 pt-4" style="border-top: 1px solid oklch(88% 0.005 355);">
              <label class="crm-label" for="reply-${t.id}">Respuesta</label>
              <textarea id="reply-${t.id}" rows="2" class="crm-input-boxed" placeholder="Escribe tu respuesta..."></textarea>
              <div class="mt-3 flex items-center gap-3">
                <button data-reply-btn="${t.id}" class="crm-button crm-button-primary" style="padding: 0.45rem 1.1rem; font-size: 0.82rem;">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                  Enviar
                </button>
                <span data-reply-status="${t.id}" class="text-xs" style="color: oklch(55% 0.008 355);"></span>
              </div>
            </div>
          </div>
        </div>
      `).join('');

      const expandedThreads = new Set<string>();

      const toggleThread = (threadId: string) => {
        const detail = document.querySelector(`[data-thread-detail="${threadId}"]`);
        const chevron = document.querySelector(`[data-chevron="${threadId}"]`);
        if (!detail) return;

        if (expandedThreads.has(threadId)) {
          detail.classList.add('hidden');
          chevron?.classList.remove('rotate-180');
          expandedThreads.delete(threadId);
        } else {
          detail.classList.remove('hidden');
          chevron?.classList.add('rotate-180');
          expandedThreads.add(threadId);
          loadThreadMessages(threadId);
        }
      };

      const loadThreadMessages = async (threadId: string) => {
        const history = document.querySelector(`[data-messages-history="${threadId}"]`);
        if (!history) return;

        try {
          const snapshot = await (await import('../lib/client-area/bootstrap')).bootstrapClientArea();
          const threadData = snapshot.messages.find(m => m.id === threadId);
          if (!threadData) {
            history.innerHTML = '<p class="text-sm" style="color: var(--gg-text-muted);">No se encontraron mensajes.</p>';
            return;
          }
          renderThreadHistory(threadId, threadData);
        } catch {
          history.innerHTML = '<p class="text-sm" style="color: var(--gg-danger);">Error al cargar mensajes.</p>';
        }
      };

      const renderThreadHistory = (threadId: string, _threadData: { lastMessagePreview?: string }) => {
        const history = document.querySelector(`[data-messages-history="${threadId}"]`);
        if (!history) return;

        history.innerHTML = `
          <div class="flex items-start gap-3 py-2 px-3 rounded-sm" style="background: var(--gg-surface);">
            <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--gg-accent-light); color: var(--gg-accent);">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <p class="text-sm" style="color: var(--gg-text);">${_threadData.lastMessagePreview || 'Sin mensajes previos'}</p>
          </div>
        `;
      };

      const sendReply = async (threadId: string) => {
        const textarea = document.getElementById(`reply-${threadId}`) as HTMLTextAreaElement | null;
        const status = document.querySelector(`[data-reply-status="${threadId}"]`);
        const btn = document.querySelector(`[data-reply-btn="${threadId}"]`);

        if (!textarea?.value?.trim()) return;

        const body = textarea.value.trim();

        if (btn) (btn as HTMLButtonElement).disabled = true;
        if (status) status.textContent = 'Enviando...';

        try {
          await api(`/api/portal/client-area/threads/${threadId}/messages`, {
            method: 'POST',
            body: JSON.stringify({ body }),
          });

          textarea.value = '';
          if (status) status.textContent = 'Enviado';
          invalidateWorkspace();

          const history = document.querySelector(`[data-messages-history="${threadId}"]`);
          if (history) {
            const msgEl = document.createElement('div');
            msgEl.className = 'flex items-start gap-3 py-2 px-3 rounded-sm';
            msgEl.style.cssText = 'background: var(--gg-surface); animation: fadeSlideIn 200ms ease-out;';
            msgEl.innerHTML = `
              <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style="background: oklch(94% 0.005 355); color: oklch(55% 0.008 355);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <p class="text-sm" style="color: var(--gg-text);">${body}</p>
                <p class="text-xs mt-0.5" style="color: oklch(55% 0.008 355);">Tú · ahora</p>
              </div>
            `;
            history.appendChild(msgEl);
          }

          setTimeout(() => { if (status) status.textContent = ''; }, 2000);
        } catch {
          if (status) status.textContent = 'Error al enviar';
        } finally {
          if (btn) (btn as HTMLButtonElement).disabled = false;
        }
      };

      list.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;

        const toggleBtn = target.closest('[data-thread-toggle]');
        if (toggleBtn) {
          const threadId = toggleBtn.getAttribute('data-thread-toggle');
          if (threadId) toggleThread(threadId);
          return;
        }

        const row = target.closest('[data-thread-id]');
        if (row && !target.closest('[data-thread-detail]')) {
          const threadId = row.getAttribute('data-thread-id');
          if (threadId) toggleThread(threadId);
          return;
        }

        const replyBtn = target.closest('[data-reply-btn]');
        if (replyBtn) {
          const threadId = replyBtn.getAttribute('data-reply-btn');
          if (threadId) sendReply(threadId);
          return;
        }
      });

      list.addEventListener('keydown', (e) => {
        const target = e.target as HTMLElement;
        if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
          const textarea = target.closest('textarea');
          if (textarea) {
            const id = textarea.id.replace('reply-', '');
            if (id) sendReply(id);
          }
        }
      });
    })();
  </script>

  <style is:global>
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</ClientAreaLayout>