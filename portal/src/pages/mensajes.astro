---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Mensajes" section="mensajes">
  <div id="client-area-root" class="space-y-8">
    <section class="crm-page-header p-6 md:p-7">
      <p class="crm-kicker">Conversaciones</p>
      <h2 class="mt-4 text-2xl font-bold tracking-tight text-white">Habla con tu equipo</h2>
      <p class="mt-2 text-sm" style="color: var(--gg-text-muted);">Hilos abiertos con el estudio sobre tus encargos.</p>
    </section>

    <div id="messages-list" class="ca-stagger">
      {[1,2].map(() => `
        <div class="crm-panel-soft p-5 mb-3 animate-pulse">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="h-5 w-40 rounded" style="background: var(--gg-surface-elevated);"></div>
              <div class="h-3 w-64 rounded mt-2" style="background: var(--gg-surface);"></div>
              <div class="h-3 w-48 rounded mt-2" style="background: var(--gg-surface);"></div>
            </div>
            <div class="w-6 h-6 rounded-full" style="background: var(--gg-surface-elevated);"></div>
          </div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toMessagesViewModel } = await import('../lib/client-area/view-models');
      const { api } = await import('../lib/api-client');
      const { invalidateWorkspace } = await import('../lib/client-area/api');

      const snapshot = await bootstrapClientArea();
      const threads = toMessagesViewModel(snapshot);
      const list = document.getElementById('messages-list');

      if (!list) return;

      if (threads.length === 0) {
        list.innerHTML = `
          <div class="crm-empty">
            <p class="crm-kicker" style="font-size: 0.72rem; color: var(--gg-text-subtle);">Sin conversaciones</p>
            <p class="text-sm mt-3" style="color: var(--gg-text-muted);">Los mensajes aparecerán cuando inicies una conversación.</p>
          </div>`;
        return;
      }

      list.innerHTML = threads.map((t, i) => `
        <div class="crm-panel-soft mb-3 overflow-hidden ca-card-enter transition-all duration-200 hover:translate-y-[-1px]" data-thread-id="${t.id}" data-thread-status="${t.status}" style="animation-delay: ${i * 60}ms;">
          <button class="w-full text-left p-5 cursor-pointer flex items-start justify-between gap-4" data-thread-toggle="${t.id}">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3">
                <h3 class="font-semibold text-white truncate">${t.subject}</h3>
                ${t.unreadCount > 0 ? `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold text-white flex-shrink-0" style="background: var(--gg-accent); box-shadow: 0 4px 12px rgba(196,22,90,0.3);">${t.unreadCount}</span>` : ''}
              </div>
              <p class="text-sm mt-1 truncate" style="color: var(--gg-text-muted);">${t.lastMessagePreview}</p>
              <p class="text-xs mt-2" style="color: var(--gg-text-subtle);">${t.participants.join(' · ')} · ${new Date(t.lastMessageAt).toLocaleDateString('es-ES')}</p>
            </div>
            <svg class="w-5 h-5 flex-shrink-0 mt-1 transition-transform duration-200" data-chevron="${t.id}" style="color: var(--gg-text-subtle);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div data-thread-detail="${t.id}" class="hidden" style="border-top: 1px solid var(--gg-border);">
            <div class="p-5 space-y-4">
              <div data-messages-history="${t.id}" class="space-y-3">
                <p class="text-sm animate-pulse" style="color: var(--gg-text-muted);">Cargando mensajes...</p>
              </div>
              <div data-reply-area="${t.id}" class="pt-4" style="border-top: 1px solid var(--gg-border);">
                <textarea id="reply-${t.id}" rows="2" class="crm-input" placeholder="Escribe tu respuesta..."></textarea>
                <div class="mt-3 flex items-center gap-3">
                  <button data-reply-btn="${t.id}" class="crm-button crm-button-primary" style="padding: 0.5rem 1rem; font-size: 0.78rem; background: var(--gg-accent); box-shadow: 0 10px 24px rgba(196,22,90,0.16);">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                    Enviar
                  </button>
                  <span data-reply-status="${t.id}" class="text-xs" style="color: var(--gg-text-subtle);"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      `).join('');

      const expandedThreads = new Set<string>();

      const toggleThread = (threadId: string) => {
        const detail = document.querySelector(`[data-thread-detail="${threadId}"]`);
        const chevron = document.querySelector(`[data-chevron="${threadId}"]`);
        if (!detail) return;

        if (expandedThreads.has(threadId)) {
          detail.classList.add('hidden');
          chevron?.classList.remove('rotate-180');
          expandedThreads.delete(threadId);
        } else {
          detail.classList.remove('hidden');
          chevron?.classList.add('rotate-180');
          expandedThreads.add(threadId);
          loadThreadMessages(threadId);
        }
      };

      const loadThreadMessages = async (threadId: string) => {
        const history = document.querySelector(`[data-messages-history="${threadId}"]`);
        if (!history) return;

        try {
          const snapshot = await (await import('../lib/client-area/bootstrap')).bootstrapClientArea();
          const threadData = snapshot.messages.find(m => m.id === threadId);
          if (!threadData) {
            history.innerHTML = '<p class="text-sm" style="color: var(--gg-text-muted);">No se encontraron mensajes.</p>';
            return;
          }
          renderThreadHistory(threadId, threadData);
        } catch {
          history.innerHTML = '<p class="text-sm" style="color: var(--gg-danger);">Error al cargar mensajes.</p>';
        }
      };

      const renderThreadHistory = (threadId: string, _threadData: { lastMessagePreview?: string }) => {
        const history = document.querySelector(`[data-messages-history="${threadId}"]`);
        if (!history) return;

        history.innerHTML = `
          <div class="flex items-center gap-3 py-2 px-3 rounded-lg" style="background: var(--gg-surface);">
            <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--gg-accent-soft); color: var(--gg-accent-bright);">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <p class="text-sm" style="color: var(--gg-text);">${_threadData.lastMessagePreview || 'Sin mensajes previos'}</p>
          </div>
        `;
      };

      const sendReply = async (threadId: string) => {
        const textarea = document.getElementById(`reply-${threadId}`) as HTMLTextAreaElement | null;
        const status = document.querySelector(`[data-reply-status="${threadId}"]`);
        const btn = document.querySelector(`[data-reply-btn="${threadId}"]`);

        if (!textarea?.value?.trim()) return;

        const body = textarea.value.trim();

        if (btn) (btn as HTMLButtonElement).disabled = true;
        if (status) status.textContent = 'Enviando...';

        try {
          await api(`/api/portal/client-area/threads/${threadId}/messages`, {
            method: 'POST',
            body: JSON.stringify({ body }),
          });

          textarea.value = '';
          if (status) status.textContent = 'Enviado';
          invalidateWorkspace();

          const history = document.querySelector(`[data-messages-history="${threadId}"]`);
          if (history) {
            const msgEl = document.createElement('div');
            msgEl.className = 'flex items-center gap-3 py-2 px-3 rounded-lg';
            msgEl.style.cssText = 'background: var(--gg-surface); animation: fadeSlideIn 200ms ease-out;';
            msgEl.innerHTML = `
              <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.08); color: var(--gg-text);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <p class="text-sm text-white">${body}</p>
                <p class="text-xs mt-0.5" style="color: var(--gg-text-subtle);">Tú · ahora</p>
              </div>
            `;
            history.appendChild(msgEl);
          }

          setTimeout(() => { if (status) status.textContent = ''; }, 2000);
        } catch {
          if (status) status.textContent = 'Error al enviar';
        } finally {
          if (btn) (btn as HTMLButtonElement).disabled = false;
        }
      };

      list.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;

        const toggleBtn = target.closest('[data-thread-toggle]');
        if (toggleBtn) {
          const threadId = toggleBtn.getAttribute('data-thread-toggle');
          if (threadId) toggleThread(threadId);
          return;
        }

        const replyBtn = target.closest('[data-reply-btn]');
        if (replyBtn) {
          const threadId = replyBtn.getAttribute('data-reply-btn');
          if (threadId) sendReply(threadId);
          return;
        }
      });

      list.addEventListener('keydown', (e) => {
        const target = e.target as HTMLElement;
        if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
          const textarea = target.closest('textarea');
          if (textarea) {
            const id = textarea.id.replace('reply-', '');
            if (id) sendReply(id);
          }
        }
      });
    })();
  </script>

  <style is:global>
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</ClientAreaLayout>