---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const subscriptionOptions = [
   ['inactive', 'Inactive'],
   ['active', 'Active'],
   ['cancelled', 'Cancelled'],
];
const datasetOptions = [
   ['pending_capture', 'Pendiente captura'],
   ['capture_ready', 'Listo para captura'],
   ['capturing', 'Capturando'],
   ['captured', 'ADN capturado'],
   ['capture_failed', 'Captura fallida'],
];
const segmentOptions = [
   ['rentable', 'Rentable'],
   ['growth', 'Growth'],
   ['premium', 'Premium'],
   ['enterprise', 'Enterprise'],
];
const marginOptions = [
   ['estrecho', 'Estrecho'],
   ['medio', 'Medio'],
   ['alto', 'Alto'],
];
---

<AdminLayout title="Detalle cliente">
   <div class="space-y-6" role="region" aria-label="Detalle del cliente">
      <section class="crm-page-header" aria-labelledby="client-name">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <a href="/admin/clients" class="inline-block text-sm text-crm-muted transition hover:text-crm-text">&larr; Clientes</a>
            <h1 id="client-name" class="mt-3 text-3xl font-bold tracking-tight text-crm-text md:text-5xl">Cargando cliente...</h1>
            <p id="client-email" class="mt-3 text-sm text-crm-muted">—</p>
            <p id="client-company" class="mt-1 text-sm text-crm-muted"></p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span id="client-status" class="crm-badge crm-badge-default">—</span>
              <span id="client-dataset" class="crm-badge crm-badge-default">—</span>
              <span id="client-brand-assets" class="crm-badge crm-badge-default">brand assets —</span>
            </div>
          </div>
          <div class="flex gap-3">
            <a id="new-job-link" href="/admin/jobs/new" class="crm-button crm-button-primary">
            Nuevo trabajo
            </a>
          </div>
        </div>
      </section>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="crm-metric-card" role="region" aria-label="Trabajos totales">
          <p class="crm-kicker">Trabajos totales</p>
          <p id="summary-total-jobs" class="mt-4 text-4xl font-bold tracking-tight text-crm-text">—</p>
        </div>
        <div class="crm-metric-card" role="region" aria-label="Activos">
          <p class="crm-kicker">Activos</p>
          <p id="summary-active-jobs" class="mt-4 text-4xl font-bold tracking-tight text-crm-text">—</p>
        </div>
        <div class="crm-metric-card" role="region" aria-label="Entregados">
          <p class="crm-kicker">Entregados</p>
          <p id="summary-delivered-jobs" class="mt-4 text-4xl font-bold tracking-tight text-crm-text">—</p>
        </div>
        <div class="crm-metric-card" role="region" aria-label="Unidades">
          <p class="crm-kicker">Unidades</p>
          <p id="summary-units" class="mt-4 text-4xl font-bold tracking-tight text-crm-text">—</p>
          <p id="summary-capacity" class="text-sm text-crm-muted mt-2">—</p>
        </div>
      </div>

      <section class="crm-form-section" role="region" aria-label="Datos fiscales">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h2 class="crm-form-section__title">Datos fiscales</h2>
            <p class="crm-form-section__text">Información tributaria y registrada del cliente.</p>
          </div>
          <div id="fiscal-save-success" class="hidden text-sm text-crm-success crm-alert crm-alert-success" role="status"></div>
        </div>
        <div id="fiscal-save-error" class="hidden crm-alert crm-alert-danger mb-4 text-sm" role="alert"></div>
        <form id="fiscal-form" class="space-y-5" novalidate>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="fiscal-legalName" class="block text-sm font-medium text-crm-muted mb-1">Razón social</label>
              <input type="text" id="fiscal-legalName" name="legalName" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-taxId" class="block text-sm font-medium text-crm-muted mb-1">CIF / NIF</label>
              <input type="text" id="fiscal-taxId" name="taxId" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-taxIdType" class="block text-sm font-medium text-crm-muted mb-1">Tipo</label>
              <select id="fiscal-taxIdType" name="taxIdType" class="crm-input">
                <option value="">Sin definir</option>
                <option value="NIF">NIF</option>
                <option value="CIF">CIF</option>
                <option value="NIE">NIE</option>
                <option value="VIES">VIES</option>
              </select>
            </div>
            <div>
              <label for="fiscal-registrationNumber" class="block text-sm font-medium text-crm-muted mb-1">Registro mercantil</label>
              <input type="text" id="fiscal-registrationNumber" name="registrationNumber" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-addressLine1" class="block text-sm font-medium text-crm-muted mb-1">Dirección</label>
              <input type="text" id="fiscal-addressLine1" name="addressLine1" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-addressLine2" class="block text-sm font-medium text-crm-muted mb-1">Complemento</label>
              <input type="text" id="fiscal-addressLine2" name="addressLine2" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-city" class="block text-sm font-medium text-crm-muted mb-1">Localidad</label>
              <input type="text" id="fiscal-city" name="city" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-region" class="block text-sm font-medium text-crm-muted mb-1">Provincia / Región</label>
              <input type="text" id="fiscal-region" name="region" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-postalCode" class="block text-sm font-medium text-crm-muted mb-1">Código postal</label>
              <input type="text" id="fiscal-postalCode" name="postalCode" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-country" class="block text-sm font-medium text-crm-muted mb-1">País</label>
              <input type="text" id="fiscal-country" name="country" maxlength="2" placeholder="ES" class="crm-input" />
            </div>
            <div>
              <label for="fiscal-phone" class="block text-sm font-medium text-crm-muted mb-1">Teléfono fiscal</label>
              <input type="text" id="fiscal-phone" name="phone" class="crm-input" />
            </div>
          </div>
          <div class="flex gap-3">
            <button type="submit" class="crm-button crm-button-primary">Guardar datos fiscales</button>
          </div>
        </form>
      </section>

      <div class="grid gap-6 xl:grid-cols-[1.3fr_1fr]">
        <section class="crm-form-section" role="region" aria-label="Ficha cliente">
          <div class="flex items-center justify-between gap-4 mb-4">
            <div>
              <h2 class="crm-form-section__title">Ficha cliente</h2>
              <p class="crm-form-section__text">Identidad, estado comercial, capacidad y seguimiento.</p>
            </div>
            <div id="client-save-success" class="hidden text-sm text-crm-success crm-alert crm-alert-success" role="status"></div>
          </div>

          <div id="client-save-error" class="hidden crm-alert crm-alert-danger mb-4 text-sm" role="alert"></div>

          <form id="client-form" class="space-y-5" novalidate>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-crm-muted mb-1">Nombre</label>
                <input type="text" id="name" name="name" required class="crm-input" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-crm-muted mb-1">Email principal</label>
                <input type="email" id="email" name="email" required class="crm-input" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-crm-muted mb-1">Empresa</label>
                <input type="text" id="company" name="company" class="crm-input" />
              </div>
              <div>
                <label for="accountManager" class="block text-sm font-medium text-crm-muted mb-1">Account manager</label>
                <input type="text" id="accountManager" name="accountManager" class="crm-input" />
              </div>
              <div>
                <label for="plan" class="block text-sm font-medium text-crm-muted mb-1">Plan</label>
                <input type="text" id="plan" name="plan" class="crm-input" />
              </div>
              <div>
                <label for="monthlyUnitCapacity" class="block text-sm font-medium text-crm-muted mb-1">Capacidad mensual</label>
                <input type="number" min="0" id="monthlyUnitCapacity" name="monthlyUnitCapacity" class="crm-input" />
              </div>
              <div>
                <label for="subscriptionStatus" class="block text-sm font-medium text-crm-muted mb-1">Suscripcion</label>
                <select id="subscriptionStatus" name="subscriptionStatus" class="crm-input">
                  {subscriptionOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
              <div>
                <label for="datasetStatus" class="block text-sm font-medium text-crm-muted mb-1">Base visual</label>
                <select id="datasetStatus" name="datasetStatus" class="crm-input">
                  {datasetOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
              <div>
                <label for="segment" class="block text-sm font-medium text-crm-muted mb-1">Segmento</label>
                <select id="segment" name="segment" class="crm-input">
                  <option value="">Sin definir</option>
                  {segmentOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
              <div>
                <label for="marginProfile" class="block text-sm font-medium text-crm-muted mb-1">Perfil margen</label>
                <select id="marginProfile" name="marginProfile" class="crm-input">
                  <option value="">Sin definir</option>
                  {marginOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
              <div>
                <label for="lastContactedAt" class="block text-sm font-medium text-crm-muted mb-1">Último contacto</label>
                <input type="date" id="lastContactedAt" name="lastContactedAt" class="crm-input" />
              </div>
              <div>
                <label for="nextReviewAt" class="block text-sm font-medium text-crm-muted mb-1">Próxima revisión</label>
                <input type="date" id="nextReviewAt" name="nextReviewAt" class="crm-input" />
              </div>
            </div>
            <div>
              <label for="notes" class="block text-sm font-medium text-crm-muted mb-1">Notas internas</label>
              <textarea id="notes" name="notes" rows="5" class="crm-input"></textarea>
            </div>
            <div class="flex gap-3">
              <button type="submit" class="crm-button crm-button-primary">Guardar cambios</button>
            </div>
          </form>
        </section>

        <section class="space-y-6">
          <div class="crm-form-section" role="region" aria-label="Acceso al portal">
            <div class="flex items-center justify-between gap-4 mb-4">
              <div>
                <h2 class="crm-form-section__title">Acceso al portal</h2>
                <p class="crm-form-section__text">Crea o resetea el acceso del cliente cuando lo necesites.</p>
              </div>
              <div id="portal-access-success" class="hidden text-sm crm-alert crm-alert-success" role="status"></div>
            </div>

            <div id="portal-access-summary" class="rounded-lg bg-crm-panel-soft p-4 text-sm text-crm-muted" aria-live="polite">
            Cargando acceso del portal...
            </div>

            <div id="portal-access-error" class="hidden crm-alert crm-alert-danger mt-4 text-sm" role="alert"></div>

            <form id="portal-access-form" class="space-y-4 mt-4">
              <div>
                <label for="portalName" class="block text-sm font-medium text-crm-muted mb-1">Nombre del usuario portal</label>
                <input type="text" id="portalName" name="portalName" class="crm-input" />
              </div>
              <div>
                <label for="portalEmail" class="block text-sm font-medium text-crm-muted mb-1">Email del usuario portal</label>
                <input type="email" id="portalEmail" name="portalEmail" class="crm-input" />
              </div>
              <div>
                <label for="portalPassword" class="block text-sm font-medium text-crm-muted mb-1">Nueva contrasena</label>
                <input type="password" id="portalPassword" name="portalPassword" minlength="8" required class="crm-input" />
              </div>
              <button type="submit" id="portal-access-button" class="crm-button crm-button-primary w-full">
              Crear acceso
              </button>
            </form>
          </div>

          <div class="crm-form-section" role="region" aria-label="Operacion Grande&Gordo">
            <h2 class="crm-form-section__title">Operacion Grande&Gordo</h2>
            <div class="mt-4 space-y-3 text-sm text-crm-muted">
              <p><span class="font-medium text-crm-text">Email operativo:</span> hola@grandeandgordo.com</p>
              <p><span class="font-medium text-crm-text">Objetivo:</span> concentrar seguimiento, acceso, delivery y margen por cuenta.</p>
              <p><span class="font-medium text-crm-text">Recomendacion:</span> mantén revisiones y dataset al dia para evitar cuellos de botella.</p>
            </div>
          </div>
        </section>
      </div>

      <section class="crm-table-wrap" role="region" aria-label="Trabajos del cliente">
        <div class="flex items-center justify-between border-b border-crm-border px-6 py-5">
          <div>
            <h2 id="jobs-heading" class="text-lg font-semibold text-crm-text">Trabajos</h2>
            <p class="mt-2 text-sm text-crm-muted">Produccion vinculada al cliente con foco en margen, stack y deadline.</p>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="crm-table min-w-full text-sm">
            <thead>
              <tr>
                <th class="px-6 py-3 text-left">Brief</th>
                <th class="px-6 py-3 text-left">Estado</th>
                <th class="px-6 py-3 text-left">Due</th>
                <th class="px-6 py-3 text-left">Units</th>
                <th class="px-6 py-3 text-left">Lane</th>
                <th class="px-6 py-3 text-left">Margen</th>
                <th class="px-6 py-3"></th>
              </tr>
            </thead>
            <tbody id="client-jobs-body">
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-crm-muted">Cargando trabajos...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <script>
      (async () => {
      const {
        API_BASE,
        api,
        dateInputValue,
        escapeHtml,
        formatDate,
        formatNumber,
        formatPercent,
       } = await import('../../../lib/api-client');
      const {
        datasetStatusClass,
        datasetStatusLabel,
        jobStatusClass,
        stackLaneClass,
        subscriptionClass,
       } = await import('../../../lib/ui-helpers');

      const clientId = new URLSearchParams(window.location.search).get('id');
      if (!clientId) {
        window.location.href = '/admin/clients';
        return;
      }

      const nameEl = document.getElementById('client-name');
      const emailEl = document.getElementById('client-email');
      const companyEl = document.getElementById('client-company');
      const statusEl = document.getElementById('client-status');
        const datasetEl = document.getElementById('client-dataset');
        const brandAssetsEl = document.getElementById('client-brand-assets');
      const jobsHeading = document.getElementById('jobs-heading');
      const newJobLink = document.getElementById('new-job-link');
      const jobsBody = document.getElementById('client-jobs-body');
      const portalSummary = document.getElementById('portal-access-summary');
      const portalButton = document.getElementById('portal-access-button');

      const clientForm = document.getElementById('client-form');
      const clientError = document.getElementById('client-save-error');
      const clientSuccess = document.getElementById('client-save-success');
      const portalForm = document.getElementById('portal-access-form');
      const portalError = document.getElementById('portal-access-error');
      const portalSuccess = document.getElementById('portal-access-success');

      let currentClient = null;

      const setInputValue = (id, value) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
          ) {
          field.value = value ?? '';
          }
       };

      const fieldValue = (id) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
          ) {
          return field.value;
          }
        return '';
       };

      const renderPortalSummary = (portalUser) => {
        if (!portalSummary) return;

        if (!portalUser) {
          portalSummary.innerHTML = `
             <p class="font-medium text-crm-text">Sin acceso activo</p>
             <p class="mt-2 text-crm-muted">Este cliente todavia no tiene usuario para entrar al portal.</p>
           `;
          if (portalButton) portalButton.textContent = 'Crear acceso';
          return;
         }

        portalSummary.innerHTML = `
           <p class="font-medium text-crm-text">Acceso activo</p>
           <p class="mt-2 text-crm-muted">Usuario: ${escapeHtml(portalUser.name ?? '—')}</p>
           <p class="mt-1 text-crm-muted">Email: ${escapeHtml(portalUser.email ?? '—')}</p>
           <p class="mt-1 text-crm-muted">Actualizado: ${escapeHtml(formatDate(portalUser.updatedAt))}</p>
         `;
        if (portalButton) portalButton.textContent = 'Resetear acceso';
       };

      const renderJobs = (jobs) => {
        if (!jobsBody) return;

        if (jobsHeading) jobsHeading.textContent = `Trabajos (${jobs.length})`;

        if (jobs.length === 0) {
          jobsBody.innerHTML = `
             <tr>
               <td colspan="7" class="px-6 py-8 text-center text-crm-muted">Este cliente todavia no tiene trabajos.</td>
             </tr>
           `;
          return;
         }

        jobsBody.innerHTML = jobs.map((job) => `
           <tr>
             <td class="px-6 py-4">
               <p class="font-medium text-crm-text">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
               <p class="text-xs text-crm-muted mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
             </td>
             <td class="px-6 py-4">
               <span class="${jobStatusClass(job.status ?? '')}">
                 ${escapeHtml(job.status ?? 'pending')}
               </span>
             </td>
             <td class="px-6 py-4 text-crm-muted">${escapeHtml(formatDate(job.dueAt))}</td>
             <td class="px-6 py-4 text-crm-muted">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
             <td class="px-6 py-4">
               <span class="${stackLaneClass(job.stackLane ?? '')}">
                 ${escapeHtml(job.stackLane ?? '—')}
               </span>
             </td>
             <td class="px-6 py-4 text-crm-muted">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
             <td class="px-6 py-4 text-right">
               <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-crm-accent transition hover:text-crm-text">Abrir</a>
             </td>
           </tr>
         `).join('');
       };

      const renderClient = (payload) => {
        const { client, summary, jobs, portalUser } = payload;
        currentClient = client;

        if (nameEl) nameEl.textContent = client.name;
        if (emailEl) emailEl.textContent = client.email;
        if (companyEl) companyEl.textContent = client.company ?? 'Sin empresa asignada';

        if (statusEl) {
          statusEl.textContent = client.subscriptionStatus ?? 'inactive';
          statusEl.className = subscriptionClass(client.subscriptionStatus ?? 'inactive');
         }

        if (datasetEl) {
          datasetEl.textContent = `ADN ${datasetStatusLabel(client.datasetStatus ?? 'pending_capture')}`;
          datasetEl.className = datasetStatusClass(client.datasetStatus ?? '');
         }

        if (brandAssetsEl) {
          const readiness = client.brandReadiness;
          const total = readiness?.totalAssets ?? 0;
          const missing = Array.isArray(readiness?.missing) ? readiness.missing : [];
          brandAssetsEl.textContent = missing.length === 0
            ? `brand assets listos (${total})`
            : `brand assets ${total}, faltan ${missing.join(', ')}`;
          brandAssetsEl.className = missing.length === 0
            ? 'crm-badge crm-badge-success'
            : 'crm-badge crm-badge-warning';
         }

        if (newJobLink instanceof HTMLAnchorElement) {
          newJobLink.href = `/admin/jobs/new?clientId=${encodeURIComponent(client.id)}`;
         }

        const setText = (id, value) => {
          const element = document.getElementById(id);
          if (element) element.textContent = value;
         };

        setText('summary-total-jobs', String(summary?.totalJobs ?? 0));
        setText('summary-active-jobs', String(summary?.activeJobs ?? 0));
        setText('summary-delivered-jobs', String(summary?.deliveredJobs ?? 0));
        setText(
           'summary-units',
           `${formatNumber(summary?.unitsConsumed ?? 0)} / ${formatNumber(summary?.unitsPlanned ?? 0)}`,
         );
        setText(
           'summary-capacity',
           `Capacidad mensual: ${formatNumber(client.monthlyUnitCapacity ?? 0)}`,
         );

        setInputValue('name', client.name);
        setInputValue('email', client.email);
        setInputValue('company', client.company ?? '');
        setInputValue('accountManager', client.accountManager ?? 'hola@grandeandgordo.com');
        setInputValue('plan', client.plan ?? '');
        setInputValue('monthlyUnitCapacity', client.monthlyUnitCapacity ?? '');
        setInputValue('subscriptionStatus', client.subscriptionStatus ?? 'inactive');
        setInputValue('datasetStatus', client.datasetStatus ?? 'pending_capture');
        setInputValue('segment', client.segment ?? '');
        setInputValue('marginProfile', client.marginProfile ?? '');
        setInputValue('lastContactedAt', dateInputValue(client.lastContactedAt));
        setInputValue('nextReviewAt', dateInputValue(client.nextReviewAt));
        setInputValue('notes', client.notes ?? '');

        setInputValue('fiscal-legalName', client.legalName ?? '');
        setInputValue('fiscal-taxId', client.taxId ?? '');
        setInputValue('fiscal-taxIdType', client.taxIdType ?? '');
        setInputValue('fiscal-registrationNumber', client.registrationNumber ?? '');
        setInputValue('fiscal-addressLine1', client.addressLine1 ?? '');
        setInputValue('fiscal-addressLine2', client.addressLine2 ?? '');
        setInputValue('fiscal-city', client.city ?? '');
        setInputValue('fiscal-region', client.region ?? '');
        setInputValue('fiscal-postalCode', client.postalCode ?? '');
        setInputValue('fiscal-country', client.country ?? 'ES');
        setInputValue('fiscal-phone', client.phone ?? '');

        setInputValue('portalName', portalUser?.name ?? client.name);
        setInputValue('portalEmail', portalUser?.email ?? client.email);
        setInputValue('portalPassword', '');
        renderPortalSummary(portalUser);
        renderJobs(Array.isArray(jobs) ? jobs : []);
       };

      const load = async () => {
        const payload = await api(`/api/portal/clients/${encodeURIComponent(clientId)}`);
        renderClient(payload);
       };

      try {
        await load();
       } catch {
        window.location.href = '/admin/clients';
        return;
       }

      clientForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        clientError?.classList.add('hidden');
        clientSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/clients/${encodeURIComponent(clientId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              name: fieldValue('name'),
              email: fieldValue('email'),
              company: fieldValue('company') || null,
              accountManager: fieldValue('accountManager') || null,
              plan: fieldValue('plan') || null,
              monthlyUnitCapacity: fieldValue('monthlyUnitCapacity') || null,
              subscriptionStatus: fieldValue('subscriptionStatus') || undefined,
              datasetStatus: fieldValue('datasetStatus') || undefined,
              segment: fieldValue('segment') || null,
              marginProfile: fieldValue('marginProfile') || null,
              lastContactedAt: fieldValue('lastContactedAt') || null,
              nextReviewAt: fieldValue('nextReviewAt') || null,
              notes: fieldValue('notes') || null,
             }),
           });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo guardar el cliente');
           }

          await load();

          if (clientSuccess instanceof HTMLDivElement) {
            clientSuccess.textContent = 'Ficha del cliente actualizada.';
            clientSuccess.classList.remove('hidden');
           }
         } catch (error) {
          if (clientError instanceof HTMLDivElement) {
            clientError.textContent =
              error instanceof Error ? error.message : 'no se pudo guardar el cliente';
            clientError.classList.remove('hidden');
           }
         }
       });

      portalForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        portalError?.classList.add('hidden');
        portalSuccess?.classList.add('hidden');
        const hadPortalAccess = Boolean(currentClient?.userId);

        try {
          const res = await fetch(`${API_BASE}/api/portal/clients/${encodeURIComponent(clientId)}/portal-access`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              name: fieldValue('portalName'),
              email: fieldValue('portalEmail'),
              password: fieldValue('portalPassword'),
             }),
           });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo actualizar el acceso');
           }

          await load();

          if (portalSuccess instanceof HTMLDivElement) {
            portalSuccess.textContent =
              hadPortalAccess ? 'Acceso de portal reseteado.' : 'Acceso de portal creado.';
            portalSuccess.classList.remove('hidden');
           }
         } catch (error) {
          if (portalError instanceof HTMLDivElement) {
            portalError.textContent =
              error instanceof Error ? error.message : 'no se pudo actualizar el acceso';
            portalError.classList.remove('hidden');
           }
         }
       });

      const fiscalForm = document.getElementById('fiscal-form');
      const fiscalError = document.getElementById('fiscal-save-error');
      const fiscalSuccess = document.getElementById('fiscal-save-success');

      fiscalForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        fiscalError?.classList.add('hidden');
        fiscalSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/clients/${encodeURIComponent(clientId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              legalName: fieldValue('fiscal-legalName') || null,
              taxId: fieldValue('fiscal-taxId') || null,
              taxIdType: fieldValue('fiscal-taxIdType') || undefined,
              registrationNumber: fieldValue('fiscal-registrationNumber') || null,
              addressLine1: fieldValue('fiscal-addressLine1') || null,
              addressLine2: fieldValue('fiscal-addressLine2') || null,
              city: fieldValue('fiscal-city') || null,
              region: fieldValue('fiscal-region') || null,
              postalCode: fieldValue('fiscal-postalCode') || null,
              country: fieldValue('fiscal-country') || 'ES',
              phone: fieldValue('fiscal-phone') || null,
             }),
           });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudieron guardar los datos fiscales');
           }

          await load();

          if (fiscalSuccess instanceof HTMLDivElement) {
            fiscalSuccess.textContent = 'Datos fiscales actualizados.';
            fiscalSuccess.classList.remove('hidden');
           }
         } catch (error) {
          if (fiscalError instanceof HTMLDivElement) {
            fiscalError.textContent =
              error instanceof Error ? error.message : 'no se pudieron guardar los datos fiscales';
            fiscalError.classList.remove('hidden');
           }
         }
       });
      })();
    </script>
</AdminLayout>
