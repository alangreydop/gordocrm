---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const subscriptionOptions = [
  ['inactive', 'Inactive'],
  ['active', 'Active'],
  ['cancelled', 'Cancelled'],
];
const datasetOptions = [
  ['pending_capture', 'Pendiente captura'],
  ['captured', 'Capturado'],
  ['trained', 'Entrenado'],
  ['active', 'Activo'],
  ['archived', 'Archivado'],
];
const segmentOptions = [
  ['rentable', 'Rentable'],
  ['growth', 'Growth'],
  ['premium', 'Premium'],
  ['enterprise', 'Enterprise'],
];
const marginOptions = [
  ['estrecho', 'Estrecho'],
  ['medio', 'Medio'],
  ['alto', 'Alto'],
];
---

<AdminLayout title="Detalle cliente">
  <div class="space-y-6">
    <section class="crm-page-header">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <a href="/admin/clients" class="inline-block text-sm text-slate-300 transition hover:text-white">&larr; Clientes</a>
          <h1 id="client-name" class="mt-3 text-3xl font-black tracking-tight text-white md:text-5xl">Cargando cliente...</h1>
          <p id="client-email" class="mt-3 text-sm text-slate-200">—</p>
          <p id="client-company" class="mt-1 text-sm text-slate-400"></p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span id="client-status" class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-200">—</span>
            <span id="client-dataset" class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-200">—</span>
          </div>
        </div>
        <div class="flex gap-3">
          <a id="new-job-link" href="/admin/jobs/new" class="crm-button crm-button-primary">
            Nuevo trabajo
          </a>
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">Trabajos totales</p>
        <p id="summary-total-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Activos</p>
        <p id="summary-active-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Entregados</p>
        <p id="summary-delivered-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Unidades</p>
        <p id="summary-units" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="summary-capacity" class="text-sm text-gray-500 mt-2">—</p>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.3fr_1fr]">
      <section class="crm-form-section">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h2 class="crm-form-section__title">Ficha cliente</h2>
            <p class="crm-form-section__text">Identidad, estado comercial, capacidad y seguimiento.</p>
          </div>
          <div id="client-save-success" class="hidden text-sm text-green-700 bg-green-50 rounded px-3 py-2"></div>
        </div>

        <div id="client-save-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

        <form id="client-form" class="space-y-5">
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
              <input type="text" id="name" name="name" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email principal</label>
              <input type="email" id="email" name="email" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Empresa</label>
              <input type="text" id="company" name="company" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="accountManager" class="block text-sm font-medium text-gray-700 mb-1">Account manager</label>
              <input type="text" id="accountManager" name="accountManager" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="plan" class="block text-sm font-medium text-gray-700 mb-1">Plan</label>
              <input type="text" id="plan" name="plan" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="monthlyUnitCapacity" class="block text-sm font-medium text-gray-700 mb-1">Capacidad mensual</label>
              <input type="number" min="0" id="monthlyUnitCapacity" name="monthlyUnitCapacity" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="subscriptionStatus" class="block text-sm font-medium text-gray-700 mb-1">Suscripcion</label>
              <select id="subscriptionStatus" name="subscriptionStatus" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                {subscriptionOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="datasetStatus" class="block text-sm font-medium text-gray-700 mb-1">Dataset</label>
              <select id="datasetStatus" name="datasetStatus" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                {datasetOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="segment" class="block text-sm font-medium text-gray-700 mb-1">Segmento</label>
              <select id="segment" name="segment" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {segmentOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="marginProfile" class="block text-sm font-medium text-gray-700 mb-1">Perfil margen</label>
              <select id="marginProfile" name="marginProfile" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {marginOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="lastContactedAt" class="block text-sm font-medium text-gray-700 mb-1">Ultimo contacto</label>
              <input type="date" id="lastContactedAt" name="lastContactedAt" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="nextReviewAt" class="block text-sm font-medium text-gray-700 mb-1">Proxima review</label>
              <input type="date" id="nextReviewAt" name="nextReviewAt" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
          </div>
          <div>
            <label for="notes" class="block text-sm font-medium text-gray-700 mb-1">Notas internas</label>
            <textarea id="notes" name="notes" rows="5" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
          </div>
          <div class="flex gap-3">
            <button type="submit" class="crm-button crm-button-primary">Guardar cambios</button>
          </div>
        </form>
      </section>

      <section class="space-y-6">
        <div class="crm-form-section">
          <div class="flex items-center justify-between gap-4 mb-4">
            <div>
              <h2 class="crm-form-section__title">Acceso al portal</h2>
              <p class="crm-form-section__text">Crea o resetea el acceso del cliente cuando lo necesites.</p>
            </div>
            <div id="portal-access-success" class="hidden text-sm text-green-700 bg-green-50 rounded px-3 py-2"></div>
          </div>

          <div id="portal-access-summary" class="rounded-lg bg-gray-50 p-4 text-sm text-gray-600">
            Cargando acceso del portal...
          </div>

          <div id="portal-access-error" class="hidden bg-red-50 text-red-700 rounded p-3 mt-4 text-sm"></div>

          <form id="portal-access-form" class="space-y-4 mt-4">
            <div>
              <label for="portalName" class="block text-sm font-medium text-gray-700 mb-1">Nombre del usuario portal</label>
              <input type="text" id="portalName" name="portalName" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="portalEmail" class="block text-sm font-medium text-gray-700 mb-1">Email del usuario portal</label>
              <input type="email" id="portalEmail" name="portalEmail" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="portalPassword" class="block text-sm font-medium text-gray-700 mb-1">Nueva contrasena</label>
              <input type="password" id="portalPassword" name="portalPassword" minlength="8" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <button type="submit" id="portal-access-button" class="crm-button crm-button-primary w-full">
              Crear acceso
            </button>
          </form>
        </div>

        <div class="crm-form-section">
          <h2 class="crm-form-section__title">Operacion Grande&Gordo</h2>
          <div class="mt-4 space-y-3 text-sm text-gray-600">
            <p><span class="font-medium text-gray-900">Email operativo:</span> hola@grandeandgordo.com</p>
            <p><span class="font-medium text-gray-900">Objetivo:</span> concentrar seguimiento, acceso, delivery y margen por cuenta.</p>
            <p><span class="font-medium text-gray-900">Recomendacion:</span> mantén revisiones y dataset al dia para evitar cuellos de botella.</p>
          </div>
        </div>
      </section>
    </div>

    <section class="crm-table-wrap">
      <div class="flex items-center justify-between border-b border-white/8 px-6 py-5">
        <div>
          <h2 id="jobs-heading" class="text-lg font-semibold text-white">Trabajos</h2>
          <p class="mt-2 text-sm text-slate-300">Produccion vinculada al cliente con foco en margen, stack y deadline.</p>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full divide-y divide-gray-200 text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left">Brief</th>
              <th class="px-6 py-3 text-left">Estado</th>
              <th class="px-6 py-3 text-left">Due</th>
              <th class="px-6 py-3 text-left">Units</th>
              <th class="px-6 py-3 text-left">Lane</th>
              <th class="px-6 py-3 text-left">Margen</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="client-jobs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-slate-400">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const {
        API_BASE,
        api,
        datasetStatusClass,
        dateInputValue,
        escapeHtml,
        formatDate,
        formatNumber,
        formatPercent,
        jobStatusClass,
        stackLaneClass,
        subscriptionClass,
      } = await import('../../../lib/api-client');

      const clientId = new URLSearchParams(window.location.search).get('id');
      if (!clientId) {
        window.location.href = '/admin/clients';
        return;
      }

      const nameEl = document.getElementById('client-name');
      const emailEl = document.getElementById('client-email');
      const companyEl = document.getElementById('client-company');
      const statusEl = document.getElementById('client-status');
      const datasetEl = document.getElementById('client-dataset');
      const jobsHeading = document.getElementById('jobs-heading');
      const newJobLink = document.getElementById('new-job-link');
      const jobsBody = document.getElementById('client-jobs-body');
      const portalSummary = document.getElementById('portal-access-summary');
      const portalButton = document.getElementById('portal-access-button');

      const clientForm = document.getElementById('client-form');
      const clientError = document.getElementById('client-save-error');
      const clientSuccess = document.getElementById('client-save-success');
      const portalForm = document.getElementById('portal-access-form');
      const portalError = document.getElementById('portal-access-error');
      const portalSuccess = document.getElementById('portal-access-success');

      let currentClient = null;

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const setInputValue = (id, value) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
        ) {
          field.value = value ?? '';
        }
      };

      const fieldValue = (id) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
        ) {
          return field.value;
        }
        return '';
      };

      const renderPortalSummary = (portalUser) => {
        if (!portalSummary) return;

        if (!portalUser) {
          portalSummary.innerHTML = `
            <p class="font-medium text-white">Sin acceso activo</p>
            <p class="mt-2 text-slate-300">Este cliente todavia no tiene usuario para entrar al portal.</p>
          `;
          if (portalButton) portalButton.textContent = 'Crear acceso';
          return;
        }

        portalSummary.innerHTML = `
          <p class="font-medium text-white">Acceso activo</p>
          <p class="mt-2 text-slate-300">Usuario: ${escapeHtml(portalUser.name ?? '—')}</p>
          <p class="mt-1 text-slate-300">Email: ${escapeHtml(portalUser.email ?? '—')}</p>
          <p class="mt-1 text-slate-300">Actualizado: ${escapeHtml(formatDate(portalUser.updatedAt))}</p>
        `;
        if (portalButton) portalButton.textContent = 'Resetear acceso';
      };

      const renderJobs = (jobs) => {
        if (!jobsBody) return;

        if (jobsHeading) jobsHeading.textContent = `Trabajos (${jobs.length})`;

        if (jobs.length === 0) {
          jobsBody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-slate-400">Este cliente todavia no tiene trabajos.</td>
            </tr>
          `;
          return;
        }

        jobsBody.innerHTML = jobs.map((job) => `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-white">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-gray-500 mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${stackLaneClass(job.stackLane ?? '')}">
                ${escapeHtml(job.stackLane ?? '—')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-sky-200 transition hover:text-white">Abrir</a>
            </td>
          </tr>
        `).join('');
      };

      const renderClient = (payload) => {
        const { client, summary, jobs, portalUser } = payload;
        currentClient = client;

        if (nameEl) nameEl.textContent = client.name;
        if (emailEl) emailEl.textContent = client.email;
        if (companyEl) companyEl.textContent = client.company ?? 'Sin empresa asignada';

        if (statusEl) {
          statusEl.textContent = client.subscriptionStatus ?? 'inactive';
          statusEl.className = `inline-flex rounded-full px-3 py-1 text-xs font-medium ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}`;
        }

        if (datasetEl) {
          datasetEl.textContent = `dataset ${client.datasetStatus ?? 'pending_capture'}`;
          datasetEl.className = `inline-flex rounded-full px-3 py-1 text-xs font-medium ${datasetStatusClass(client.datasetStatus ?? '')}`;
        }

        if (newJobLink instanceof HTMLAnchorElement) {
          newJobLink.href = `/admin/jobs/new?clientId=${encodeURIComponent(client.id)}`;
        }

        setText('summary-total-jobs', String(summary?.totalJobs ?? 0));
        setText('summary-active-jobs', String(summary?.activeJobs ?? 0));
        setText('summary-delivered-jobs', String(summary?.deliveredJobs ?? 0));
        setText(
          'summary-units',
          `${formatNumber(summary?.unitsConsumed ?? 0)} / ${formatNumber(summary?.unitsPlanned ?? 0)}`,
        );
        setText(
          'summary-capacity',
          `Capacidad mensual: ${formatNumber(client.monthlyUnitCapacity ?? 0)}`,
        );

        setInputValue('name', client.name);
        setInputValue('email', client.email);
        setInputValue('company', client.company ?? '');
        setInputValue('accountManager', client.accountManager ?? 'hola@grandeandgordo.com');
        setInputValue('plan', client.plan ?? '');
        setInputValue('monthlyUnitCapacity', client.monthlyUnitCapacity ?? '');
        setInputValue('subscriptionStatus', client.subscriptionStatus ?? 'inactive');
        setInputValue('datasetStatus', client.datasetStatus ?? 'pending_capture');
        setInputValue('segment', client.segment ?? '');
        setInputValue('marginProfile', client.marginProfile ?? '');
        setInputValue('lastContactedAt', dateInputValue(client.lastContactedAt));
        setInputValue('nextReviewAt', dateInputValue(client.nextReviewAt));
        setInputValue('notes', client.notes ?? '');

        setInputValue('portalName', portalUser?.name ?? client.name);
        setInputValue('portalEmail', portalUser?.email ?? client.email);
        setInputValue('portalPassword', '');
        renderPortalSummary(portalUser);
        renderJobs(Array.isArray(jobs) ? jobs : []);
      };

      const load = async () => {
        const payload = await api(`/api/portal/clients/${encodeURIComponent(clientId)}`);
        renderClient(payload);
      };

      try {
        await load();
      } catch {
        window.location.href = '/admin/clients';
        return;
      }

      clientForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        clientError?.classList.add('hidden');
        clientSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/clients/${encodeURIComponent(clientId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              name: fieldValue('name'),
              email: fieldValue('email'),
              company: fieldValue('company') || null,
              accountManager: fieldValue('accountManager') || null,
              plan: fieldValue('plan') || null,
              monthlyUnitCapacity: fieldValue('monthlyUnitCapacity') || null,
              subscriptionStatus: fieldValue('subscriptionStatus') || undefined,
              datasetStatus: fieldValue('datasetStatus') || undefined,
              segment: fieldValue('segment') || null,
              marginProfile: fieldValue('marginProfile') || null,
              lastContactedAt: fieldValue('lastContactedAt') || null,
              nextReviewAt: fieldValue('nextReviewAt') || null,
              notes: fieldValue('notes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo guardar el cliente');
          }

          await load();

          if (clientSuccess instanceof HTMLDivElement) {
            clientSuccess.textContent = 'Ficha del cliente actualizada.';
            clientSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (clientError instanceof HTMLDivElement) {
            clientError.textContent =
              error instanceof Error ? error.message : 'No se pudo guardar el cliente';
            clientError.classList.remove('hidden');
          }
        }
      });

      portalForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        portalError?.classList.add('hidden');
        portalSuccess?.classList.add('hidden');
        const hadPortalAccess = Boolean(currentClient?.userId);

        try {
          const res = await fetch(`${API_BASE}/api/portal/clients/${encodeURIComponent(clientId)}/portal-access`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              name: fieldValue('portalName'),
              email: fieldValue('portalEmail'),
              password: fieldValue('portalPassword'),
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo actualizar el acceso');
          }

          await load();

          if (portalSuccess instanceof HTMLDivElement) {
            portalSuccess.textContent =
              hadPortalAccess ? 'Acceso de portal reseteado.' : 'Acceso de portal creado.';
            portalSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (portalError instanceof HTMLDivElement) {
            portalError.textContent =
              error instanceof Error ? error.message : 'No se pudo actualizar el acceso';
            portalError.classList.remove('hidden');
          }
        }
      });
    })();
  </script>
</AdminLayout>
