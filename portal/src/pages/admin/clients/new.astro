---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const subscriptionOptions = [
  ['inactive', 'Inactive'],
  ['active', 'Active'],
  ['cancelled', 'Cancelled'],
];
const datasetOptions = [
   ['pending_capture', 'Pendiente captura'],
   ['capture_ready', 'Listo para captura'],
   ['capturing', 'Capturando'],
   ['captured', 'ADN capturado'],
   ['capture_failed', 'Captura fallida'],
];
const segmentOptions = [
  ['rentable', 'Rentable'],
  ['growth', 'Growth'],
  ['premium', 'Premium'],
  ['enterprise', 'Enterprise'],
];
const marginOptions = [
  ['estrecho', 'Estrecho'],
  ['medio', 'Medio'],
  ['alto', 'Alto'],
];
---

<AdminLayout title="Nuevo cliente">
  <div class="max-w-5xl space-y-6" role="region" aria-label="Contenido principal">
    <section class="crm-page-header">
      <p class="crm-kicker">Nueva cuenta</p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-crm-text md:text-5xl">Nuevo cliente</h1>
      <p class="crm-page-header__meta mt-4">
        Crea la ficha comercial, operativa y de acceso al portal en un solo paso.
      </p>
    </section>

    <div id="form-error" class="hidden crm-alert crm-alert-danger"></div>

    <form id="client-form" class="space-y-6" role="region" aria-label="Contenido principal">
      <section class="crm-form-section space-y-4">
        <div class="crm-form-section__header">
          <h2 class="crm-form-section__title">Identidad</h2>
          <p class="crm-form-section__text">Base de contacto y ownership operativo de la cuenta.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-sm font-medium text-crm-muted mb-1">Nombre</label>
            <input type="text" id="name" name="name" required
              class="crm-input" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-crm-muted mb-1">Email principal</label>
            <input type="email" id="email" name="email" required placeholder="hola@grandeandgordo.com"
              class="crm-input" />
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-crm-muted mb-1">Empresa</label>
            <input type="text" id="company" name="company"
              class="crm-input" />
          </div>
          <div>
            <label for="accountManager" class="block text-sm font-medium text-crm-muted mb-1">Account manager</label>
            <input type="text" id="accountManager" name="accountManager" value="hola@grandeandgordo.com"
              class="crm-input" />
          </div>
        </div>
      </section>

      <section class="crm-form-section space-y-4">
        <div class="crm-form-section__header">
          <h2 class="crm-form-section__title">Plan y operativa</h2>
          <p class="crm-form-section__text">Configuracion comercial, capacidad y proximas revisiones.</p>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
          <div>
            <label for="plan" class="block text-sm font-medium text-crm-muted mb-1">Plan</label>
            <input type="text" id="plan" name="plan" placeholder="Campaña Pro"
              class="crm-input" />
          </div>
          <div>
            <label for="subscriptionStatus" class="block text-sm font-medium text-crm-muted mb-1">Suscripción</label>
            <select id="subscriptionStatus" name="subscriptionStatus"
              class="crm-input">
              {subscriptionOptions.map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="datasetStatus" class="block text-sm font-medium text-crm-muted mb-1">Base visual</label>
            <select id="datasetStatus" name="datasetStatus"
              class="crm-input">
              {datasetOptions.map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="monthlyUnitCapacity" class="block text-sm font-medium text-crm-muted mb-1">Capacidad mensual</label>
            <input type="number" id="monthlyUnitCapacity" name="monthlyUnitCapacity" min="0" placeholder="72"
              class="crm-input" />
          </div>
          <div>
            <label for="segment" class="block text-sm font-medium text-crm-muted mb-1">Segmento</label>
            <select id="segment" name="segment"
              class="crm-input">
              <option value="">Sin definir</option>
              {segmentOptions.map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="marginProfile" class="block text-sm font-medium text-crm-muted mb-1">Perfil margen</label>
            <select id="marginProfile" name="marginProfile"
              class="crm-input">
              <option value="">Sin definir</option>
              {marginOptions.map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="lastContactedAt" class="block text-sm font-medium text-crm-muted mb-1">Último contacto</label>
            <input type="date" id="lastContactedAt" name="lastContactedAt"
              class="crm-input" />
          </div>
          <div>
            <label for="nextReviewAt" class="block text-sm font-medium text-crm-muted mb-1">Próxima review</label>
            <input type="date" id="nextReviewAt" name="nextReviewAt"
              class="crm-input" />
          </div>
        </div>
        <div>
          <label for="notes" class="block text-sm font-medium text-crm-muted mb-1">Notas internas</label>
          <textarea id="notes" name="notes" rows="4" placeholder="Contexto comercial, próximas acciones, riesgos..."
            class="crm-input"></textarea>
        </div>
      </section>

      <section class="crm-form-section space-y-4">
        <div>
          <h2 class="crm-form-section__title">Datos fiscales</h2>
          <p class="crm-form-section__text">Información tributaria y registrada del cliente.</p>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
          <div>
            <label for="legalName" class="block text-sm font-medium text-crm-muted mb-1">Razón social</label>
            <input type="text" id="legalName" name="legalName"
              class="crm-input" />
          </div>
          <div>
            <label for="taxId" class="block text-sm font-medium text-crm-muted mb-1">CIF / NIF</label>
            <input type="text" id="taxId" name="taxId"
              class="crm-input" />
          </div>
          <div>
            <label for="taxIdType" class="block text-sm font-medium text-crm-muted mb-1">Tipo</label>
            <select id="taxIdType" name="taxIdType"
              class="crm-input">
              <option value="">Sin definir</option>
              <option value="NIF">NIF</option>
              <option value="CIF">CIF</option>
              <option value="NIE">NIE</option>
              <option value="VIES">VIES</option>
            </select>
          </div>
          <div>
            <label for="addressLine1" class="block text-sm font-medium text-crm-muted mb-1">Dirección</label>
            <input type="text" id="addressLine1" name="addressLine1"
              class="crm-input" />
          </div>
          <div>
            <label for="addressLine2" class="block text-sm font-medium text-crm-muted mb-1">Complemento</label>
            <input type="text" id="addressLine2" name="addressLine2"
              class="crm-input" />
          </div>
          <div>
            <label for="city" class="block text-sm font-medium text-crm-muted mb-1">Localidad</label>
            <input type="text" id="city" name="city"
              class="crm-input" />
          </div>
          <div>
            <label for="region" class="block text-sm font-medium text-crm-muted mb-1">Provincia / Región</label>
            <input type="text" id="region" name="region"
              class="crm-input" />
          </div>
          <div>
            <label for="postalCode" class="block text-sm font-medium text-crm-muted mb-1">Código postal</label>
            <input type="text" id="postalCode" name="postalCode"
              class="crm-input" />
          </div>
          <div>
            <label for="country" class="block text-sm font-medium text-crm-muted mb-1">País</label>
            <input type="text" id="country" name="country" maxlength="2" placeholder="ES"
              class="crm-input" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-crm-muted mb-1">Teléfono fiscal</label>
            <input type="text" id="phone" name="phone"
              class="crm-input" />
          </div>
          <div>
            <label for="registrationNumber" class="block text-sm font-medium text-crm-muted mb-1">Registro mercantil</label>
            <input type="text" id="registrationNumber" name="registrationNumber"
              class="crm-input" />
          </div>
        </div>
      </section>

      <section class="crm-form-section space-y-4">
        <div>
          <h2 class="crm-form-section__title">Acceso al portal</h2>
          <p class="crm-form-section__text">Si defines una contrasena ahora, el cliente sale ya con acceso habilitado.</p>
        </div>
        <div class="max-w-md">
          <label for="portalPassword" class="block text-sm font-medium text-crm-muted mb-1">Contraseña inicial</label>
          <input type="password" id="portalPassword" name="portalPassword" minlength="8"
            class="crm-input" />
        </div>
      </section>

      <div class="flex gap-3">
        <button type="submit" class="crm-button crm-button-primary">
          Crear cliente
        </button>
        <a href="/admin/clients" class="crm-button crm-button-secondary">
          Cancelar
        </a>
      </div>
    </form>
  </div>

  <script>
    (async () => {
    const { API_BASE } = await import('../../../lib/api-client');

    const form = document.getElementById('client-form');
    const errorDiv = document.getElementById('form-error');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorDiv?.classList.add('hidden');

      const fieldValue = (id) => {
        const field = document.getElementById(id);
        return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement
          ? field.value
          : '';
      };

      try {
        const res = await fetch(`${API_BASE}/api/portal/clients`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            name: fieldValue('name'),
            email: fieldValue('email'),
            company: fieldValue('company') || undefined,
            plan: fieldValue('plan') || undefined,
            accountManager: fieldValue('accountManager') || undefined,
            subscriptionStatus: fieldValue('subscriptionStatus') || undefined,
            datasetStatus: fieldValue('datasetStatus') || undefined,
            monthlyUnitCapacity: fieldValue('monthlyUnitCapacity') || undefined,
            segment: fieldValue('segment') || undefined,
            marginProfile: fieldValue('marginProfile') || undefined,
            lastContactedAt: fieldValue('lastContactedAt') || undefined,
            nextReviewAt: fieldValue('nextReviewAt') || undefined,
            notes: fieldValue('notes') || undefined,
            portalPassword: fieldValue('portalPassword') || undefined,
            taxId: fieldValue('taxId') || undefined,
            taxIdType: fieldValue('taxIdType') || undefined,
            legalName: fieldValue('legalName') || undefined,
            addressLine1: fieldValue('addressLine1') || undefined,
            addressLine2: fieldValue('addressLine2') || undefined,
            city: fieldValue('city') || undefined,
            region: fieldValue('region') || undefined,
            postalCode: fieldValue('postalCode') || undefined,
            country: fieldValue('country') || undefined,
            phone: fieldValue('phone') || undefined,
            registrationNumber: fieldValue('registrationNumber') || undefined,
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'Error creating client');
        }

        const data = await res.json();
        window.location.href = `/admin/clients/detail?id=${encodeURIComponent(data.client.id)}`;
      } catch (error) {
        if (errorDiv instanceof HTMLDivElement) {
          errorDiv.textContent =
            error instanceof Error ? error.message : 'Error creating client';
          errorDiv.classList.remove('hidden');
        }
      }
    });
    })();
  </script>
</AdminLayout>
