---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Clientes">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Clientes</h1>
    <a href="/admin/clients/new" class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800">
      Nuevo cliente
    </a>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nombre</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Empresa</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trabajos</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody id="clients-body" class="divide-y divide-gray-200">
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">Cargando clientes...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <script>
    (async () => {
    const { api, escapeHtml, subscriptionClass } = await import('../../../lib/api-client');

    const tbody = document.getElementById('clients-body');

    try {
      const data = await api('/api/portal/clients');
      const clients = Array.isArray(data.clients) ? data.clients : [];

      if (!tbody) return;

      if (clients.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">No hay clientes todavia.</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = clients.map((client) => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 font-medium">${escapeHtml(client.name)}</td>
          <td class="px-6 py-4 text-gray-600">${escapeHtml(client.email)}</td>
          <td class="px-6 py-4 text-gray-600">${escapeHtml(client.company ?? '—')}</td>
          <td class="px-6 py-4 text-gray-600">${escapeHtml(client.jobCount ?? 0)}</td>
          <td class="px-6 py-4">
            <span class="inline-block px-2 py-1 rounded text-xs font-medium ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}">
              ${escapeHtml(client.subscriptionStatus ?? 'inactive')}
            </span>
          </td>
          <td class="px-6 py-4 text-right">
            <a href="/admin/clients/detail?id=${encodeURIComponent(client.id)}" class="text-blue-600 hover:text-blue-800 text-sm">Ver</a>
          </td>
        </tr>
      `).join('');
    } catch {
      if (tbody) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-red-600">No se pudieron cargar los clientes.</td>
          </tr>
        `;
      }
    }
    })();
  </script>
</AdminLayout>
