---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiWithCookie } from '../../../lib/api-client';

const cookie = Astro.request.headers.get('cookie') ?? '';
const fetchApi = apiWithCookie<any>(cookie);

let clients: any[] = [];
try {
  const data = await fetchApi('/api/portal/clients');
  clients = data.clients;
} catch {}
---

<AdminLayout title="Clientes">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Clientes</h1>
    <a href="/admin/clients/new" class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800">
      Nuevo cliente
    </a>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nombre</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Empresa</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trabajos</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {clients.length === 0 ? (
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
              No hay clientes todavia.
            </td>
          </tr>
        ) : (
          clients.map((c: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-medium">{c.name}</td>
              <td class="px-6 py-4 text-gray-600">{c.email}</td>
              <td class="px-6 py-4 text-gray-600">{c.company ?? '—'}</td>
              <td class="px-6 py-4 text-gray-600">{c.jobCount}</td>
              <td class="px-6 py-4">
                <span class={`inline-block px-2 py-1 rounded text-xs font-medium ${
                  c.subscriptionStatus === 'active'
                    ? 'bg-green-100 text-green-800'
                    : 'bg-gray-100 text-gray-600'
                }`}>
                  {c.subscriptionStatus ?? 'inactive'}
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <a href={`/admin/clients/${c.id}`} class="text-blue-600 hover:text-blue-800 text-sm">Ver</a>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
