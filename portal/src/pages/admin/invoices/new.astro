---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Nuevo registro de factura">
  <div class="space-y-6" role="region" aria-label="Nuevo registro de factura">
    <section class="crm-page-header" aria-labelledby="invoice-register-title">
      <a href="/admin/invoices" class="inline-block text-sm text-crm-muted transition hover:text-crm-text">&larr; Facturas</a>
      <div>
        <p class="crm-kicker">Billing Pro</p>
        <h1 id="invoice-register-title" class="mt-3 text-3xl font-bold tracking-tight text-crm-text md:text-5xl">
          Nuevo registro de factura
        </h1>
        <p class="crm-page-header__meta mt-4">
          Guarda en CRM la factura emitida fuera del sistema. El PDF y el envío siguen viviendo en Billing Pro.
        </p>
      </div>
    </section>

    <form id="invoice-register-form" class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]" novalidate>
      <section class="crm-form-section space-y-5" aria-label="Datos de factura">
        <div>
          <h2 class="crm-form-section__title">Factura emitida</h2>
          <p class="crm-form-section__text">Valores fiscales y estado operativo que se sincronizan con el cliente.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="client-id" class="block text-sm font-medium text-crm-muted mb-1">Cliente</label>
            <select id="client-id" name="clientId" required class="crm-input">
              <option value="">Selecciona un cliente...</option>
            </select>
            <p id="client-fiscal-info" class="mt-2 text-sm text-crm-muted"></p>
          </div>
          <div>
            <label for="invoice-number" class="block text-sm font-medium text-crm-muted mb-1">Número Billing Pro</label>
            <input id="invoice-number" name="invoiceNumber" class="crm-input" placeholder="F-2026-001" />
          </div>
          <div>
            <label for="issue-date" class="block text-sm font-medium text-crm-muted mb-1">Fecha de emisión</label>
            <input id="issue-date" name="issueDate" type="date" class="crm-input" />
          </div>
          <div>
            <label for="due-date" class="block text-sm font-medium text-crm-muted mb-1">Fecha de vencimiento</label>
            <input id="due-date" name="dueDate" type="date" class="crm-input" />
          </div>
          <div>
            <label for="subtotal-euros" class="block text-sm font-medium text-crm-muted mb-1">Subtotal (€)</label>
            <input id="subtotal-euros" name="subtotalEuros" type="number" min="0" step="0.01" required class="crm-input" placeholder="1200.00" />
          </div>
          <div>
            <label for="tax-rate" class="block text-sm font-medium text-crm-muted mb-1">IVA</label>
            <input id="tax-rate" name="taxRate" type="number" min="0" max="1" step="0.01" value="0.21" class="crm-input" />
          </div>
          <div>
            <label for="status" class="block text-sm font-medium text-crm-muted mb-1">Estado</label>
            <select id="status" name="status" class="crm-input">
              <option value="draft">Borrador</option>
              <option value="issued">Emitida</option>
              <option value="sent">Enviada</option>
              <option value="paid">Pagada</option>
              <option value="cancelled">Cancelada</option>
              <option value="overdue">Vencida</option>
            </select>
          </div>
          <div>
            <label for="billing-pro-url" class="block text-sm font-medium text-crm-muted mb-1">Enlace Billing Pro</label>
            <input id="billing-pro-url" name="billingProUrl" type="url" class="crm-input" placeholder="https://..." />
          </div>
        </div>

        <div>
          <label for="notes" class="block text-sm font-medium text-crm-muted mb-1">Notas internas</label>
          <textarea id="notes" name="notes" rows="4" class="crm-input" placeholder="Contexto de cobro, enlace interno o referencia del envío."></textarea>
        </div>

        <div id="form-error" class="hidden crm-alert crm-alert-danger text-sm" role="alert"></div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <button type="submit" class="crm-button crm-button-primary flex-1">Guardar registro</button>
          <a href="/admin/invoices" class="crm-button crm-button-secondary flex-1">Cancelar</a>
        </div>
      </section>

      <aside class="space-y-6">
        <section class="crm-form-section" aria-label="Resumen">
          <h2 class="crm-form-section__title">Resumen</h2>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-crm-muted">Subtotal</dt>
              <dd id="summary-subtotal" class="font-medium text-crm-text">0,00 €</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-crm-muted">IVA</dt>
              <dd id="summary-tax" class="font-medium text-crm-text">0,00 €</dd>
            </div>
            <div class="flex justify-between gap-4 border-t border-crm-border pt-3 text-base">
              <dt class="font-semibold text-crm-text">Total</dt>
              <dd id="summary-total" class="font-semibold text-crm-text">0,00 €</dd>
            </div>
          </dl>
        </section>

        <section class="crm-alert crm-alert-info" aria-label="Nota de flujo">
          Este formulario no genera PDF ni envía email. Solo registra la factura que ya existe en Billing Pro.
        </section>
      </aside>
    </form>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml } = await import('../../../lib/api-client');
      const { showToast } = await import('../../../lib/crm-ui');

      const form = document.getElementById('invoice-register-form');
      const clientSelect = document.getElementById('client-id');
      const fiscalInfo = document.getElementById('client-fiscal-info');
      const errorEl = document.getElementById('form-error');
      const subtotalInput = document.getElementById('subtotal-euros');
      const taxRateInput = document.getElementById('tax-rate');
      const issueDateInput = document.getElementById('issue-date');
      const dueDateInput = document.getElementById('due-date');
      let clients = [];

      const money = (amount) => new Intl.NumberFormat('es-ES', {
        style: 'currency',
        currency: 'EUR',
      }).format(amount);

      const toIsoDate = (value) => {
        if (!value) return undefined;
        return new Date(value + 'T00:00:00').toISOString();
      };

      const readNumber = (input, fallback = 0) => {
        const value = Number(input?.value ?? fallback);
        return Number.isFinite(value) ? value : fallback;
      };

      const updateSummary = () => {
        const subtotal = readNumber(subtotalInput);
        const taxRate = readNumber(taxRateInput, 0.21);
        const tax = subtotal * taxRate;
        const total = subtotal + tax;
        document.getElementById('summary-subtotal').textContent = money(subtotal);
        document.getElementById('summary-tax').textContent = money(tax);
        document.getElementById('summary-total').textContent = money(total);
      };

      const setDefaultDates = () => {
        const now = new Date();
        const due = new Date(now);
        due.setDate(due.getDate() + 30);
        const asInput = (date) => date.toISOString().slice(0, 10);
        if (issueDateInput) issueDateInput.value = asInput(now);
        if (dueDateInput) dueDateInput.value = asInput(due);
      };

      const renderFiscalInfo = () => {
        const client = clients.find((item) => item.id === clientSelect?.value);
        if (!fiscalInfo) return;
        if (!client) {
          fiscalInfo.textContent = '';
          return;
        }
        const missing = !client.taxId || !client.legalName || !client.addressLine1 || !client.city || !client.postalCode;
        fiscalInfo.innerHTML = `
          <span class="font-medium text-crm-text">${escapeHtml(client.legalName || client.name || client.company || 'Cliente')}</span><br>
          NIF/CIF: ${escapeHtml(client.taxId || 'Sin dato')} · ${escapeHtml(client.postalCode || 'CP pendiente')} ${escapeHtml(client.city || '')}
          ${missing ? `<br><a href="/admin/clients/detail?id=${encodeURIComponent(client.id)}" class="text-crm-warning underline hover:text-crm-accent">Completar datos fiscales</a>` : ''}
        `;
      };

      const loadClients = async () => {
        const data = await api('/api/portal/clients');
        clients = Array.isArray(data.clients) ? data.clients : [];
        if (!clientSelect) return;
        clientSelect.innerHTML = '<option value="">Selecciona un cliente...</option>';
        clients.forEach((client) => {
          const option = document.createElement('option');
          option.value = client.id;
          option.textContent = `${client.legalName || client.name || client.company || client.email} (${client.taxId || 'sin NIF/CIF'})`;
          clientSelect.appendChild(option);
        });
      };

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorEl?.classList.add('hidden');

        const clientId = clientSelect?.value ?? '';
        const subtotalEuros = readNumber(subtotalInput);
        const taxRate = readNumber(taxRateInput, 0.21);
        const invoiceNumber = document.getElementById('invoice-number')?.value.trim();
        const billingProUrl = document.getElementById('billing-pro-url')?.value.trim();
        const notes = document.getElementById('notes')?.value.trim();
        const status = document.getElementById('status')?.value || 'draft';

        if (!clientId) {
          showToast('Selecciona un cliente', 'warning');
          return;
        }
        if (!subtotalEuros || subtotalEuros <= 0) {
          showToast('Introduce un subtotal válido', 'warning');
          return;
        }

        const payload = {
          clientId,
          invoiceNumber: invoiceNumber || undefined,
          issueDate: toIsoDate(issueDateInput?.value),
          dueDate: toIsoDate(dueDateInput?.value),
          subtotalCents: Math.round(subtotalEuros * 100),
          taxRate,
          status,
          billingProUrl: billingProUrl || undefined,
          notes: notes || undefined,
        };

        try {
          const data = await api('/api/admin/invoices', {
            method: 'POST',
            body: JSON.stringify(payload),
          });
          const invoice = data.invoice || data;
          showToast('Registro de factura guardado', 'success');
          window.location.href = `/admin/invoices/detail?id=${encodeURIComponent(invoice.id)}`;
        } catch (error) {
          if (errorEl) {
            errorEl.textContent = error instanceof Error ? error.message : 'No se pudo guardar el registro.';
            errorEl.classList.remove('hidden');
          }
        }
      });

      clientSelect?.addEventListener('change', renderFiscalInfo);
      subtotalInput?.addEventListener('input', updateSummary);
      taxRateInput?.addEventListener('input', updateSummary);

      setDefaultDates();
      updateSummary();
      await loadClients();
    })();
  </script>
</AdminLayout>
