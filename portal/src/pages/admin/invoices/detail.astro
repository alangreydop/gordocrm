---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Detalle de Factura">
  <div class="space-y-6" role="region" aria-label="Contenido principal">
    <!-- Header -->
    <section class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/admin/invoices" class="text-crm-muted hover:text-crm-text transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-crm-muted">Factura</p>
          <h1 id="invoice-number" class="mt-2 text-3xl font-bold tracking-tight text-crm-text">
            Cargando...
          </h1>
          <p id="invoice-status" class="mt-2 text-sm"></p>
        </div>
      </div>
      <div id="action-buttons" class="flex gap-3">
        <!-- Buttons injected by JS based on status -->
      </div>
    </section>

    <!-- Invoice Details -->
    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Client Info -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Cliente</h2>
          <div id="client-info" class="text-sm text-crm-muted">
            Cargando...
          </div>
        </section>

        <!-- Issuer Info -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Emisor</h2>
          <div id="issuer-info" class="text-sm text-crm-muted">
            Cargando...
          </div>
        </section>

        <!-- Lines -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Líneas de factura</h2>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="border-b border-crm-border">
                <tr>
                  <th class="py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">Descripción</th>
                  <th class="py-3 text-right text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">Cant.</th>
                  <th class="py-3 text-right text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">Precio</th>
                  <th class="py-3 text-right text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">Subtotal</th>
                  <th class="py-3 text-right text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">IVA</th>
                  <th class="py-3 text-right text-xs font-bold uppercase tracking-[0.2em] text-crm-muted">Total</th>
                </tr>
              </thead>
              <tbody id="lines-body" class="divide-y divide-crm-border">
                <tr>
                  <td colspan="6" class="py-4 text-center text-crm-muted">Cargando líneas...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6" role="region" aria-label="Contenido principal">
        <!-- Totals -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Importes</h2>
          <div class="space-y-3">
            <div class="flex justify-between text-sm">
              <span class="text-crm-muted">Subtotal</span>
              <span id="subtotal-display" class="text-crm-text">€0,00</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-crm-muted">IVA (21%)</span>
              <span id="tax-display" class="text-crm-text">€0,00</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-crm-muted">IRPF</span>
              <span id="irpf-display" class="text-crm-text">€0,00</span>
            </div>
            <div class="border-t border-crm-border pt-3 flex justify-between text-lg font-bold">
              <span class="text-crm-text">Total</span>
              <span id="total-display" class="text-crm-text">€0,00</span>
            </div>
          </div>
        </section>

        <!-- Payment Info -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Pago</h2>
          <div class="space-y-3 text-sm">
            <div>
              <span class="text-crm-muted">Vencimiento</span>
              <p id="due-date-display" class="mt-1 font-medium text-crm-text">—</p>
            </div>
            <div>
              <span class="text-crm-muted">Método</span>
              <p id="payment-method-display" class="mt-1 font-medium text-crm-text">—</p>
            </div>
            <div>
              <span class="text-crm-muted">Notas</span>
              <p id="payment-notes-display" class="mt-1 text-crm-muted">—</p>
            </div>
          </div>
        </section>

        <!-- Metadata -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Metadata</h2>
          <div class="space-y-3 text-sm">
            <div>
              <span class="text-crm-muted">Fecha de emisión</span>
              <p id="issue-date-display" class="mt-1 font-medium text-crm-text">—</p>
            </div>
            <div>
              <span class="text-crm-muted">Año fiscal</span>
              <p id="fiscal-year-display" class="mt-1 font-medium text-crm-text">—</p>
            </div>
            <div>
              <span class="text-crm-muted">Serie</span>
              <p id="series-display" class="mt-1 font-medium text-crm-text">—</p>
            </div>
          </div>
        </section>

        <!-- Audit Log -->
        <section class="rounded-xl border border-crm-border bg-crm-bg-alt p-6">
          <h2 class="text-lg font-semibold text-crm-text mb-4">Actividad</h2>
          <div id="audit-log" class="space-y-2 text-sm">
            <p class="text-crm-muted">Cargando actividad...</p>
          </div>
        </section>
      </div>
    </div>

    <div id="invoice-action-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background: rgba(11, 6, 8, 0.58);">
      <form id="invoice-action-form" class="crm-panel w-full max-w-md space-y-4" role="dialog" aria-modal="true" aria-labelledby="invoice-action-title">
        <div>
          <p class="crm-kicker">acción de factura</p>
          <h2 id="invoice-action-title" class="mt-2 text-xl font-semibold text-crm-text">Confirmar acción</h2>
          <p id="invoice-action-copy" class="mt-2 text-sm text-crm-muted"></p>
        </div>

        <div id="invoice-action-field" class="space-y-2">
          <label id="invoice-action-label" for="invoice-action-input" class="block text-sm font-medium text-crm-muted">Detalle</label>
          <input id="invoice-action-input" class="crm-input" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="button" id="invoice-action-cancel" class="crm-button crm-button-secondary flex-1">cancelar</button>
          <button type="submit" id="invoice-action-submit" class="crm-button crm-button-primary flex-1">confirmar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml, formatDate: sharedFormatDate, getQueryParam } = await import('../../../lib/api-client');
      const { showToast } = await import('../../../lib/crm-ui');
      (window as any).__showToast = showToast;

      const statusLabels = {
        draft: 'Borrador',
        issued: 'Emitida',
        sent: 'Enviada',
        paid: 'Pagada',
        cancelled: 'Cancelada',
        overdue: 'Vencida',
      };

      const statusClasses = {
        draft: 'crm-badge-default',
        issued: 'crm-badge-warning',
        sent: 'crm-badge-info',
        paid: 'crm-badge-success',
        cancelled: 'crm-badge-danger',
        overdue: 'crm-badge-warning',
      };

      const formatMoney = (cents) =>
        new Intl.NumberFormat('es-ES', {
          style: 'currency',
          currency: 'EUR',
        }).format((Number(cents) || 0) / 100);

      const formatDate = (dateString) => {
        if (!dateString) return '—';
        const date = new Date(dateString);
        if (Number.isNaN(date.getTime())) return '—';
        return new Intl.DateTimeFormat('es-ES', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        }).format(date);
      };

      const renderActionButtons = (invoice) => {
        const container = document.getElementById('action-buttons');
        const buttons = [];
        const invoicePdfUrl = `/api/admin/invoices/${encodeURIComponent(invoice.id)}/pdf?download=1`;

        buttons.push(`
          <a href="${invoicePdfUrl}" class="crm-button crm-button-secondary">
            Descargar PDF
          </a>
        `);

        if (invoice.status === 'draft') {
          buttons.push(`
            <button onclick="issueInvoice()" class="crm-button crm-button-primary">
              Emitir factura
            </button>
          `);
        }

        if (['issued', 'sent'].includes(invoice.status)) {
          buttons.push(`
            <button onclick="sendInvoice()" class="crm-button crm-button-primary">
              Enviar por email
            </button>
          `);
        }

        if (['issued', 'sent', 'overdue'].includes(invoice.status)) {
          buttons.push(`
            <button onclick="openInvoiceAction('pay')" class="crm-button crm-button-success">
              Marcar como pagada
            </button>
          `);
        }

        if (['draft', 'issued', 'sent'].includes(invoice.status)) {
          buttons.push(`
            <button onclick="openInvoiceAction('cancel')" class="crm-button crm-button-danger">
              Cancelar
            </button>
          `);
        }

        container.innerHTML = buttons.join('');
      };

      let invoiceId = '';
      let pendingAction = null;

      const issueInvoice = async () => {
        if (!confirm('¿Emitir esta factura? Una vez emitida, el número de factura es definitivo.')) return;

        try {
          await api(`/api/admin/invoices/${invoiceId}/issue`, {
            method: 'POST',
          });

          window.location.reload();
        } catch (error) {
          (window as any).__showToast?.(error instanceof Error ? error.message : 'Error al emitir', 'error');
        }
      };

      const sendInvoice = async () => {
        if (!confirm('¿Enviar factura por email al cliente?')) return;

        try {
          await api(`/api/admin/invoices/${invoiceId}/send`, {
            method: 'POST',
          });

          (window as any).__showToast?.('factura enviada correctamente', 'success');
          window.location.reload();
        } catch (error) {
          (window as any).__showToast?.(error instanceof Error ? error.message : 'error al enviar', 'error');
        }
      };

      const markAsPaid = async (paymentMethod) => {
        try {
          await api(`/api/admin/invoices/${invoiceId}/pay`, {
            method: 'POST',
            body: JSON.stringify({ paymentMethod: paymentMethod || 'transferencia' }),
          });

          window.location.reload();
        } catch (error) {
          (window as any).__showToast?.(error instanceof Error ? error.message : 'Error al marcar como pagada', 'error');
        }
      };

      const cancelInvoice = async (reason) => {
        if (!reason) return;

        try {
          await api(`/api/admin/invoices/${invoiceId}/cancel`, {
            method: 'POST',
            body: JSON.stringify({ reason }),
          });

          window.location.reload();
        } catch (error) {
          (window as any).__showToast?.(error instanceof Error ? error.message : 'Error al cancelar', 'error');
        }
      };

      const modal = document.getElementById('invoice-action-modal');
      const modalForm = document.getElementById('invoice-action-form');
      const modalTitle = document.getElementById('invoice-action-title');
      const modalCopy = document.getElementById('invoice-action-copy');
      const modalLabel = document.getElementById('invoice-action-label');
      const modalInput = document.getElementById('invoice-action-input');
      const modalCancel = document.getElementById('invoice-action-cancel');

      const closeInvoiceAction = () => {
        pendingAction = null;
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        if (modalInput instanceof HTMLInputElement) {
          modalInput.value = '';
        }
      };

      const openInvoiceAction = (action) => {
        pendingAction = action;
        if (modalTitle) {
          modalTitle.textContent = action === 'pay' ? 'Marcar como pagada' : 'Cancelar factura';
        }
        if (modalCopy) {
          modalCopy.textContent = action === 'pay'
            ? 'Registra el método de pago usado por el cliente.'
            : 'Indica el motivo interno de cancelación antes de continuar.';
        }
        if (modalLabel) {
          modalLabel.textContent = action === 'pay' ? 'Método de pago' : 'Motivo de cancelación';
        }
        if (modalInput instanceof HTMLInputElement) {
          modalInput.value = action === 'pay' ? 'transferencia' : '';
          modalInput.placeholder = action === 'pay' ? 'transferencia, tarjeta...' : 'motivo interno';
          modalInput.required = action === 'cancel';
        }
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        modalInput?.focus();
      };

      (window as any).issueInvoice = issueInvoice;
      (window as any).sendInvoice = sendInvoice;
      (window as any).openInvoiceAction = openInvoiceAction;

      modalCancel?.addEventListener('click', closeInvoiceAction);
      modal?.addEventListener('click', (event) => {
        if (event.target === modal) closeInvoiceAction();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal?.classList.contains('hidden')) {
          closeInvoiceAction();
        }
      });
      modalForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const value = modalInput instanceof HTMLInputElement ? modalInput.value.trim() : '';
        if (pendingAction === 'pay') {
          await markAsPaid(value);
        } else if (pendingAction === 'cancel') {
          await cancelInvoice(value);
        }
      });

      const loadInvoice = async () => {
        invoiceId = getQueryParam('id') ?? '';

        if (!invoiceId) {
          (window as any).__showToast?.('ID de factura no válido', 'warning');
          window.location.href = '/admin/invoices';
          return;
        }

        try {
          const data = await api(`/api/admin/invoices/${invoiceId}`);
          const invoice = data.invoice;
          const items = data.items || [];

          document.getElementById('invoice-number').textContent = invoice.invoiceNumber;
          document.getElementById('invoice-status').innerHTML = `
            <span class="crm-badge ${statusClasses[invoice.status]}">
              ${statusLabels[invoice.status]}
            </span>
          `;

          renderActionButtons(invoice);

          document.getElementById('client-info').innerHTML = `
            <p class="font-medium text-crm-text">${escapeHtml(invoice.clientLegalName)}</p>
            <p>NIF: ${escapeHtml(invoice.clientTaxId)}</p>
            <p>${escapeHtml(invoice.clientAddressLine1)}</p>
            <p>${escapeHtml(invoice.clientPostalCode)} ${escapeHtml(invoice.clientCity)}</p>
            <p class="mt-2 text-crm-muted">${escapeHtml(invoice.clientEmail)}</p>
          `;

          document.getElementById('issuer-info').innerHTML = `
            <p class="font-medium text-crm-text">${escapeHtml(invoice.issuerLegalName)}</p>
            <p>NIF: ${escapeHtml(invoice.issuerTaxId)}</p>
            <p>${escapeHtml(invoice.issuerAddressLine1)}</p>
            <p>${escapeHtml(invoice.issuerPostalCode)} ${escapeHtml(invoice.issuerCity)}</p>
          `;

          const linesBody = document.getElementById('lines-body');
          linesBody.innerHTML = items.length > 0
            ? items.map((item) => `
              <tr>
                <td class="py-4 text-crm-text">${escapeHtml(item.description)}</td>
                <td class="py-4 text-right text-crm-muted">${escapeHtml(item.quantity)}</td>
                <td class="py-4 text-right text-crm-muted">${formatMoney(item.unitPriceCents)}</td>
                <td class="py-4 text-right text-crm-muted">${formatMoney(item.subtotalCents)}</td>
                <td class="py-4 text-right text-crm-muted">${formatMoney(item.taxAmountCents)}</td>
                <td class="py-4 text-right font-medium text-crm-text">${formatMoney(item.totalCents)}</td>
              </tr>
            `).join('')
            : `
              <tr>
                <td colspan="6" class="py-4 text-center text-crm-muted">No hay líneas asociadas a esta factura</td>
              </tr>
            `;

          document.getElementById('subtotal-display').textContent = formatMoney(invoice.subtotalCents);
          document.getElementById('tax-display').textContent = formatMoney(invoice.taxAmountCents);
          document.getElementById('irpf-display').textContent = formatMoney(invoice.irpfAmountCents || 0);
          document.getElementById('total-display').textContent = formatMoney(invoice.totalCents);

          document.getElementById('due-date-display').textContent = formatDate(invoice.dueDate);
          document.getElementById('payment-method-display').textContent = invoice.paymentMethod || '—';
          document.getElementById('payment-notes-display').textContent = invoice.paymentNotes || '—';

          document.getElementById('issue-date-display').textContent = formatDate(invoice.issueDate);
          document.getElementById('fiscal-year-display').textContent = String(invoice.fiscalYear ?? '—');
          document.getElementById('series-display').textContent = invoice.series;

          if (data.logs && data.logs.length > 0) {
            document.getElementById('audit-log').innerHTML = data.logs.map((log) => `
              <div class="flex items-center gap-2 text-crm-muted">
                <span class="w-2 h-2 rounded-full bg-crm-surface-hover"></span>
                <span>${escapeHtml(log.action)} - ${formatDate(log.createdAt ?? sharedFormatDate(log.createdAt))}</span>
              </div>
            `).join('');
          } else {
            document.getElementById('audit-log').innerHTML = '<p class="text-crm-muted">Sin actividad registrada</p>';
          }
        } catch (error) {
          console.error('Error loading invoice:', error);
          (window as any).__showToast?.('error al cargar la factura', 'error');
          window.location.href = '/admin/invoices';
        }
      };

      loadInvoice();
    })();
  </script>
</AdminLayout>
