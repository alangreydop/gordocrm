---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_BASE || 'http://127.0.0.1:8787';
---

<AdminLayout title="Facturación">
  <div class="space-y-6">
    <!-- Header -->
    <section class="flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Administración</p>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white">Facturación</h1>
        <p class="mt-2 text-sm text-zinc-400">Gestiona las facturas de tus clientes</p>
      </div>
      <a
        href="/admin/invoices/new"
        class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-bold text-black transition hover:bg-zinc-200"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nueva factura
      </a>
    </section>

    <!-- Filters -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-4">
      <div class="flex flex-wrap gap-3">
        <select id="filter-status" class="rounded-xl border border-zinc-800 bg-black px-4 py-2 text-sm text-white focus:border-zinc-600 focus:outline-none">
          <option value="">Todos los estados</option>
          <option value="draft">Borrador</option>
          <option value="issued">Emitida</option>
          <option value="sent">Enviada</option>
          <option value="paid">Pagada</option>
          <option value="cancelled">Cancelada</option>
          <option value="overdue">Vencida</option>
        </select>
        <select id="filter-year" class="rounded-xl border border-zinc-800 bg-black px-4 py-2 text-sm text-white focus:border-zinc-600 focus:outline-none">
          <option value="2026">2026</option>
          <option value="2025">2025</option>
        </select>
      </div>
    </section>

    <!-- Invoices Table -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
      <div class="border-b border-zinc-800 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Todas las facturas</h2>
        <p class="mt-1 text-sm text-zinc-400">Listado completo de facturas emitidas</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-black">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Factura</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Cliente</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">NIF</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Fecha</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Vencimiento</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Importe</th>
              <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Estado</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="invoices-body" class="divide-y divide-zinc-800">
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-zinc-500">Cargando facturas...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    const API_BASE = 'http://127.0.0.1:8787';

    const statusLabels = {
      draft: 'Borrador',
      issued: 'Emitida',
      sent: 'Enviada',
      paid: 'Pagada',
      cancelled: 'Cancelada',
      overdue: 'Vencida',
    };

    const statusClasses = {
      draft: 'bg-zinc-800 text-zinc-300',
      issued: 'bg-blue-900/30 text-blue-300 border border-blue-800/50',
      sent: 'bg-violet-900/30 text-violet-300 border border-violet-800/50',
      paid: 'bg-emerald-900/30 text-emerald-300 border border-emerald-800/50',
      cancelled: 'bg-red-900/30 text-red-300 border border-red-800/50',
      overdue: 'bg-amber-900/30 text-amber-300 border border-amber-800/50',
    };

    const formatMoney = (cents) => {
      return new Intl.NumberFormat('es-ES', {
        style: 'currency',
        currency: 'EUR',
      }).format(cents / 100);
    };

    const formatDate = (dateString) => {
      if (!dateString) return '—';
      const date = new Date(dateString);
      return new Intl.DateTimeFormat('es-ES', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(date);
    };

    const escapeHtml = (value) => {
      if (!value) return '';
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    };

    let allInvoices = [];

    const renderInvoices = (invoices) => {
      const tbody = document.getElementById('invoices-body');
      if (!tbody) return;

      if (invoices.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="8" class="px-6 py-8 text-center text-zinc-500">No hay facturas que mostrar</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = invoices.map((invoice) => `
        <tr class="hover:bg-zinc-900 transition">
          <td class="px-6 py-4">
            <span class="font-medium text-white">${escapeHtml(invoice.invoiceNumber)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="text-zinc-300">${escapeHtml(invoice.clientLegalName)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="text-zinc-400">${escapeHtml(invoice.clientTaxId)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="text-zinc-400">${formatDate(invoice.issueDate)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="text-zinc-400">${formatDate(invoice.dueDate)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="font-medium text-white">${formatMoney(invoice.totalCents)}</span>
          </td>
          <td class="px-6 py-4">
            <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${statusClasses[invoice.status] || statusClasses.draft}">
              ${statusLabels[invoice.status] || invoice.status}
            </span>
          </td>
          <td class="px-6 py-4 text-right">
            <a href="/admin/invoices/detail?id=${encodeURIComponent(invoice.id)}" class="font-medium text-white underline decoration-zinc-700 underline-offset-4 transition hover:decoration-white">Ver</a>
          </td>
        </tr>
      `).join('');
    };

    const loadInvoices = async () => {
      try {
        const res = await fetch(`${API_BASE}/api/admin/invoices`, {
          credentials: 'include',
        });

        if (!res.ok) {
          throw new Error('No se pudieron cargar las facturas');
        }

        const data = await res.json();
        allInvoices = data.invoices || [];
        renderInvoices(allInvoices);
      } catch (error) {
        console.error('Error loading invoices:', error);
        const tbody = document.getElementById('invoices-body');
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-rose-200">Error al cargar las facturas</td>
            </tr>
          `;
        }
      }
    };

    // Filter handlers
    const applyFilters = () => {
      const statusFilter = document.getElementById('filter-status').value;
      const yearFilter = document.getElementById('filter-year').value;

      let filtered = allInvoices;

      if (statusFilter) {
        filtered = filtered.filter(inv => inv.status === statusFilter);
      }

      if (yearFilter) {
        filtered = filtered.filter(inv => inv.fiscalYear === parseInt(yearFilter));
      }

      renderInvoices(filtered);
    };

    document.getElementById('filter-status')?.addEventListener('change', applyFilters);
    document.getElementById('filter-year')?.addEventListener('change', applyFilters);

    // Initial load
    loadInvoices();
  </script>
</AdminLayout>
