---
layout: '../../../layouts/AdminLayout.astro'
title: 'Gestión de Facturas'
---

<div class="max-w-7xl mx-auto space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white">Facturas</h1>
      <p class="text-zinc-400 mt-1">Gestión completa de facturación</p>
    </div>
    <button
      onclick="openCreateModal()"
      class="rounded-2xl bg-white px-6 py-3 font-bold text-black hover:bg-zinc-200 transition"
    >
      + Nueva factura
    </button>
  </div>

  <!-- Filters -->
  <div class="flex gap-4">
    <select id="status-filter" class="rounded-xl border border-zinc-800 bg-zinc-900 px-4 py-2 text-white">
      <option value="">Todos los estados</option>
      <option value="draft">Borrador</option>
      <option value="issued">Emitida</option>
      <option value="sent">Enviada</option>
      <option value="paid">Pagada</option>
      <option value="cancelled">Cancelada</option>
    </select>
  </div>

  <!-- Invoices table -->
  <div class="rounded-3xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-zinc-950 border-b border-zinc-800">
        <tr>
          <th class="text-left py-4 px-6 text-zinc-400 font-medium">Factura</th>
          <th class="text-left py-4 px-6 text-zinc-400 font-medium">Cliente</th>
          <th class="text-center py-4 px-6 text-zinc-400 font-medium">Estado</th>
          <th class="text-right py-4 px-6 text-zinc-400 font-medium">Importe</th>
          <th class="text-right py-4 px-6 text-zinc-400 font-medium">Vencimiento</th>
          <th class="text-right py-4 px-6 text-zinc-400 font-medium">Acciones</th>
        </tr>
      </thead>
      <tbody id="invoices-body"></tbody>
    </table>
  </div>
</div>

<!-- Create Modal -->
<div id="create-modal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50">
  <div class="bg-zinc-900 rounded-3xl border border-zinc-800 p-8 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-white">Nueva factura</h2>
      <button onclick="closeCreateModal()" class="text-zinc-400 hover:text-white">✕</button>
    </div>

    <form id="create-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-zinc-400 mb-2">Cliente</label>
        <select id="client-select" required class="w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 py-3 text-white">
          <option value="">Seleccionar cliente...</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-zinc-400 mb-2">Descripción</label>
        <input type="text" id="description" class="w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 py-3 text-white" placeholder="Ej: Producción de contenidos - Marzo 2026" />
      </div>

      <div>
        <label class="block text-sm font-medium text-zinc-400 mb-2">Vencimiento</label>
        <input type="date" id="due-date" class="w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 py-3 text-white" />
      </div>

      <div>
        <label class="block text-sm font-medium text-zinc-400 mb-2">Método de pago</label>
        <select id="payment-method" class="w-full rounded-xl border border-zinc-800 bg-zinc-950 px-4 py-3 text-white">
          <option value="Transferencia bancaria">Transferencia bancaria</option>
          <option value="Tarjeta">Tarjeta</option>
          <option value="Efectivo">Efectivo</option>
        </select>
      </div>

      <div id="items-container" class="space-y-3">
        <h3 class="text-sm font-semibold text-zinc-500 uppercase">Conceptos</h3>
      </div>

      <button type="button" onclick="addItem()" class="w-full rounded-xl border border-dashed border-zinc-700 py-3 text-zinc-400 hover:text-white hover:border-zinc-500 transition">
        + Añadir concepto
      </button>

      <div class="flex gap-3 pt-4">
        <button type="button" onclick="closeCreateModal()" class="flex-1 rounded-xl border border-zinc-800 py-3 text-zinc-400 hover:text-white">
          Cancelar
        </button>
        <button type="submit" class="flex-1 rounded-xl bg-white py-3 font-bold text-black hover:bg-zinc-200">
          Crear factura
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  (async () => {
    const { api } = await import('../../../lib/api-client');

    let allInvoices = [];
    let clients = [];

    const loadInvoices = async () => {
      try {
        const response = await api('/api/admin/invoices');
        allInvoices = response.invoices || [];
        renderInvoices(allInvoices);
      } catch (e) {
        console.error('Failed to load invoices:', e);
      }
    };

    const loadClients = async () => {
      try {
        const response = await api('/api/portal/clients');
        clients = response.clients || [];
        populateClientSelect();
      } catch (e) {
        console.error('Failed to load clients:', e);
      }
    };

    const getStatusBadge = (status: string) => {
      const badges: Record<string, string> = {
        draft: 'bg-zinc-800 text-zinc-400',
        issued: 'bg-yellow-500/20 text-yellow-400',
        sent: 'bg-blue-500/20 text-blue-400',
        paid: 'bg-green-500/20 text-green-400',
        cancelled: 'bg-red-500/20 text-red-400',
        overdue: 'bg-orange-500/20 text-orange-400',
      };
      const labels: Record<string, string> = {
        draft: 'Borrador',
        issued: 'Emitida',
        sent: 'Enviada',
        paid: 'Pagada',
        cancelled: 'Cancelada',
        overdue: 'Vencida',
      };
      return `<span class="px-3 py-1 rounded-full text-xs font-bold ${badges[status] || badges.draft}">${labels[status] || status}</span>`;
    };

    const formatMoney = (cents: number) => `€${(cents / 100).toFixed(2)}`;

    const renderInvoices = (invoices) => {
      const tbody = document.getElementById('invoices-body');

      if (!invoices.length) {
        tbody!.innerHTML = '<tr><td colspan="6" class="text-center py-12 text-zinc-500">No hay facturas</td></tr>';
        return;
      }

      tbody!.innerHTML = invoices
        .map(
          (inv: any) => `
          <tr class="border-b border-zinc-800 last:border-0 hover:bg-zinc-800/50">
            <td class="py-4 px-6">
              <div class="font-medium text-white">${inv.invoiceNumber}</div>
              <div class="text-xs text-zinc-500">${new Date(inv.issueDate).toLocaleDateString('es-ES')}</div>
            </td>
            <td class="py-4 px-6">
              <div class="text-white">${inv.clientLegalName || 'Sin cliente'}</div>
              <div class="text-xs text-zinc-500">${inv.clientTaxId || ''}</div>
            </td>
            <td class="py-4 px-6 text-center">${getStatusBadge(inv.status)}</td>
            <td class="py-4 px-6 text-right font-medium text-white">${formatMoney(inv.totalCents)}</td>
            <td class="py-4 px-6 text-right">
              <div class="${new Date(inv.dueDate) < new Date() && inv.status !== 'paid' ? 'text-red-400' : 'text-zinc-400'}">
                ${new Date(inv.dueDate).toLocaleDateString('es-ES')}
              </div>
            </td>
            <td class="py-4 px-6 text-right">
              <div class="flex gap-2 justify-end">
                <a href="/admin/invoices/${inv.id}" class="text-zinc-400 hover:text-white text-sm">Ver</a>
                ${inv.status === 'draft' ? `
                  <button onclick="issueInvoice('${inv.id}')" class="text-yellow-400 hover:text-yellow-300 text-sm">Emitir</button>
                ` : ''}
                ${inv.status === 'sent' || inv.status === 'issued' ? `
                  <button onclick="markAsPaid('${inv.id}')" class="text-green-400 hover:text-green-300 text-sm">Pagar</button>
                ` : ''}
              </div>
            </td>
          </tr>
        `,
        )
        .join('');
    };

    const populateClientSelect = () => {
      const select = document.getElementById('client-select');
      clients.forEach((c: any) => {
        const option = document.createElement('option');
        option.value = c.id;
        option.textContent = `${c.name} (${c.email})`;
        select?.appendChild(option);
      });
    };

    const openCreateModal = async () => {
      if (!clients.length) await loadClients();
      document.getElementById('create-modal')!.classList.remove('hidden');
      document.getElementById('create-modal')!.classList.add('flex');
      addItem(); // Add first item row
    };

    const closeCreateModal = () => {
      document.getElementById('create-modal')!.classList.add('hidden');
      document.getElementById('create-modal')!.classList.remove('flex');
      document.getElementById('create-form')?.reset();
      document.getElementById('items-container')!.innerHTML = '<h3 class="text-sm font-semibold text-zinc-500 uppercase">Conceptos</h3>';
    };

    const addItem = () => {
      const container = document.getElementById('items-container');
      const index = container!.children.length - 1;
      const itemHtml = `
        <div class="item-row grid grid-cols-12 gap-3 p-3 rounded-xl bg-zinc-950 border border-zinc-800">
          <input type="text" name="desc_${index}" placeholder="Concepto" required class="col-span-5 rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-white text-sm" />
          <input type="number" name="qty_${index}" placeholder="Cant." value="1" min="1" required class="col-span-2 rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-white text-sm text-center" />
          <input type="number" name="price_${index}" placeholder="€" min="0" step="0.01" required class="col-span-4 rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-white text-sm" />
          <button type="button" onclick="this.parentElement.remove()" class="col-span-1 text-red-400 hover:text-red-300">🗑</button>
        </div>
      `;
      container!.insertAdjacentHTML('beforeend', itemHtml);
    };

    const createInvoice = async (e: Event) => {
      e.preventDefault();

      const clientId = (document.getElementById('client-select') as HTMLSelectElement).value;
      const description = (document.getElementById('description') as HTMLInputElement).value;
      const dueDate = (document.getElementById('due-date') as HTMLInputElement).value;
      const paymentMethod = (document.getElementById('payment-method') as HTMLSelectElement).value;

      if (!clientId) {
        alert('Selecciona un cliente');
        return;
      }

      // Collect items
      const items: any[] = [];
      document.querySelectorAll('.item-row').forEach((row: any) => {
        const desc = row.querySelector('[name^="desc_"]')?.value;
        const qty = parseFloat(row.querySelector('[name^="qty_"]')?.value) || 1;
        const price = parseFloat(row.querySelector('[name^="price_"]')?.value) || 0;

        if (desc) {
          items.push({
            description: desc,
            quantity: qty,
            unitPriceCents: Math.round(price * 100),
          });
        }
      });

      if (!items.length) {
        alert('Añade al menos un concepto');
        return;
      }

      try {
        const response = await api('/api/admin/invoices', {
          method: 'POST',
          body: JSON.stringify({
            clientId,
            description,
            dueDate: new Date(dueDate).toISOString(),
            paymentMethod,
            items,
          }),
        });

        alert('Factura creada: ' + response.invoice.invoiceNumber);
        closeCreateModal();
        loadInvoices();
      } catch (e) {
        alert('Error: ' + e.message);
      }
    };

    const issueInvoice = async (id: string) => {
      if (!confirm('¿Emitir esta factura?')) return;
      try {
        await api(`/api/admin/invoices/${id}/issue`, { method: 'POST' });
        alert('Factura emitida');
        loadInvoices();
      } catch (e) {
        alert('Error: ' + e.message);
      }
    };

    const markAsPaid = async (id: string) => {
      if (!confirm('¿Marcar como pagada?')) return;
      try {
        await api(`/api/admin/invoices/${id}/pay`, {
          method: 'POST',
          body: JSON.stringify({ paymentMethod: 'Transferencia bancaria' }),
        });
        alert('Factura marcada como pagada');
        loadInvoices();
      } catch (e) {
        alert('Error: ' + e.message);
      }
    };

    // Expose functions globally
    (window as any).openCreateModal = openCreateModal;
    (window as any).closeCreateModal = closeCreateModal;
    (window as any).addItem = addItem;
    (window as any).createInvoice = createInvoice;
    (window as any).issueInvoice = issueInvoice;
    (window as any).markAsPaid = markAsPaid;

    document.getElementById('create-form')?.addEventListener('submit', createInvoice);

    // Filter by status
    document.getElementById('status-filter')?.addEventListener('change', (e) => {
      const status = (e.target as HTMLSelectElement).value;
      const filtered = status ? allInvoices.filter((i: any) => i.status === status) : allInvoices;
      renderInvoices(filtered);
    });

    await loadInvoices();
  })();
</script>
