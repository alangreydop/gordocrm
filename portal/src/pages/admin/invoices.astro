---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Facturas">
<div class="max-w-crm mx-auto space-y-8" role="region" aria-label="Contenido principal">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-crm-text">Facturas</h1>
      <p class="text-crm-muted mt-1">Todas las facturas de tus clientes</p>
    </div>
    <button
      onclick="openCreateModal()"
      class="crm-button crm-button-primary"
    >
      + Nueva factura
    </button>
  </div>

  <!-- Filters -->
  <div class="flex gap-4">
    <select id="status-filter" class="rounded-xl border border-crm-border bg-crm-bg-alt px-4 py-2 text-crm-text">
      <option value="">Todos los estados</option>
      <option value="draft">Borrador</option>
      <option value="issued">Emitida</option>
      <option value="sent">Enviada</option>
      <option value="paid">Pagada</option>
      <option value="cancelled">Cancelada</option>
    </select>
  </div>

  <!-- Invoices table -->
  <div class="rounded-xl border border-crm-border bg-crm-bg-alt overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-crm-bg-alt border-b border-crm-border">
        <tr>
          <th class="text-left py-4 px-6 text-crm-muted font-medium">Factura</th>
          <th class="text-left py-4 px-6 text-crm-muted font-medium">Cliente</th>
          <th class="text-center py-4 px-6 text-crm-muted font-medium">Estado</th>
          <th class="text-right py-4 px-6 text-crm-muted font-medium">Importe</th>
          <th class="text-right py-4 px-6 text-crm-muted font-medium">Vencimiento</th>
          <th class="text-right py-4 px-6 text-crm-muted font-medium">Acciones</th>
        </tr>
      </thead>
      <tbody id="invoices-body"></tbody>
    </table>
  </div>
</div>

<!-- Create Modal -->
<div id="create-modal" class="fixed inset-0 hidden items-center justify-center z-50" style="background-color: rgba(0,0,0,0.8);">
  <div class="bg-crm-bg-alt rounded-xl border border-crm-border p-8 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-crm-text">Nueva factura</h2>
      <button onclick="closeCreateModal()" class="text-crm-muted hover:text-crm-text">✕</button>
    </div>

    <form id="create-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-crm-muted mb-2">Cliente</label>
        <select id="client-select" required class="w-full rounded-xl border border-crm-border bg-crm-bg-alt px-4 py-3 text-crm-text">
          <option value="">Seleccionar cliente...</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-crm-muted mb-2">Descripción</label>
        <input type="text" id="description" class="w-full rounded-xl border border-crm-border bg-crm-bg-alt px-4 py-3 text-crm-text" placeholder="Ej: Producción de contenidos - Marzo 2026" />
      </div>

      <div>
        <label class="block text-sm font-medium text-crm-muted mb-2">Vencimiento</label>
        <input type="date" id="due-date" class="w-full rounded-xl border border-crm-border bg-crm-bg-alt px-4 py-3 text-crm-text" />
      </div>

      <div>
        <label class="block text-sm font-medium text-crm-muted mb-2">Método de pago</label>
        <select id="payment-method" class="w-full rounded-xl border border-crm-border bg-crm-bg-alt px-4 py-3 text-crm-text">
          <option value="Transferencia bancaria">Transferencia bancaria</option>
          <option value="Tarjeta">Tarjeta</option>
          <option value="Efectivo">Efectivo</option>
        </select>
      </div>

      <div id="items-container" class="space-y-3">
        <h3 class="text-sm font-semibold text-crm-muted uppercase">Conceptos</h3>
      </div>

      <button type="button" onclick="addItem()" class="w-full rounded-xl border border-dashed border-crm-border-strong py-3 text-crm-muted hover:text-crm-text hover:border-crm-accent transition">
        + Añadir concepto
      </button>

      <div class="flex gap-3 pt-4">
        <button type="button" onclick="closeCreateModal()" class="crm-button crm-button-secondary flex-1">
          Cancelar
        </button>
        <button type="submit" class="crm-button crm-button-primary flex-1">
          Crear factura
        </button>
      </div>
    </form>
  </div>
</div>

  <script>
  (async () => {
    const { api, escapeHtml } = await import('../../lib/api-client');
    const { showToast } = await import('../../lib/crm-ui');

    let allInvoices = [];
    let clients = [];

    const loadInvoices = async () => {
      try {
        const response = await api('/api/admin/invoices');
        allInvoices = response.invoices || [];
        renderInvoices(allInvoices);
      } catch (e) {
        console.error('error cargando facturas:', e);
      }
    };

    const loadClients = async () => {
      try {
        const response = await api('/api/portal/clients');
        clients = response.clients || [];
        populateClientSelect();
      } catch (e) {
        console.error('error cargando clientes:', e);
      }
    };

    const getStatusBadge = (status: string) => {
      const badges: Record<string, string> = {
        draft: 'crm-badge-default',
        issued: 'crm-badge-warning',
        sent: 'crm-badge-info',
        paid: 'crm-badge-success',
        cancelled: 'crm-badge-danger',
        overdue: 'crm-badge-warning',
      };
      const labels: Record<string, string> = {
        draft: 'Borrador',
        issued: 'Emitida',
        sent: 'Enviada',
        paid: 'Pagada',
        cancelled: 'Cancelada',
        overdue: 'Vencida',
      };
      return `<span class="crm-badge ${badges[status] || badges.draft}">${escapeHtml(labels[status] || status)}</span>`;
    };

    const formatMoney = (cents: number) => `€${(cents / 100).toFixed(2)}`;

    const renderInvoices = (invoices) => {
      const tbody = document.getElementById('invoices-body');

      if (!invoices.length) {
        tbody!.innerHTML = '<tr><td colspan="6" class="text-center py-12 text-crm-muted">No hay facturas</td></tr>';
        return;
      }

      tbody!.innerHTML = invoices
        .map(
          (inv: any) => `
          <tr class="border-b border-crm-border last:border-0 hover:bg-crm-panel-soft/50">
            <td class="py-4 px-6">
              <div class="font-medium text-crm-text">${escapeHtml(inv.invoiceNumber)}</div>
              <div class="text-xs text-crm-muted">${new Date(inv.issueDate).toLocaleDateString('es-ES')}</div>
            </td>
            <td class="py-4 px-6">
              <div class="text-crm-text">${escapeHtml(inv.clientLegalName || 'Sin cliente')}</div>
              <div class="text-xs text-crm-muted">${escapeHtml(inv.clientTaxId || '')}</div>
            </td>
            <td class="py-4 px-6 text-center">${getStatusBadge(inv.status)}</td>
            <td class="py-4 px-6 text-right font-medium text-crm-text">${formatMoney(inv.totalCents)}</td>
            <td class="py-4 px-6 text-right">
              <div class="${new Date(inv.dueDate) < new Date() && inv.status !== 'paid' ? 'text-crm-danger' : 'text-crm-muted'}">
                ${new Date(inv.dueDate).toLocaleDateString('es-ES')}
              </div>
            </td>
            <td class="py-4 px-6 text-right">
              <div class="flex gap-2 justify-end">
                <a href="/admin/invoices/detail?id=${encodeURIComponent(inv.id)}" class="text-crm-muted hover:text-crm-text text-sm">Ver</a>
                <a href="/api/admin/invoices/${encodeURIComponent(inv.id)}/pdf?download=1" class="text-crm-muted hover:text-crm-text text-sm">PDF</a>
                ${inv.status === 'draft' ? `
                  <button onclick="issueInvoice('${inv.id}')" class="text-crm-warning hover:text-crm-accent text-sm">Emitir</button>
                ` : ''}
                ${inv.status === 'sent' || inv.status === 'issued' ? `
                  <button onclick="markAsPaid('${inv.id}')" class="text-crm-success hover:text-crm-success text-sm">Pagar</button>
                ` : ''}
              </div>
            </td>
          </tr>
        `,
        )
        .join('');
    };

    const populateClientSelect = () => {
      const select = document.getElementById('client-select');
      clients.forEach((c: any) => {
        const option = document.createElement('option');
        option.value = c.id;
        option.textContent = `${c.name} (${c.email})`;
        select?.appendChild(option);
      });
    };

    const openCreateModal = async () => {
      if (!clients.length) await loadClients();
      document.getElementById('create-modal')!.classList.remove('hidden');
      document.getElementById('create-modal')!.classList.add('flex');
      addItem(); // Add first item row
    };

    const closeCreateModal = () => {
      document.getElementById('create-modal')!.classList.add('hidden');
      document.getElementById('create-modal')!.classList.remove('flex');
      document.getElementById('create-form')?.reset();
      document.getElementById('items-container')!.innerHTML = '<h3 class="text-sm font-semibold text-crm-muted uppercase">Conceptos</h3>';
    };

    const addItem = () => {
      const container = document.getElementById('items-container');
      const index = container!.children.length - 1;
      const itemHtml = `
        <div class="item-row grid grid-cols-12 gap-3 p-3 rounded-xl bg-crm-bg-alt border border-crm-border">
          <input type="text" name="desc_${index}" placeholder="Concepto" required class="col-span-5 rounded-lg border border-crm-border bg-crm-bg-alt px-3 py-2 text-crm-text text-sm" />
          <input type="number" name="qty_${index}" placeholder="Cant." value="1" min="1" required class="col-span-2 rounded-lg border border-crm-border bg-crm-bg-alt px-3 py-2 text-crm-text text-sm text-center" />
          <input type="number" name="price_${index}" placeholder="€" min="0" step="0.01" required class="col-span-4 rounded-lg border border-crm-border bg-crm-bg-alt px-3 py-2 text-crm-text text-sm" />
          <button type="button" onclick="this.parentElement.remove()" class="col-span-1 text-crm-danger hover:text-crm-danger">🗑</button>
        </div>
      `;
      container!.insertAdjacentHTML('beforeend', itemHtml);
    };

    const createInvoice = async (e: Event) => {
      e.preventDefault();

      const clientId = (document.getElementById('client-select') as HTMLSelectElement).value;
      const description = (document.getElementById('description') as HTMLInputElement).value;
      const dueDate = (document.getElementById('due-date') as HTMLInputElement).value;
      const paymentMethod = (document.getElementById('payment-method') as HTMLSelectElement).value;

      if (!clientId) {
        showToast('selecciona un cliente', 'warning');
        return;
      }

      // Collect items
      const items: any[] = [];
      document.querySelectorAll('.item-row').forEach((row: any) => {
        const desc = row.querySelector('[name^="desc_"]')?.value;
        const qty = parseFloat(row.querySelector('[name^="qty_"]')?.value) || 1;
        const price = parseFloat(row.querySelector('[name^="price_"]')?.value) || 0;

        if (desc) {
          items.push({
            description: desc,
            quantity: qty,
            unitPriceCents: Math.round(price * 100),
          });
        }
      });

      if (!items.length) {
        showToast('añade al menos un concepto', 'warning');
        return;
      }

      try {
        const response = await api('/api/admin/invoices', {
          method: 'POST',
          body: JSON.stringify({
            clientId,
            description,
            dueDate: dueDate ? new Date(dueDate).toISOString() : undefined,
            paymentMethod,
            items,
          }),
        });

        showToast('factura creada: ' + response.invoice.invoiceNumber, 'success');
        closeCreateModal();
        loadInvoices();
      } catch (e) {
        showToast('error: ' + e.message, 'error');
      }
    };

    const issueInvoice = async (id: string) => {
      if (!confirm('¿Emitir esta factura?')) return;
      try {
        await api(`/api/admin/invoices/${id}/issue`, { method: 'POST' });
        showToast('factura emitida', 'success');
        loadInvoices();
      } catch (e) {
        showToast('error: ' + e.message, 'error');
      }
    };

    const markAsPaid = async (id: string) => {
      if (!confirm('¿Marcar como pagada?')) return;
      try {
        await api(`/api/admin/invoices/${id}/pay`, {
          method: 'POST',
          body: JSON.stringify({ paymentMethod: 'Transferencia bancaria' }),
        });
        showToast('factura marcada como pagada', 'success');
        loadInvoices();
      } catch (e) {
        showToast('error: ' + e.message, 'error');
      }
    };

    // Expose functions globally
    (window as any).openCreateModal = openCreateModal;
    (window as any).closeCreateModal = closeCreateModal;
    (window as any).addItem = addItem;
    (window as any).createInvoice = createInvoice;
    (window as any).issueInvoice = issueInvoice;
    (window as any).markAsPaid = markAsPaid;

    document.getElementById('create-form')?.addEventListener('submit', createInvoice);

    // Filter by status
    document.getElementById('status-filter')?.addEventListener('change', (e) => {
      const status = (e.target as HTMLSelectElement).value;
      const filtered = status ? allInvoices.filter((i: any) => i.status === status) : allInvoices;
      renderInvoices(filtered);
    });

    await Promise.all([loadInvoices(), loadClients()]);
  })();
</script>
</AdminLayout>
