---
layout: '../../../layouts/AdminLayout.astro'
title: 'Production Kanban'
---

<div class="h-screen flex flex-col" style="background: var(--crm-bg);" role="region" aria-label="Production Kanban">
    <!-- Header -->
    <header class="crm-panel border-b-0 rounded-none mb-4 px-6 py-4 flex items-center justify-between" style="border-radius: 0;">
        <div>
            <h1 class="text-2xl font-bold text-crm-text">Production Kanban</h1>
            <p class="text-sm text-crm-muted">Gestión visual de producción</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="flex gap-3 text-sm">
                <div class="crm-panel-soft px-3 py-1 rounded-lg">
                    <span id="stat-pending" class="font-bold">0</span> Pendientes
                </div>
                <div class="crm-panel-soft px-3 py-1 rounded-lg">
                    <span id="stat-processing" class="font-bold">0</span> En Progreso
                </div>
                <div class="crm-panel-soft px-3 py-1 rounded-lg">
                    <span id="stat-review" class="font-bold">0</span> En Review
                </div>
                <div class="crm-panel-soft px-3 py-1 rounded-lg">
                    <span id="stat-delivered" class="font-bold">0</span> Entregados
                </div>
            </div>
            <button
                id="refresh-btn"
                class="crm-button crm-button-secondary text-sm"
                aria-label="Actualizar tablero"
            >
                ↻ Refresh
            </button>
        </div>
    </header>

    <!-- Kanban Board -->
    <div class="flex-1 overflow-x-auto overflow-y-hidden px-6 pb-6">
        <div class="flex h-full min-w-max gap-6">
            <!-- Pending -->
            <div class="w-80 flex flex-col">
                <div class="flex items-center justify-between mb-4 px-2">
                    <h2 class="font-bold text-crm-text flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full bg-crm-text-secondary"></span>
                        Pendientes
                    </h2>
                    <span id="count-pending" class="text-xs text-crm-muted">0</span>
                </div>
                <div id="col-pending" class="flex-1 overflow-y-auto space-y-3 pr-2"></div>
            </div>

            <!-- Processing -->
            <div class="w-80 flex flex-col">
                <div class="flex items-center justify-between mb-4 px-2">
                    <h2 class="font-bold text-crm-text flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full" style="background: var(--crm-info)"></span>
                        En Progreso
                    </h2>
                    <span id="count-processing" class="text-xs text-crm-muted">0</span>
                </div>
                <div id="col-processing" class="flex-1 overflow-y-auto space-y-3 pr-2"></div>
            </div>

            <!-- Review -->
            <div class="w-80 flex flex-col">
                <div class="flex items-center justify-between mb-4 px-2">
                    <h2 class="font-bold text-crm-text flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full" style="background: var(--crm-warning)"></span>
                        En Review
                    </h2>
                    <span id="count-review" class="text-xs text-crm-muted">0</span>
                </div>
                <div id="col-review" class="flex-1 overflow-y-auto space-y-3 pr-2"></div>
            </div>

            <!-- Delivered -->
            <div class="w-80 flex flex-col">
                <div class="flex items-center justify-between mb-4 px-2">
                    <h2 class="font-bold text-crm-text flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full" style="background: var(--crm-success)"></span>
                        Entregados
                    </h2>
                    <span id="count-delivered" class="text-xs text-crm-muted">0</span>
                </div>
                <div id="col-delivered" class="flex-1 overflow-y-auto space-y-3 pr-2"></div>
            </div>

            <!-- Completed -->
            <div class="w-80 flex flex-col">
                <div class="flex items-center justify-between mb-4 px-2">
                    <h2 class="font-bold text-crm-text flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full" style="background: var(--crm-success)"></span>
                        Completados
                    </h2>
                    <span id="count-completed" class="text-xs text-crm-muted">0</span>
                </div>
                <div id="col-completed" class="flex-1 overflow-y-auto space-y-3 pr-2"></div>
            </div>
        </div>
    </div>
</div>

<script>
    (async () => {
        const { api } = await import('../../lib/api-client');

        const refreshBtn = document.getElementById('refresh-btn');

        const loadKanban = async () => {
            try {
                const [columnsRes, statsRes] = await Promise.all([
                    api('/api/admin/kanban/columns'),
                    api('/api/admin/kanban/stats'),
                    ]);

                renderColumns(columnsRes.columns);
                renderStats(statsRes.stats);
                } catch (e) {
                console.error('error cargando kanban:', e);
                }
            };

        const renderStats = (stats) => {
            document.getElementById('stat-pending').textContent = stats.pending || 0;
            document.getElementById('stat-processing').textContent = stats.processing || 0;
            document.getElementById('stat-review').textContent = stats.review || 0;
            document.getElementById('stat-delivered').textContent = stats.delivered || 0;

            document.getElementById('count-pending').textContent = stats.pending || 0;
            document.getElementById('count-processing').textContent = stats.processing || 0;
            document.getElementById('count-review').textContent = stats.review || 0;
            document.getElementById('count-delivered').textContent = stats.delivered || 0;
            document.getElementById('count-completed').textContent = stats.completed || 0;
            };

        const renderColumns = (columns) => {
            const renderCard = (job) => `
                <div class="crm-panel p-4 rounded-lg hover:border-crm-accent transition cursor-pointer group">
                    <div class="flex items-start justify-between mb-2">
                        <span class="text-xs font-mono text-crm-muted">#${job.id.slice(0, 8)}</span>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition">
                            ${job.status !== 'pending' ? `<button class="move-left text-xs text-crm-muted hover:text-crm-text" data-id="${job.id}" data-direction="prev">←</button>` : ''}
                            ${job.status !== 'completed' ? `<button class="move-right text-xs text-crm-muted hover:text-crm-text" data-id="${job.id}" data-direction="next">→</button>` : ''}
                        </div>
                    </div>
                    <h3 class="font-semibold text-crm-text text-sm mb-1 truncate">${job.clientName || 'Sin cliente'}</h3>
                    <p class="text-xs text-crm-muted line-clamp-2 mb-3">${job.briefText || 'Sin descripción'}</p>
                    <div class="flex items-center justify-between text-xs">
                        <div class="flex items-center gap-2">
                            <span class="crm-panel-soft px-2 py-0.5 rounded text-crm-muted">${job.platform || 'N/A'}</span>
                            <span class="crm-panel-soft px-2 py-0.5 rounded text-crm-muted">${job.type || 'N/A'}</span>
                        </div>
                        <span class="text-crm-muted">${job.assetCount} assets</span>
                    </div>
                    ${job.dueAt ? `<div class="mt-3 pt-3 border-t border-crm-border text-xs ${new Date(job.dueAt) < new Date() ? 'text-crm-danger' : 'text-crm-muted'}">
                        Due: ${new Date(job.dueAt).toLocaleDateString()}
                    </div>` : ''}
                </div>
            `;

            document.getElementById('col-pending').innerHTML = (columns.pending || []).map(renderCard).join('');
            document.getElementById('col-processing').innerHTML = (columns.processing || []).map(renderCard).join('');
            document.getElementById('col-review').innerHTML = (columns.review || []).map(renderCard).join('');
            document.getElementById('col-delivered').innerHTML = (columns.delivered || []).map(renderCard).join('');
            document.getElementById('col-completed').innerHTML = (columns.completed || []).map(renderCard).join('');

                // Add event listeners for move buttons
            document.querySelectorAll('.move-right').forEach((btn) => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const id = (e.target as HTMLElement).dataset.id;
                    await moveJob(id, 'next');
                    });
                });

            document.querySelectorAll('.move-left').forEach((btn) => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const id = (e.target as HTMLElement).dataset.id;
                    await moveJob(id, 'prev');
                    });
                });
            };

        const moveJob = async (id: string, direction: 'next' | 'prev') => {
            const statusOrder = ['pending', 'processing', 'review', 'delivered', 'completed'];

                // Need to fetch current status first
            const columnsRes = await api('/api/admin/kanban/columns');
            let currentStatus = '';

            for (const [status, jobs] of Object.entries(columnsRes.columns)) {
                if ((jobs as any[]).some((j) => j.id === id)) {
                    currentStatus = status;
                    break;
                    }
                }

            const currentIndex = statusOrder.indexOf(currentStatus);
            const newIndex = direction === 'next' ? currentIndex + 1 : currentIndex - 1;

            if (newIndex >= 0 && newIndex < statusOrder.length) {
                const newStatus = statusOrder[newIndex];
                try {
                    await api(`/api/admin/kanban/jobs/${id}/status`, {
                        method: 'PATCH',
                        body: JSON.stringify({ status: newStatus }),
                        });
                    await loadKanban();
                    } catch (e) {
                    console.error('error moviendo trabajo:', e);
                    }
                }
            };

        refreshBtn?.addEventListener('click', loadKanban);

            // Initial load
        await loadKanban();

            // Auto-refresh: 30s → 60s (performance fix)
        setInterval(loadKanban, 60000);
        })();
</script>
