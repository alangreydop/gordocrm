---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Settings">
  <div class="max-w-4xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Settings</h1>
      <p class="text-gray-500 mt-1">Gestiona tu acceso al CRM y la identidad operativa de la cuenta.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.1fr_.9fr]">
      <section class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Tu cuenta</h2>
        <dl class="grid sm:grid-cols-2 gap-4 text-sm">
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Nombre</dt>
            <dd id="settings-name" class="font-medium text-gray-900 mt-1">Cargando...</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Email</dt>
            <dd id="settings-email" class="font-medium text-gray-900 mt-1">—</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Rol</dt>
            <dd id="settings-role" class="font-medium text-gray-900 mt-1">—</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Empresa</dt>
            <dd id="settings-company" class="font-medium text-gray-900 mt-1">—</dd>
          </div>
        </dl>
      </section>

      <section class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Cambiar contraseña</h2>
        <div id="password-success" class="hidden bg-green-50 text-green-700 rounded p-3 mb-4 text-sm"></div>
        <div id="password-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

        <form id="password-form" class="space-y-4">
          <div>
            <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-1">Contraseña actual</label>
            <input type="password" id="currentPassword" name="currentPassword" required
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900" />
          </div>
          <div>
            <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">Nueva contraseña</label>
            <input type="password" id="newPassword" name="newPassword" required minlength="8"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900" />
          </div>
          <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800">
            Actualizar contraseña
          </button>
        </form>
      </section>
    </div>
  </div>

  <script>
    (async () => {
    const { API_BASE, getSessionUser } = await import('../../lib/api-client');

    const user = await getSessionUser();
    if (user) {
      const name = document.getElementById('settings-name');
      const email = document.getElementById('settings-email');
      const role = document.getElementById('settings-role');
      const company = document.getElementById('settings-company');

      if (name) name.textContent = user.name;
      if (email) email.textContent = user.email;
      if (role) role.textContent = user.role;
      if (company) company.textContent = user.company ?? 'Grande&Gordo';
    }

    const form = document.getElementById('password-form');
    const errorDiv = document.getElementById('password-error');
    const successDiv = document.getElementById('password-success');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorDiv?.classList.add('hidden');
      successDiv?.classList.add('hidden');

      const currentPassword = document.getElementById('currentPassword');
      const newPassword = document.getElementById('newPassword');

      try {
        const res = await fetch(`${API_BASE}/api/portal/auth/change-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            currentPassword:
              currentPassword instanceof HTMLInputElement ? currentPassword.value : '',
            newPassword:
              newPassword instanceof HTMLInputElement ? newPassword.value : '',
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'No se pudo cambiar la contraseña');
        }

        if (form instanceof HTMLFormElement) {
          form.reset();
        }

        if (successDiv instanceof HTMLDivElement) {
          successDiv.textContent = 'Contraseña actualizada correctamente.';
          successDiv.classList.remove('hidden');
        }
      } catch (error) {
        if (errorDiv instanceof HTMLDivElement) {
          errorDiv.textContent =
            error instanceof Error ? error.message : 'No se pudo cambiar la contraseña';
          errorDiv.classList.remove('hidden');
        }
      }
    });
    })();
  </script>
</AdminLayout>
