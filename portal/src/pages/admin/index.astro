---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Operations Console">
     <div class="space-y-6" role="region" aria-label="Contenido principal">
         <section class="crm-page-header">
             <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
                 <div>
                     <p class="crm-kicker crm-kicker--accent">operations console</p>
                     <h1 class="crm-page-header__title mt-4">operaciones</h1>
                     <p class="crm-page-header__meta mt-4">
                        visibilidad rápida de briefs, producción, capacidad y alertas para decidir
                        qué desbloquear hoy y dónde puede aparecer fricción operativa.
                     </p>
                 </div>
                 <div class="grid gap-4 sm:grid-cols-2">
                     <div class="crm-panel-soft p-5">
                         <p class="crm-kicker">ops</p>
                         <p class="mt-3 text-sm leading-relaxed text-crm-muted">
                            hola@grandeandgordo.com
                         </p>
                     </div>
                     <div class="crm-panel-soft p-5">
                         <p class="crm-kicker">Enfoque</p>
                         <p class="mt-3 text-sm leading-relaxed text-crm-text">
                            Produccion, facturacion y revisiones proximas en una sola vista.
                         </p>
                     </div>
                 </div>
             </div>
         </section>

         <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
             <div class="crm-metric-card">
                 <p class="crm-kicker">trabajos activos</p>
                 <p id="active-jobs" class="crm-metric-card__value">—</p>
                 <p id="urgent-jobs" class="text-sm text-crm-danger mt-2">—</p>
                 <p id="past-due-jobs" class="text-sm text-crm-danger mt-1">—</p>
             </div>
             <div class="crm-metric-card">
                 <p class="crm-kicker">capacidad del mes</p>
                 <p id="units-planned" class="crm-metric-card__value">—</p>
                 <p id="units-consumed" class="text-sm text-crm-muted mt-2">—</p>
                 <p id="capacity-utilization" class="text-sm text-crm-muted mt-1">—</p>
             </div>
             <div class="crm-metric-card">
                 <p class="crm-kicker">margen estimado medio</p>
                 <p id="avg-margin" class="crm-metric-card__value">—</p>
                 <p id="low-margin-jobs" class="text-sm text-crm-warning mt-2">—</p>
             </div>
             <div class="crm-metric-card">
                 <p class="crm-kicker">clientes y revisiones</p>
                 <p id="total-clients" class="crm-metric-card__value">—</p>
                 <p id="reviews-due" class="text-sm text-crm-info mt-2">—</p>
                 <p id="active-clients" class="text-sm text-crm-muted mt-1">—</p>
             </div>
         </div>

         <div class="grid gap-6 lg:grid-cols-2">
             <section class="crm-panel overflow-hidden">
                 <div class="border-b border-crm-border px-6 py-5">
                     <p class="crm-kicker">lanes</p>
                     <h2 class="mt-3 text-lg font-semibold text-crm-text">distribución por lane</h2>
                     <p class="mt-2 text-sm text-crm-muted">Como estan repartidos los trabajos entre los lanes del stack.</p>
                 </div>
                 <div id="lane-chart" class="p-6">
                     <div class="space-y-3">
                         <div class="text-sm text-crm-muted">Cargando distribucion...</div>
                     </div>
                 </div>
             </section>

             <section class="crm-panel overflow-hidden">
                 <div class="border-b border-crm-border px-6 py-5">
                     <p class="crm-kicker">pipeline</p>
                     <h2 class="mt-3 text-lg font-semibold text-crm-text">estado de trabajos</h2>
                     <p class="mt-2 text-sm text-crm-muted">Breakdown por estado del pipeline.</p>
                 </div>
                 <div id="status-chart" class="p-6">
                     <div class="space-y-3">
                         <div class="text-sm text-crm-muted">Cargando estados...</div>
                     </div>
                 </div>
             </section>
         </div>

         <section class="crm-panel overflow-hidden">
             <div class="border-b border-crm-border px-6 py-5">
                 <p class="crm-kicker">alertas</p>
                 <h2 class="mt-3 text-lg font-semibold text-crm-text">alertas operativas</h2>
                 <p class="mt-2 text-sm text-crm-muted">Trabajos vencidos y clientes con capacidad baja.</p>
             </div>
             <div id="alerts-list" class="divide-y divide-crm-border">
                 <div class="px-6 py-4 text-sm text-crm-muted">Verificando alertas...</div>
             </div>
         </section>

         <div class="grid gap-6 xl:grid-cols-[1.35fr_.95fr]">
             <section class="crm-table-wrap">
                 <div class="flex items-center justify-between gap-4 border-b border-crm-border px-6 py-5">
                     <div>
                         <p class="crm-kicker">trabajos</p>
                         <h2 class="mt-3 text-lg font-semibold text-crm-text">trabajos recientes</h2>
                         <p class="mt-2 text-sm text-crm-muted">Lo que conviene revisar hoy antes de producir.</p>
                     </div>
                     <a href="/admin/jobs" class="text-sm font-medium text-crm-accent transition hover:text-crm-accent-hover">Ver todos</a>
                 </div>
                 <div class="overflow-x-auto">
                     <table class="crm-table min-w-full divide-y divide-crm-border text-sm">
                         <thead>
                             <tr>
                                 <th class="px-6 py-3 text-left">Cliente</th>
                                 <th class="px-6 py-3 text-left">Brief</th>
                                 <th class="px-6 py-3 text-left">Estado</th>
                                 <th class="px-6 py-3 text-left">Due</th>
                                 <th class="px-6 py-3 text-left">Lane</th>
                                 <th class="px-6 py-3 text-left">Margen</th>
                                 <th class="px-6 py-3 text-left"></th>
                             </tr>
                         </thead>
                         <tbody id="recent-jobs-body" class="divide-y divide-crm-border">
                             <tr>
                                 <td colspan="7" class="px-6 py-8 text-center text-crm-muted">Cargando trabajos...</td>
                             </tr>
                         </tbody>
                     </table>
                 </div>
             </section>

             <section class="crm-panel overflow-hidden">
                 <div class="border-b border-crm-border px-6 py-5">
                     <p class="crm-kicker">seguimiento</p>
                     <h2 class="mt-3 text-lg font-semibold text-crm-text">revisiones próximas</h2>
                     <p class="mt-2 text-sm text-crm-muted">Clientes que deberian tener seguimiento en los proximos 14 dias.</p>
                 </div>
                 <div id="reviews-list" class="divide-y divide-crm-border">
                     <div class="px-6 py-8 text-center text-crm-muted">Cargando revisiones...</div>
                 </div>
             </section>
         </div>
     </div>

     <script>
         (async () => {
        const {
            api,
            escapeHtml,
            formatDate,
            formatPercent,
            formatNumber,
        } = await import('../../lib/api-client');
        const {
            jobStatusClass,
            stackLaneClass,
        } = await import('../../lib/ui-helpers');

        const recentJobsBody = document.getElementById('recent-jobs-body');
        const reviewsList = document.getElementById('reviews-list');
        const laneChart = document.getElementById('lane-chart');
        const statusChart = document.getElementById('status-chart');
        const alertsList = document.getElementById('alerts-list');

        try {
            const stats = await api('/api/portal/dashboard/stats');

            const setText = (id, value) => {
                const element = document.getElementById(id);
                if (element) element.textContent = value;
              };

            setText('active-jobs', String(stats.activeJobs ?? 0));
            setText('urgent-jobs', `${stats.urgentJobs ?? 0} urgentes`);
            setText('past-due-jobs', stats.pastDueJobs > 0 ? `${stats.pastDueJobs} vencidos` : '');
            setText('units-planned', String(stats.unitsPlannedThisMonth ?? 0));
            setText('units-consumed', `${stats.unitsConsumedThisMonth ?? 0} unidades consumidas`);

            const utilizationPct = stats.totalMonthlyCapacity > 0
                 ? Math.round((stats.unitsConsumedThisMonth / stats.totalMonthlyCapacity) * 100)
                 : 0;
            setText('capacity-utilization', `${utilizationPct}% capacidad total utilizada`);

            setText('avg-margin', formatPercent(stats.avgEstimatedMargin ?? 0));
            setText('low-margin-jobs', `${stats.lowMarginJobs ?? 0} trabajos por debajo del 65%`);
            setText('total-clients', String(stats.totalClients ?? 0));
            setText('reviews-due', `${stats.reviewsDueSoon ?? 0} revisiones próximas`);
            setText('active-clients', `${stats.activeClients ?? 0} clientes activos`);

             // Render lane distribution chart
            if (laneChart) {
                const lanes = stats.laneDistribution || [];
                const totalLanes = lanes.reduce((sum, l) => sum + (l.count ?? 0), 0);
                if (lanes.length === 0 || totalLanes === 0) {
                    laneChart.innerHTML = '<div class="text-sm text-crm-muted">Sin datos de lanes aun.</div>';
                  } else {
                    laneChart.innerHTML = lanes.map((lane) => {
                        const pct = totalLanes > 0 ? Math.round((lane.count / totalLanes) * 100) : 0;
                        const laneColors = {
                            A: 'var(--crm-success)',
                            B: 'var(--crm-info)',
                            C: 'var(--crm-accent)',
                            D: 'var(--crm-warning)',
                         };
                        const colorValue = laneColors[lane.lane] ?? 'var(--crm-muted)';
                        return `
                             <div>
                                 <div class="flex items-center justify-between text-sm mb-1">
                                     <span class="font-medium text-crm-text">Lane ${escapeHtml(lane.lane ?? '—')}</span>
                                     <span class="text-crm-muted">${escapeHtml(lane.count ?? 0)} trabajos (${pct}%)</span>
                                 </div>
                                 <div class="h-2 w-full bg-crm-border rounded-md overflow-hidden">
                                     <div class="h-full rounded-md" style="width: ${pct}%; background: ${colorValue}"></div>
                                 </div>
                             </div>
                         `;
                      }).join('');
                  }
              }

             // Render status breakdown chart
            if (statusChart) {
                const statuses = stats.statusBreakdown || [];
                const totalStatus = statuses.reduce((sum, s) => sum + (s.count ?? 0), 0);
                if (statuses.length === 0 || totalStatus === 0) {
                    statusChart.innerHTML = '<div class="text-sm text-crm-muted">Sin datos de estados.</div>';
                  } else {
                    statusChart.innerHTML = statuses.map((status) => {
                        const pct = totalStatus > 0 ? Math.round((status.count / totalStatus) * 100) : 0;
                        const statusColors = {
                            pending: 'var(--crm-warning)',
                            processing: 'var(--crm-info)',
                            completed: 'var(--crm-success)',
                            delivered: 'var(--crm-accent)',
                            failed: 'var(--crm-danger)',
                         };
                        const colorValue = statusColors[status.status] ?? 'var(--crm-muted)';
                        return `
                             <div>
                                 <div class="flex items-center justify-between text-sm mb-1">
                                     <span class="font-medium text-crm-text capitalize">${escapeHtml(status.status ?? '—')}</span>
                                     <span class="text-crm-muted">${escapeHtml(status.count ?? 0)} trabajos (${pct}%)</span>
                                 </div>
                                 <div class="h-2 w-full bg-crm-border rounded-md overflow-hidden">
                                     <div class="h-full rounded-md" style="width: ${pct}%; background: ${colorValue}"></div>
                                 </div>
                             </div>
                         `;
                      }).join('');
                  }
              }

             // Render alerts list
            if (alertsList) {
                const alerts = [];
                if (stats.pastDueJobs > 0) {
                    alerts.push({
                        type: 'danger',
                        title: 'Trabajos vencidos',
                        description: `${stats.pastDueJobs} trabajos estan past due y necesitan atencion inmediata.`,
                      });
                  }
                if (stats.clientsLowCapacity > 0) {
                    alerts.push({
                        type: 'warning',
                        title: 'Capacidad baja',
                        description: `${stats.clientsLowCapacity} clientes tienen menos de 5 unidades de capacidad restante.`,
                      });
                  }
                if (stats.lowMarginJobs > 0) {
                    alerts.push({
                        type: 'warning',
                        title: 'Margen estrecho',
                        description: `${stats.lowMarginJobs} trabajos tienen margen estimado por debajo del 65%.`,
                      });
                  }
                if (alerts.length === 0) {
                    alertsList.innerHTML = '<div class="px-6 py-4 text-sm text-crm-success">No hay alertas operativas. Todo en orden.</div>';
                  } else {
                    alertsList.innerHTML = alerts.map((alert) => `
                         <div class="px-6 py-4 flex items-start gap-4 ${alert.type === 'danger' ? 'crm-alert crm-alert-danger' : 'crm-alert crm-alert-warning'}">
                             <div class="flex-1">
                                 <p class="font-medium">${escapeHtml(alert.title)}</p>
                                 <p class="text-sm mt-1">${escapeHtml(alert.description)}</p>
                             </div>
                         </div>
                     `).join('');
                  }
              }

            const recentJobs = Array.isArray(stats.recentJobs) ? stats.recentJobs : [];
            if (recentJobsBody) {
                recentJobsBody.innerHTML = recentJobs.length === 0
                     ? `<tr><td colspan="7" class="px-6 py-8 text-center text-crm-muted">No hay trabajos recientes.</td></tr>`
                     : recentJobs.map((job) => `
                         <tr class="hover:bg-crm-panel-soft">
                             <td class="px-6 py-4 font-medium text-crm-text">${escapeHtml(job.clientName ?? '—')}</td>
                             <td class="px-6 py-4 max-w-xs truncate text-crm-text">${escapeHtml(job.briefText ?? 'Sin brief')}</td>
                             <td class="px-6 py-4">
                                 <span class="${jobStatusClass(job.status ?? '')}">
                                     ${escapeHtml(job.status ?? 'pending')}
                                 </span>
                                 ${job.turnaround === 'urgente' ? '<span class="ml-2 crm-badge crm-badge-danger">urgente</span>' : ''}
                             </td>
                             <td class="px-6 py-4 text-crm-muted">${escapeHtml(formatDate(job.dueAt))}</td>
                             <td class="px-6 py-4">
                                 <span class="${stackLaneClass(job.stackLane ?? '')}">
                                     ${escapeHtml(job.stackLane ?? '—')}
                                 </span>
                             </td>
                             <td class="px-6 py-4 text-crm-muted">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
                             <td class="px-6 py-4 text-right">
                                 <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-crm-accent transition hover:text-crm-accent-hover">Ver</a>
                             </td>
                         </tr>
                     `).join('');
              }

            const reviews = Array.isArray(stats.upcomingReviews) ? stats.upcomingReviews : [];
            if (reviewsList) {
                reviewsList.innerHTML = reviews.length === 0
                     ? `<div class="px-6 py-8 text-center text-crm-muted">No hay revisiones proximas.</div>`
                     : reviews.map((client) => `
                         <div class="px-6 py-4 flex items-start justify-between gap-4">
                             <div>
                                 <p class="font-medium text-crm-text">${escapeHtml(client.name)}</p>
                                 <p class="text-sm text-crm-muted mt-1">${escapeHtml(client.company ?? client.plan ?? 'Sin empresa')}</p>
                                 <p class="text-sm text-crm-muted mt-1">Account manager: ${escapeHtml(client.accountManager ?? 'hola@grandeandgordo.com')}</p>
                             </div>
                             <div class="text-right">
                                 <p class="text-sm font-medium text-crm-text">${escapeHtml(formatDate(client.nextReviewAt))}</p>
                                 <a href="/admin/clients/detail?id=${encodeURIComponent(client.id)}" class="text-sm font-medium text-crm-accent transition hover:text-crm-accent-hover">Abrir cliente</a>
                             </div>
                         </div>
                     `).join('');
              }
          } catch {
              const errorMsg = 'No se pudo cargar el dashboard.';
              if (recentJobsBody) recentJobsBody.innerHTML = `<tr><td colspan="7" class="px-6 py-8 text-center text-crm-danger">${errorMsg}</td></tr>`;
              if (reviewsList) reviewsList.innerHTML = `<div class="px-6 py-8 text-center text-crm-danger">${errorMsg}</div>`;
              if (alertsList) alertsList.innerHTML = `<div class="px-6 py-8 text-center text-crm-danger">${errorMsg}</div>`;
              if (laneChart) laneChart.innerHTML = `<div class="text-sm text-crm-danger">${errorMsg}</div>`;
              if (statusChart) statusChart.innerHTML = `<div class="text-sm text-crm-danger">${errorMsg}</div>`;
          }
          })();
     </script>
</AdminLayout>
