---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="space-y-6">
    <section class="crm-page-header">
      <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
        <div>
          <p class="crm-kicker">Control operativo</p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">Dashboard</h1>
          <p class="crm-page-header__meta mt-4">
            Visibilidad rapida de pipeline, margen, capacidad y seguimiento comercial
            para decidir que revisar hoy y donde puede aparecer friccion.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Operacion</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-200">
              hola@grandeandgordo.com
            </p>
          </div>
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Enfoque</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">
              Produccion, margen y revisiones proximas en una sola vista.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">Trabajos activos</p>
        <p id="active-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="urgent-jobs" class="text-sm text-red-600 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Capacidad del mes</p>
        <p id="units-planned" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="units-consumed" class="text-sm text-gray-500 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Margen estimado medio</p>
        <p id="avg-margin" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="low-margin-jobs" class="text-sm text-amber-700 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Clientes y revisiones</p>
        <p id="total-clients" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="reviews-due" class="text-sm text-blue-700 mt-2">—</p>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.35fr_.95fr]">
      <section class="crm-table-wrap">
        <div class="flex items-center justify-between gap-4 border-b border-white/8 px-6 py-5">
          <div>
            <h2 class="text-lg font-semibold text-white">Trabajos recientes</h2>
            <p class="mt-2 text-sm text-slate-300">Lo que conviene revisar hoy antes de producir.</p>
          </div>
          <a href="/admin/jobs" class="text-sm font-medium text-sky-200 transition hover:text-white">Ver todos</a>
        </div>
        <div class="overflow-x-auto">
          <table class="crm-table min-w-full divide-y divide-gray-200 text-sm">
            <thead>
              <tr>
                <th class="px-6 py-3 text-left">Cliente</th>
                <th class="px-6 py-3 text-left">Brief</th>
                <th class="px-6 py-3 text-left">Estado</th>
                <th class="px-6 py-3 text-left">Due</th>
                <th class="px-6 py-3 text-left">Lane</th>
                <th class="px-6 py-3 text-left">Margen</th>
                <th class="px-6 py-3"></th>
              </tr>
            </thead>
            <tbody id="recent-jobs-body" class="divide-y divide-gray-200">
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-slate-400">Cargando trabajos...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="crm-panel overflow-hidden">
        <div class="border-b border-white/8 px-6 py-5">
          <h2 class="text-lg font-semibold text-white">Revisiones proximas</h2>
          <p class="mt-2 text-sm text-slate-300">Clientes que deberian tener seguimiento en los proximos 14 dias.</p>
        </div>
        <div id="reviews-list" class="divide-y divide-gray-200">
          <div class="px-6 py-8 text-center text-slate-400">Cargando revisiones...</div>
        </div>
      </section>
    </div>
  </div>

  <script>
    (async () => {
    const {
      api,
      escapeHtml,
      formatDate,
      formatPercent,
      jobStatusClass,
      stackLaneClass,
    } = await import('../../lib/api-client');

    const recentJobsBody = document.getElementById('recent-jobs-body');
    const reviewsList = document.getElementById('reviews-list');

    try {
      const stats = await api('/api/portal/dashboard/stats');

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      setText('active-jobs', String(stats.activeJobs ?? 0));
      setText('urgent-jobs', `${stats.urgentJobs ?? 0} urgentes`);
      setText('units-planned', String(stats.unitsPlannedThisMonth ?? 0));
      setText('units-consumed', `${stats.unitsConsumedThisMonth ?? 0} unidades consumidas`);
      setText('avg-margin', formatPercent(stats.avgEstimatedMargin ?? 0));
      setText('low-margin-jobs', `${stats.lowMarginJobs ?? 0} trabajos por debajo del 65%`);
      setText('total-clients', String(stats.totalClients ?? 0));
      setText('reviews-due', `${stats.reviewsDueSoon ?? 0} revisiones próximas`);

      const recentJobs = Array.isArray(stats.recentJobs) ? stats.recentJobs : [];
      if (recentJobsBody) {
        recentJobsBody.innerHTML = recentJobs.length === 0
          ? `<tr><td colspan="7" class="px-6 py-8 text-center text-slate-400">No hay trabajos recientes.</td></tr>`
          : recentJobs.map((job) => `
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-medium text-white">${escapeHtml(job.clientName ?? '—')}</td>
              <td class="px-6 py-4 max-w-xs truncate text-slate-200">${escapeHtml(job.briefText ?? 'Sin brief')}</td>
              <td class="px-6 py-4">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                  ${escapeHtml(job.status ?? 'pending')}
                </span>
                ${job.turnaround === 'urgente' ? '<span class="ml-2 inline-flex rounded-full border border-rose-300/20 bg-rose-400/10 px-3 py-1 text-xs font-medium text-rose-100">urgente</span>' : ''}
              </td>
              <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.dueAt))}</td>
              <td class="px-6 py-4">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${stackLaneClass(job.stackLane ?? '')}">
                  ${escapeHtml(job.stackLane ?? '—')}
                </span>
              </td>
              <td class="px-6 py-4 text-gray-600">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
              <td class="px-6 py-4 text-right">
                <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-sky-200 transition hover:text-white">Ver</a>
              </td>
            </tr>
          `).join('');
      }

      const reviews = Array.isArray(stats.upcomingReviews) ? stats.upcomingReviews : [];
      if (reviewsList) {
        reviewsList.innerHTML = reviews.length === 0
          ? `<div class="px-6 py-8 text-center text-slate-400">No hay revisiones proximas.</div>`
          : reviews.map((client) => `
            <div class="px-6 py-4 flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-white">${escapeHtml(client.name)}</p>
                <p class="text-sm text-gray-500">${escapeHtml(client.company ?? client.plan ?? 'Sin empresa')}</p>
                <p class="text-sm text-gray-500 mt-1">Account manager: ${escapeHtml(client.accountManager ?? 'hola@grandeandgordo.com')}</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-white">${escapeHtml(formatDate(client.nextReviewAt))}</p>
                <a href="/admin/clients/detail?id=${encodeURIComponent(client.id)}" class="text-sm font-medium text-sky-200 transition hover:text-white">Abrir cliente</a>
              </div>
            </div>
          `).join('');
      }
    } catch {
      if (recentJobsBody) {
        recentJobsBody.innerHTML = `<tr><td colspan="7" class="px-6 py-8 text-center text-rose-200">No se pudo cargar el dashboard.</td></tr>`;
      }
      if (reviewsList) {
        reviewsList.innerHTML = `<div class="px-6 py-8 text-center text-rose-200">No se pudieron cargar las revisiones.</div>`;
      }
    }
    })();
  </script>
</AdminLayout>
