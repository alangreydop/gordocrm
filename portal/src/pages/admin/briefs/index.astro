---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Briefs">
  <div class="space-y-6">
    <section class="crm-panel-strong p-6 md:p-8">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="crm-kicker">Inbox de contexto</p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">Briefs</h1>
          <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-300 md:text-base">
            Bandeja operativa para el contexto que entra desde la web publica y para las
            siguientes capas de intake del sistema.
          </p>
        </div>
        <div class="w-full md:w-80">
          <label for="briefs-search" class="mb-2 block text-sm font-medium text-slate-200">Buscar</label>
          <input
            type="search"
            id="briefs-search"
            placeholder="Cliente, email o contenido"
            class="crm-input"
          />
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-panel p-5">
        <p class="crm-kicker">Briefs totales</p>
        <p id="metric-total-briefs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Nuevos</p>
        <p id="metric-new-briefs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Revisados</p>
        <p id="metric-reviewed-briefs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Sin cliente enlazado</p>
        <p id="metric-unlinked-briefs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
    </div>

    <div class="crm-table-wrap">
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full divide-y divide-gray-200 text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left">Cliente</th>
              <th class="px-6 py-3 text-left">Entrada</th>
              <th class="px-6 py-3 text-left">Resumen</th>
              <th class="px-6 py-3 text-left">Estado</th>
              <th class="px-6 py-3 text-left">Acciones</th>
            </tr>
          </thead>
          <tbody id="briefs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-slate-400">Cargando briefs...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        escapeHtml,
        formatDate,
      } = await import('../../../lib/api-client');

      const tbody = document.getElementById('briefs-body');
      const searchInput = document.getElementById('briefs-search');

      let briefs = [];

      const setMetric = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const briefStatusClass = (status) => (
        {
          new: 'border border-amber-300/20 bg-amber-400/10 text-amber-100',
          reviewed: 'border border-emerald-300/20 bg-emerald-400/10 text-emerald-100',
          archived: 'border border-white/10 bg-white/5 text-slate-200',
        }[status] ?? 'border border-white/10 bg-white/5 text-slate-200'
      );

      const excerpt = (value) => {
        const text = String(value ?? '').trim();
        if (!text) return 'Sin descripcion';
        return text.length > 180 ? `${text.slice(0, 177)}...` : text;
      };

      const setBriefStatus = async (briefId, status) => {
        await api(`/api/portal/briefs/${encodeURIComponent(briefId)}`, {
          method: 'PATCH',
          body: JSON.stringify({ status }),
        });
      };

      const createJobFromBrief = async (briefId) => (
        api(`/api/portal/briefs/${encodeURIComponent(briefId)}/create-job`, {
          method: 'POST',
        })
      );

      const render = () => {
        if (!tbody) return;

        const query =
          searchInput instanceof HTMLInputElement
            ? searchInput.value.trim().toLowerCase()
            : '';

        const filtered = briefs.filter((brief) => {
          if (!query) return true;
          return [
            brief.clientName,
            brief.clientCompany,
            brief.email,
            brief.description,
            brief.tipo,
            brief.status,
          ]
            .filter(Boolean)
            .some((value) => String(value).toLowerCase().includes(query));
        });

        setMetric('metric-total-briefs', String(briefs.length));
        setMetric(
          'metric-new-briefs',
          String(briefs.filter((brief) => brief.status === 'new').length),
        );
        setMetric(
          'metric-reviewed-briefs',
          String(briefs.filter((brief) => brief.status === 'reviewed').length),
        );
        setMetric(
          'metric-unlinked-briefs',
          String(briefs.filter((brief) => !brief.clientId).length),
        );

        if (filtered.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-slate-400">No hay briefs para ese filtro.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = filtered.map((brief) => `
          <tr class="align-top hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">${escapeHtml(brief.clientName ?? 'Sin cliente enlazado')}</p>
              <p class="text-gray-500 mt-1">${escapeHtml(brief.email)}</p>
              <p class="text-xs text-gray-500 mt-2">${escapeHtml(brief.clientCompany ?? brief.clientPlan ?? 'Cuenta sin enlazar')}</p>
            </td>
            <td class="px-6 py-4 text-gray-600">
              <p class="font-medium text-gray-900">${escapeHtml(brief.tipo ?? 'brief')}</p>
              <p class="mt-1">${escapeHtml(formatDate(brief.createdAt))}</p>
              <p class="text-xs text-gray-500 mt-2">Source: ${escapeHtml(brief.source ?? 'website')}</p>
            </td>
            <td class="px-6 py-4 text-gray-600">
              <p class="max-w-xl leading-relaxed">${escapeHtml(excerpt(brief.description))}</p>
              ${
                brief.sourcePage
                  ? `<a href="${escapeHtml(brief.sourcePage)}" target="_blank" rel="noreferrer" class="mt-3 inline-flex text-xs font-medium text-sky-200 transition hover:text-white">Abrir origen</a>`
                  : ''
              }
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${briefStatusClass(brief.status)}">
                ${escapeHtml(brief.status ?? 'new')}
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-col gap-2 items-start">
                <button data-brief-id="${escapeHtml(brief.id)}" data-status="reviewed" class="rounded-full border border-white/10 bg-white px-3 py-2 text-xs font-semibold text-slate-950 transition hover:-translate-y-0.5">
                  Marcar revisado
                </button>
                <button data-brief-id="${escapeHtml(brief.id)}" data-status="archived" class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/8">
                  Archivar
                </button>
                ${
                  brief.clientId
                    ? `<button data-brief-id="${escapeHtml(brief.id)}" data-action="create-job" class="rounded-full border border-sky-300/20 bg-sky-400/10 px-3 py-2 text-xs font-semibold text-sky-100 transition hover:-translate-y-0.5 hover:border-sky-200/30 hover:bg-sky-400/15">
                        Crear trabajo
                      </button>`
                    : ''
                }
                ${
                  brief.clientId
                    ? `<a href="/admin/clients/detail?id=${encodeURIComponent(brief.clientId)}" class="text-xs font-medium text-sky-200 transition hover:text-white">Abrir cliente</a>`
                    : '<span class="text-xs text-amber-100">Pendiente de enlazar</span>'
                }
              </div>
            </td>
          </tr>
        `).join('');
      };

      try {
        const data = await api('/api/portal/briefs');
        briefs = Array.isArray(data.briefs) ? data.briefs : [];
        render();
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-rose-200">No se pudieron cargar los briefs.</td>
            </tr>
          `;
        }
      }

      searchInput?.addEventListener('input', render);

      tbody?.addEventListener('click', async (event) => {
        const target = event.target instanceof Element
          ? event.target.closest('button[data-brief-id]')
          : null;
        if (!(target instanceof HTMLButtonElement)) return;

        const briefId = target.dataset.briefId;
        const previousLabel = target.textContent;
        const action = target.dataset.action ?? 'set-status';

        if (!briefId) return;
        target.disabled = true;
        target.textContent = action === 'create-job' ? 'Creando...' : 'Guardando...';

        try {
          if (action === 'create-job') {
            const data = await createJobFromBrief(briefId);
            briefs = briefs.map((brief) =>
              brief.id === briefId ? { ...brief, status: data?.brief?.status ?? 'reviewed' } : brief,
            );
            window.location.href = `/admin/jobs/detail?id=${encodeURIComponent(data.job.id)}`;
            return;
          }

          const status = target.dataset.status;
          if (!status) throw new Error('Missing brief status');

          await setBriefStatus(briefId, status);
          briefs = briefs.map((brief) =>
            brief.id === briefId ? { ...brief, status } : brief,
          );
          render();
        } catch {
          target.disabled = false;
          target.textContent = previousLabel;
        }
      });
    })();
  </script>
</AdminLayout>
