---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Briefs">
  <div class="space-y-6" role="region" aria-label="Contenido principal">
    <!-- Header -->
    <section class="crm-page-header">
      <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
        <div>
          <p class="crm-kicker">Briefs recibidos</p>
          <h1 class="mt-4 text-3xl font-bold tracking-tight text-crm-text md:text-5xl">Briefs Recibidos</h1>
          <p class="crm-page-header__meta mt-4">
            Briefs submissions desde la web y formularios. Revisa, crea jobs o archiva según corresponda.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Nuevos</p>
            <p id="stat-new" class="mt-3 text-3xl font-bold text-crm-text">—</p>
          </div>
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Pendientes</p>
            <p id="stat-pending" class="mt-3 text-3xl font-bold text-crm-text">—</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section class="crm-panel p-4 flex flex-wrap gap-3 items-center">
      <select id="filter-status" class="crm-input text-sm max-w-xs">
        <option value="">Todos los estados</option>
        <option value="new">Nuevos</option>
        <option value="reviewed">Revisados</option>
        <option value="archived">Archivados</option>
      </select>
      <select id="filter-source" class="crm-input text-sm max-w-xs">
        <option value="">Todas las fuentes</option>
        <option value="web_form">Formulario Web</option>
        <option value="email">Email</option>
        <option value="manual">Manual</option>
      </select>
      <input
        type="text"
        id="search-client"
        class="crm-input text-sm max-w-xs"
        placeholder="Buscar por cliente o email..."
      />
      <button id="clear-filters-btn" class="crm-button crm-button-secondary text-sm">
        Limpiar
      </button>
    </section>

    <!-- Briefs Table -->
    <section class="crm-panel overflow-hidden">
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left">Cliente</th>
              <th class="px-6 py-3 text-left">Email</th>
              <th class="px-6 py-3 text-left">Tipo</th>
              <th class="px-6 py-3 text-left">Descripción</th>
              <th class="px-6 py-3 text-left">Fuente</th>
              <th class="px-6 py-3 text-left">Estado</th>
              <th class="px-6 py-3 text-left">Creado</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="briefs-body">
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-crm-muted">Cargando briefs...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml, formatDate } = await import('../../../lib/api-client');
      const { showToast } = await import('../../../lib/crm-ui');

      // State
      let allBriefs = [];
      let filteredBriefs = [];

      // DOM Elements
      const briefsBody = document.getElementById('briefs-body');
      const filterStatus = document.getElementById('filter-status');
      const filterSource = document.getElementById('filter-source');
      const searchClient = document.getElementById('search-client');
      const clearFiltersBtn = document.getElementById('clear-filters-btn');
      const statNew = document.getElementById('stat-new');
      const statPending = document.getElementById('stat-pending');

      // Status badges
      const statusLabels = {
        new: 'Nuevo',
        reviewed: 'Revisado',
        archived: 'Archivado',
      };

      const statusClasses = {
        new: 'crm-badge crm-badge-info',
        reviewed: 'crm-badge crm-badge-success',
        archived: 'crm-badge crm-badge-default',
      };

      // Source labels
      const sourceLabels = {
        web_form: 'Formulario Web',
        email: 'Email',
        manual: 'Manual',
      };

      // Type labels
      const typeLabels = {
        foto: 'Foto',
        video: 'Video',
        ambos: 'Foto + Video',
      };

      // Load briefs
      async function loadBriefs() {
        try {
          const { briefs } = await api('/api/portal/briefs');
          allBriefs = briefs.sort((a, b) =>
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
          );
          filteredBriefs = [...allBriefs];
          renderBriefs();
          updateStats();
        } catch (error) {
          console.error('Error loading briefs:', error);
          briefsBody.innerHTML = `
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-crm-danger">
                error cargando briefs
                <button onclick="window.location.reload()" class="crm-button crm-button-primary mt-4 ml-2">
                  Recargar
                </button>
              </td>
            </tr>
          `;
        }
      }

      // Update stats
      function updateStats() {
        const newCount = allBriefs.filter(b => b.status === 'new').length;
        const pendingCount = allBriefs.filter(b => ['new', 'reviewed'].includes(b.status) && !b.jobId).length;
        statNew.textContent = newCount;
        statPending.textContent = pendingCount;
      }

      // Filter briefs
      function applyFilters() {
        const status = filterStatus.value;
        const source = filterSource.value;
        const search = searchClient.value.toLowerCase();

        filteredBriefs = allBriefs.filter(brief => {
          if (status && brief.status !== status) return false;
          if (source && brief.source !== source) return false;
          if (search) {
            const clientName = (brief.clientName || '').toLowerCase();
            const clientCompany = (brief.clientCompany || '').toLowerCase();
            const email = (brief.email || '').toLowerCase();
            if (!clientName.includes(search) && !clientCompany.includes(search) && !email.includes(search)) {
              return false;
            }
          }
          return true;
        });

        renderBriefs();
      }

      // Render briefs
      function renderBriefs() {
        if (filteredBriefs.length === 0) {
          briefsBody.innerHTML = `
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-crm-muted">
                No hay briefs que coincidan con los filtros
              </td>
            </tr>
          `;
          return;
        }

        briefsBody.innerHTML = filteredBriefs.map(brief => `
          <tr>
            <td class="px-6 py-4">
              <div class="font-medium text-crm-text">${escapeHtml(brief.clientName || '—')}</div>
              <div class="text-xs text-crm-muted">${escapeHtml(brief.clientCompany || '—')}</div>
            </td>
            <td class="px-6 py-4 text-crm-muted">${escapeHtml(brief.email)}</td>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-2 py-1 text-xs font-medium bg-crm-surface-hover text-crm-muted">
                ${escapeHtml(typeLabels[brief.tipo] || brief.tipo)}
              </span>
            </td>
            <td class="px-6 py-4 max-w-xs truncate text-crm-muted" title="${escapeHtml(brief.description)}">
              ${escapeHtml(brief.description)}
            </td>
            <td class="px-6 py-4 text-crm-muted">
              ${escapeHtml(sourceLabels[brief.source] || brief.source || '—')}
            </td>
            <td class="px-6 py-4">
              <span class="${statusClasses[brief.status] || 'crm-badge crm-badge-default'}">
                ${escapeHtml(statusLabels[brief.status] || brief.status)}
              </span>
            </td>
            <td class="px-6 py-4 text-crm-muted">${formatDate(brief.createdAt)}</td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                ${brief.status === 'new' || brief.status === 'reviewed' ? `
                  <button
                    onclick="createJob('${brief.id}')"
                    class="text-sm font-medium text-crm-success transition hover:text-crm-text"
                    title="Crear job desde brief"
                  >
                    Crear job
                  </button>
                ` : ''}
                ${brief.status !== 'archived' ? `
                  <button
                    onclick="archiveBrief('${brief.id}')"
                    class="text-sm font-medium text-crm-muted hover:text-crm-text transition"
                    title="Archivar brief"
                  >
                    Archivar
                  </button>
                ` : ''}
              </div>
            </td>
          </tr>
        `).join('');
      }

      // Create job from brief
      window.createJob = async (briefId) => {
        if (!confirm('¿Crear un nuevo job desde este brief?')) return;

        try {
          const { job } = await api(`/api/portal/briefs/${briefId}/create-job`, { method: 'POST' });
          showToast(`trabajo creado: ${job.briefText?.slice(0, 50)}...`, 'success');
          window.location.reload();
        } catch (error) {
          console.error('Error creating job:', error);
          showToast('error creando trabajo. revisa que el brief esté vinculado a un cliente.', 'error');
        }
      };

      // Archive brief
      window.archiveBrief = async (briefId) => {
        if (!confirm('¿Archivar este brief?')) return;

        try {
          await api(`/api/portal/briefs/${briefId}`, {
            method: 'PATCH',
            body: JSON.stringify({ status: 'archived' }),
          });
          showToast('brief archivado', 'success');
          window.location.reload();
        } catch (error) {
          console.error('Error archiving brief:', error);
          showToast('error archivando brief', 'error');
        }
      };

      // Event listeners
      filterStatus.addEventListener('change', applyFilters);
      filterSource.addEventListener('change', applyFilters);
      searchClient.addEventListener('input', applyFilters);
      clearFiltersBtn.addEventListener('click', () => {
        filterStatus.value = '';
        filterSource.value = '';
        searchClient.value = '';
        applyFilters();
      });

      // Initialize
      loadBriefs();
    })();
  </script>
</AdminLayout>
