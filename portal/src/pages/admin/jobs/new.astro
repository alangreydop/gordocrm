---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiWithCookie } from '../../../lib/api-client';

const cookie = Astro.request.headers.get('cookie') ?? '';
const fetchApi = apiWithCookie<any>(cookie);

let clients: any[] = [];
try {
  const data = await fetchApi('/api/portal/clients');
  clients = data.clients;
} catch {}

const preselectedClientId = Astro.url.searchParams.get('clientId') ?? '';
---

<AdminLayout title="Nuevo trabajo">
  <div class="max-w-xl">
    <h1 class="text-2xl font-bold mb-6">Nuevo trabajo</h1>

    <div id="form-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

    <form id="job-form" class="space-y-4">
      <div>
        <label for="clientId" class="block text-sm font-medium text-gray-700 mb-1">Cliente</label>
        <select id="clientId" name="clientId" required
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
          <option value="">Seleccionar cliente...</option>
          {clients.map((c: any) => (
            <option value={c.id} selected={c.id === preselectedClientId}>{c.name} ({c.email})</option>
          ))}
        </select>
      </div>
      <div>
        <label for="briefText" class="block text-sm font-medium text-gray-700 mb-1">Brief</label>
        <textarea id="briefText" name="briefText" rows="3"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900"
          placeholder="Descripcion del trabajo..."></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="platform" class="block text-sm font-medium text-gray-700 mb-1">Plataforma</label>
          <select id="platform" name="platform"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
            <option value="">Sin especificar</option>
            <option value="instagram">Instagram</option>
            <option value="tiktok">TikTok</option>
            <option value="amazon_pdp">Amazon PDP</option>
            <option value="paid_ads">Paid Ads</option>
          </select>
        </div>
        <div>
          <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
          <select id="type" name="type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
            <option value="">Sin especificar</option>
            <option value="image">Imagen</option>
            <option value="video">Video</option>
          </select>
        </div>
      </div>
      <div class="flex gap-3">
        <button type="submit"
          class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800">
          Crear trabajo
        </button>
        <a href="/admin/jobs" class="px-4 py-2 rounded-md border border-gray-300 hover:bg-gray-50">
          Cancelar
        </a>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById('job-form') as HTMLFormElement;
    const errorDiv = document.getElementById('form-error') as HTMLDivElement;
    const apiBase = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const clientId = (document.getElementById('clientId') as HTMLSelectElement).value;
      const briefText = (document.getElementById('briefText') as HTMLTextAreaElement).value || undefined;
      const platform = (document.getElementById('platform') as HTMLSelectElement).value || undefined;
      const type = (document.getElementById('type') as HTMLSelectElement).value || undefined;

      try {
        const res = await fetch(`${apiBase}/api/portal/jobs`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ clientId, briefText, platform, type }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'Error creating job');
        }
        const data = await res.json();
        window.location.href = `/admin/jobs/${data.job.id}`;
      } catch (err: any) {
        errorDiv.textContent = err.message;
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
