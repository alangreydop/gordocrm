---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Nuevo trabajo">
  <div class="max-w-xl">
    <h1 class="text-2xl font-bold mb-6">Nuevo trabajo</h1>

    <div id="form-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

    <form id="job-form" class="space-y-4">
      <div>
        <label for="clientId" class="block text-sm font-medium text-gray-700 mb-1">Cliente</label>
        <select id="clientId" name="clientId" required
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
          <option value="">Cargando clientes...</option>
        </select>
      </div>
      <div>
        <label for="briefText" class="block text-sm font-medium text-gray-700 mb-1">Brief</label>
        <textarea id="briefText" name="briefText" rows="3"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900"
          placeholder="Descripcion del trabajo..."></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="platform" class="block text-sm font-medium text-gray-700 mb-1">Plataforma</label>
          <select id="platform" name="platform"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
            <option value="">Sin especificar</option>
            <option value="instagram">Instagram</option>
            <option value="tiktok">TikTok</option>
            <option value="amazon_pdp">Amazon PDP</option>
            <option value="paid_ads">Paid Ads</option>
          </select>
        </div>
        <div>
          <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
          <select id="type" name="type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-900">
            <option value="">Sin especificar</option>
            <option value="image">Imagen</option>
            <option value="video">Video</option>
          </select>
        </div>
      </div>
      <div class="flex gap-3">
        <button type="submit"
          class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800">
          Crear trabajo
        </button>
        <a href="/admin/jobs" class="px-4 py-2 rounded-md border border-gray-300 hover:bg-gray-50">
          Cancelar
        </a>
      </div>
    </form>
  </div>

  <script type="module">
    import { API_BASE, api, escapeHtml, getQueryParam } from '../../../lib/api-client';

    const form = document.getElementById('job-form');
    const errorDiv = document.getElementById('form-error');
    const clientSelect = document.getElementById('clientId');
    const preselectedClientId = getQueryParam('clientId');

    try {
      const data = await api('/api/portal/clients');
      const clients = Array.isArray(data.clients) ? data.clients : [];

      if (clientSelect instanceof HTMLSelectElement) {
        clientSelect.innerHTML = `
          <option value="">Seleccionar cliente...</option>
          ${clients.map((client) => `
            <option value="${escapeHtml(client.id)}" ${client.id === preselectedClientId ? 'selected' : ''}>
              ${escapeHtml(client.name)} (${escapeHtml(client.email)})
            </option>
          `).join('')}
        `;
      }
    } catch {
      if (clientSelect instanceof HTMLSelectElement) {
        clientSelect.innerHTML = `<option value="">No se pudieron cargar los clientes</option>`;
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      errorDiv?.classList.add('hidden');

      const briefText = document.getElementById('briefText');
      const platform = document.getElementById('platform');
      const type = document.getElementById('type');

      try {
        const res = await fetch(`${API_BASE}/api/portal/jobs`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            clientId: clientSelect instanceof HTMLSelectElement ? clientSelect.value : '',
            briefText:
              briefText instanceof HTMLTextAreaElement && briefText.value
                ? briefText.value
                : undefined,
            platform:
              platform instanceof HTMLSelectElement && platform.value
                ? platform.value
                : undefined,
            type:
              type instanceof HTMLSelectElement && type.value
                ? type.value
                : undefined,
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'Error creating job');
        }

        const data = await res.json();
        window.location.href = `/admin/jobs/detail?id=${encodeURIComponent(data.job.id)}`;
      } catch (error) {
        if (errorDiv instanceof HTMLDivElement) {
          errorDiv.textContent =
            error instanceof Error ? error.message : 'Error creating job';
          errorDiv.classList.remove('hidden');
        }
      }
    });
  </script>
</AdminLayout>
