---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiWithCookie } from '../../../lib/api-client';

const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie') ?? '';
const fetchApi = apiWithCookie<any>(cookie);

let job: any = null;
let assets: any[] = [];
try {
  const data = await fetchApi(`/api/portal/jobs/${id}`);
  job = data.job;
  assets = data.assets;
} catch {
  return Astro.redirect('/admin/jobs');
}

const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800',
  processing: 'bg-blue-100 text-blue-800',
  completed: 'bg-green-100 text-green-800',
  failed: 'bg-red-100 text-red-800',
  delivered: 'bg-purple-100 text-purple-800',
};

const allStatuses = ['pending', 'processing', 'completed', 'failed', 'delivered'];
---

<AdminLayout title={`Trabajo — ${job.briefText ?? job.id.slice(0, 8)}`}>
  <a href="/admin/jobs" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">&larr; Trabajos</a>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h1 class="text-xl font-bold">{job.briefText ?? 'Sin brief'}</h1>
        <p class="text-gray-600 mt-1">
          Cliente: <a href={`/admin/clients/${job.clientId}`} class="text-blue-600 hover:text-blue-800">{job.clientName}</a>
        </p>
      </div>
      <span class={`inline-block px-2 py-1 rounded text-xs font-medium ${statusColors[job.status] ?? 'bg-gray-100 text-gray-600'}`}>
        {job.status}
      </span>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div>
        <p class="text-gray-500">Plataforma</p>
        <p class="font-medium">{job.platform ?? '—'}</p>
      </div>
      <div>
        <p class="text-gray-500">Tipo</p>
        <p class="font-medium">{job.type ?? '—'}</p>
      </div>
      <div>
        <p class="text-gray-500">Creado</p>
        <p class="font-medium">{new Date(job.createdAt).toLocaleDateString('es-ES')}</p>
      </div>
      <div>
        <p class="text-gray-500">Actualizado</p>
        <p class="font-medium">{new Date(job.updatedAt).toLocaleDateString('es-ES')}</p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">Cambiar estado</h2>
    <div id="status-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-3 text-sm"></div>
    <div class="flex gap-2 flex-wrap">
      {allStatuses.map((s) => (
        <button
          data-status={s}
          class={`status-btn px-3 py-1.5 rounded text-sm font-medium border transition ${
            s === job.status
              ? 'border-gray-900 bg-gray-900 text-white cursor-default'
              : 'border-gray-300 hover:bg-gray-50 cursor-pointer'
          }`}
          disabled={s === job.status}
        >
          {s}
        </button>
      ))}
    </div>
  </div>

  {assets.length > 0 && (
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-3">Assets ({assets.length})</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {assets.map((a: any) => (
          <div class="border rounded-lg p-3 text-center">
            <p class="text-sm font-medium">{a.type}</p>
            <p class="text-xs text-gray-500 truncate mt-1">{a.r2Key}</p>
            {a.qaStatus && (
              <span class={`inline-block mt-2 px-2 py-0.5 rounded text-xs ${
                a.qaStatus === 'approved' ? 'bg-green-100 text-green-800' :
                a.qaStatus === 'rejected' ? 'bg-red-100 text-red-800' :
                'bg-yellow-100 text-yellow-800'
              }`}>{a.qaStatus}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  <script define:vars={{ jobId: id }}>
    const apiBase = import.meta.env?.PUBLIC_API_URL ?? 'http://localhost:3000';
    const errorDiv = document.getElementById('status-error');

    document.querySelectorAll('.status-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const status = btn.getAttribute('data-status');
        errorDiv.classList.add('hidden');
        try {
          const res = await fetch(`${apiBase}/api/portal/jobs/${jobId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ status }),
          });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'Error updating status');
          }
          window.location.reload();
        } catch (err) {
          errorDiv.textContent = err.message;
          errorDiv.classList.remove('hidden');
        }
      });
    });
  </script>
</AdminLayout>
