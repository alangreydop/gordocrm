---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Trabajos">
  <div class="space-y-6">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-2xl font-bold">Trabajos</h1>
        <p class="text-gray-500 mt-1">Vista de produccion con deadline, stack, consumo, margen y urgencia.</p>
      </div>
      <div class="flex gap-3">
        <input
          type="search"
          id="jobs-search"
          placeholder="Buscar por cliente, brief, lane o plataforma"
          class="w-full md:w-80 rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900"
        />
        <a href="/admin/jobs/new" class="bg-gray-900 text-white px-4 py-2 rounded-md hover:bg-gray-800 whitespace-nowrap">
          Nuevo trabajo
        </a>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Trabajos activos</p>
        <p id="metric-active-jobs" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Urgentes</p>
        <p id="metric-urgent-jobs" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Margen bajo</p>
        <p id="metric-low-margin" class="text-3xl font-bold mt-2">—</p>
        <p class="text-sm text-gray-500 mt-2">&lt; 65%</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Due en 7 dias</p>
        <p id="metric-due-soon" class="text-3xl font-bold mt-2">—</p>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Cliente</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Brief</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Estado</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Due</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Operacion</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Margen</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="jobs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-500">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        escapeHtml,
        formatDate,
        formatNumber,
        formatPercent,
        jobStatusClass,
        stackLaneClass,
        turnaroundClass,
      } = await import('../../../lib/api-client');

      const tbody = document.getElementById('jobs-body');
      const searchInput = document.getElementById('jobs-search');
      let jobs = [];

      const setMetric = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const isDueSoon = (value) => {
        if (!value) return false;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return false;
        const now = new Date();
        const diff = date.getTime() - now.getTime();
        return diff >= 0 && diff <= 7 * 24 * 60 * 60 * 1000;
      };

      const render = () => {
        if (!tbody) return;

        const query =
          searchInput instanceof HTMLInputElement
            ? searchInput.value.trim().toLowerCase()
            : '';

        const filtered = jobs.filter((job) => {
          if (!query) return true;
          return [
            job.clientName,
            job.briefText,
            job.platform,
            job.type,
            job.stackLane,
            job.benchmarkLevel,
          ]
            .filter(Boolean)
            .some((value) => String(value).toLowerCase().includes(query));
        });

        setMetric(
          'metric-active-jobs',
          String(jobs.filter((job) => ['pending', 'processing'].includes(job.status)).length),
        );
        setMetric(
          'metric-urgent-jobs',
          String(jobs.filter((job) => job.turnaround === 'urgente').length),
        );
        setMetric(
          'metric-low-margin',
          String(jobs.filter((job) => Number(job.grossMarginEstimated) < 65).length),
        );
        setMetric(
          'metric-due-soon',
          String(jobs.filter((job) => isDueSoon(job.dueAt)).length),
        );

        if (filtered.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-500">No hay trabajos para ese filtro.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = filtered.map((job) => `
          <tr class="hover:bg-gray-50 align-top">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">${escapeHtml(job.clientName ?? '—')}</p>
              <p class="text-xs text-gray-500 mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900 max-w-xs">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-gray-500 mt-1">Benchmark ${escapeHtml(job.benchmarkLevel ?? '—')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-gray-600">
              <div class="flex flex-wrap gap-2">
                <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${turnaroundClass(job.turnaround ?? 'normal')}">
                  ${escapeHtml(job.turnaround ?? 'normal')}
                </span>
                <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${stackLaneClass(job.stackLane ?? '')}">
                  lane ${escapeHtml(job.stackLane ?? '—')}
                </span>
              </div>
              <p class="text-xs text-gray-500 mt-2">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))} unidades</p>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="text-blue-600 hover:text-blue-800 font-medium">
                Abrir
              </a>
            </td>
          </tr>
        `).join('');
      };

      try {
        const data = await api('/api/portal/jobs');
        jobs = Array.isArray(data.jobs) ? data.jobs : [];
        render();
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-red-600">No se pudieron cargar los trabajos.</td>
            </tr>
          `;
        }
      }

      searchInput?.addEventListener('input', render);
    })();
  </script>
</AdminLayout>
