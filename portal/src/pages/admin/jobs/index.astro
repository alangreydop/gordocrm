---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Trabajos">
  <div class="space-y-6" role="region" aria-label="Contenido principal">
    <section class="crm-page-header">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="crm-kicker">Produccion</p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-crm-text md:text-5xl">trabajos</h1>
          <p class="crm-page-header__meta mt-4">
            vista de producción con deadline, stack, consumo, margen y urgencia
            para priorizar bien antes de entrar al detalle.
          </p>
        </div>
        <div class="flex gap-3 md:items-end">
          <input
            type="search"
            id="jobs-search"
            placeholder="Buscar por cliente, brief, lane o plataforma"
            class="crm-input w-full md:w-80"
          />
          <a href="/admin/jobs/new" class="crm-button crm-button-primary whitespace-nowrap">
            Nuevo trabajo
          </a>
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">Trabajos activos</p>
        <p id="metric-active-jobs" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Urgentes</p>
        <p id="metric-urgent-jobs" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Margen bajo</p>
        <p id="metric-low-margin" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
        <p class="mt-2 text-sm text-crm-muted">&lt; 65%</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Due en 7 dias</p>
        <p id="metric-due-soon" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
      </div>
    </div>

    <div class="crm-table-wrap">
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">cliente</th>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">brief</th>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">estado</th>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">due</th>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">operación</th>
              <th class="px-6 py-3 text-left text-xs font-medium tracking-[0.02em] text-crm-subtle">margen</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="jobs-body">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-crm-muted">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        escapeHtml,
        formatDate,
        formatNumber,
        formatPercent,
      } = await import('../../../lib/api-client');
      const {
        jobStatusClass,
        stackLaneClass,
        turnaroundClass,
      } = await import('../../../lib/ui-helpers');

      const tbody = document.getElementById('jobs-body');
      const searchInput = document.getElementById('jobs-search');
      let jobs = [];

      const setMetric = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const isDueSoon = (value) => {
        if (!value) return false;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return false;
        const now = new Date();
        const diff = date.getTime() - now.getTime();
        return diff >= 0 && diff <= 7 * 24 * 60 * 60 * 1000;
      };

      const render = () => {
        if (!tbody) return;

        const query =
          searchInput instanceof HTMLInputElement
            ? searchInput.value.trim().toLowerCase()
            : '';

        const filtered = jobs.filter((job) => {
          if (!query) return true;
          return [
            job.clientName,
            job.briefText,
            job.platform,
            job.type,
            job.stackLane,
            job.benchmarkLevel,
          ]
            .filter(Boolean)
            .some((value) => String(value).toLowerCase().includes(query));
        });

        setMetric(
          'metric-active-jobs',
          String(jobs.filter((job) => ['pending', 'processing'].includes(job.status)).length),
        );
        setMetric(
          'metric-urgent-jobs',
          String(jobs.filter((job) => job.turnaround === 'urgente').length),
        );
        setMetric(
          'metric-low-margin',
          String(jobs.filter((job) => Number(job.grossMarginEstimated) < 65).length),
        );
        setMetric(
          'metric-due-soon',
          String(jobs.filter((job) => isDueSoon(job.dueAt)).length),
        );

        if (filtered.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-crm-muted">No hay trabajos para ese filtro.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = filtered.map((job) => `
          <tr class="align-top">
            <td class="px-6 py-4">
              <p class="font-medium text-crm-text">${escapeHtml(job.clientName ?? '—')}</p>
              <p class="text-xs text-crm-muted mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <p class="font-medium text-crm-text max-w-xs">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-crm-muted mt-1">Benchmark ${escapeHtml(job.benchmarkLevel ?? '—')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-crm-text-secondary">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-crm-text-secondary">
              <div class="flex flex-wrap gap-2">
                <span class="${turnaroundClass(job.turnaround ?? 'normal')}">
                  ${escapeHtml(job.turnaround ?? 'normal')}
                </span>
                <span class="${stackLaneClass(job.stackLane ?? '')}">
                  lane ${escapeHtml(job.stackLane ?? '—')}</span>
              </div>
              <p class="text-xs text-crm-muted mt-2">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))} unidades</p>
            </td>
            <td class="px-6 py-4 text-crm-text-secondary">${escapeHtml(formatPercent(job.grossMarginEstimated))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/admin/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-crm-accent transition hover:text-crm-text">
                Abrir
              </a>
            </td>
          </tr>
        `).join('');
      };

      try {
        const data = await api('/api/portal/jobs');
        jobs = Array.isArray(data.jobs) ? data.jobs : [];
        render();
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-crm-danger">No se pudieron cargar los trabajos.</td>
            </tr>
          `;
        }
      }

      searchInput?.addEventListener('input', render);
    })();
  </script>
</AdminLayout>
