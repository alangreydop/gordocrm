---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const statusOptions = [
   ['pending', 'Pending'],
   ['processing', 'Processing'],
   ['completed', 'Completed'],
   ['failed', 'Failed'],
   ['delivered', 'Delivered'],
];
const platformOptions = [
   ['instagram', 'Instagram'],
   ['tiktok', 'TikTok'],
   ['amazon_pdp', 'Amazon PDP'],
   ['paid_ads', 'Paid Ads'],
];
const typeOptions = [
   ['image', 'Imagen'],
   ['video', 'Video'],
];
const segmentOptions = [
   ['rentable', 'Rentable'],
   ['growth', 'Growth'],
   ['premium', 'Premium'],
   ['enterprise', 'Enterprise'],
];
const marginOptions = [
   ['estrecho', 'Estrecho'],
   ['medio', 'Medio'],
   ['alto', 'Alto'],
];
const assetDominantOptions = [
   ['catalogo', 'Catalogo'],
   ['paid_static', 'Paid Static'],
   ['pdp_packaging', 'PDP Packaging'],
   ['video_ads', 'Video Ads'],
   ['video_edit', 'Video Edit'],
   ['mixto', 'Mixto'],
];
const legalRiskOptions = [
   ['normal', 'Normal'],
   ['alto', 'Alto'],
];
const turnaroundOptions = [
   ['normal', 'Normal'],
   ['urgente', 'Urgente'],
];
const portabilityOptions = [
   ['si', 'Si'],
   ['no', 'No'],
];
const structuralDemandOptions = [
   ['normal', 'Normal'],
   ['alta', 'Alta'],
];
const benchmarkOptions = [
   ['L0', 'L0'],
   ['L1', 'L1'],
   ['L2', 'L2'],
   ['L3', 'L3'],
];
const stackLaneOptions = [
   ['A', 'A'],
   ['B', 'B'],
   ['C', 'C'],
   ['D', 'D'],
];
const qaOptions = [
   ['pending', 'Pending'],
   ['approved', 'Approved'],
   ['rejected', 'Rejected'],
];
---

<AdminLayout title="Detalle trabajo">
   <div class="space-y-6" role="region" aria-label="Detalle del trabajo">
     <section class="crm-page-header" aria-labelledby="job-title">
       <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
         <div>
           <a href="/admin/jobs" class="inline-block text-sm text-crm-text-secondary transition hover:text-crm-text">&larr; Trabajos</a>
           <h1 id="job-title" class="mt-3 text-3xl font-black tracking-tight text-crm-text md:text-5xl">Cargando trabajo...</h1>
           <p class="mt-3 text-sm text-crm-text-secondary">
            Cliente: <a id="job-client-link" href="/admin/clients" class="font-medium text-crm-accent transition hover:text-crm-text">—</a>
           </p>
         </div>
         <div class="flex flex-wrap gap-2">
           <span id="job-status-pill" class="inline-flex rounded-full border border-crm-border bg-crm-surface-hover px-3 py-1 text-xs font-medium text-crm-text-secondary">—</span>
           <span id="job-lane-pill" class="inline-flex rounded-full border border-crm-border bg-crm-surface-hover px-3 py-1 text-xs font-medium text-crm-text-secondary">—</span>
         </div>
         <div class="flex flex-wrap items-center gap-2">
           <span id="ai-engine-status" class="hidden crm-badge">—</span>
           <button id="execute-ai-btn" class="crm-button crm-button-accent">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
             </svg>
            Ejecutar en AI Engine
           </button>
         </div>
       </div>
     </section>

     <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
       <div class="crm-metric-card" role="region" aria-label="Due date">
         <p class="crm-kicker">Due</p>
         <p id="metric-due" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
         <p id="metric-turnaround" class="text-sm text-crm-muted mt-2">—</p>
       </div>
       <div class="crm-metric-card" role="region" aria-label="Unidades">
         <p class="crm-kicker">Units</p>
         <p id="metric-units" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
         <p id="metric-platform" class="text-sm text-crm-muted mt-2">—</p>
       </div>
       <div class="crm-metric-card" role="region" aria-label="Margen y coste">
         <p class="crm-kicker">Margen y coste</p>
         <p id="metric-margin" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
         <p id="metric-ai-cost" class="text-sm text-crm-muted mt-2">—</p>
       </div>
       <div class="crm-metric-card" role="region" aria-label="Assets">
         <p class="crm-kicker">Assets</p>
         <p id="metric-assets" class="mt-4 text-4xl font-black tracking-tight text-crm-text">—</p>
         <p id="metric-updated" class="text-sm text-crm-muted mt-2">—</p>
       </div>
     </div>

     <!-- Timeline visual del job -->
     <section class="crm-panel p-6" role="region" aria-label="Timeline del trabajo">
       <h2 class="text-lg font-semibold text-crm-text mb-4">Timeline del trabajo</h2>
       <div id="job-timeline" class="relative">
         <!-- Se renderiza dinámicamente -->
       </div>
     </section>

     <div class="grid gap-6 xl:grid-cols-[1.3fr_1fr]">
       <section class="crm-form-section" role="region" aria-label="Ficha de produccion">
         <div class="flex items-center justify-between gap-4 mb-4">
           <div>
             <h2 class="crm-form-section__title">Ficha de produccion</h2>
             <p class="crm-form-section__text">Estado, stack, benchmark, riesgo, margen y notas internas.</p>
           </div>
           <div id="job-save-success" class="hidden text-sm crm-alert crm-alert-success" role="status"></div>
         </div>

         <div id="job-save-error" class="hidden crm-alert crm-alert-danger mb-4 text-sm" role="alert"></div>

         <form id="job-form" class="space-y-5" novalidate>
           <div>
             <label for="briefText" class="block text-sm font-medium text-crm-text-secondary mb-1">Brief</label>
             <textarea id="briefText" name="briefText" rows="4" class="crm-input"></textarea>
           </div>

           <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
             <div>
               <label for="status" class="block text-sm font-medium text-crm-text-secondary mb-1">Estado</label>
               <select id="status" name="status" class="crm-input">
                 {statusOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="platform" class="block text-sm font-medium text-crm-text-secondary mb-1">Plataforma</label>
               <select id="platform" name="platform" class="crm-input">
                 <option value="">Sin definir</option>
                 {platformOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="type" class="block text-sm font-medium text-crm-text-secondary mb-1">Tipo</label>
               <select id="type" name="type" class="crm-input">
                 <option value="">Sin definir</option>
                 {typeOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="dueAt" class="block text-sm font-medium text-crm-text-secondary mb-1">Due date</label>
               <input type="date" id="dueAt" name="dueAt" class="crm-input" />
             </div>
             <div>
               <label for="unitsPlanned" class="block text-sm font-medium text-crm-text-secondary mb-1">Units planned</label>
               <input type="number" min="0" id="unitsPlanned" name="unitsPlanned" class="crm-input" />
             </div>
             <div>
               <label for="unitsConsumed" class="block text-sm font-medium text-crm-text-secondary mb-1">Units consumed</label>
               <input type="number" min="0" id="unitsConsumed" name="unitsConsumed" class="crm-input" />
             </div>
             <div>
               <label for="turnaround" class="block text-sm font-medium text-crm-text-secondary mb-1">Turnaround</label>
               <select id="turnaround" name="turnaround" class="crm-input">
                 <option value="">Sin definir</option>
                 {turnaroundOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="assetDominant" class="block text-sm font-medium text-crm-text-secondary mb-1">Dominante</label>
               <select id="assetDominant" name="assetDominant" class="crm-input">
                 <option value="">Sin definir</option>
                 {assetDominantOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="clientSegment" class="block text-sm font-medium text-crm-text-secondary mb-1">Segmento</label>
               <select id="clientSegment" name="clientSegment" class="crm-input">
                 <option value="">Sin definir</option>
                 {segmentOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="marginProfile" class="block text-sm font-medium text-crm-text-secondary mb-1">Perfil margen</label>
               <select id="marginProfile" name="marginProfile" class="crm-input">
                 <option value="">Sin definir</option>
                 {marginOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="grossMarginEstimated" class="block text-sm font-medium text-crm-text-secondary mb-1">Margen bruto estimado</label>
               <input type="number" min="0" step="0.1" id="grossMarginEstimated" name="grossMarginEstimated" class="crm-input" />
             </div>
             <div>
               <label for="legalRisk" class="block text-sm font-medium text-crm-text-secondary mb-1">Riesgo legal</label>
               <select id="legalRisk" name="legalRisk" class="crm-input">
                 <option value="">Sin definir</option>
                 {legalRiskOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="aiCostEstimated" class="block text-sm font-medium text-crm-text-secondary mb-1">Coste AI estimado</label>
               <input type="number" min="0" step="0.01" id="aiCostEstimated" name="aiCostEstimated" class="crm-input" />
             </div>
             <div>
               <label for="aiCostReal" class="block text-sm font-medium text-crm-text-secondary mb-1">Coste AI real</label>
               <input type="number" min="0" step="0.01" id="aiCostReal" name="aiCostReal" class="crm-input" />
             </div>
             <div>
               <label for="portabilityRequired" class="block text-sm font-medium text-crm-text-secondary mb-1">Portabilidad</label>
               <select id="portabilityRequired" name="portabilityRequired" class="crm-input">
                 <option value="">Sin definir</option>
                 {portabilityOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="structuralDemand" class="block text-sm font-medium text-crm-text-secondary mb-1">Demanda estructural</label>
               <select id="structuralDemand" name="structuralDemand" class="crm-input">
                 <option value="">Sin definir</option>
                 {structuralDemandOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="benchmarkLevel" class="block text-sm font-medium text-crm-text-secondary mb-1">Nivel benchmark</label>
               <select id="benchmarkLevel" name="benchmarkLevel" class="crm-input">
                 <option value="">Sin definir</option>
                 {benchmarkOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
             <div>
               <label for="stackLane" class="block text-sm font-medium text-crm-text-secondary mb-1">Stack lane</label>
               <select id="stackLane" name="stackLane" class="crm-input">
                 <option value="">Sin definir</option>
                 {stackLaneOptions.map(([value, label]) => <option value={value}>{label}</option>)}
               </select>
             </div>
           </div>

           <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
             <div>
               <label for="stackCandidate1" class="block text-sm font-medium text-crm-text-secondary mb-1">Candidate 1</label>
               <input type="text" id="stackCandidate1" name="stackCandidate1" class="crm-input" />
             </div>
             <div>
               <label for="stackCandidate2" class="block text-sm font-medium text-crm-text-secondary mb-1">Candidate 2</label>
               <input type="text" id="stackCandidate2" name="stackCandidate2" class="crm-input" />
             </div>
             <div>
               <label for="stackCandidate3" class="block text-sm font-medium text-crm-text-secondary mb-1">Candidate 3</label>
               <input type="text" id="stackCandidate3" name="stackCandidate3" class="crm-input" />
             </div>
             <div>
               <label for="stackWinner" class="block text-sm font-medium text-crm-text-secondary mb-1">Ganador</label>
               <input type="text" id="stackWinner" name="stackWinner" class="crm-input" />
             </div>
           </div>

           <div>
             <label for="stackSnapshot" class="block text-sm font-medium text-crm-text-secondary mb-1">Snapshot stack</label>
             <textarea id="stackSnapshot" name="stackSnapshot" rows="4" class="crm-input"></textarea>
           </div>
           <div>
             <label for="clientGoal" class="block text-sm font-medium text-crm-text-secondary mb-1">Objetivo del cliente</label>
             <textarea id="clientGoal" name="clientGoal" rows="3" class="crm-input"></textarea>
           </div>
           <div>
             <label for="internalNotes" class="block text-sm font-medium text-crm-text-secondary mb-1">Notas internas</label>
             <textarea id="internalNotes" name="internalNotes" rows="4" class="crm-input"></textarea>
           </div>

           <div class="flex gap-3">
             <button type="submit" class="crm-button crm-button-primary">Guardar trabajo</button>
           </div>
         </form>
       </section>

       <section class="space-y-6">
         <div class="crm-form-section" role="region" aria-label="Nuevo asset">
           <div class="flex items-center justify-between gap-4 mb-4">
             <div>
               <h2 class="crm-form-section__title">Nuevo asset</h2>
               <p class="crm-form-section__text">Registra entregables, links y estado de QA.</p>
             </div>
             <div id="asset-create-success" class="hidden text-sm crm-alert crm-alert-success" role="status"></div>
           </div>

           <div id="asset-create-error" class="hidden crm-alert crm-alert-danger mb-4 text-sm" role="alert"></div>

           <form id="asset-form" class="space-y-4">
             <div>
               <label for="assetLabel" class="block text-sm font-medium text-crm-text-secondary mb-1">Label</label>
               <input type="text" id="assetLabel" name="assetLabel" class="crm-input" />
             </div>
             <div class="grid md:grid-cols-2 gap-4">
               <div>
                 <label for="assetType" class="block text-sm font-medium text-crm-text-secondary mb-1">Tipo</label>
                 <select id="assetType" name="assetType" class="crm-input">
                   {typeOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                 </select>
               </div>
               <div>
                 <label for="assetQaStatus" class="block text-sm font-medium text-crm-text-secondary mb-1">QA</label>
                 <select id="assetQaStatus" name="assetQaStatus" class="crm-input">
                   {qaOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                 </select>
               </div>
             </div>
             <div>
               <label for="assetR2Key" class="block text-sm font-medium text-crm-text-secondary mb-1">R2 key</label>
               <input type="text" id="assetR2Key" name="assetR2Key" class="crm-input" />
             </div>
             <div>
               <label for="assetDeliveryUrl" class="block text-sm font-medium text-crm-text-secondary mb-1">Delivery URL</label>
               <input type="url" id="assetDeliveryUrl" name="assetDeliveryUrl" class="crm-input" />
             </div>
             <div>
               <label for="assetQaNotes" class="block text-sm font-medium text-crm-text-secondary mb-1">Notas QA</label>
               <textarea id="assetQaNotes" name="assetQaNotes" rows="3" class="crm-input"></textarea>
             </div>
             <button type="submit" class="crm-button crm-button-primary w-full">
              Crear asset
             </button>
           </form>

           <!-- Upload file directly -->
           <div class="mt-6 border-t border-crm-border pt-6">
             <p class="text-xs font-bold uppercase tracking-[0.2em] text-crm-subtle mb-3">O subir archivo</p>
             <div id="upload-quota-info" class="mb-3 text-xs text-crm-muted">
              Cargando quota del cliente...
             </div>
             <form id="upload-form" class="flex flex-col gap-3">
               <input
                type="file"
                id="upload-file"
                accept="image/jpeg,image/png,image/webp,video/mp4,video/quicktime"
                class="crm-input text-sm"
               />
               <div class="flex items-center gap-3">
                 <button type="submit" id="upload-btn" class="crm-button crm-button-accent text-sm w-full">
                  Subir a R2
                 </button>
               </div>
               <p class="text-xs text-crm-muted">Max 50MB. JPG, PNG, WebP, MP4, MOV.</p>
               <div id="upload-status" class="hidden text-xs"></div>
             </form>
           </div>
         </div>

         <div class="crm-form-section" role="region" aria-label="Operacion">
           <h2 class="crm-form-section__title">Operacion</h2>
           <div class="mt-4 space-y-3 text-sm text-crm-text-secondary">
             <p><span class="font-medium text-crm-text">Email operativo:</span> hola@grandeandgordo.com</p>
             <p><span class="font-medium text-crm-text">Recomendacion:</span> usa QA aprobado para lo que deba ver el cliente y deja notas internas si algo cambia.</p>
           </div>
         </div>
       </section>
     </div>

     <section class="crm-form-section" role="region" aria-label="Assets del trabajo">
       <div class="flex items-center justify-between gap-4 mb-4">
         <div>
           <h2 id="assets-heading" class="text-lg font-semibold text-crm-text">Assets</h2>
           <p class="mt-2 text-sm text-crm-text-secondary">Edita metadata, links de entrega y estado de QA sin salir del trabajo.</p>
         </div>
         <div id="asset-update-success" class="hidden text-sm crm-alert crm-alert-success" role="status"></div>
       </div>

       <div id="asset-update-error" class="hidden crm-alert crm-alert-danger mb-4 text-sm" role="alert"></div>

       <div id="assets-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
         <p class="text-crm-muted">Cargando assets...</p>
       </div>
     </section>
   </div>

   <script>
     (async () => {
      const {
        API_BASE,
        api,
        dateInputValue,
        escapeHtml,
        formatCurrency,
        formatDate,
        formatNumber,
        formatPercent,
        numberInputValue,
        setText,
        isDueSoon,
       } = await import('../../../lib/crm-ui');
      const {
        jobStatusClass,
        qaStatusClass,
        stackLaneClass,
        turnaroundClass,
       } = await import('../../../lib/ui-helpers');

      const jobId = new URLSearchParams(window.location.search).get('id');
      if (!jobId) {
        window.location.href = '/admin/jobs';
        return;
      }

      const jobForm = document.getElementById('job-form');
      const jobError = document.getElementById('job-save-error');
      const jobSuccess = document.getElementById('job-save-success');
      const executeAiBtn = document.getElementById('execute-ai-btn');
      const assetForm = document.getElementById('asset-form');
      const assetCreateError = document.getElementById('asset-create-error');
      const assetCreateSuccess = document.getElementById('asset-create-success');
      const assetUpdateError = document.getElementById('asset-update-error');
      const assetUpdateSuccess = document.getElementById('asset-update-success');
      const assetsGrid = document.getElementById('assets-grid');
      const assetsHeading = document.getElementById('assets-heading');

      let currentJob = null;
      let currentAssets = [];

      const setInputValue = (id, value) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
         ) {
          field.value = value ?? '';
         }
      };

      const fieldValue = (id) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
         ) {
          return field.value;
         }
        return '';
      };

      const renderAssets = () => {
        if (!assetsGrid) return;
        if (assetsHeading) assetsHeading.textContent = `Assets (${currentAssets.length})`;

        if (currentAssets.length === 0) {
          assetsGrid.innerHTML = '<div class="crm-empty md:col-span-2 xl:col-span-3">Todavia no hay assets registrados.</div>';
          return;
        }

        assetsGrid.innerHTML = currentAssets.map((asset) => `
           <article class="crm-panel-soft space-y-3 p-4" data-asset-id="${escapeHtml(asset.id)}">
             <div class="flex items-start justify-between gap-4">
               <div>
                 <p class="font-medium text-crm-text">${escapeHtml(asset.label ?? asset.type)}</p>
                 <p class="text-xs text-crm-muted mt-1">${escapeHtml(asset.r2Key ?? 'Sin key')}</p>
               </div>
               <span class="${qaStatusClass(asset.qaStatus ?? 'pending')}">
                 ${escapeHtml(asset.qaStatus ?? 'pending')}
               </span>
             </div>

             <div class="space-y-3">
               <div>
                 <label class="block text-xs font-medium text-crm-muted mb-1">Label</label>
                 <input data-field="label" type="text" value="${escapeHtml(asset.label ?? '')}" class="crm-input" />
               </div>
               <div class="grid grid-cols-2 gap-3">
                 <div>
                   <label class="block text-xs font-medium text-crm-muted mb-1">Tipo</label>
                   <select data-field="type" class="crm-input">
                     <option value="image" ${asset.type === 'image' ? 'selected' : ''}>Imagen</option>
                     <option value="video" ${asset.type === 'video' ? 'selected' : ''}>Video</option>
                   </select>
                 </div>
                 <div>
                   <label class="block text-xs font-medium text-crm-muted mb-1">QA</label>
                   <select data-field="qaStatus" class="crm-input">
                     <option value="pending" ${asset.qaStatus === 'pending' ? 'selected' : ''}>Pending</option>
                     <option value="approved" ${asset.qaStatus === 'approved' ? 'selected' : ''}>Approved</option>
                     <option value="rejected" ${asset.qaStatus === 'rejected' ? 'selected' : ''}>Rejected</option>
                   </select>
                 </div>
               </div>
               <div>
                 <label class="block text-xs font-medium text-crm-muted mb-1">R2 key</label>
                 <input data-field="r2Key" type="text" value="${escapeHtml(asset.r2Key ?? '')}" class="crm-input" />
               </div>
               <div>
                 <label class="block text-xs font-medium text-crm-muted mb-1">Delivery URL</label>
                 <input data-field="deliveryUrl" type="url" value="${escapeHtml(asset.deliveryUrl ?? '')}" class="crm-input" />
               </div>
               <div>
                 <label class="block text-xs font-medium text-crm-muted mb-1">QA notes</label>
                 <textarea data-field="qaNotes" rows="3" class="crm-input">${escapeHtml(asset.qaNotes ?? '')}</textarea>
               </div>
             </div>

             <div class="flex items-center justify-between gap-3">
               ${
                asset.deliveryUrl
                   ? `<a href="${escapeHtml(asset.deliveryUrl)}" target="_blank" rel="noreferrer" class="text-sm font-medium text-crm-accent transition hover:text-crm-text">Abrir entrega</a>`
                   : '<span class="text-sm text-crm-muted">Sin link de entrega</span>'
               }
               <button type="button" class="asset-save-button bg-crm-bg-alt text-crm-text px-3 py-2 rounded-md text-sm hover:bg-crm-panel-soft">
                Guardar asset
               </button>
             </div>
           </article>
         `).join('');
      };

      const jobStatusSteps = {
        pending: { label: 'Pendiente', step: 1 },
        processing: { label: 'En producción', step: 2 },
        completed: { label: 'Completado', step: 3 },
        delivered: { label: 'Entregado', step: 4 },
      };

      const renderTimeline = (job) => {
        const timelineEl = document.getElementById('job-timeline');
        if (!timelineEl) return;

        const currentStep = jobStatusSteps[job.status]?.step ?? 1;
        const steps = [
          { step: 1, label: 'Brief recibido', description: 'El trabajo fue creado y está en cola', date: job.createdAt },
          { step: 2, label: 'En producción', description: 'Estamos creando tus assets', date: job.startedAt },
          { step: 3, label: 'QA completado', description: 'Los assets fueron aprobados internamente', date: job.completedAt },
          { step: 4, label: 'Entregado', description: 'Assets disponibles para descarga', date: job.deliveredAt },
        ];

        timelineEl.innerHTML = `<div class="relative pl-8 border-l-2 border-crm-border-strong space-y-6">${
          steps.map((s, idx) => {
            const isCompleted = s.step <= currentStep;
            const isCurrent = s.step === currentStep;
            const dateStr = s.date ? formatDate(s.date) : '—';
            return `
              <div class="relative">
                <div class="absolute -left-[41px] h-5 w-5 rounded-full ${isCompleted ? 'bg-crm-success' : 'bg-crm-muted'} ${isCurrent ? 'ring-4' : ''}" style="${isCurrent ? 'box-shadow: 0 0 0 4px rgba(16,185,129,0.3)' : ''}"></div>
                <div class="${isCurrent ? 'opacity-100' : 'opacity-60'}">
                  <p class="text-sm font-medium ${isCompleted ? 'text-crm-text' : 'text-crm-muted'}">${escapeHtml(s.label)}</p>
                  <p class="text-xs text-crm-muted mt-0.5">${escapeHtml(s.description)}</p>
                  <p class="text-xs text-crm-muted mt-1">${dateStr}</p>
                </div>
              </div>
            `;
          }).join('')
        }</div>`;
      };

      const render = (payload) => {
        const { job, assets } = payload;
        currentJob = job;
        currentAssets = Array.isArray(assets) ? assets : [];

        const title = document.getElementById('job-title');
        const clientLink = document.getElementById('job-client-link');
        const statusPill = document.getElementById('job-status-pill');
        const lanePill = document.getElementById('job-lane-pill');

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;

        if (clientLink instanceof HTMLAnchorElement) {
          clientLink.textContent = job.clientName ?? '—';
          clientLink.href = `/admin/clients/detail?id=${encodeURIComponent(job.clientId)}`;
        }

        if (statusPill) {
          statusPill.textContent = job.status ?? 'pending';
          statusPill.className = jobStatusClass(job.status ?? '');
        }

        if (lanePill) {
          lanePill.textContent = `lane ${job.stackLane ?? '—'}`;
          lanePill.className = stackLaneClass(job.stackLane ?? '');
        }

        setText('metric-due', formatDate(job.dueAt));
        setText('metric-turnaround', job.turnaround ?? 'Sin turnaround definido');
        setText('metric-units', `${formatNumber(job.unitsConsumed ?? 0)} / ${formatNumber(job.unitsPlanned ?? 0)}`);
        setText('metric-platform', `${job.platform ?? 'Sin plataforma'} · ${job.type ?? 'Sin tipo'}`);
        setText('metric-margin', formatPercent(job.grossMarginEstimated));
        setText('metric-ai-cost', `${formatCurrency(job.aiCostEstimated)} est. · ${formatCurrency(job.aiCostReal)} real`);
        setText('metric-assets', String(currentAssets.length));
        setText('metric-updated', `Actualizado ${formatDate(job.updatedAt)}`);

        setInputValue('briefText', job.briefText ?? '');
        setInputValue('status', job.status ?? 'pending');
        setInputValue('platform', job.platform ?? '');
        setInputValue('type', job.type ?? '');
        setInputValue('dueAt', dateInputValue(job.dueAt));
        setInputValue('unitsPlanned', numberInputValue(job.unitsPlanned));
        setInputValue('unitsConsumed', numberInputValue(job.unitsConsumed));
        setInputValue('turnaround', job.turnaround ?? '');
        setInputValue('assetDominant', job.assetDominant ?? '');
        setInputValue('clientSegment', job.clientSegment ?? '');
        setInputValue('marginProfile', job.marginProfile ?? '');
        setInputValue('grossMarginEstimated', numberInputValue(job.grossMarginEstimated));
        setInputValue('legalRisk', job.legalRisk ?? '');
        setInputValue('aiCostEstimated', numberInputValue(job.aiCostEstimated));
        setInputValue('aiCostReal', numberInputValue(job.aiCostReal));
        setInputValue('portabilityRequired', job.portabilityRequired ?? '');
        setInputValue('structuralDemand', job.structuralDemand ?? '');
        setInputValue('benchmarkLevel', job.benchmarkLevel ?? '');
        setInputValue('stackLane', job.stackLane ?? '');
        setInputValue('stackCandidate1', job.stackCandidate1 ?? '');
        setInputValue('stackCandidate2', job.stackCandidate2 ?? '');
        setInputValue('stackCandidate3', job.stackCandidate3 ?? '');
        setInputValue('stackWinner', job.stackWinner ?? '');
        setInputValue('stackSnapshot', job.stackSnapshot ?? '');
        setInputValue('clientGoal', job.clientGoal ?? '');
        setInputValue('internalNotes', job.internalNotes ?? '');

        renderAssets();
        renderTimeline(job);
      };

      const load = async () => {
        const payload = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        render(payload);
        return payload;
      };

      const fetchAIEngineStatus = async (job) => {
        const statusBadge = document.getElementById('ai-engine-status');
        if (!statusBadge) return;

        if (!job?.externalJobId) {
          statusBadge.textContent = 'IA: no ejecutado';
          statusBadge.className = 'crm-badge crm-badge-default';
          statusBadge.classList.remove('hidden');
          return;
        }

        try {
          const res = await fetch(`${API_BASE}/api/ai/jobs/${encodeURIComponent(job.externalJobId)}`, {
            credentials: 'include',
          });

          if (!res.ok) {
            statusBadge.textContent = 'IA: error';
            statusBadge.className = 'crm-badge crm-badge-danger';
            statusBadge.classList.remove('hidden');
            return;
          }

          const data = await res.json();
          const status = data.status ?? data.state ?? data.job_status ?? 'unknown';
          const statusMap = {
            pending: { label: 'IA: en cola', class: 'crm-badge crm-badge-warning' },
            queued: { label: 'IA: en cola', class: 'crm-badge crm-badge-warning' },
            running: { label: 'IA: en ejecución', class: 'crm-badge crm-badge-info' },
            processing: { label: 'IA: procesando', class: 'crm-badge crm-badge-info' },
            completed: { label: 'IA: completado', class: 'crm-badge crm-badge-success' },
            success: { label: 'IA: completado', class: 'crm-badge crm-badge-success' },
            failed: { label: 'IA: fallido', class: 'crm-badge crm-badge-danger' },
            error: { label: 'IA: fallido', class: 'crm-badge crm-badge-danger' },
            cancelled: { label: 'IA: cancelado', class: 'crm-badge crm-badge-default' },
            paused: { label: 'IA: pausado', class: 'crm-badge crm-badge-default' },
            unknown: { label: 'IA: desconocido', class: 'crm-badge crm-badge-default' },
          };
          const mapped = statusMap[String(status).toLowerCase()] ?? statusMap.unknown;
          statusBadge.textContent = mapped.label;
          statusBadge.className = mapped.class;
          statusBadge.classList.remove('hidden');
        } catch {
          statusBadge.textContent = 'IA: no disponible';
          statusBadge.className = 'crm-badge crm-badge-default';
          statusBadge.classList.remove('hidden');
        }
      };

      try {
        const payload = await load();
        if (payload?.job) {
          await fetchAIEngineStatus(payload.job);
        }
      } catch {
        window.location.href = '/admin/jobs';
        return;
      }

      executeAiBtn?.addEventListener('click', async () => {
        if (!confirm('¿Enviar este job a AI Engine para ejecución?')) return;

        executeAiBtn.disabled = true;
        executeAiBtn.innerHTML = `
          <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
         Enviando...
        `;

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}/execute-ai`, {
            method: 'POST',
            credentials: 'include',
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({ error: 'Error desconocido' }));
            throw new Error(data.error || 'error al ejecutar el trabajo');
          }

          const result = await res.json();
          alert(`Job enviado a AI Engine correctamente.\nAI Job ID: ${result.ai_job_id}`);
          await load(); // Recargar para ver estado actualizado
        } catch (error) {
          console.error('Execute AI error:', error);
          alert(error instanceof Error ? error.message : 'no se pudo ejecutar el job en AI Engine');
        } finally {
          executeAiBtn.disabled = false;
          executeAiBtn.innerHTML = `
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
           Ejecutar en AI Engine
         `;
        }
      });

      jobForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        jobError?.classList.add('hidden');
        jobSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              briefText: fieldValue('briefText') || null,
              status: fieldValue('status') || undefined,
              platform: fieldValue('platform') || null,
              type: fieldValue('type') || null,
              dueAt: fieldValue('dueAt') || null,
              unitsPlanned: fieldValue('unitsPlanned') || 0,
              unitsConsumed: fieldValue('unitsConsumed') || 0,
              turnaround: fieldValue('turnaround') || null,
              assetDominant: fieldValue('assetDominant') || null,
              clientSegment: fieldValue('clientSegment') || null,
              marginProfile: fieldValue('marginProfile') || null,
              grossMarginEstimated: fieldValue('grossMarginEstimated') || null,
              legalRisk: fieldValue('legalRisk') || null,
              aiCostEstimated: fieldValue('aiCostEstimated') || null,
              aiCostReal: fieldValue('aiCostReal') || null,
              portabilityRequired: fieldValue('portabilityRequired') || null,
              structuralDemand: fieldValue('structuralDemand') || null,
              benchmarkLevel: fieldValue('benchmarkLevel') || null,
              stackLane: fieldValue('stackLane') || null,
              stackCandidate1: fieldValue('stackCandidate1') || null,
              stackCandidate2: fieldValue('stackCandidate2') || null,
              stackCandidate3: fieldValue('stackCandidate3') || null,
              stackWinner: fieldValue('stackWinner') || null,
              stackSnapshot: fieldValue('stackSnapshot') || null,
              clientGoal: fieldValue('clientGoal') || null,
              internalNotes: fieldValue('internalNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo guardar el trabajo');
          }

          await load();

          if (jobSuccess instanceof HTMLDivElement) {
            jobSuccess.textContent = 'Trabajo actualizado.';
            jobSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (jobError instanceof HTMLDivElement) {
            jobError.textContent = error instanceof Error ? error.message : 'no se pudo guardar el trabajo';
            jobError.classList.remove('hidden');
          }
        }
      });

      assetForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        assetCreateError?.classList.add('hidden');
        assetCreateSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}/assets`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              label: fieldValue('assetLabel') || null,
              type: fieldValue('assetType'),
              r2Key: fieldValue('assetR2Key'),
              deliveryUrl: fieldValue('assetDeliveryUrl') || null,
              qaStatus: fieldValue('assetQaStatus') || 'pending',
              qaNotes: fieldValue('assetQaNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo crear el asset');
          }

          if (assetForm instanceof HTMLFormElement) {
            assetForm.reset();
          }
          setInputValue('assetQaStatus', 'pending');
          setInputValue('assetType', 'image');

          await load();

          if (assetCreateSuccess instanceof HTMLDivElement) {
            assetCreateSuccess.textContent = 'Asset creado.';
            assetCreateSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (assetCreateError instanceof HTMLDivElement) {
            assetCreateError.textContent = error instanceof Error ? error.message : 'no se pudo crear el asset';
            assetCreateError.classList.remove('hidden');
          }
        }
      });

      assetsGrid?.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement) || !target.classList.contains('asset-save-button')) {
          return;
        }

        const card = target.closest('[data-asset-id]');
        if (!(card instanceof HTMLElement)) return;

        const assetId = card.dataset.assetId;
        if (!assetId) return;

        assetUpdateError?.classList.add('hidden');
        assetUpdateSuccess?.classList.add('hidden');

        const readField = (field) => {
          const element = card.querySelector(`[data-field="${field}"]`);
          if (
            element instanceof HTMLInputElement ||
            element instanceof HTMLTextAreaElement ||
            element instanceof HTMLSelectElement
          ) {
            return element.value;
          }
          return '';
        };

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}/assets/${encodeURIComponent(assetId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              label: readField('label') || null,
              type: readField('type') || null,
              r2Key: readField('r2Key') || null,
              deliveryUrl: readField('deliveryUrl') || null,
              qaStatus: readField('qaStatus') || null,
              qaNotes: readField('qaNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo actualizar el asset');
          }

          await load();

          if (assetUpdateSuccess instanceof HTMLDivElement) {
            assetUpdateSuccess.textContent = 'Asset actualizado.';
            assetUpdateSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (assetUpdateError instanceof HTMLDivElement) {
            assetUpdateError.textContent = error instanceof Error ? error.message : 'no se pudo actualizar el asset';
            assetUpdateError.classList.remove('hidden');
          }
        }
      });

      // Load client quota for upload context
      const uploadQuotaInfo = document.getElementById('upload-quota-info');
      const uploadForm = document.getElementById('upload-form');
      const uploadFile = document.getElementById('upload-file');
      const uploadBtn = document.getElementById('upload-btn');
      const uploadStatus = document.getElementById('upload-status');

      const loadQuota = async () => {
        if (!currentJob?.clientId) return;
        try {
          const quota = await api(`/api/portal/upload/quota?clientId=${encodeURIComponent(currentJob.clientId)}`);
          if (uploadQuotaInfo) {
            const usedMB = (quota.storageUsed / (1024 * 1024)).toFixed(1);
            const maxMB = (quota.storageMax / (1024 * 1024)).toFixed(0);
            const remainingMB = (quota.storageRemaining / (1024 * 1024)).toFixed(1);
            uploadQuotaInfo.innerHTML = `<span class="text-crm-text-secondary">${quota.filesUsed}/${quota.filesMax} archivos · ${usedMB}/${maxMB} MB · ${remainingMB} MB libres</span>`;
          }
        } catch {
          if (uploadQuotaInfo) uploadQuotaInfo.textContent = '';
        }
      };

      loadQuota();

      uploadForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!(uploadFile instanceof HTMLInputElement) || !uploadFile.files?.length) {
          uploadFile?.focus();
          return;
        }

        const file = uploadFile.files[0];
        const formData = new FormData();
        formData.append('file', file);

        if (uploadBtn) {
          uploadBtn.disabled = true;
          uploadBtn.textContent = 'Subiendo...';
        }
        if (uploadStatus) {
          uploadStatus.className = 'text-xs text-crm-info';
          uploadStatus.textContent = 'Subiendo...';
          uploadStatus.classList.remove('hidden');
        }

        try {
          const res = await fetch(`${API_BASE}/api/portal/upload/jobs/${encodeURIComponent(jobId)}/upload`, {
            method: 'POST',
            body: formData,
            credentials: 'include',
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({ error: 'Error desconocido' }));
            throw new Error(data.error || 'error al subir archivo');
          }

          uploadFile.value = '';
          if (uploadBtn) {
            uploadBtn.disabled = false;
            uploadBtn.textContent = 'Subir a R2';
          }
          if (uploadStatus) {
            uploadStatus.className = 'text-xs text-crm-success';
            uploadStatus.textContent = '¡Subido correctamente!';
          }

          await load();
          await loadQuota();
        } catch (error) {
          console.error('Upload failed:', error);
          if (uploadBtn) {
            uploadBtn.disabled = false;
            uploadBtn.textContent = 'Subir a R2';
          }
          if (uploadStatus) {
            uploadStatus.className = 'text-xs text-crm-danger';
            uploadStatus.textContent = error instanceof Error ? error.message : 'error al subir';
          }
        }
      });
     })();
   </script>
</AdminLayout>
