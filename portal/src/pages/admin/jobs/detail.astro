---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const statusOptions = [
  ['pending', 'Pending'],
  ['processing', 'Processing'],
  ['completed', 'Completed'],
  ['failed', 'Failed'],
  ['delivered', 'Delivered'],
];
const platformOptions = [
  ['instagram', 'Instagram'],
  ['tiktok', 'TikTok'],
  ['amazon_pdp', 'Amazon PDP'],
  ['paid_ads', 'Paid Ads'],
];
const typeOptions = [
  ['image', 'Imagen'],
  ['video', 'Video'],
];
const segmentOptions = [
  ['rentable', 'Rentable'],
  ['growth', 'Growth'],
  ['premium', 'Premium'],
  ['enterprise', 'Enterprise'],
];
const marginOptions = [
  ['estrecho', 'Estrecho'],
  ['medio', 'Medio'],
  ['alto', 'Alto'],
];
const assetDominantOptions = [
  ['catalogo', 'Catalogo'],
  ['paid_static', 'Paid Static'],
  ['pdp_packaging', 'PDP Packaging'],
  ['video_ads', 'Video Ads'],
  ['video_edit', 'Video Edit'],
  ['mixto', 'Mixto'],
];
const legalRiskOptions = [
  ['normal', 'Normal'],
  ['alto', 'Alto'],
];
const turnaroundOptions = [
  ['normal', 'Normal'],
  ['urgente', 'Urgente'],
];
const portabilityOptions = [
  ['si', 'Si'],
  ['no', 'No'],
];
const structuralDemandOptions = [
  ['normal', 'Normal'],
  ['alta', 'Alta'],
];
const benchmarkOptions = [
  ['L0', 'L0'],
  ['L1', 'L1'],
  ['L2', 'L2'],
  ['L3', 'L3'],
];
const stackLaneOptions = [
  ['A', 'A'],
  ['B', 'B'],
  ['C', 'C'],
  ['D', 'D'],
];
const qaOptions = [
  ['pending', 'Pending'],
  ['approved', 'Approved'],
  ['rejected', 'Rejected'],
];
---

<AdminLayout title="Detalle trabajo">
  <div class="space-y-6">
    <section class="crm-page-header">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <a href="/admin/jobs" class="inline-block text-sm text-slate-300 transition hover:text-white">&larr; Trabajos</a>
          <h1 id="job-title" class="mt-3 text-3xl font-black tracking-tight text-white md:text-5xl">Cargando trabajo...</h1>
          <p class="mt-3 text-sm text-slate-200">
            Cliente: <a id="job-client-link" href="/admin/clients" class="font-medium text-sky-200 transition hover:text-white">—</a>
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <span id="job-status-pill" class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-200">—</span>
          <span id="job-lane-pill" class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-200">—</span>
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">Due</p>
        <p id="metric-due" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-turnaround" class="text-sm text-gray-500 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Units</p>
        <p id="metric-units" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-platform" class="text-sm text-gray-500 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Margen y coste</p>
        <p id="metric-margin" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-ai-cost" class="text-sm text-gray-500 mt-2">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Assets</p>
        <p id="metric-assets" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-updated" class="text-sm text-gray-500 mt-2">—</p>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.3fr_1fr]">
      <section class="crm-form-section">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h2 class="crm-form-section__title">Ficha de produccion</h2>
            <p class="crm-form-section__text">Estado, stack, benchmark, riesgo, margen y notas internas.</p>
          </div>
          <div id="job-save-success" class="hidden text-sm text-green-700 bg-green-50 rounded px-3 py-2"></div>
        </div>

        <div id="job-save-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

        <form id="job-form" class="space-y-5">
          <div>
            <label for="briefText" class="block text-sm font-medium text-gray-700 mb-1">Brief</label>
            <textarea id="briefText" name="briefText" rows="4" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
          </div>

          <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div>
              <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
              <select id="status" name="status" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                {statusOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="platform" class="block text-sm font-medium text-gray-700 mb-1">Plataforma</label>
              <select id="platform" name="platform" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {platformOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
              <select id="type" name="type" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {typeOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="dueAt" class="block text-sm font-medium text-gray-700 mb-1">Due date</label>
              <input type="date" id="dueAt" name="dueAt" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="unitsPlanned" class="block text-sm font-medium text-gray-700 mb-1">Units planned</label>
              <input type="number" min="0" id="unitsPlanned" name="unitsPlanned" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="unitsConsumed" class="block text-sm font-medium text-gray-700 mb-1">Units consumed</label>
              <input type="number" min="0" id="unitsConsumed" name="unitsConsumed" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="turnaround" class="block text-sm font-medium text-gray-700 mb-1">Turnaround</label>
              <select id="turnaround" name="turnaround" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {turnaroundOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="assetDominant" class="block text-sm font-medium text-gray-700 mb-1">Dominante</label>
              <select id="assetDominant" name="assetDominant" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {assetDominantOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="clientSegment" class="block text-sm font-medium text-gray-700 mb-1">Segmento</label>
              <select id="clientSegment" name="clientSegment" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {segmentOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="marginProfile" class="block text-sm font-medium text-gray-700 mb-1">Perfil margen</label>
              <select id="marginProfile" name="marginProfile" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {marginOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="grossMarginEstimated" class="block text-sm font-medium text-gray-700 mb-1">Margen bruto estimado</label>
              <input type="number" min="0" step="0.1" id="grossMarginEstimated" name="grossMarginEstimated" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="legalRisk" class="block text-sm font-medium text-gray-700 mb-1">Riesgo legal</label>
              <select id="legalRisk" name="legalRisk" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {legalRiskOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="aiCostEstimated" class="block text-sm font-medium text-gray-700 mb-1">Coste AI estimado</label>
              <input type="number" min="0" step="0.01" id="aiCostEstimated" name="aiCostEstimated" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="aiCostReal" class="block text-sm font-medium text-gray-700 mb-1">Coste AI real</label>
              <input type="number" min="0" step="0.01" id="aiCostReal" name="aiCostReal" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="portabilityRequired" class="block text-sm font-medium text-gray-700 mb-1">Portabilidad</label>
              <select id="portabilityRequired" name="portabilityRequired" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {portabilityOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="structuralDemand" class="block text-sm font-medium text-gray-700 mb-1">Demanda estructural</label>
              <select id="structuralDemand" name="structuralDemand" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {structuralDemandOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="benchmarkLevel" class="block text-sm font-medium text-gray-700 mb-1">Nivel benchmark</label>
              <select id="benchmarkLevel" name="benchmarkLevel" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {benchmarkOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="stackLane" class="block text-sm font-medium text-gray-700 mb-1">Stack lane</label>
              <select id="stackLane" name="stackLane" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="">Sin definir</option>
                {stackLaneOptions.map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </div>
          </div>

          <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div>
              <label for="stackCandidate1" class="block text-sm font-medium text-gray-700 mb-1">Candidate 1</label>
              <input type="text" id="stackCandidate1" name="stackCandidate1" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="stackCandidate2" class="block text-sm font-medium text-gray-700 mb-1">Candidate 2</label>
              <input type="text" id="stackCandidate2" name="stackCandidate2" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="stackCandidate3" class="block text-sm font-medium text-gray-700 mb-1">Candidate 3</label>
              <input type="text" id="stackCandidate3" name="stackCandidate3" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="stackWinner" class="block text-sm font-medium text-gray-700 mb-1">Ganador</label>
              <input type="text" id="stackWinner" name="stackWinner" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
          </div>

          <div>
            <label for="stackSnapshot" class="block text-sm font-medium text-gray-700 mb-1">Snapshot stack</label>
            <textarea id="stackSnapshot" name="stackSnapshot" rows="4" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
          </div>
          <div>
            <label for="clientGoal" class="block text-sm font-medium text-gray-700 mb-1">Objetivo del cliente</label>
            <textarea id="clientGoal" name="clientGoal" rows="3" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
          </div>
          <div>
            <label for="internalNotes" class="block text-sm font-medium text-gray-700 mb-1">Notas internas</label>
            <textarea id="internalNotes" name="internalNotes" rows="4" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
          </div>

          <div class="flex gap-3">
            <button type="submit" class="crm-button crm-button-primary">Guardar trabajo</button>
          </div>
        </form>
      </section>

      <section class="space-y-6">
        <div class="crm-form-section">
          <div class="flex items-center justify-between gap-4 mb-4">
            <div>
              <h2 class="crm-form-section__title">Nuevo asset</h2>
              <p class="crm-form-section__text">Registra entregables, links y estado de QA.</p>
            </div>
            <div id="asset-create-success" class="hidden text-sm text-green-700 bg-green-50 rounded px-3 py-2"></div>
          </div>

          <div id="asset-create-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

          <form id="asset-form" class="space-y-4">
            <div>
              <label for="assetLabel" class="block text-sm font-medium text-gray-700 mb-1">Label</label>
              <input type="text" id="assetLabel" name="assetLabel" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="assetType" class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
                <select id="assetType" name="assetType" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                  {typeOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
              <div>
                <label for="assetQaStatus" class="block text-sm font-medium text-gray-700 mb-1">QA</label>
                <select id="assetQaStatus" name="assetQaStatus" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900">
                  {qaOptions.map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </div>
            </div>
            <div>
              <label for="assetR2Key" class="block text-sm font-medium text-gray-700 mb-1">R2 key</label>
              <input type="text" id="assetR2Key" name="assetR2Key" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="assetDeliveryUrl" class="block text-sm font-medium text-gray-700 mb-1">Delivery URL</label>
              <input type="url" id="assetDeliveryUrl" name="assetDeliveryUrl" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
            </div>
            <div>
              <label for="assetQaNotes" class="block text-sm font-medium text-gray-700 mb-1">Notas QA</label>
              <textarea id="assetQaNotes" name="assetQaNotes" rows="3" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
            </div>
            <button type="submit" class="crm-button crm-button-primary w-full">
              Crear asset
            </button>
          </form>
        </div>

        <div class="crm-form-section">
          <h2 class="crm-form-section__title">Operacion</h2>
          <div class="mt-4 space-y-3 text-sm text-gray-600">
            <p><span class="font-medium text-gray-900">Email operativo:</span> hola@grandeandgordo.com</p>
            <p><span class="font-medium text-gray-900">Recomendacion:</span> usa QA aprobado para lo que deba ver el cliente y deja notas internas si algo cambia.</p>
          </div>
        </div>
      </section>
    </div>

    <section class="crm-form-section">
      <div class="flex items-center justify-between gap-4 mb-4">
        <div>
          <h2 id="assets-heading" class="text-lg font-semibold text-white">Assets</h2>
          <p class="mt-2 text-sm text-slate-300">Edita metadata, links de entrega y estado de QA sin salir del trabajo.</p>
        </div>
        <div id="asset-update-success" class="hidden text-sm text-green-700 bg-green-50 rounded px-3 py-2"></div>
      </div>

      <div id="asset-update-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

      <div id="assets-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <p class="text-gray-500">Cargando assets...</p>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const {
        API_BASE,
        api,
        dateInputValue,
        escapeHtml,
        formatCurrency,
        formatDate,
        formatNumber,
        formatPercent,
        jobStatusClass,
        numberInputValue,
        qaStatusClass,
        stackLaneClass,
        turnaroundClass,
      } = await import('../../../lib/api-client');

      const jobId = new URLSearchParams(window.location.search).get('id');
      if (!jobId) {
        window.location.href = '/admin/jobs';
        return;
      }

      const jobForm = document.getElementById('job-form');
      const jobError = document.getElementById('job-save-error');
      const jobSuccess = document.getElementById('job-save-success');
      const assetForm = document.getElementById('asset-form');
      const assetCreateError = document.getElementById('asset-create-error');
      const assetCreateSuccess = document.getElementById('asset-create-success');
      const assetUpdateError = document.getElementById('asset-update-error');
      const assetUpdateSuccess = document.getElementById('asset-update-success');
      const assetsGrid = document.getElementById('assets-grid');
      const assetsHeading = document.getElementById('assets-heading');

      let currentJob = null;
      let currentAssets = [];

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const setInputValue = (id, value) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
        ) {
          field.value = value ?? '';
        }
      };

      const fieldValue = (id) => {
        const field = document.getElementById(id);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
        ) {
          return field.value;
        }
        return '';
      };

      const renderAssets = () => {
        if (!assetsGrid) return;
        if (assetsHeading) assetsHeading.textContent = `Assets (${currentAssets.length})`;

        if (currentAssets.length === 0) {
          assetsGrid.innerHTML = '<div class="crm-empty md:col-span-2 xl:col-span-3">Todavia no hay assets registrados.</div>';
          return;
        }

        assetsGrid.innerHTML = currentAssets.map((asset) => `
          <article class="crm-panel-soft space-y-3 p-4" data-asset-id="${escapeHtml(asset.id)}">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-white">${escapeHtml(asset.label ?? asset.type)}</p>
                <p class="text-xs text-gray-500 mt-1">${escapeHtml(asset.r2Key ?? 'Sin key')}</p>
              </div>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${qaStatusClass(asset.qaStatus ?? 'pending')}">
                ${escapeHtml(asset.qaStatus ?? 'pending')}
              </span>
            </div>

            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Label</label>
                <input data-field="label" type="text" value="${escapeHtml(asset.label ?? '')}" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">Tipo</label>
                  <select data-field="type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                    <option value="image" ${asset.type === 'image' ? 'selected' : ''}>Imagen</option>
                    <option value="video" ${asset.type === 'video' ? 'selected' : ''}>Video</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">QA</label>
                  <select data-field="qaStatus" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                    <option value="pending" ${asset.qaStatus === 'pending' ? 'selected' : ''}>Pending</option>
                    <option value="approved" ${asset.qaStatus === 'approved' ? 'selected' : ''}>Approved</option>
                    <option value="rejected" ${asset.qaStatus === 'rejected' ? 'selected' : ''}>Rejected</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">R2 key</label>
                <input data-field="r2Key" type="text" value="${escapeHtml(asset.r2Key ?? '')}" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Delivery URL</label>
                <input data-field="deliveryUrl" type="url" value="${escapeHtml(asset.deliveryUrl ?? '')}" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">QA notes</label>
                <textarea data-field="qaNotes" rows="3" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">${escapeHtml(asset.qaNotes ?? '')}</textarea>
              </div>
            </div>

            <div class="flex items-center justify-between gap-3">
              ${
                asset.deliveryUrl
                  ? `<a href="${escapeHtml(asset.deliveryUrl)}" target="_blank" rel="noreferrer" class="text-sm font-medium text-sky-200 transition hover:text-white">Abrir entrega</a>`
                  : '<span class="text-sm text-gray-400">Sin link de entrega</span>'
              }
              <button type="button" class="asset-save-button bg-gray-900 text-white px-3 py-2 rounded-md text-sm hover:bg-gray-800">
                Guardar asset
              </button>
            </div>
          </article>
        `).join('');
      };

      const render = (payload) => {
        const { job, assets } = payload;
        currentJob = job;
        currentAssets = Array.isArray(assets) ? assets : [];

        const title = document.getElementById('job-title');
        const clientLink = document.getElementById('job-client-link');
        const statusPill = document.getElementById('job-status-pill');
        const lanePill = document.getElementById('job-lane-pill');

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;

        if (clientLink instanceof HTMLAnchorElement) {
          clientLink.textContent = job.clientName ?? '—';
          clientLink.href = `/admin/clients/detail?id=${encodeURIComponent(job.clientId)}`;
        }

        if (statusPill) {
          statusPill.textContent = job.status ?? 'pending';
          statusPill.className = `inline-flex rounded-full px-3 py-1 text-xs font-medium ${jobStatusClass(job.status ?? '')}`;
        }

        if (lanePill) {
          lanePill.textContent = `lane ${job.stackLane ?? '—'}`;
          lanePill.className = `inline-flex rounded-full px-3 py-1 text-xs font-medium ${stackLaneClass(job.stackLane ?? '')}`;
        }

        setText('metric-due', formatDate(job.dueAt));
        setText('metric-turnaround', job.turnaround ?? 'Sin turnaround definido');
        setText('metric-units', `${formatNumber(job.unitsConsumed ?? 0)} / ${formatNumber(job.unitsPlanned ?? 0)}`);
        setText('metric-platform', `${job.platform ?? 'Sin plataforma'} · ${job.type ?? 'Sin tipo'}`);
        setText('metric-margin', formatPercent(job.grossMarginEstimated));
        setText('metric-ai-cost', `${formatCurrency(job.aiCostEstimated)} est. · ${formatCurrency(job.aiCostReal)} real`);
        setText('metric-assets', String(currentAssets.length));
        setText('metric-updated', `Actualizado ${formatDate(job.updatedAt)}`);

        setInputValue('briefText', job.briefText ?? '');
        setInputValue('status', job.status ?? 'pending');
        setInputValue('platform', job.platform ?? '');
        setInputValue('type', job.type ?? '');
        setInputValue('dueAt', dateInputValue(job.dueAt));
        setInputValue('unitsPlanned', numberInputValue(job.unitsPlanned));
        setInputValue('unitsConsumed', numberInputValue(job.unitsConsumed));
        setInputValue('turnaround', job.turnaround ?? '');
        setInputValue('assetDominant', job.assetDominant ?? '');
        setInputValue('clientSegment', job.clientSegment ?? '');
        setInputValue('marginProfile', job.marginProfile ?? '');
        setInputValue('grossMarginEstimated', numberInputValue(job.grossMarginEstimated));
        setInputValue('legalRisk', job.legalRisk ?? '');
        setInputValue('aiCostEstimated', numberInputValue(job.aiCostEstimated));
        setInputValue('aiCostReal', numberInputValue(job.aiCostReal));
        setInputValue('portabilityRequired', job.portabilityRequired ?? '');
        setInputValue('structuralDemand', job.structuralDemand ?? '');
        setInputValue('benchmarkLevel', job.benchmarkLevel ?? '');
        setInputValue('stackLane', job.stackLane ?? '');
        setInputValue('stackCandidate1', job.stackCandidate1 ?? '');
        setInputValue('stackCandidate2', job.stackCandidate2 ?? '');
        setInputValue('stackCandidate3', job.stackCandidate3 ?? '');
        setInputValue('stackWinner', job.stackWinner ?? '');
        setInputValue('stackSnapshot', job.stackSnapshot ?? '');
        setInputValue('clientGoal', job.clientGoal ?? '');
        setInputValue('internalNotes', job.internalNotes ?? '');

        renderAssets();
      };

      const load = async () => {
        const payload = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        render(payload);
      };

      try {
        await load();
      } catch {
        window.location.href = '/admin/jobs';
        return;
      }

      jobForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        jobError?.classList.add('hidden');
        jobSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              briefText: fieldValue('briefText') || null,
              status: fieldValue('status') || undefined,
              platform: fieldValue('platform') || null,
              type: fieldValue('type') || null,
              dueAt: fieldValue('dueAt') || null,
              unitsPlanned: fieldValue('unitsPlanned') || 0,
              unitsConsumed: fieldValue('unitsConsumed') || 0,
              turnaround: fieldValue('turnaround') || null,
              assetDominant: fieldValue('assetDominant') || null,
              clientSegment: fieldValue('clientSegment') || null,
              marginProfile: fieldValue('marginProfile') || null,
              grossMarginEstimated: fieldValue('grossMarginEstimated') || null,
              legalRisk: fieldValue('legalRisk') || null,
              aiCostEstimated: fieldValue('aiCostEstimated') || null,
              aiCostReal: fieldValue('aiCostReal') || null,
              portabilityRequired: fieldValue('portabilityRequired') || null,
              structuralDemand: fieldValue('structuralDemand') || null,
              benchmarkLevel: fieldValue('benchmarkLevel') || null,
              stackLane: fieldValue('stackLane') || null,
              stackCandidate1: fieldValue('stackCandidate1') || null,
              stackCandidate2: fieldValue('stackCandidate2') || null,
              stackCandidate3: fieldValue('stackCandidate3') || null,
              stackWinner: fieldValue('stackWinner') || null,
              stackSnapshot: fieldValue('stackSnapshot') || null,
              clientGoal: fieldValue('clientGoal') || null,
              internalNotes: fieldValue('internalNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo guardar el trabajo');
          }

          await load();

          if (jobSuccess instanceof HTMLDivElement) {
            jobSuccess.textContent = 'Trabajo actualizado.';
            jobSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (jobError instanceof HTMLDivElement) {
            jobError.textContent = error instanceof Error ? error.message : 'No se pudo guardar el trabajo';
            jobError.classList.remove('hidden');
          }
        }
      });

      assetForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        assetCreateError?.classList.add('hidden');
        assetCreateSuccess?.classList.add('hidden');

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}/assets`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              label: fieldValue('assetLabel') || null,
              type: fieldValue('assetType'),
              r2Key: fieldValue('assetR2Key'),
              deliveryUrl: fieldValue('assetDeliveryUrl') || null,
              qaStatus: fieldValue('assetQaStatus') || 'pending',
              qaNotes: fieldValue('assetQaNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo crear el asset');
          }

          if (assetForm instanceof HTMLFormElement) {
            assetForm.reset();
          }
          setInputValue('assetQaStatus', 'pending');
          setInputValue('assetType', 'image');

          await load();

          if (assetCreateSuccess instanceof HTMLDivElement) {
            assetCreateSuccess.textContent = 'Asset creado.';
            assetCreateSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (assetCreateError instanceof HTMLDivElement) {
            assetCreateError.textContent = error instanceof Error ? error.message : 'No se pudo crear el asset';
            assetCreateError.classList.remove('hidden');
          }
        }
      });

      assetsGrid?.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement) || !target.classList.contains('asset-save-button')) {
          return;
        }

        const card = target.closest('[data-asset-id]');
        if (!(card instanceof HTMLElement)) return;

        const assetId = card.dataset.assetId;
        if (!assetId) return;

        assetUpdateError?.classList.add('hidden');
        assetUpdateSuccess?.classList.add('hidden');

        const readField = (field) => {
          const element = card.querySelector(`[data-field="${field}"]`);
          if (
            element instanceof HTMLInputElement ||
            element instanceof HTMLTextAreaElement ||
            element instanceof HTMLSelectElement
          ) {
            return element.value;
          }
          return '';
        };

        try {
          const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}/assets/${encodeURIComponent(assetId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              label: readField('label') || null,
              type: readField('type') || null,
              r2Key: readField('r2Key') || null,
              deliveryUrl: readField('deliveryUrl') || null,
              qaStatus: readField('qaStatus') || null,
              qaNotes: readField('qaNotes') || null,
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo actualizar el asset');
          }

          await load();

          if (assetUpdateSuccess instanceof HTMLDivElement) {
            assetUpdateSuccess.textContent = 'Asset actualizado.';
            assetUpdateSuccess.classList.remove('hidden');
          }
        } catch (error) {
          if (assetUpdateError instanceof HTMLDivElement) {
            assetUpdateError.textContent = error instanceof Error ? error.message : 'No se pudo actualizar el asset';
            assetUpdateError.classList.remove('hidden');
          }
        }
      });
    })();
  </script>
</AdminLayout>
