---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Detalle trabajo">
  <a href="/admin/jobs" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">&larr; Trabajos</a>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h1 id="job-title" class="text-xl font-bold">Cargando trabajo...</h1>
        <p class="text-gray-600 mt-1">
          Cliente: <a id="job-client-link" href="/admin/clients" class="text-blue-600 hover:text-blue-800">—</a>
        </p>
      </div>
      <span id="job-status-pill" class="inline-block px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-600">
        —
      </span>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div>
        <p class="text-gray-500">Plataforma</p>
        <p id="job-platform" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Tipo</p>
        <p id="job-type" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Creado</p>
        <p id="job-created-at" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Actualizado</p>
        <p id="job-updated-at" class="font-medium">—</p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">Cambiar estado</h2>
    <div id="status-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-3 text-sm"></div>
    <div class="flex gap-2 flex-wrap">
      <button data-status="pending" class="status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50">pending</button>
      <button data-status="processing" class="status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50">processing</button>
      <button data-status="completed" class="status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50">completed</button>
      <button data-status="failed" class="status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50">failed</button>
      <button data-status="delivered" class="status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50">delivered</button>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h2 id="assets-heading" class="text-lg font-semibold mb-3">Assets</h2>
    <div id="assets-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <p class="text-gray-500">Cargando assets...</p>
    </div>
  </div>

  <script>
    (async () => {
    const {
      API_BASE,
      api,
      escapeHtml,
      formatDate,
      getQueryParam,
      jobStatusClass,
    } = await import('../../../lib/api-client');

    const jobId = getQueryParam('id');
    if (!jobId) {
      window.location.href = '/admin/jobs';
    } else {
      const title = document.getElementById('job-title');
      const clientLink = document.getElementById('job-client-link');
      const statusPill = document.getElementById('job-status-pill');
      const platform = document.getElementById('job-platform');
      const type = document.getElementById('job-type');
      const createdAt = document.getElementById('job-created-at');
      const updatedAt = document.getElementById('job-updated-at');
      const errorDiv = document.getElementById('status-error');
      const assetsHeading = document.getElementById('assets-heading');
      const assetsGrid = document.getElementById('assets-grid');

      const syncStatusButtons = (currentStatus) => {
        document.querySelectorAll('.status-btn').forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const status = button.dataset.status;
          const active = status === currentStatus;
          button.disabled = active;
          button.className = active
            ? 'status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-900 bg-gray-900 text-white cursor-default'
            : 'status-btn px-3 py-1.5 rounded text-sm font-medium border transition border-gray-300 hover:bg-gray-50 cursor-pointer';
        });
      };

      const loadJob = async () => {
        const data = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        const job = data.job;
        const assets = Array.isArray(data.assets) ? data.assets : [];

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;
        if (platform) platform.textContent = job.platform ?? '—';
        if (type) type.textContent = job.type ?? '—';
        if (createdAt) createdAt.textContent = formatDate(job.createdAt);
        if (updatedAt) updatedAt.textContent = formatDate(job.updatedAt);

        if (clientLink instanceof HTMLAnchorElement) {
          clientLink.textContent = job.clientName ?? '—';
          clientLink.href = `/admin/clients/detail?id=${encodeURIComponent(job.clientId)}`;
        }

        if (statusPill) {
          statusPill.textContent = job.status ?? 'pending';
          statusPill.className = `inline-block px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}`;
        }

        syncStatusButtons(job.status ?? '');

        if (assetsHeading) assetsHeading.textContent = `Assets (${assets.length})`;
        if (assetsGrid) {
          assetsGrid.innerHTML = assets.length === 0
            ? `<p class="text-gray-500">Este trabajo todavia no tiene assets.</p>`
            : assets.map((asset) => `
              <div class="border rounded-lg p-3 text-center">
                <p class="text-sm font-medium">${escapeHtml(asset.type)}</p>
                <p class="text-xs text-gray-500 truncate mt-1">${escapeHtml(asset.r2Key)}</p>
                ${asset.qaStatus ? `<span class="inline-block mt-2 px-2 py-0.5 rounded text-xs ${asset.qaStatus === 'approved' ? 'bg-green-100 text-green-800' : asset.qaStatus === 'rejected' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'}">${escapeHtml(asset.qaStatus)}</span>` : ''}
              </div>
            `).join('');
        }
      };

      try {
        await loadJob();
      } catch {
        window.location.href = '/admin/jobs';
      }

      document.querySelectorAll('.status-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          if (!(button instanceof HTMLButtonElement)) return;
          const nextStatus = button.dataset.status;
          if (!nextStatus) return;

          errorDiv?.classList.add('hidden');

          try {
            const res = await fetch(`${API_BASE}/api/portal/jobs/${encodeURIComponent(jobId)}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ status: nextStatus }),
            });

            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              throw new Error(data.error ?? 'Error updating status');
            }

            await loadJob();
          } catch (error) {
            if (errorDiv instanceof HTMLDivElement) {
              errorDiv.textContent =
                error instanceof Error ? error.message : 'Error updating status';
              errorDiv.classList.remove('hidden');
            }
          }
        });
      });
    }
    })();
  </script>
</AdminLayout>
