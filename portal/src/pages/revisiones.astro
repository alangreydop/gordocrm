---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Revisiones" section="revisiones">
  <div id="client-area-root" class="space-y-6">
    <div class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
      <div class="border-b border-zinc-800 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Revisiones</h2>
        <p class="mt-1 text-sm text-zinc-400">Revisa y aprueba entregas pendientes.</p>
      </div>
      <div id="reviews-list" class="p-6">
        <div class="space-y-4" id="skeleton-reviews">
          {[1,2,3].map(() => `
            <div class="rounded-xl border border-zinc-800 bg-black p-5 animate-pulse">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="h-5 w-48 rounded bg-zinc-800"></div>
                  <div class="h-4 w-32 rounded bg-zinc-800/60 mt-2"></div>
                </div>
                <div class="h-6 w-24 rounded-full bg-zinc-800"></div>
              </div>
              <div class="h-3 w-28 rounded bg-zinc-800/40 mt-3"></div>
            </div>
          `).join('')}
        </div>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toReviewsViewModel } = await import('../lib/client-area/view-models');
      const { api } = await import('../lib/api-client');
      const { invalidateWorkspace } = await import('../lib/client-area/api');

      const snapshot = await bootstrapClientArea();
      const reviews = toReviewsViewModel(snapshot);
      const list = document.getElementById('reviews-list');

      if (!list) return;

      if (reviews.length === 0) {
        list.innerHTML = `
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <svg class="w-12 h-12 text-zinc-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-zinc-400">No hay revisiones pendientes.</p>
            <p class="text-xs text-zinc-600 mt-1">Las revisiones aparecerán cuando tu equipo suba entregas.</p>
          </div>`;
        return;
      }

      const statusBadgeClass = (status: string): string => {
        switch (status) {
          case 'needs_review': return 'border-amber-300/20 bg-amber-400/10 text-amber-100';
          case 'approved': return 'border-emerald-300/20 bg-emerald-400/10 text-emerald-100';
          case 'changes_requested': return 'border-rose-300/20 bg-rose-400/10 text-rose-100';
          default: return 'border-zinc-700 bg-zinc-900 text-white';
        }
      };

      list.innerHTML = `<div class="space-y-4">${reviews.map((r) => {
        const needsAction = r.status === 'needs_review';
        return `
        <div class="rounded-xl border border-zinc-800 bg-black p-5 transition-all duration-200 hover:border-zinc-700" data-review-id="${r.id}">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h3 class="font-semibold text-white">${r.title}</h3>
              ${r.summary ? `<p class="text-sm text-zinc-400 mt-1">${r.summary}</p>` : ''}
            </div>
            <span class="inline-flex rounded-full border ${statusBadgeClass(r.status)} px-3 py-1 text-xs font-medium flex-shrink-0">${r.statusLabel}</span>
          </div>
          <div class="mt-3 text-xs text-zinc-400 flex items-center gap-3">
            ${r.dueAt ? `<span>Vence: ${new Date(r.dueAt).toLocaleDateString('es-ES')}</span>` : ''}
          </div>
          ${r.decisionNote ? `<div class="mt-3 rounded-lg border border-zinc-800 bg-zinc-950 px-4 py-3 text-sm text-zinc-300"><span class="text-xs font-bold uppercase tracking-wider text-zinc-500">Nota</span><p class="mt-1">${r.decisionNote}</p></div>` : ''}
          ${needsAction ? `
          <div class="mt-4 border-t border-zinc-800 pt-4" data-action-area="${r.id}">
            <textarea id="note-${r.id}" rows="2" class="w-full rounded-lg border border-zinc-800 bg-zinc-950 px-4 py-3 text-sm text-white placeholder-zinc-600 focus:border-white/30 focus:outline-none transition resize-none" placeholder="Nota opcional sobre tu decisión..."></textarea>
            <div class="mt-3 flex items-center gap-3">
              <button data-action="approve" data-review-id="${r.id}" class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 border border-emerald-400/20 px-5 py-2.5 text-sm font-semibold text-emerald-300 transition-all duration-200 hover:bg-emerald-500/20 hover:border-emerald-400/30 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Aprobar
              </button>
              <button data-action="reject" data-review-id="${r.id}" class="inline-flex items-center gap-2 rounded-full bg-rose-500/10 border border-rose-400/20 px-5 py-2.5 text-sm font-semibold text-rose-300 transition-all duration-200 hover:bg-rose-500/20 hover:border-rose-400/30 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                Solicitar cambios
              </button>
            </div>
          </div>
          ` : ''}
        </div>
      `}).join('')}</div>`;

      const handleDecision = async (reviewId: string, status: 'approved' | 'changes_requested') => {
        const noteEl = document.getElementById(`note-${reviewId}`) as HTMLTextAreaElement | null;
        const note = noteEl?.value?.trim() ?? null;
        const actionArea = document.querySelector(`[data-action-area="${reviewId}"]`);

        if (actionArea) {
          actionArea.innerHTML = '<p class="text-sm text-zinc-400 animate-pulse">Enviando decisión...</p>';
        }

        try {
          await api(`/api/portal/client-area/reviews/${reviewId}/decision`, {
            method: 'POST',
            body: JSON.stringify({ status, note }),
          });

          invalidateWorkspace();
          const card = document.querySelector(`[data-review-id="${reviewId}"]`);
          if (card) {
            card.style.transition = 'opacity 300ms, transform 300ms';
            card.style.opacity = '0';
            card.style.transform = 'translateY(-8px)';
            setTimeout(() => {
              card.innerHTML = `
                <div class="flex items-center gap-3 py-2">
                  <svg class="w-5 h-5 ${status === 'approved' ? 'text-emerald-400' : 'text-rose-400'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${status === 'approved' ? 'M5 13l4 4L19 7' : 'M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'}"/></svg>
                  <span class="text-sm font-medium ${status === 'approved' ? 'text-emerald-300' : 'text-rose-300'}">${status === 'approved' ? 'Aprobado' : 'Cambios solicitados'}</span>
                </div>`;
              card.style.opacity = '1';
              card.style.transform = 'none';
            }, 300);
          }
        } catch (err) {
          if (actionArea) {
            actionArea.innerHTML = '<p class="text-sm text-rose-400">Error al enviar. Inténtalo de nuevo.</p>';
          }
        }
      };

      list.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const btn = target.closest('button[data-action]');
        if (!btn) return;

        const action = btn.getAttribute('data-action');
        const reviewId = btn.getAttribute('data-review-id');
        if (!reviewId || !action) return;

        if (action === 'approve') handleDecision(reviewId, 'approved');
        if (action === 'reject') handleDecision(reviewId, 'changes_requested');
      });
    })();
  </script>
</ClientAreaLayout>