---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Revisiones" section="revisiones">
  <div id="client-area-root">
    <div class="crm-masthead">
      <p class="crm-kicker">Revisiones</p>
      <h1 class="crm-masthead-title">Aprueba tus entregas</h1>
      <p class="crm-masthead-deck">Revisa y aprueba las entregas pendientes antes de cierre.</p>
    </div>

    <div id="reviews-list">
      {[1,2,3].map(() => `
        <div class="crm-row animate-pulse" style="border-bottom-color: oklch(92% 0.005 355);">
          <div class="flex-1">
            <div class="h-4 w-44 rounded" style="background: var(--gg-border-light);"></div>
            <div class="h-3 w-28 rounded mt-2" style="background: oklch(94% 0.005 355);"></div>
          </div>
          <div class="h-5 w-24 rounded-full" style="background: var(--gg-border-light);"></div>
        </div>
      `).join('')}
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toReviewsViewModel } = await import('../lib/client-area/view-models');
      const { api } = await import('../lib/api-client');
      const { invalidateWorkspace } = await import('../lib/client-area/api');

      const snapshot = await bootstrapClientArea();
      const reviews = toReviewsViewModel(snapshot);
      const list = document.getElementById('reviews-list');

      if (!list) return;

      if (reviews.length === 0) {
        list.innerHTML = `
          <div class="py-10 text-center">
            <p class="crm-kicker" style="color: oklch(55% 0.008 355);">Sin revisiones</p>
            <p class="text-sm mt-2" style="color: var(--gg-text-muted);">Las revisiones aparecerán cuando tu equipo suba entregas.</p>
          </div>`;
        return;
      }

      const statusBadge = (status: string): { cls: string; label: string } => {
        switch (status) {
          case 'needs_review': return { cls: 'crm-badge crm-badge--warning', label: 'Pendiente' };
          case 'approved': return { cls: 'crm-badge crm-badge--success', label: 'Aprobado' };
          case 'changes_requested': return { cls: 'crm-badge crm-badge--danger', label: 'Cambios solicitados' };
          default: return { cls: 'crm-badge crm-badge--muted', label: status };
        }
      };

      list.innerHTML = reviews.map((r, i) => {
        const needsAction = r.status === 'needs_review';
        const badge = statusBadge(r.status);
        return `
        <div class="crm-row ca-card-enter" data-review-id="${r.id}" style="border-bottom-color: oklch(92% 0.005 355); animation-delay: ${i * 40}ms;">
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-semibold" style="color: var(--gg-text);">${r.title}</h3>
                ${r.summary ? `<p class="text-sm mt-0.5" style="color: oklch(50% 0.008 355);">${r.summary}</p>` : ''}
              </div>
              <span class="${badge.cls} flex-shrink-0">${badge.label}</span>
            </div>
            ${r.dueAt ? `<p class="text-xs mt-1" style="color: oklch(55% 0.008 355);">Vence: ${new Date(r.dueAt).toLocaleDateString('es-ES')}</p>` : ''}
            ${r.decisionNote ? `
            <div class="mt-2 px-3 py-2" style="border-top: 1px solid oklch(92% 0.005 355);">
              <p class="crm-kicker" style="font-size: 0.68rem;">Nota</p>
              <p class="text-sm mt-0.5" style="color: var(--gg-text-secondary);">${r.decisionNote}</p>
            </div>` : ''}
            ${needsAction ? `
            <div data-action-area="${r.id}" class="mt-3 pt-3" style="border-top: 1px solid oklch(92% 0.005 355);">
              <textarea id="note-${r.id}" rows="2" class="crm-input-boxed" placeholder="Nota opcional sobre tu decisión..."></textarea>
              <div class="mt-3 flex items-center gap-3">
                <button data-action="approve" data-review-id="${r.id}" class="crm-button crm-button-primary" style="padding: 0.45rem 1.1rem; font-size: 0.82rem;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Aprobar
                </button>
                <button data-action="reject" data-review-id="${r.id}" class="crm-button crm-button-ghost" style="padding: 0.45rem 1.1rem; font-size: 0.82rem;">
                  Solicitar cambios
                </button>
              </div>
            </div>` : ''}
          </div>
        </div>`;
      }).join('');

      const handleDecision = async (reviewId: string, status: 'approved' | 'changes_requested') => {
        const noteEl = document.getElementById(`note-${reviewId}`) as HTMLTextAreaElement | null;
        const note = noteEl?.value?.trim() ?? null;
        const actionArea = document.querySelector(`[data-action-area="${reviewId}"]`);

        if (actionArea) {
          actionArea.innerHTML = '<p class="text-sm animate-pulse" style="color: var(--gg-text-muted);">Enviando decisión...</p>';
        }

        try {
          await api(`/api/portal/client-area/reviews/${reviewId}/decision`, {
            method: 'POST',
            body: JSON.stringify({ status, note }),
          });

          invalidateWorkspace();
          const card = document.querySelector(`[data-review-id="${reviewId}"]`);
          if (card) {
            card.style.transition = 'opacity 300ms, transform 300ms';
            card.style.opacity = '0';
            card.style.transform = 'translateY(-4px)';
            setTimeout(() => {
              card.innerHTML = `
                <div class="flex items-center gap-2 py-1">
                  <svg class="w-4 h-4" style="color: ${status === 'approved' ? 'var(--gg-success)' : 'var(--gg-accent)'};" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${status === 'approved' ? 'M5 13l4 4L19 7' : 'M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'}"/></svg>
                  <span class="text-sm font-medium" style="color: ${status === 'approved' ? 'var(--gg-success)' : 'var(--gg-accent)'};">${status === 'approved' ? 'Aprobado' : 'Cambios solicitados'}</span>
                </div>`;
              card.style.opacity = '1';
              card.style.transform = 'none';
            }, 300);
          }
        } catch {
          if (actionArea) {
            actionArea.innerHTML = '<p class="text-sm" style="color: var(--gg-danger);">Error al enviar. Inténtalo de nuevo.</p>';
          }
        }
      };

      list.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const btn = target.closest('button[data-action]');
        if (!btn) return;

        const action = btn.getAttribute('data-action');
        const reviewId = btn.getAttribute('data-review-id');
        if (!reviewId || !action) return;

        if (action === 'approve') handleDecision(reviewId, 'approved');
        if (action === 'reject') handleDecision(reviewId, 'changes_requested');
      });
    })();
  </script>
</ClientAreaLayout>