---
import ClientLayout from '../../layouts/ClientLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<ClientLayout title="Casos y referencias">
  <div class="mx-auto max-w-5xl space-y-6" role="region" aria-label="Contenido principal">
    <section class="crm-panel-strong p-6 md:p-8">
      <PageHeader
        kicker="Casos"
        title="Referencias en preparación"
        description="Estamos rehaciendo esta sección para que solo muestre trabajo real, vigente y bien contextualizado. Cuando publiquemos casos, aparecerán aquí."
      />
    </section>

    <section class="crm-panel p-8 text-center md:p-10">
      <div class="mx-auto max-w-2xl space-y-4">
        <p class="crm-kicker">Sin humo</p>
        <h2 class="text-2xl font-bold tracking-tight text-crm-text md:text-3xl">
          Preferimos no enseñar un caso antes de que esté listo para sostenerse solo.
        </h2>
        <p class="text-sm leading-relaxed text-crm-text-secondary md:text-base">
          Si necesitas contexto comercial o ejemplos cercanos a tu categoría, pídelos al equipo y te orientaremos con material pertinente.
        </p>
        <div class="flex flex-wrap justify-center gap-3 pt-2">
          <a href="/client/brief-assistant" class="crm-button crm-button-primary">Actualizar brief</a>
          <a href="mailto:hola@grandeandgordo.com" class="crm-button crm-button-secondary">Hablar con el equipo</a>
        </div>
      </div>
    </section>
  </div>
</ClientLayout>
