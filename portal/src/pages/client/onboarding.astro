---
import ClientLayout from '../../layouts/ClientLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<ClientLayout title="Activacion">
  <div class="max-w-5xl space-y-6" role="region" aria-label="Activacion de cuenta">
    <PageHeader
      kicker="activación"
      title="deja lista la primera sesión"
      description="confirma preparación, foco inicial y disponibilidad. con eso el equipo puede entrar en producción sin ruido ni ida y vuelta innecesaria."
    />

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">cuenta</p>
        <p id="activation-company" class="crm-metric-card__value text-[clamp(1.6rem,2.6vw,2.2rem)]">Cargando...</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">contacto</p>
        <p id="activation-manager" class="mt-4 text-sm font-semibold text-crm-text">hola@grandeandgordo.com</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">base visual</p>
        <p id="activation-dataset" class="mt-4 text-sm font-semibold text-crm-text">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">primera sesión</p>
        <p id="activation-session" class="mt-4 text-sm font-semibold text-crm-text">Sin fecha propuesta</p>
      </div>
    </section>

    <section
      id="activation-status"
      class="hidden rounded-xl border p-6"
      style="border-color: color-mix(in srgb, var(--crm-success) 50%, transparent); background-color: color-mix(in srgb, var(--crm-success) 10%, transparent);"
    >
      <p class="crm-kicker" style="color: var(--crm-success);">estado</p>
      <h2 id="activation-status-title" class="mt-3 text-2xl font-bold text-crm-text">Activacion confirmada</h2>
      <p id="activation-status-body" class="mt-3 max-w-3xl text-sm leading-relaxed text-crm-muted">
        El equipo ya tiene tu activacion registrada.
      </p>
    </section>

    <form id="activation-form" class="space-y-6">
      <section class="crm-form-section">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="crm-kicker">preparación mínima</p>
            <h2 class="mt-3 text-2xl font-bold tracking-tight text-crm-text">Confirma lo que ya está listo</h2>
            <p class="mt-3 text-sm leading-relaxed text-crm-muted">
              No hace falta marcarlo todo. Marca solo los bloques que hoy están realmente preparados.
            </p>
          </div>
          <p id="activation-progress" class="text-sm font-medium text-crm-muted">0 de 3 bloques listos</p>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <label class="activation-option">
            <input id="materials-ready" type="checkbox" class="sr-only" />
            <span class="text-sm font-semibold text-crm-text">Materiales</span>
            <p class="mt-2 text-sm text-crm-muted">Producto, muestras, packaging y referencias físicas listas para sesión.</p>
          </label>
          <label class="activation-option">
            <input id="brand-ready" type="checkbox" class="sr-only" />
            <span class="text-sm font-semibold text-crm-text">Identidad</span>
            <p class="mt-2 text-sm text-crm-muted">Logo, paleta, tono, tablero visual o ejemplos ya definidos.</p>
          </label>
          <label class="activation-option">
            <input id="access-ready" type="checkbox" class="sr-only" />
            <span class="text-sm font-semibold text-crm-text">Accesos</span>
            <p class="mt-2 text-sm text-crm-muted">Drive, tienda o cuentas colaborativas listas si van a hacer falta.</p>
          </label>
        </div>
      </section>

      <section class="activation-page">
        <div class="crm-form-section">
          <p class="crm-kicker">dirección inicial</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-crm-text">Qué hay que resolver primero</h2>
          <p class="mt-3 text-sm leading-relaxed text-crm-muted">
            Define la prioridad con la que quieres arrancar. Esto orienta la primera sesión y el primer trabajo.
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <label for="priority-focus" class="activation-label">foco inicial</label>
              <input
                id="priority-focus"
                type="text"
                maxlength="200"
                class="crm-input w-full"
                placeholder="Ej: Lanzamiento PDP Amazon, campaña paid, nuevo packshot..."
              />
            </div>
            <div>
              <label for="open-questions" class="activation-label">bloqueos o preguntas</label>
              <textarea
                id="open-questions"
                rows="5"
                maxlength="1200"
                class="crm-input w-full"
                placeholder="Ej: necesitamos decidir fondo, ratio, claims o materiales pendientes."
              ></textarea>
            </div>
          </div>
        </div>

        <div class="crm-form-section">
          <p class="crm-kicker">disponibilidad</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-crm-text">Propón la primera sesión</h2>

          <div class="mt-6 space-y-4">
            <div>
              <label for="session-date" class="activation-label">fecha preferida</label>
              <input id="session-date" type="date" class="crm-input w-full" />
            </div>
            <div>
              <label for="session-time" class="activation-label">ventana horaria</label>
              <select id="session-time" class="crm-input w-full">
                <option value="">Sin preferencia</option>
                <option value="morning">Mañana (09:00 - 13:00)</option>
                <option value="afternoon">Tarde (15:00 - 19:00)</option>
                <option value="flexible">Flexible</option>
              </select>
            </div>
            <div class="rounded-xl border border-crm-border bg-crm-panel p-4">
              <p class="text-sm font-medium text-crm-text">Qué pasa al confirmar</p>
              <p class="mt-2 text-sm text-crm-muted">
                Guardamos tu activacion en la cuenta, registramos el resumen para operaciones y dejamos lista la siguiente coordinación.
              </p>
            </div>
          </div>
        </div>
      </section>

      <div class="sticky bottom-4 z-10">
        <button
          type="submit"
          id="submit-btn"
          disabled
          class="crm-button crm-button-primary w-full disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="btn-text">Confirmar activacion</span>
          <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
        <p class="mt-3 text-center text-xs text-crm-muted">
          Marca al menos un bloque, define un foco o deja propuesta de sesión para activar el envío.
        </p>
      </div>
    </form>
  </div>

  <script>
    (async () => {
      const { API_BASE, formatDate, getSessionContext } = await import('../../lib/api-client');

      const companyEl = document.getElementById('activation-company');
      const managerEl = document.getElementById('activation-manager');
      const datasetEl = document.getElementById('activation-dataset');
      const sessionEl = document.getElementById('activation-session');
      const statusBox = document.getElementById('activation-status');
      const statusTitle = document.getElementById('activation-status-title');
      const statusBody = document.getElementById('activation-status-body');
      const progressEl = document.getElementById('activation-progress');
      const form = document.getElementById('activation-form');
      const submitBtn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const btnSpinner = document.getElementById('btn-spinner');
      const sessionDate = document.getElementById('session-date');
      const sessionTime = document.getElementById('session-time');
      const priorityFocus = document.getElementById('priority-focus');
      const openQuestions = document.getElementById('open-questions');
      const readinessInputs = [
        document.getElementById('materials-ready'),
        document.getElementById('brand-ready'),
        document.getElementById('access-ready'),
      ];

      const labelFor = (input) => input instanceof HTMLInputElement ? input.closest('label') : null;

      const syncReadinessCards = () => {
        readinessInputs.forEach((input) => {
          const label = labelFor(input);
          if (!label || !(input instanceof HTMLInputElement)) return;

          label.classList.toggle('border-crm-accent', input.checked);
          label.classList.toggle('bg-crm-accent-soft', input.checked);
        });
      };

      const updateFormState = () => {
        const readinessCount = readinessInputs.filter(
          (input) => input instanceof HTMLInputElement && input.checked,
        ).length;

        if (progressEl) {
          progressEl.textContent = `${readinessCount} de 3 bloques listos`;
        }

        const hasFocus =
          priorityFocus instanceof HTMLInputElement && priorityFocus.value.trim().length > 0;
        const hasQuestions =
          openQuestions instanceof HTMLTextAreaElement && openQuestions.value.trim().length > 0;
        const hasSession =
          sessionDate instanceof HTMLInputElement && sessionDate.value.trim().length > 0;

        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = readinessCount === 0 && !hasFocus && !hasQuestions && !hasSession;
        }

        syncReadinessCards();
      };

      const setLoading = (loading) => {
        if (!(submitBtn instanceof HTMLButtonElement) || !(btnText instanceof HTMLElement) || !(btnSpinner instanceof SVGElement)) {
          return;
        }

        submitBtn.disabled = loading;
        btnText.textContent = loading ? 'Guardando activacion...' : 'Confirmar activacion';
        btnSpinner.classList.toggle('hidden', !loading);
      };

      try {
        const session = await getSessionContext();
        const client = session?.client;

        if (!client) {
          window.location.href = '/login';
          return;
        }

        if (companyEl) companyEl.textContent = client.company ?? client.name;
        if (managerEl) managerEl.textContent = client.accountManager ?? 'hola@grandeandgordo.com';
        if (datasetEl) datasetEl.textContent = client.datasetStatus ?? 'pending_capture';

        if (sessionDate instanceof HTMLInputElement && client.firstSessionAt) {
          const currentSessionDate = new Date(client.firstSessionAt);
          if (!Number.isNaN(currentSessionDate.getTime())) {
            sessionDate.value = currentSessionDate.toISOString().slice(0, 10);
          }
        }

        if (sessionEl) {
          sessionEl.textContent = client.firstSessionAt
            ? formatDate(client.firstSessionAt)
            : 'Sin fecha propuesta';
        }

        if (client.onboardingCompletedAt && statusBox && statusTitle && statusBody) {
          statusBox.classList.remove('hidden');
          statusTitle.textContent = 'Activacion ya confirmada';
          statusBody.textContent = client.firstSessionAt
            ? `La activacion ya está registrada. Primera sesión propuesta: ${formatDate(client.firstSessionAt)}. Puedes reenviar una actualización si cambió algo.`
            : 'La activacion ya está registrada. Puedes reenviar una actualización si cambió algo operativo.';
        }
      } catch (error) {
        console.error('Activation session error:', error);
      }

      readinessInputs.forEach((input) => input?.addEventListener('change', updateFormState));
      priorityFocus?.addEventListener('input', updateFormState);
      openQuestions?.addEventListener('input', updateFormState);
      sessionDate?.addEventListener('input', updateFormState);
      sessionTime?.addEventListener('change', updateFormState);
      updateFormState();

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();

        const readiness = {
          materialsReady: readinessInputs[0] instanceof HTMLInputElement ? readinessInputs[0].checked : false,
          brandReady: readinessInputs[1] instanceof HTMLInputElement ? readinessInputs[1].checked : false,
          accessReady: readinessInputs[2] instanceof HTMLInputElement ? readinessInputs[2].checked : false,
        };

        const selectedDate = sessionDate instanceof HTMLInputElement ? sessionDate.value : '';
        const selectedTime = sessionTime instanceof HTMLSelectElement ? sessionTime.value : '';
        const sessionDateTime = selectedDate
          ? `${selectedDate}T${selectedTime === 'morning' ? '10:00' : selectedTime === 'afternoon' ? '16:00' : '12:00'}`
          : null;

        setLoading(true);

        try {
          const res = await fetch(`${API_BASE}/api/portal/webhooks/web/onboarding`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              checklistCompleted: true,
              sessionScheduled: Boolean(selectedDate),
              sessionDate: sessionDateTime,
              readiness,
              priorityFocus: priorityFocus instanceof HTMLInputElement ? priorityFocus.value.trim() : '',
              openQuestions: openQuestions instanceof HTMLTextAreaElement ? openQuestions.value.trim() : '',
            }),
          });

          if (!res.ok) {
            const error = await res.json().catch(() => ({}));
            throw new Error(error.error || 'No se pudo guardar la activacion');
          }

          if (statusBox && statusTitle && statusBody) {
            statusBox.classList.remove('hidden');
            statusTitle.textContent = 'Activacion confirmada';
            statusBody.textContent = selectedDate
              ? `Todo guardado. Hemos dejado propuesta la sesión del ${formatDate(selectedDate)} y el equipo ya tiene el resumen operativo.`
              : 'Todo guardado. El equipo ya tiene el resumen operativo y te contactará para cerrar la primera sesión.';
          }

          if (sessionEl) {
            sessionEl.textContent = selectedDate ? formatDate(selectedDate) : 'Pendiente de coordinación';
          }

          (window).__showToast?.('activacion guardada correctamente.', 'success');
        } catch (error) {
          console.error('Activation save error:', error);
          (window).__showToast?.('no se pudo guardar la activacion. Intenta de nuevo.', 'error');
        } finally {
          setLoading(false);
          updateFormState();
        }
      });
    })();
  </script>

  <style>
    .activation-option {
      border: 1px solid var(--crm-border);
      border-radius: var(--radius-lg);
      background: var(--crm-panel);
      padding: 1.25rem;
      cursor: pointer;
      transition:
        border-color var(--duration-fast) var(--ease-out),
        background-color var(--duration-fast) var(--ease-out),
        transform var(--duration-fast) var(--ease-out);
    }

    .activation-option:hover {
      border-color: var(--crm-accent);
      transform: translateY(-1px);
    }

    .activation-page {
      display: grid;
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 22.5rem);
      align-items: start;
    }

    .activation-label {
      display: block;
      margin-bottom: 0.55rem;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--crm-muted);
      text-transform: lowercase;
    }

    @media (max-width: 1023px) {
      .activation-page {
        grid-template-columns: 1fr;
      }
    }
  </style>
</ClientLayout>
