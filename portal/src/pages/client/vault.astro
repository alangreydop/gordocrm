---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Vault de activos">
  <div class="space-y-6" role="region" aria-label="Contenido principal">

    <!-- Header -->
    <div class="crm-panel">
      <p class="crm-kicker crm-kicker--accent">Vault</p>
      <h1 class="crm-page-header__title mt-3">
        Biblioteca <em class="baskerville-italic" style="font-weight: 400;">viva</em> de referencias
      </h1>
      <p class="crm-page-header__meta mt-3">
        Revisa el material ya aprobado, filtra por tono o estilo y reutiliza decisiones visuales que ya funcionan para tu cuenta.
      </p>
    </div>

    <!-- Search + filters -->
    <div class="crm-panel-soft">
      <div class="grid gap-3 xl:grid-cols-[minmax(0,2fr)_repeat(3,minmax(0,1fr))]">
        <input
          type="text"
          id="search-input"
          placeholder="Buscar por nombre, descripción o tags"
          class="crm-input"
        />
        <select id="style-filter" class="crm-input">
          <option value="">Todos los estilos</option>
        </select>
        <select id="tone-filter" class="crm-input">
          <option value="">Todos los tonos</option>
        </select>
        <select id="type-filter" class="crm-input">
          <option value="">Todos los tipos</option>
          <option value="image">Imagen</option>
          <option value="video">Vídeo</option>
        </select>
      </div>
      <p id="results-count" class="mt-4 text-sm text-crm-muted">Cargando activos curados...</p>
    </div>

    <!-- Asset grid -->
    <div id="vault-grid" class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3"></div>

  </div>

  <script>
    (async () => {
      const { api, escapeHtml } = await import('../../lib/api-client');

      const gridEl = document.getElementById('vault-grid');
      const searchInput = document.getElementById('search-input');
      const styleFilter = document.getElementById('style-filter');
      const toneFilter = document.getElementById('tone-filter');
      const typeFilter = document.getElementById('type-filter');
      const countEl = document.getElementById('results-count');

      let allAssets = [];

      const formatDate = (value) => {
        if (!value) return 'Sin fecha';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return 'Sin fecha';
        return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });
      };

      const appendOptions = (element, values) => {
        if (!(element instanceof HTMLSelectElement)) return;
        values.forEach((value) => {
          const option = document.createElement('option');
          option.value = value;
          option.textContent = value;
          element.appendChild(option);
        });
      };

      const renderAssets = (assets) => {
        if (!gridEl || !countEl) return;

        if (!assets.length) {
          gridEl.innerHTML = `
            <div class="crm-empty col-span-full">
              No hay activos en el vault con los filtros actuales.
            </div>
          `;
          countEl.textContent = '0 activos visibles';
          return;
        }

        countEl.textContent = `Mostrando ${assets.length} activo${assets.length !== 1 ? 's' : ''} aprobado${assets.length !== 1 ? 's' : ''}`;

        gridEl.innerHTML = assets.map((asset) => `
          <article class="crm-panel overflow-hidden" style="padding: 0;">
            <div class="relative overflow-hidden" style="aspect-ratio: 4/3; background: var(--gg-surface);">
              ${
                asset.type === 'video'
                  ? `<video src="${asset.deliveryUrl || ''}" class="h-full w-full object-cover" muted loop playsinline onmouseover="this.play()" onmouseout="this.pause()"></video>`
                  : `<img src="${asset.deliveryUrl || ''}" alt="${escapeHtml(asset.label || 'Asset')}" class="h-full w-full object-cover" loading="lazy" decoding="async" />`
              }
              <div class="absolute left-3 top-3">
                <span class="crm-badge ${asset.type === 'video' ? 'crm-badge-accent' : 'crm-badge-default'}">
                  ${asset.type === 'video' ? 'Vídeo' : 'Imagen'}
                </span>
              </div>
            </div>
            <div style="padding: 1.1rem 1.25rem;">
              <h2 class="text-sm font-semibold tracking-tight text-crm-text" style="margin-bottom: 0.3rem;">${escapeHtml(asset.label || 'Sin título')}</h2>
              ${asset.description
                ? `<p class="text-xs leading-relaxed text-crm-muted">${escapeHtml(asset.description)}</p>`
                : '<p class="text-xs text-crm-muted">Asset aprobado y listo para reutilizar como referencia.</p>'
              }
              <div class="flex flex-wrap gap-2 mt-3">
                ${asset.visualStyle ? `<span class="crm-badge crm-badge-info">${escapeHtml(asset.visualStyle)}</span>` : ''}
                ${asset.emotionalTone ? `<span class="crm-badge crm-badge-accent">${escapeHtml(asset.emotionalTone)}</span>` : ''}
              </div>
              <div class="flex items-center justify-between gap-3 mt-4 pt-3" style="border-top: 1px solid var(--gg-border);">
                <span class="text-xs text-crm-muted">${formatDate(asset.createdAt)}</span>
                <a href="${asset.deliveryUrl || '#'}" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-crm-accent transition hover:opacity-75">
                  Abrir asset
                </a>
              </div>
            </div>
          </article>
        `).join('');
      };

      const filterAssets = () => {
        const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : '';
        const style = styleFilter instanceof HTMLSelectElement ? styleFilter.value : '';
        const tone = toneFilter instanceof HTMLSelectElement ? toneFilter.value : '';
        const type = typeFilter instanceof HTMLSelectElement ? typeFilter.value : '';

        const filtered = allAssets.filter((asset) => {
          if (query) {
            const searchTarget = `${asset.label ?? ''} ${asset.description ?? ''} ${Array.isArray(asset.tags) ? asset.tags.join(' ') : asset.tags ?? ''}`.toLowerCase();
            if (!searchTarget.includes(query)) return false;
          }
          if (style && asset.visualStyle !== style) return false;
          if (tone && asset.emotionalTone !== tone) return false;
          if (type && asset.type !== type) return false;
          return true;
        });

        renderAssets(filtered);
      };

      try {
        const [stylesRes, tonesRes, assetsRes] = await Promise.all([
          api('/api/portal/vault/styles'),
          api('/api/portal/vault/tones'),
          api('/api/portal/vault'),
        ]);

        appendOptions(styleFilter, stylesRes.styles || []);
        appendOptions(toneFilter, tonesRes.tones || []);
        allAssets = assetsRes.assets || [];
        renderAssets(allAssets);
      } catch (error) {
        console.error('Error cargando vault:', error);
        if (gridEl) {
          gridEl.innerHTML = `
            <div class="crm-empty col-span-full">
              No hemos podido cargar tu vault ahora mismo. Intenta de nuevo en unos minutos.
            </div>
          `;
        }
        if (countEl) countEl.textContent = 'Error de carga';
      }

      searchInput?.addEventListener('input', filterAssets);
      styleFilter?.addEventListener('change', filterAssets);
      toneFilter?.addEventListener('change', filterAssets);
      typeFilter?.addEventListener('change', filterAssets);
    })();
  </script>
</ClientLayout>
