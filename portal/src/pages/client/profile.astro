---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Perfil">
  <div class="max-w-5xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Mi perfil</h1>
      <p class="text-gray-500 mt-1">Gestiona tu cuenta de acceso y revisa el contexto operativo de tu relacion con Grande&Gordo.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.15fr_.85fr]">
      <section class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Cuenta</h2>
        <dl class="grid sm:grid-cols-2 gap-4 text-sm">
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Nombre</dt>
            <dd id="profile-name" class="mt-1 text-lg font-medium text-gray-900">Cargando...</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Email</dt>
            <dd id="profile-email" class="mt-1 text-lg font-medium text-gray-900">—</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Empresa</dt>
            <dd id="profile-company" class="mt-1 text-lg font-medium text-gray-900">—</dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4">
            <dt class="text-gray-500">Contacto operativo</dt>
            <dd id="profile-account-manager" class="mt-1 text-lg font-medium text-gray-900">hola@grandeandgordo.com</dd>
          </div>
        </dl>
      </section>

      <section class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Cambiar contrasena</h2>
        <div id="password-success" class="hidden bg-green-50 text-green-700 rounded p-3 mb-4 text-sm"></div>
        <div id="password-error" class="hidden bg-red-50 text-red-700 rounded p-3 mb-4 text-sm"></div>

        <form id="password-form" class="space-y-4">
          <div>
            <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-1">Contrasena actual</label>
            <input type="password" id="currentPassword" name="currentPassword" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
          </div>
          <div>
            <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">Nueva contrasena</label>
            <input type="password" id="newPassword" name="newPassword" required minlength="8" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900" />
          </div>
          <button type="submit" class="bg-blue-900 text-white px-4 py-2 rounded-md hover:bg-blue-800">
            Actualizar contrasena
          </button>
        </form>
      </section>
    </div>

    <section class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Estado operativo</h2>
      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4 text-sm">
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Plan</p>
          <p id="profile-plan" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Dataset</p>
          <p id="profile-dataset" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Capacidad mensual</p>
          <p id="profile-capacity" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Segmento / margen</p>
          <p id="profile-segment" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Proxima review</p>
          <p id="profile-next-review" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-gray-500">Ultimo contacto</p>
          <p id="profile-last-contact" class="text-lg font-medium text-gray-900 mt-1">—</p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4 md:col-span-2">
          <p class="text-gray-500">Notas compartidas</p>
          <p id="profile-notes" class="text-base text-gray-900 mt-1">—</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const {
        API_BASE,
        formatDate,
        formatNumber,
        getSessionContext,
      } = await import('../../lib/api-client');

      const session = await getSessionContext();
      const user = session?.user;
      const client = session?.client;

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      if (user) {
        setText('profile-name', user.name);
        setText('profile-email', user.email);
        setText('profile-company', user.company ?? client?.company ?? 'Grande&Gordo');
      }

      if (client) {
        setText('profile-account-manager', client.accountManager ?? 'hola@grandeandgordo.com');
        setText('profile-plan', client.plan ?? 'Sin plan definido');
        setText('profile-dataset', client.datasetStatus ?? 'pending_capture');
        setText('profile-capacity', `${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);
        setText('profile-segment', `${client.segment ?? 'Sin segmento'} / ${client.marginProfile ?? 'Sin margen'}`);
        setText('profile-next-review', formatDate(client.nextReviewAt));
        setText('profile-last-contact', formatDate(client.lastContactedAt));
        setText('profile-notes', client.notes ?? 'Sin notas compartidas por ahora.');
      }

      const form = document.getElementById('password-form');
      const errorDiv = document.getElementById('password-error');
      const successDiv = document.getElementById('password-success');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorDiv?.classList.add('hidden');
        successDiv?.classList.add('hidden');

        const currentPassword = document.getElementById('currentPassword');
        const newPassword = document.getElementById('newPassword');

        try {
          const res = await fetch(`${API_BASE}/api/portal/auth/change-password`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              currentPassword:
                currentPassword instanceof HTMLInputElement ? currentPassword.value : '',
              newPassword:
                newPassword instanceof HTMLInputElement ? newPassword.value : '',
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'No se pudo cambiar la contrasena');
          }

          if (form instanceof HTMLFormElement) {
            form.reset();
          }

          if (successDiv instanceof HTMLDivElement) {
            successDiv.textContent = 'Contrasena actualizada correctamente.';
            successDiv.classList.remove('hidden');
          }
        } catch (error) {
          if (errorDiv instanceof HTMLDivElement) {
            errorDiv.textContent =
              error instanceof Error ? error.message : 'No se pudo cambiar la contrasena';
            errorDiv.classList.remove('hidden');
          }
        }
      });
    })();
  </script>
</ClientLayout>
