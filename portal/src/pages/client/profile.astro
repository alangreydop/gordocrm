---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { getSessionUser } from '../../lib/session';

const user = await getSessionUser(Astro.cookies);
if (!user) return Astro.redirect('/login');
---

<ClientLayout title="Mi perfil">
  <h1 class="text-2xl font-bold mb-6">Mi perfil</h1>

  <div class="bg-white rounded-lg shadow p-6 max-w-lg">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-500">Nombre</label>
        <p class="mt-1 text-lg">{user.name}</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-500">Email</label>
        <p class="mt-1 text-lg">{user.email}</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-500">Empresa</label>
        <p class="mt-1 text-lg">{user.company ?? '—'}</p>
      </div>
    </div>
  </div>
</ClientLayout>
