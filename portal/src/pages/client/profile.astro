---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { siteLinks } from '../../lib/site-links';
---

<ClientLayout title="Perfil">
  <div class="space-y-6 max-w-5xl" role="region" aria-label="Contenido principal">

    <!-- Header -->
    <div class="crm-panel" style="background: linear-gradient(135deg, rgba(196,22,90,0.04), rgba(247,240,243,0));">
      <p class="crm-kicker crm-kicker--accent">Perfil cliente</p>
      <h1 class="crm-page-header__title mt-3">
        Mi <em class="baskerville-italic" style="font-weight: 400;">perfil</em>
      </h1>
      <p class="crm-page-header__meta mt-3">
        Gestiona tu cuenta de acceso y revisa el contexto operativo de tu relación con Grande&Gordo desde una sola vista.
      </p>
    </div>

    <!-- Cuenta + Cambiar contraseña -->
    <div class="grid gap-6 lg:grid-cols-[1.15fr_.85fr]">

      <section class="crm-panel">
        <h2 class="text-lg font-semibold tracking-tight" style="color: var(--gg-text); margin-bottom: 1.1rem;">Cuenta</h2>
        <dl class="grid sm:grid-cols-2 gap-3 text-sm">
          <div class="crm-panel-soft p-4">
            <dt class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Nombre</dt>
            <dd id="profile-name" class="mt-2 text-base font-semibold" style="color: var(--gg-text);">Cargando...</dd>
          </div>
          <div class="crm-panel-soft p-4">
            <dt class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Email</dt>
            <dd id="profile-email" class="mt-2 text-base font-semibold" style="color: var(--gg-text);">—</dd>
          </div>
          <div class="crm-panel-soft p-4">
            <dt class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Empresa</dt>
            <dd id="profile-company" class="mt-2 text-base font-semibold" style="color: var(--gg-text);">—</dd>
          </div>
          <div class="crm-panel-soft p-4">
            <dt class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Contacto operativo</dt>
            <dd id="profile-account-manager" class="mt-2 text-base font-semibold" style="color: var(--gg-text);">hola@grandeandgordo.com</dd>
          </div>
        </dl>
      </section>

      <section class="crm-panel">
        <h2 class="text-lg font-semibold tracking-tight" style="color: var(--gg-text); margin-bottom: 1.1rem;">Cambiar contraseña</h2>
        <div id="password-success" class="hidden crm-alert crm-alert-success mb-4"></div>
        <div id="password-error" class="hidden crm-alert crm-alert-danger mb-4"></div>
        <form id="password-form" class="space-y-4">
          <div>
            <label for="currentPassword" class="block text-sm font-bold mb-2" style="color: var(--gg-text-muted);">Contraseña actual</label>
            <input type="password" id="currentPassword" name="currentPassword" required class="crm-input w-full" />
          </div>
          <div>
            <label for="newPassword" class="block text-sm font-bold mb-2" style="color: var(--gg-text-muted);">Nueva contraseña</label>
            <input type="password" id="newPassword" name="newPassword" required minlength="8" class="crm-input w-full" />
          </div>
          <button type="submit" class="crm-button crm-button-primary w-full">
            Actualizar contraseña
          </button>
        </form>
      </section>

    </div>

    <!-- Estado operativo -->
    <section class="crm-panel">
      <h2 class="text-lg font-semibold tracking-tight" style="color: var(--gg-text); margin-bottom: 1.1rem;">Estado operativo</h2>
      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-3 text-sm">
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Plan</p>
          <p id="profile-plan" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Base visual</p>
          <p id="profile-dataset" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Capacidad mensual</p>
          <p id="profile-capacity" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Segmento / margen</p>
          <p id="profile-segment" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Próxima revisión</p>
          <p id="profile-next-review" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Último contacto</p>
          <p id="profile-last-contact" class="text-base font-semibold mt-2" style="color: var(--gg-text);">—</p>
        </div>
        <div class="crm-panel-soft p-4 md:col-span-2">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Notas compartidas</p>
          <p id="profile-notes" class="text-sm mt-2 text-crm-muted">—</p>
        </div>
      </div>
    </section>

    <!-- Continuidad / último brief -->
    <section class="crm-panel">
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="crm-kicker">Continuidad</p>
          <h2 class="mt-3 text-xl font-bold tracking-tight" style="letter-spacing: -0.03em; color: var(--gg-text);">
            Último brief recibido
          </h2>
          <p id="profile-brief-meta" class="text-sm text-crm-muted mt-3">
            Aún no tenemos un brief reciente asociado a tu cuenta.
          </p>
          <p id="profile-brief-description" class="text-sm text-crm-muted mt-3 leading-relaxed">
            Si quieres actualizar contexto, referencias o necesidades, puedes hacerlo desde el portal y quedará unido a tu operativa real.
          </p>
        </div>
        <a href={siteLinks.brief} class="crm-button crm-button-primary" style="white-space: nowrap;">
          Actualizar brief
        </a>
      </div>
    </section>

    <!-- Links operativos -->
    <div class="grid gap-3 md:grid-cols-3">
      <a href={siteLinks.brief} class="crm-link-tile">
        <p class="text-sm font-semibold" style="color: var(--gg-text);">Brief de proyecto</p>
        <p class="mt-2 text-sm text-crm-muted">Comparte referencias, producto, tono y necesidades nuevas.</p>
      </a>
      <a href={siteLinks.onboarding} class="crm-link-tile">
        <p class="text-sm font-semibold" style="color: var(--gg-text);">Activación y checklist</p>
        <p class="mt-2 text-sm text-crm-muted">Revisa preparación de sesión, materiales y siguientes pasos.</p>
      </a>
      <a href="/client/invoices" class="crm-link-tile">
        <p class="text-sm font-semibold" style="color: var(--gg-text);">Facturación</p>
        <p class="mt-2 text-sm text-crm-muted">Consulta facturas, estado de pago y justificantes desde una sola vista.</p>
      </a>
    </div>

  </div>

  <script>
    (async () => {
      const {
        api,
        API_BASE,
        formatDate,
        formatNumber,
        getSessionContext,
      } = await import('../../lib/api-client');

      const [session, briefData] = await Promise.all([
        getSessionContext(),
        api('/api/portal/briefs/latest').catch(() => ({ brief: null })),
      ]);
      const user = session?.user;
      const client = session?.client;
      const latestBrief = briefData?.brief ?? null;

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      if (user) {
        setText('profile-name', user.name);
        setText('profile-email', user.email);
        setText('profile-company', user.company ?? client?.company ?? 'Grande&Gordo');
      }

      if (client) {
        setText('profile-account-manager', client.accountManager ?? 'hola@grandeandgordo.com');
        setText('profile-plan', client.plan ?? 'Sin plan definido');
        setText('profile-dataset', client.datasetStatus ?? 'pending_capture');
        setText('profile-capacity', `${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);
        setText('profile-segment', `${client.segment ?? 'Sin segmento'} / ${client.marginProfile ?? 'Sin margen'}`);
        setText('profile-next-review', formatDate(client.nextReviewAt));
        setText('profile-last-contact', formatDate(client.lastContactedAt));
        setText('profile-notes', client.notes ?? 'Sin notas compartidas por ahora.');
      }

      const profileBriefMeta = document.getElementById('profile-brief-meta');
      const profileBriefDescription = document.getElementById('profile-brief-description');
      if (latestBrief) {
        if (profileBriefMeta) {
          profileBriefMeta.textContent =
            `${latestBrief.tipo ?? 'brief'} · recibido ${formatDate(latestBrief.createdAt)} · estado ${latestBrief.status ?? 'new'}`;
        }
        if (profileBriefDescription) {
          const excerpt = String(latestBrief.description ?? '').trim();
          profileBriefDescription.textContent =
            excerpt.length > 280 ? `${excerpt.slice(0, 277)}...` : excerpt || 'Brief recibido correctamente.';
        }
      }

      const form = document.getElementById('password-form');
      const errorDiv = document.getElementById('password-error');
      const successDiv = document.getElementById('password-success');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorDiv?.classList.add('hidden');
        successDiv?.classList.add('hidden');

        const currentPassword = document.getElementById('currentPassword');
        const newPassword = document.getElementById('newPassword');

        try {
          const res = await fetch(`${API_BASE}/api/portal/auth/change-password`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              currentPassword: currentPassword instanceof HTMLInputElement ? currentPassword.value : '',
              newPassword: newPassword instanceof HTMLInputElement ? newPassword.value : '',
            }),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error ?? 'no se pudo cambiar la contraseña');
          }

          if (form instanceof HTMLFormElement) form.reset();

          if (successDiv instanceof HTMLDivElement) {
            successDiv.textContent = 'Contraseña actualizada correctamente.';
            successDiv.classList.remove('hidden');
          }
        } catch (error) {
          if (errorDiv instanceof HTMLDivElement) {
            errorDiv.textContent = error instanceof Error ? error.message : 'no se pudo cambiar la contraseña';
            errorDiv.classList.remove('hidden');
          }
        }
      });
    })();
  </script>
</ClientLayout>
