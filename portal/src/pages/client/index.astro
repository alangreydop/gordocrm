---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Resumen">
  <div class="space-y-6">
    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 id="client-heading" class="text-2xl font-bold">Cargando tu portal...</h1>
        <p id="client-subheading" class="text-gray-500 mt-1">Estamos cargando tu estado de cuenta y tus trabajos.</p>
      </div>
      <div id="client-contact" class="text-sm text-gray-500">
        Soporte operativo: <span class="font-medium text-gray-900">hola@grandeandgordo.com</span>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Trabajos activos</p>
        <p id="metric-active-jobs" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Entregados</p>
        <p id="metric-delivered-jobs" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Consumo</p>
        <p id="metric-units" class="text-3xl font-bold mt-2">—</p>
        <p id="metric-capacity" class="text-sm text-gray-500 mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Estado operativo</p>
        <p id="metric-plan" class="text-lg font-semibold mt-2">—</p>
        <p id="metric-dataset" class="text-sm text-gray-500 mt-2">—</p>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold">Tus trabajos</h2>
        <p class="text-sm text-gray-500">Sigue el estado de entrega y entra al detalle para ver assets aprobados.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Brief</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Estado</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Due</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Units</th>
              <th class="px-6 py-3 text-left font-medium text-gray-500 uppercase">Actualizado</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="jobs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        datasetStatusClass,
        escapeHtml,
        formatDate,
        formatNumber,
        getSessionContext,
        jobStatusClass,
        subscriptionClass,
      } = await import('../../lib/api-client');

      const tbody = document.getElementById('jobs-body');

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      try {
        const [session, jobsData] = await Promise.all([
          getSessionContext(),
          api('/api/portal/jobs'),
        ]);

        const client = session?.client;
        const jobs = Array.isArray(jobsData.jobs) ? jobsData.jobs : [];

        if (client) {
          const heading = document.getElementById('client-heading');
          const subheading = document.getElementById('client-subheading');
          const contact = document.getElementById('client-contact');

          if (heading) heading.textContent = client.company ?? client.name;
          if (subheading) {
            subheading.textContent =
              `${client.plan ?? 'Sin plan definido'} · ${client.subscriptionStatus ?? 'inactive'} · review ${formatDate(client.nextReviewAt)}`;
          }

          if (contact) {
            const accountManager = client.accountManager ?? 'hola@grandeandgordo.com';
            contact.innerHTML = `Tu contacto operativo: <span class="font-medium text-gray-900">${escapeHtml(accountManager)}</span>`;
          }

          const datasetMetric = document.getElementById('metric-dataset');
          if (datasetMetric) {
            datasetMetric.textContent = `Dataset ${client.datasetStatus ?? 'pending_capture'}`;
            datasetMetric.className = `text-sm mt-2 inline-flex px-2 py-1 rounded font-medium ${datasetStatusClass(client.datasetStatus ?? '')}`;
          }

          const planMetric = document.getElementById('metric-plan');
          if (planMetric) {
            planMetric.textContent = client.plan ?? 'Sin plan definido';
            planMetric.className = `text-lg font-semibold mt-2 inline-flex px-2 py-1 rounded ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}`;
          }

          setText('metric-capacity', `Capacidad mensual: ${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);
        }

        setText(
          'metric-active-jobs',
          String(jobs.filter((job) => ['pending', 'processing'].includes(job.status)).length),
        );
        setText(
          'metric-delivered-jobs',
          String(jobs.filter((job) => job.status === 'delivered').length),
        );

        const planned = jobs.reduce((total, job) => total + Number(job.unitsPlanned ?? 0), 0);
        const consumed = jobs.reduce((total, job) => total + Number(job.unitsConsumed ?? 0), 0);
        setText('metric-units', `${formatNumber(consumed)} / ${formatNumber(planned)}`);

        if (!tbody) return;

        if (jobs.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500">Todavia no tienes trabajos activos en el portal.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = jobs.map((job) => `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-gray-500 mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.updatedAt))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="text-blue-600 hover:text-blue-800 font-medium">Ver detalle</a>
            </td>
          </tr>
        `).join('');
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-red-600">No se pudieron cargar tus trabajos.</td>
            </tr>
          `;
        }
      }
    })();
  </script>
</ClientLayout>
