---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Mis trabajos">
  <h1 class="text-2xl font-bold mb-6">Mis trabajos</h1>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Brief</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plataforma</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody id="jobs-body" class="divide-y divide-gray-200">
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">Cargando trabajos...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <script>
    (async () => {
    const { api, escapeHtml, formatDate, jobStatusClass } = await import('../../lib/api-client');

    const tbody = document.getElementById('jobs-body');

    try {
      const data = await api('/api/portal/jobs');
      const jobs = Array.isArray(data.jobs) ? data.jobs : [];

      if (!tbody) return;

      if (jobs.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">No tienes trabajos todavia.</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = jobs.map((job) => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm">${escapeHtml(job.briefText ?? '—')}</td>
          <td class="px-6 py-4 text-sm text-gray-600">${escapeHtml(job.platform ?? '—')}</td>
          <td class="px-6 py-4 text-sm text-gray-600">${escapeHtml(job.type ?? '—')}</td>
          <td class="px-6 py-4">
            <span class="inline-block px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
              ${escapeHtml(job.status ?? 'pending')}
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500">${escapeHtml(formatDate(job.createdAt))}</td>
          <td class="px-6 py-4 text-right">
            <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="text-blue-600 hover:text-blue-800 text-sm">Ver</a>
          </td>
        </tr>
      `).join('');
    } catch {
      if (tbody) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-red-600">No se pudieron cargar tus trabajos.</td>
          </tr>
        `;
      }
    }
    })();
  </script>
</ClientLayout>
