---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { apiWithCookie } from '../../lib/api-client';

const cookie = Astro.request.headers.get('cookie') ?? '';
const fetchApi = apiWithCookie<any>(cookie);

let jobs: any[] = [];
try {
  const data = await fetchApi('/api/portal/jobs');
  jobs = data.jobs;
} catch {}

const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800',
  processing: 'bg-blue-100 text-blue-800',
  completed: 'bg-green-100 text-green-800',
  failed: 'bg-red-100 text-red-800',
  delivered: 'bg-purple-100 text-purple-800',
};
---

<ClientLayout title="Mis trabajos">
  <h1 class="text-2xl font-bold mb-6">Mis trabajos</h1>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Brief</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plataforma</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {jobs.length === 0 ? (
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
              No tienes trabajos todavia.
            </td>
          </tr>
        ) : (
          jobs.map((j: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm">{j.briefText ?? '—'}</td>
              <td class="px-6 py-4 text-sm text-gray-600">{j.platform ?? '—'}</td>
              <td class="px-6 py-4 text-sm text-gray-600">{j.type ?? '—'}</td>
              <td class="px-6 py-4">
                <span class={`inline-block px-2 py-1 rounded text-xs font-medium ${statusColors[j.status] ?? 'bg-gray-100 text-gray-600'}`}>
                  {j.status}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">{new Date(j.createdAt).toLocaleDateString('es-ES')}</td>
              <td class="px-6 py-4 text-right">
                <a href={`/client/jobs/${j.id}`} class="text-blue-600 hover:text-blue-800 text-sm">Ver</a>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</ClientLayout>
