---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { siteLinks } from '../../lib/site-links';
---

<ClientLayout title="Resumen">
  <div class="space-y-6">
    <section class="rounded-3xl border border-zinc-800 bg-zinc-950 overflow-hidden p-6 md:p-8">
      <!-- Review Due Alert -->
      <div id="review-alert" class="hidden mb-6 rounded-xl border border-amber-700/50 bg-amber-900/20 p-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <h3 class="text-sm font-semibold text-amber-400">Review pendiente</h3>
            <p id="review-alert-text" class="text-xs text-amber-300/80 mt-1">Tu revisión trimestral está próxima. Contacta con tu account manager.</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Resumen cliente</p>
          <h1 id="client-heading" class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">
            Cargando tu portal...
          </h1>
          <p id="client-subheading" class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-400 md:text-base">
            Estamos cargando tu estado de cuenta y tus trabajos.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-zinc-800 bg-black p-5">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Soporte operativo</p>
            <div id="client-contact" class="mt-3 text-sm leading-relaxed text-zinc-300">
              <span class="font-medium text-white">hola@grandeandgordo.com</span>
            </div>
          </div>
          <div class="rounded-2xl border border-zinc-800 bg-black p-5">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Capa conectada</p>
            <p class="mt-3 text-sm leading-relaxed text-zinc-400">
              Web y CRM trabajan juntos: brief, onboarding, seguimiento y entregables.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Trabajos activos</p>
        <p id="metric-active-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Entregados</p>
        <p id="metric-delivered-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Consumo</p>
        <p id="metric-units" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-capacity" class="mt-3 text-xs text-zinc-500">—</p>
      </div>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Estado operativo</p>
        <p id="metric-plan" class="mt-4 inline-flex rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs font-medium text-white">—</p>
        <p id="metric-dataset" class="mt-3 inline-flex rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs font-medium text-white">—</p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.1fr_.9fr]">
      <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Siguiente paso</p>
            <h2 id="next-step-title" class="mt-3 text-2xl font-black tracking-tight text-white">
              Estamos preparando tu siguiente mejor movimiento.
            </h2>
            <p id="next-step-description" class="mt-4 max-w-2xl text-sm leading-relaxed text-zinc-400">
              Vamos a usar tu estado de cuenta y el momento del proyecto para recomendarte la accion mas util ahora mismo.
            </p>
          </div>
          <span id="next-step-badge" class="inline-flex rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs font-medium text-zinc-400">
            Journey conectado
          </span>
        </div>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            id="next-step-link"
            href={siteLinks.brief}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-bold text-black transition hover:bg-zinc-200"
          >
            Abrir siguiente paso
          </a>
          <a
            href={siteLinks.portalHub}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-full border border-zinc-700 px-6 py-3 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:text-white"
          >
            Ver centro de cliente
          </a>
        </div>
      </section>

      <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Web + CRM</p>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-white">Todo el journey, conectado</h2>
        <div class="mt-5 rounded-2xl border border-zinc-800 bg-black p-4">
          <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Ultimo brief recibido</p>
          <p id="latest-brief-meta" class="mt-3 text-sm font-medium text-white">
            Aun no tenemos un brief reciente en tu cuenta.
          </p>
          <p id="latest-brief-description" class="mt-3 text-sm leading-relaxed text-zinc-400">
            Si cambian objetivos, referencias o necesidades, actualiza el brief desde la web y quedará conectado con tu operativa del CRM.
          </p>
        </div>
        <div class="mt-5 grid gap-3">
          <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="block rounded-2xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
            <p class="text-sm font-semibold text-white">Brief de proyecto</p>
            <p class="mt-2 text-sm text-zinc-400">Comparte referencias, producto, tono y necesidades nuevas.</p>
          </a>
          <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="block rounded-2xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
            <p class="text-sm font-semibold text-white">Onboarding y checklist</p>
            <p class="mt-2 text-sm text-zinc-400">Revisa preparacion de sesion, materiales y preguntas frecuentes.</p>
          </a>
          <a href={siteLinks.home} target="_blank" rel="noreferrer" class="block rounded-2xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
            <p class="text-sm font-semibold text-white">Web publica</p>
            <p class="mt-2 text-sm text-zinc-400">Servicios, pricing y referencias de Grande&amp;Gordo cuando necesites contexto mas amplio.</p>
          </a>
        </div>
      </section>
    </div>

    <!-- Activity Feed -->
    <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 overflow-hidden">
        <div class="border-b border-zinc-800 px-6 py-5">
          <h2 class="text-lg font-semibold text-white">Tus trabajos</h2>
          <p class="mt-2 text-sm text-zinc-400">Sigue el estado de entrega y entra al detalle para ver assets aprobados.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="bg-black">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Brief</th>
                <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Due</th>
                <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Units</th>
                <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Actualizado</th>
                <th class="px-6 py-3"></th>
              </tr>
            </thead>
            <tbody id="jobs-body" class="divide-y divide-zinc-800">
              <tr>
                <td colspan="6" class="px-6 py-8 text-center text-zinc-500">Cargando trabajos...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Activity Feed Sidebar -->
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500 mb-4">Actividad reciente</p>
        <div id="activity-feed" class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-2 h-2 mt-2 rounded-full bg-zinc-700"></div>
            <div>
              <p class="text-sm text-zinc-400">Cargando actividad...</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ briefUrl: siteLinks.brief, onboardingUrl: siteLinks.onboarding, portalHubUrl: siteLinks.portalHub }}>
    (async () => {
      const {
        api,
        datasetStatusClass,
        escapeHtml,
        formatDate,
        formatNumber,
        getSessionContext,
        jobStatusClass,
        subscriptionClass,
      } = await import('../../lib/api-client');

      const tbody = document.getElementById('jobs-body');
      const nextStepTitle = document.getElementById('next-step-title');
      const nextStepDescription = document.getElementById('next-step-description');
      const nextStepBadge = document.getElementById('next-step-badge');
      const nextStepLink = document.getElementById('next-step-link');
      const latestBriefMeta = document.getElementById('latest-brief-meta');
      const latestBriefDescription = document.getElementById('latest-brief-description');

      const nextStepForClient = (client, jobs) => {
        const activeJobs = jobs.filter((job) => ['pending', 'processing'].includes(job.status));
        const datasetStatus = client?.datasetStatus ?? 'pending_capture';

        if (datasetStatus === 'pending_capture') {
          return {
            badge: 'Preparacion',
            title: 'Completa el brief para acelerar la sesion.',
            description:
              'Todavia estamos en fase de captura inicial. Cuanto mejor contexto nos dejes en la web, mejor saldra la preparacion del proyecto y la primera sesion.',
            href: briefUrl,
            label: 'Completar brief',
          };
        }

        if (datasetStatus === 'captured') {
          return {
            badge: 'Activacion',
            title: 'Revisa el onboarding mientras activamos tu sistema visual.',
            description:
              'Tu captura ya esta hecha. Este es el mejor momento para revisar checklist, expectativas y siguientes pasos del proceso.',
            href: onboardingUrl,
            label: 'Abrir onboarding',
          };
        }

        if (activeJobs.length === 0) {
          return {
            badge: 'Operacion',
            title: 'No tienes trabajos activos: deja el siguiente contexto preparado.',
            description:
              'Si quieres arrancar un nuevo trabajo o abrir una nueva linea de contenido, el brief es la mejor puerta de entrada para alinear necesidades.',
            href: briefUrl,
            label: 'Actualizar brief',
          };
        }

        return {
          badge: 'Seguimiento',
          title: 'Tu operacion ya esta en marcha.',
          description:
            'Usa el CRM para seguir entregables y mantennos alineados desde la web cuando necesites sumar contexto, referencias o nuevos objetivos.',
          href: portalHubUrl,
          label: 'Ver centro de cliente',
        };
      };

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      try {
        const [session, jobsData, briefData] = await Promise.all([
          getSessionContext(),
          api('/api/portal/jobs'),
          api('/api/portal/briefs/latest').catch(() => ({ brief: null })),
        ]);

        const client = session?.client;
        const jobs = Array.isArray(jobsData.jobs) ? jobsData.jobs : [];
        const latestBrief = briefData?.brief ?? null;

        if (client) {
          const heading = document.getElementById('client-heading');
          const subheading = document.getElementById('client-subheading');
          const contact = document.getElementById('client-contact');

          if (heading) heading.textContent = client.company ?? client.name;
          if (subheading) {
            subheading.textContent =
              `${client.plan ?? 'Sin plan definido'} · ${client.subscriptionStatus ?? 'inactive'} · review ${formatDate(client.nextReviewAt)}`;
          }

          if (contact) {
            const accountManager = client.accountManager ?? 'hola@grandeandgordo.com';
            contact.innerHTML = `Tu contacto operativo: <span class="font-medium text-white">${escapeHtml(accountManager)}</span>`;
          }

          const datasetMetric = document.getElementById('metric-dataset');
          if (datasetMetric) {
            datasetMetric.textContent = `Dataset ${client.datasetStatus ?? 'pending_capture'}`;
            datasetMetric.className = `text-sm mt-2 inline-flex px-2 py-1 rounded font-medium ${datasetStatusClass(client.datasetStatus ?? '')}`;
          }

          const planMetric = document.getElementById('metric-plan');
          if (planMetric) {
            planMetric.textContent = client.plan ?? 'Sin plan definido';
            planMetric.className = `text-lg font-semibold mt-2 inline-flex px-2 py-1 rounded ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}`;
          }

          setText('metric-capacity', `Capacidad mensual: ${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);

          // Review due alert - mostrar si review está en los próximos 30 días
          const reviewAlert = document.getElementById('review-alert');
          const reviewAlertText = document.getElementById('review-alert-text');
          if (reviewAlert && reviewAlertText && client.nextReviewAt) {
            const reviewDate = new Date(client.nextReviewAt);
            const now = new Date();
            const daysUntilReview = Math.ceil((reviewDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));

            if (daysUntilReview <= 30 && daysUntilReview >= -7) {
              reviewAlert.classList.remove('hidden');
              if (daysUntilReview < 0) {
                reviewAlertText.textContent = `Tu revisión trimestral está vencida desde hace ${Math.abs(daysUntilReview)} días. Contacta con tu account manager.`;
              } else if (daysUntilReview === 0) {
                reviewAlertText.textContent = `Tu revisión trimestral es hoy. Contacta con tu account manager.`;
              } else if (daysUntilReview <= 7) {
                reviewAlertText.textContent = `Tu revisión trimestral es en ${daysUntilReview} días. Contacta con tu account manager.`;
              } else {
                reviewAlertText.textContent = `Tu revisión trimestral es en ${daysUntilReview} días. Contacta con tu account manager.`;
              }
            }
          }
        }

        const nextStep = nextStepForClient(client, jobs);
        if (nextStepTitle) nextStepTitle.textContent = nextStep.title;
        if (nextStepDescription) nextStepDescription.textContent = nextStep.description;
        if (nextStepBadge) nextStepBadge.textContent = nextStep.badge;
        if (nextStepLink instanceof HTMLAnchorElement) {
          nextStepLink.href = nextStep.href;
          nextStepLink.textContent = nextStep.label;
        }

        if (latestBriefMeta && latestBriefDescription) {
          if (latestBrief) {
            latestBriefMeta.textContent =
              `${latestBrief.tipo ?? 'brief'} · recibido ${formatDate(latestBrief.createdAt)}`;

            const excerpt = String(latestBrief.description ?? '').trim();
            latestBriefDescription.textContent =
              excerpt.length > 180 ? `${excerpt.slice(0, 177)}...` : excerpt || 'Brief recibido correctamente.';
          }
        }

        setText(
          'metric-active-jobs',
          String(jobs.filter((job) => ['pending', 'processing'].includes(job.status)).length),
        );
        setText(
          'metric-delivered-jobs',
          String(jobs.filter((job) => job.status === 'delivered').length),
        );

        const planned = jobs.reduce((total, job) => total + Number(job.unitsPlanned ?? 0), 0);
        const consumed = jobs.reduce((total, job) => total + Number(job.unitsConsumed ?? 0), 0);
        setText('metric-units', `${formatNumber(consumed)} / ${formatNumber(planned)}`);

        if (!tbody) return;

        if (jobs.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-slate-400">Todavia no tienes trabajos activos en el portal.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = jobs.map((job) => `
          <tr class="hover:bg-zinc-900 transition">
            <td class="px-6 py-4">
              <p class="font-medium text-white">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-zinc-500 mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-zinc-400">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-zinc-400">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
            <td class="px-6 py-4 text-zinc-400">${escapeHtml(formatDate(job.updatedAt))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-white underline decoration-zinc-700 underline-offset-4 transition hover:decoration-white">Ver detalle</a>
            </td>
          </tr>
        `).join('');

        // Activity feed - generate from jobs data
        const activityFeed = document.getElementById('activity-feed');
        if (activityFeed && jobs.length > 0) {
          const activities = [];

          // Add job status changes as activities
          jobs.forEach((job) => {
            if (job.status === 'completed' || job.status === 'delivered') {
              activities.push({
                type: 'job_completed',
                title: `Trabajo "${job.briefText?.slice(0, 40) || 'Job'}" completado`,
                time: job.updatedAt,
                icon: '✅',
                href: `/client/jobs/detail?id=${job.id}`,
              });
            } else if (job.status === 'processing') {
              activities.push({
                type: 'job_processing',
                title: `Trabajo "${job.briefText?.slice(0, 40) || 'Job'}" en producción`,
                time: job.updatedAt,
                icon: '🟢',
                href: `/client/jobs/detail?id=${job.id}`,
              });
            }
          });

          // Sort by most recent
          activities.sort((a, b) => new Date(b.time).getTime() - new Date(a.time).getTime());

          // Show last 5 activities
          const recentActivities = activities.slice(0, 5);

          if (recentActivities.length === 0) {
            activityFeed.innerHTML = '<p class="text-sm text-zinc-400">Sin actividad reciente</p>';
          } else {
            activityFeed.innerHTML = recentActivities.map((activity) => `
              <a href="${activity.href}" class="flex items-start gap-3 group">
                <div class="w-2 h-2 mt-2 rounded-full ${activity.type === 'job_completed' ? 'bg-emerald-500' : 'bg-sky-500'}"></div>
                <div>
                  <p class="text-sm text-zinc-300 group-hover:text-white transition">${escapeHtml(activity.title)}</p>
                  <p class="text-xs text-zinc-500 mt-0.5">${formatDate(activity.time)}</p>
                </div>
              </a>
            `).join('');
          }
        }
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-rose-200">No se pudieron cargar tus trabajos.</td>
            </tr>
          `;
        }
      }
    })();
  </script>
</ClientLayout>
