---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { siteLinks } from '../../lib/site-links';
---

<ClientLayout title="Resumen">
  <div class="space-y-6">
    <section class="crm-panel-strong overflow-hidden p-6 md:p-8">
      <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
        <div>
          <p class="crm-kicker">Resumen cliente</p>
          <h1 id="client-heading" class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">
            Cargando tu portal...
          </h1>
          <p id="client-subheading" class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-300 md:text-base">
            Estamos cargando tu estado de cuenta y tus trabajos.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Soporte operativo</p>
            <div id="client-contact" class="mt-3 text-sm leading-relaxed text-slate-200">
              <span class="font-medium text-white">hola@grandeandgordo.com</span>
            </div>
          </div>
          <div class="crm-panel-soft p-5">
            <p class="crm-kicker">Capa conectada</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">
              Web y CRM trabajan juntos: brief, onboarding, seguimiento y entregables.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="crm-panel p-5">
        <p class="crm-kicker">Trabajos activos</p>
        <p id="metric-active-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Entregados</p>
        <p id="metric-delivered-jobs" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Consumo</p>
        <p id="metric-units" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
        <p id="metric-capacity" class="mt-3 text-sm text-slate-400">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Estado operativo</p>
        <p id="metric-plan" class="mt-4 inline-flex rounded-full px-3 py-1 text-sm font-semibold">—</p>
        <p id="metric-dataset" class="mt-3 inline-flex rounded-full px-3 py-1 text-sm font-medium">—</p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.1fr_.9fr]">
      <section class="crm-panel p-6 md:p-7">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="crm-kicker">Siguiente paso</p>
            <h2 id="next-step-title" class="mt-3 text-2xl font-black tracking-tight text-white">
              Estamos preparando tu siguiente mejor movimiento.
            </h2>
            <p id="next-step-description" class="mt-4 max-w-2xl text-sm leading-relaxed text-slate-300">
              Vamos a usar tu estado de cuenta y el momento del proyecto para recomendarte la accion mas util ahora mismo.
            </p>
          </div>
          <span id="next-step-badge" class="inline-flex rounded-full border border-sky-300/20 bg-sky-400/10 px-3 py-1 text-xs font-medium text-sky-100">
            Journey conectado
          </span>
        </div>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            id="next-step-link"
            href={siteLinks.brief}
            target="_blank"
            rel="noreferrer"
            class="crm-button crm-button-primary"
          >
            Abrir siguiente paso
          </a>
          <a
            href={siteLinks.portalHub}
            target="_blank"
            rel="noreferrer"
            class="crm-button crm-button-secondary"
          >
            Ver centro de cliente
          </a>
        </div>
      </section>

      <section class="crm-panel p-6 md:p-7">
        <p class="crm-kicker">Web + CRM</p>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-white">Todo el journey, conectado</h2>
        <div class="crm-panel-soft mt-5 p-4">
          <p class="crm-kicker">Ultimo brief recibido</p>
          <p id="latest-brief-meta" class="mt-3 text-sm font-medium text-white">
            Aun no tenemos un brief reciente en tu cuenta.
          </p>
          <p id="latest-brief-description" class="mt-3 text-sm leading-relaxed text-slate-300">
            Si cambian objetivos, referencias o necesidades, actualiza el brief desde la web y quedará conectado con tu operativa del CRM.
          </p>
        </div>
        <div class="mt-5 grid gap-3">
          <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="crm-link-tile transition hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/6">
            <p class="font-semibold text-white">Brief de proyecto</p>
            <p class="mt-2 text-sm text-slate-300">Comparte referencias, producto, tono y necesidades nuevas.</p>
          </a>
          <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="crm-link-tile transition hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/6">
            <p class="font-semibold text-white">Onboarding y checklist</p>
            <p class="mt-2 text-sm text-slate-300">Revisa preparacion de sesion, materiales y preguntas frecuentes.</p>
          </a>
          <a href={siteLinks.home} target="_blank" rel="noreferrer" class="crm-link-tile transition hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/6">
            <p class="font-semibold text-white">Web publica</p>
            <p class="mt-2 text-sm text-slate-300">Servicios, pricing y referencias de Grande&amp;Gordo cuando necesites contexto mas amplio.</p>
          </a>
        </div>
      </section>
    </div>

    <div class="crm-table-wrap">
      <div class="border-b border-white/8 px-6 py-5">
        <h2 class="text-lg font-semibold text-white">Tus trabajos</h2>
        <p class="mt-2 text-sm text-slate-300">Sigue el estado de entrega y entra al detalle para ver assets aprobados.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full divide-y divide-gray-200 text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left">Brief</th>
              <th class="px-6 py-3 text-left">Estado</th>
              <th class="px-6 py-3 text-left">Due</th>
              <th class="px-6 py-3 text-left">Units</th>
              <th class="px-6 py-3 text-left">Actualizado</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="jobs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-slate-400">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script define:vars={{ briefUrl: siteLinks.brief, onboardingUrl: siteLinks.onboarding, portalHubUrl: siteLinks.portalHub }}>
    (async () => {
      const {
        api,
        datasetStatusClass,
        escapeHtml,
        formatDate,
        formatNumber,
        getSessionContext,
        jobStatusClass,
        subscriptionClass,
      } = await import('../../lib/api-client');

      const tbody = document.getElementById('jobs-body');
      const nextStepTitle = document.getElementById('next-step-title');
      const nextStepDescription = document.getElementById('next-step-description');
      const nextStepBadge = document.getElementById('next-step-badge');
      const nextStepLink = document.getElementById('next-step-link');
      const latestBriefMeta = document.getElementById('latest-brief-meta');
      const latestBriefDescription = document.getElementById('latest-brief-description');

      const nextStepForClient = (client, jobs) => {
        const activeJobs = jobs.filter((job) => ['pending', 'processing'].includes(job.status));
        const datasetStatus = client?.datasetStatus ?? 'pending_capture';

        if (datasetStatus === 'pending_capture') {
          return {
            badge: 'Preparacion',
            title: 'Completa el brief para acelerar la sesion.',
            description:
              'Todavia estamos en fase de captura inicial. Cuanto mejor contexto nos dejes en la web, mejor saldra la preparacion del proyecto y la primera sesion.',
            href: briefUrl,
            label: 'Completar brief',
          };
        }

        if (datasetStatus === 'captured') {
          return {
            badge: 'Activacion',
            title: 'Revisa el onboarding mientras activamos tu sistema visual.',
            description:
              'Tu captura ya esta hecha. Este es el mejor momento para revisar checklist, expectativas y siguientes pasos del proceso.',
            href: onboardingUrl,
            label: 'Abrir onboarding',
          };
        }

        if (activeJobs.length === 0) {
          return {
            badge: 'Operacion',
            title: 'No tienes trabajos activos: deja el siguiente contexto preparado.',
            description:
              'Si quieres arrancar un nuevo trabajo o abrir una nueva linea de contenido, el brief es la mejor puerta de entrada para alinear necesidades.',
            href: briefUrl,
            label: 'Actualizar brief',
          };
        }

        return {
          badge: 'Seguimiento',
          title: 'Tu operacion ya esta en marcha.',
          description:
            'Usa el CRM para seguir entregables y mantennos alineados desde la web cuando necesites sumar contexto, referencias o nuevos objetivos.',
          href: portalHubUrl,
          label: 'Ver centro de cliente',
        };
      };

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      try {
        const [session, jobsData, briefData] = await Promise.all([
          getSessionContext(),
          api('/api/portal/jobs'),
          api('/api/portal/briefs/latest').catch(() => ({ brief: null })),
        ]);

        const client = session?.client;
        const jobs = Array.isArray(jobsData.jobs) ? jobsData.jobs : [];
        const latestBrief = briefData?.brief ?? null;

        if (client) {
          const heading = document.getElementById('client-heading');
          const subheading = document.getElementById('client-subheading');
          const contact = document.getElementById('client-contact');

          if (heading) heading.textContent = client.company ?? client.name;
          if (subheading) {
            subheading.textContent =
              `${client.plan ?? 'Sin plan definido'} · ${client.subscriptionStatus ?? 'inactive'} · review ${formatDate(client.nextReviewAt)}`;
          }

          if (contact) {
            const accountManager = client.accountManager ?? 'hola@grandeandgordo.com';
            contact.innerHTML = `Tu contacto operativo: <span class="font-medium text-white">${escapeHtml(accountManager)}</span>`;
          }

          const datasetMetric = document.getElementById('metric-dataset');
          if (datasetMetric) {
            datasetMetric.textContent = `Dataset ${client.datasetStatus ?? 'pending_capture'}`;
            datasetMetric.className = `text-sm mt-2 inline-flex px-2 py-1 rounded font-medium ${datasetStatusClass(client.datasetStatus ?? '')}`;
          }

          const planMetric = document.getElementById('metric-plan');
          if (planMetric) {
            planMetric.textContent = client.plan ?? 'Sin plan definido';
            planMetric.className = `text-lg font-semibold mt-2 inline-flex px-2 py-1 rounded ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}`;
          }

          setText('metric-capacity', `Capacidad mensual: ${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);
        }

        const nextStep = nextStepForClient(client, jobs);
        if (nextStepTitle) nextStepTitle.textContent = nextStep.title;
        if (nextStepDescription) nextStepDescription.textContent = nextStep.description;
        if (nextStepBadge) nextStepBadge.textContent = nextStep.badge;
        if (nextStepLink instanceof HTMLAnchorElement) {
          nextStepLink.href = nextStep.href;
          nextStepLink.textContent = nextStep.label;
        }

        if (latestBriefMeta && latestBriefDescription) {
          if (latestBrief) {
            latestBriefMeta.textContent =
              `${latestBrief.tipo ?? 'brief'} · recibido ${formatDate(latestBrief.createdAt)}`;

            const excerpt = String(latestBrief.description ?? '').trim();
            latestBriefDescription.textContent =
              excerpt.length > 180 ? `${excerpt.slice(0, 177)}...` : excerpt || 'Brief recibido correctamente.';
          }
        }

        setText(
          'metric-active-jobs',
          String(jobs.filter((job) => ['pending', 'processing'].includes(job.status)).length),
        );
        setText(
          'metric-delivered-jobs',
          String(jobs.filter((job) => job.status === 'delivered').length),
        );

        const planned = jobs.reduce((total, job) => total + Number(job.unitsPlanned ?? 0), 0);
        const consumed = jobs.reduce((total, job) => total + Number(job.unitsConsumed ?? 0), 0);
        setText('metric-units', `${formatNumber(consumed)} / ${formatNumber(planned)}`);

        if (!tbody) return;

        if (jobs.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-slate-400">Todavia no tienes trabajos activos en el portal.</td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = jobs.map((job) => `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-gray-500 mt-1">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.dueAt))}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(formatDate(job.updatedAt))}</td>
            <td class="px-6 py-4 text-right">
              <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-sky-200 transition hover:text-white">Ver detalle</a>
            </td>
          </tr>
        `).join('');
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-rose-200">No se pudieron cargar tus trabajos.</td>
            </tr>
          `;
        }
      }
    })();
  </script>
</ClientLayout>
