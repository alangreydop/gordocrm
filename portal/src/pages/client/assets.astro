---
import ClientLayout from '../../layouts/ClientLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<ClientLayout title="Assets aprobados">
  <div class="space-y-6" role="region" aria-label="Contenido principal">
    <section class="crm-panel-strong p-6 md:p-8">
      <PageHeader
        kicker="Biblioteca de assets"
        title="Entregables listos para descarga"
        description="Consulta todo el material aprobado, filtra por proyecto o formato y recupera piezas listas para usar sin perder contexto."
      />
    </section>

    <section class="crm-panel p-5 md:p-6">
      <div class="grid gap-3 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_auto]">
        <select id="filter-project" class="crm-input">
          <option value="">Todos los proyectos</option>
        </select>
        <select id="filter-type" class="crm-input">
          <option value="">Todos los tipos</option>
          <option value="image">Imagen</option>
          <option value="video">Video</option>
        </select>
        <input type="date" id="filter-from" class="crm-input" aria-label="Filtrar desde fecha" />
        <input type="date" id="filter-to" class="crm-input" aria-label="Filtrar hasta fecha" />
        <button id="clear-filters-btn" class="crm-button crm-button-secondary lg:self-stretch">
          Limpiar
        </button>
      </div>
      <p id="assets-summary" class="mt-4 text-sm text-crm-muted">Cargando assets aprobados...</p>
    </section>

    <section class="crm-panel p-6 md:p-7">
      <div id="assets-grid" class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <div class="col-span-full text-center py-12 text-crm-muted">Cargando assets...</div>
      </div>
      <div id="pagination" class="mt-6 flex flex-wrap justify-center gap-2"></div>
    </section>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml, formatDate } = await import('../../lib/api-client');

      let allAssets = [];
      let filteredAssets = [];
      const PAGE_SIZE = 12;
      let currentPage = 1;

      const assetsGrid = document.getElementById('assets-grid');
      const filterProject = document.getElementById('filter-project');
      const filterType = document.getElementById('filter-type');
      const filterFrom = document.getElementById('filter-from');
      const filterTo = document.getElementById('filter-to');
      const clearFiltersBtn = document.getElementById('clear-filters-btn');
      const pagination = document.getElementById('pagination');
      const assetsSummary = document.getElementById('assets-summary');

      const populateProjectFilter = () => {
        if (!(filterProject instanceof HTMLSelectElement)) return;
        const projects = [...new Set(allAssets.map((asset) => asset.jobName))];
        filterProject.innerHTML = `
          <option value="">Todos los proyectos</option>
          ${projects.map((project) => `<option value="${escapeHtml(project)}">${escapeHtml(project)}</option>`).join('')}
        `;
      };

      const renderPagination = (totalPages) => {
        if (!pagination) return;
        pagination.innerHTML = '';

        if (totalPages <= 1) return;

        Array.from({ length: totalPages }, (_, index) => index + 1).forEach((page) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.textContent = String(page);
          button.className = currentPage === page
            ? 'h-9 min-w-[2.25rem] rounded-full border border-crm-accent bg-[rgba(196,22,90,0.12)] px-3 text-sm font-semibold text-crm-accent'
            : 'h-9 min-w-[2.25rem] rounded-full border border-crm-border bg-[rgba(255,255,255,0.7)] px-3 text-sm font-medium text-crm-text-secondary hover:border-crm-accent hover:text-crm-text';
          button.addEventListener('click', () => {
            currentPage = page;
            renderAssets();
          });
          pagination.appendChild(button);
        });
      };

      const renderAssets = () => {
        if (!assetsGrid || !assetsSummary) return;

        const start = (currentPage - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;
        const pageAssets = filteredAssets.slice(start, end);
        const totalPages = Math.ceil(filteredAssets.length / PAGE_SIZE);

        assetsSummary.textContent = `Mostrando ${filteredAssets.length} asset${filteredAssets.length !== 1 ? 's' : ''} aprobado${filteredAssets.length !== 1 ? 's' : ''}`;

        if (pageAssets.length === 0) {
          assetsGrid.innerHTML = `
            <div class="crm-empty col-span-full">
              No hay assets que coincidan con los filtros seleccionados.
            </div>
          `;
          renderPagination(totalPages);
          return;
        }

        assetsGrid.innerHTML = pageAssets.map((asset) => `
          <article class="crm-panel-soft overflow-hidden">
            <div class="relative aspect-square overflow-hidden bg-[rgba(255,248,251,0.92)]">
              ${asset.type === 'video'
                ? `<video src="${asset.deliveryUrl || ''}" class="h-full w-full object-cover" muted loop playsinline></video>`
                : `<img src="${asset.deliveryUrl || ''}" alt="${escapeHtml(asset.label || 'Asset')}" class="h-full w-full object-cover" loading="lazy" decoding="async" />`
              }
              <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-3 p-3" style="background: linear-gradient(180deg, rgba(11, 6, 8, 0), rgba(11, 6, 8, 0.42));">
                <span class="crm-badge ${asset.type === 'video' ? 'crm-badge-accent' : 'crm-badge-default'}">
                  ${asset.type === 'video' ? 'Video' : 'Imagen'}
                </span>
                <div class="flex items-center gap-2">
                  ${asset.deliveryUrl
                    ? `<a href="${asset.deliveryUrl}" target="_blank" rel="noreferrer" class="crm-button crm-button-primary text-xs">Ver</a>`
                    : ''
                  }
                  ${asset.deliveryUrl
                    ? `<a href="${asset.deliveryUrl}" download class="crm-button crm-button-secondary text-xs">Descargar</a>`
                    : ''
                  }
                </div>
              </div>
            </div>
            <div class="space-y-3 p-4">
              <div>
                <p class="text-sm font-semibold text-crm-text">${escapeHtml(asset.label || asset.type)}</p>
                <p class="mt-1 text-xs text-crm-text-secondary">${escapeHtml(asset.jobName)}</p>
              </div>
              <div class="flex items-center justify-between gap-3 border-t border-crm-border pt-3">
                <span class="text-xs text-crm-text-secondary">${formatDate(asset.createdAt)}</span>
                <span class="text-xs text-crm-muted">${escapeHtml(asset.jobPlatform)}</span>
              </div>
            </div>
          </article>
        `).join('');

        renderPagination(totalPages);
      };

      const applyFilters = () => {
        const project = filterProject instanceof HTMLSelectElement ? filterProject.value : '';
        const type = filterType instanceof HTMLSelectElement ? filterType.value : '';
        const from = filterFrom instanceof HTMLInputElement && filterFrom.value ? new Date(filterFrom.value) : null;
        const to = filterTo instanceof HTMLInputElement && filterTo.value ? new Date(`${filterTo.value}T23:59:59`) : null;

        filteredAssets = allAssets.filter((asset) => {
          if (project && asset.jobName !== project) return false;
          if (type && asset.type !== type) return false;
          if (from && new Date(asset.createdAt) < from) return false;
          if (to && new Date(asset.createdAt) > to) return false;
          return true;
        });

        currentPage = 1;
        renderAssets();
      };

      const loadAssets = async () => {
        try {
          const { jobs } = await api('/api/portal/jobs');
          const relevantJobs = jobs
            .filter((job) => job.status === 'completed' || job.status === 'delivered')
            .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
            .slice(0, 30);

          const concurrency = 5;
          const assetsArrays: any[] = [];

          for (let i = 0; i < relevantJobs.length; i += concurrency) {
            const batch = relevantJobs.slice(i, i + concurrency);
            const batchResults = await Promise.all(
              batch.map(async (job) => {
                const jobData = await api(`/api/portal/jobs/${job.id}`);
                return jobData.assets
                  .filter((asset) => asset.status === 'approved' || !asset.status)
                  .map((asset) => ({
                    ...asset,
                    jobName: job.briefText || `Trabajo ${job.id.slice(0, 8)}`,
                    jobId: job.id,
                    jobPlatform: job.platform || 'Sin plataforma',
                    jobCreatedAt: job.createdAt,
                  }));
              }),
            );
            assetsArrays.push(...batchResults);
          }

          allAssets = assetsArrays
            .flat()
            .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
          filteredAssets = [...allAssets];
          populateProjectFilter();
          renderAssets();
        } catch (error) {
          console.error('Error loading assets:', error);
          if (assetsGrid) {
            assetsGrid.innerHTML = `
              <div class="crm-empty col-span-full">
                No hemos podido cargar tus assets ahora mismo.
              </div>
            `;
          }
          if (assetsSummary) assetsSummary.textContent = 'Error de carga';
        }
      };

      filterProject?.addEventListener('change', applyFilters);
      filterType?.addEventListener('change', applyFilters);
      filterFrom?.addEventListener('change', applyFilters);
      filterTo?.addEventListener('change', applyFilters);
      clearFiltersBtn?.addEventListener('click', () => {
        if (filterProject instanceof HTMLSelectElement) filterProject.value = '';
        if (filterType instanceof HTMLSelectElement) filterType.value = '';
        if (filterFrom instanceof HTMLInputElement) filterFrom.value = '';
        if (filterTo instanceof HTMLInputElement) filterTo.value = '';
        applyFilters();
      });

      await loadAssets();
    })();
  </script>
</ClientLayout>
