---
import ClientLayout from '../../../layouts/ClientLayout.astro';
---

<ClientLayout title="Detalle de Factura">
  <div class="max-w-4xl mx-auto space-y-8" role="region" aria-label="Contenido principal">
    <div class="flex items-center gap-4">
      <a href="/client/invoices" class="text-crm-muted hover:text-crm-text transition">← Volver</a>
      <h1 class="text-3xl font-bold text-crm-text" id="invoice-number">Factura</h1>
    </div>

    <div id="invoice-detail" class="space-y-6" role="region" aria-label="Contenido principal">
      <div class="text-center text-crm-muted py-12">Cargando...</div>
    </div>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml } = await import('../../../lib/api-client');
      const { showToast } = await import('../../../lib/crm-ui');
      const detailEl = document.getElementById('invoice-detail');
      const titleEl = document.getElementById('invoice-number');

      const formatMoney = (cents: number) => `€${((Number(cents) || 0) / 100).toFixed(2)}`;
      const formatDate = (value) => {
        const date = new Date(value);
        return Number.isNaN(date.getTime()) ? '—' : date.toLocaleDateString('es-ES');
      };

      const getStatusBadge = (status: string) => {
        const badges: Record<string, string> = {
          draft: 'bg-crm-panel-soft text-crm-muted',
          issued: 'bg-crm-warning/20 text-crm-warning',
          sent: 'bg-crm-info/20 text-crm-info',
          paid: 'bg-crm-success/20 text-crm-success',
          cancelled: 'bg-crm-danger/20 text-crm-danger',
          overdue: 'bg-crm-danger/20 text-crm-danger',
        };
        const labels: Record<string, string> = {
          draft: 'Borrador',
          issued: 'Emitida',
          sent: 'Enviada',
          paid: 'Pagada',
          cancelled: 'Cancelada',
          overdue: 'Vencida',
        };
        return `<span class="px-3 py-1 rounded-full text-xs font-bold ${badges[status] || badges.draft}">${escapeHtml(labels[status] || status)}</span>`;
      };

      const urlParams = new URLSearchParams(window.location.search);
      const invoiceId = urlParams.get('id');

      if (!invoiceId) {
        detailEl!.innerHTML = '<div class="text-crm-danger py-12 text-center">ID de factura no proporcionado</div>';
        return;
      }

      const loadInvoice = async () => {
        try {
          const response = await api(`/api/portal/invoices/${invoiceId}`);
          const { invoice, items } = response;

          if (!invoice) {
            detailEl!.innerHTML = '<div class="text-crm-danger">Factura no encontrada</div>';
            return;
          }

          titleEl!.textContent = `Factura ${invoice.invoiceNumber}`;

          const isPaid = invoice.status === 'paid';
          const pdfUrl = `/api/portal/invoices/${encodeURIComponent(invoiceId)}/pdf?download=1`;

          detailEl!.innerHTML = `
            <!-- Header -->
            <div class="rounded-xl border border-crm-border bg-crm-bg-alt p-8">
              <div class="flex items-start justify-between mb-8">
                <div>
                  <h2 class="text-2xl font-bold text-crm-text mb-2">${escapeHtml(invoice.issuerLegalName)}</h2>
                  <p class="text-crm-muted text-sm">NIF: ${escapeHtml(invoice.issuerTaxId)}</p>
                  <p class="text-crm-muted text-sm">${escapeHtml(invoice.issuerEmail)}</p>
                </div>
                <div class="text-right">
                  <div class="text-3xl font-bold text-crm-text mb-2">${formatMoney(invoice.totalCents)}</div>
                  ${getStatusBadge(invoice.status)}
                </div>
              </div>

              <!-- Info grid -->
              <div class="grid md:grid-cols-2 gap-6 pt-6 border-t border-crm-border">
                <div>
                  <h3 class="text-sm font-semibold text-crm-muted uppercase mb-3">Facturar a</h3>
                  <p class="text-crm-text font-medium">${escapeHtml(invoice.clientLegalName)}</p>
                  <p class="text-crm-muted text-sm">NIF: ${escapeHtml(invoice.clientTaxId)}</p>
                  <p class="text-crm-muted text-sm">${escapeHtml(invoice.clientAddressLine1)}</p>
                  <p class="text-crm-muted text-sm">${escapeHtml(invoice.clientPostalCode)} ${escapeHtml(invoice.clientCity)}</p>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-crm-muted uppercase mb-3">Detalles</h3>
                  <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                      <span class="text-crm-muted">Número:</span>
                      <span class="text-crm-text font-medium">${escapeHtml(invoice.invoiceNumber)}</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-crm-muted">Fecha:</span>
                      <span class="text-crm-text">${formatDate(invoice.issueDate)}</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-crm-muted">Vencimiento:</span>
                      <span class="text-crm-text">${formatDate(invoice.dueDate)}</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-crm-muted">Método de pago:</span>
                      <span class="text-crm-text">${escapeHtml(invoice.paymentMethod || 'Transferencia bancaria')}</span>
                    </div>
                    ${invoice.paidAt ? `
                      <div class="flex justify-between">
                        <span class="text-crm-muted">Pagada el:</span>
                        <span class="text-crm-success">${formatDate(invoice.paidAt)}</span>
                      </div>
                    ` : ''}
                  </div>
                </div>
              </div>

              ${invoice.description ? `
                <div class="pt-6 border-t border-crm-border">
                  <h3 class="text-sm font-semibold text-crm-muted uppercase mb-2">Descripción</h3>
                  <p class="text-crm-muted">${escapeHtml(invoice.description)}</p>
                </div>
              ` : ''}
            </div>

            <!-- Line items -->
            <div class="rounded-xl border border-crm-border bg-crm-bg-alt overflow-hidden">
              <table class="w-full text-sm">
                <thead class="bg-crm-bg-alt border-b border-crm-border">
                  <tr>
                    <th class="text-left py-4 px-6 text-crm-muted font-medium">Concepto</th>
                    <th class="text-center py-4 px-6 text-crm-muted font-medium">Cant.</th>
                    <th class="text-right py-4 px-6 text-crm-muted font-medium">Precio</th>
                    <th class="text-right py-4 px-6 text-crm-muted font-medium">Total</th>
                  </tr>
                </thead>
                <tbody>
                  ${(items || []).length > 0 ? (items || []).map((item: any) => `
                    <tr class="border-b border-crm-border last:border-0">
                      <td class="py-4 px-6 text-crm-text">${escapeHtml(item.description)}</td>
                      <td class="py-4 px-6 text-center text-crm-muted">${escapeHtml(item.quantity)}</td>
                      <td class="py-4 px-6 text-right text-crm-muted">${formatMoney(item.unitPriceCents)}</td>
                      <td class="py-4 px-6 text-right text-crm-text font-medium">${formatMoney(item.totalCents)}</td>
                    </tr>
                  `).join('') : `
                    <tr>
                      <td colspan="4" class="py-4 px-6 text-center text-crm-muted">Sin conceptos asociados</td>
                    </tr>
                  `}
                </tbody>
              </table>
            </div>

            <!-- Totals -->
            <div class="rounded-xl border border-crm-border bg-crm-bg-alt p-6 ml-auto max-w-sm">
              <div class="space-y-3">
                <div class="flex justify-between text-sm">
                  <span class="text-crm-muted">Subtotal</span>
                  <span class="text-crm-text">${formatMoney(invoice.subtotalCents)}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-crm-muted">IVA (21%)</span>
                  <span class="text-crm-text">${formatMoney(invoice.taxAmountCents)}</span>
                </div>
                ${invoice.irpfAmountCents ? `
                  <div class="flex justify-between text-sm">
                    <span class="text-crm-muted">IRPF</span>
                    <span class="text-crm-danger">-${formatMoney(invoice.irpfAmountCents)}</span>
                  </div>
                ` : ''}
                <div class="flex justify-between text-lg font-bold pt-3 border-t border-crm-border">
                  <span class="text-crm-text">Total</span>
                  <span class="text-crm-text">${formatMoney(invoice.totalCents)}</span>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4 justify-end">
              <a href="${pdfUrl}" class="crm-button crm-button-secondary">Descargar PDF</a>
              ${!isPaid ? `
                <button
                  onclick="uploadPaymentProof()"
                  class="crm-button crm-button-primary"
                >
                  Subir justificante de pago
                </button>
              ` : `
                <div class="text-crm-success text-sm font-medium">
                  ✓ Factura pagada el ${formatDate(invoice.paidAt)}
                </div>
              `}
            </div>
          `;
        } catch (e) {
          console.error('error cargando factura:', e);
          detailEl!.innerHTML = `
            <div class="text-crm-danger py-12 text-center">
              error cargando la factura. Intenta de nuevo.
            </div>
          `;
        }
      };

      const uploadPaymentProof = () => {
        const notes = prompt('Introduce una nota o referencia de la transferencia (opcional):');
        if (notes === null) return;

        const proofUrl = prompt('URL del justificante (captura, PDF, etc.) - opcional:');

        api(`/api/portal/invoices/${invoiceId}/payment-proof`, {
          method: 'POST',
          body: JSON.stringify({
            paymentDate: new Date().toISOString(),
            notes: notes || undefined,
            proofUrl: proofUrl || undefined,
          }),
        })
          .then(() => {
            showToast('justificante enviado. verificaremos el pago en breve.', 'success');
            loadInvoice();
          })
          .catch((e) => {
            showToast('error: ' + e.message, 'error');
          });
      };

      (window as any).uploadPaymentProof = uploadPaymentProof;

      await loadInvoice();
    })();
  </script>
</ClientLayout>
