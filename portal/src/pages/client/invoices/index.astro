---
import ClientLayout from '../../../layouts/ClientLayout.astro';
---

<ClientLayout title="Mis facturas">
  <div class="max-w-5xl space-y-6" role="region" aria-label="Contenido principal">

    <!-- Header -->
    <div>
      <p class="crm-kicker crm-kicker--accent">Facturación</p>
      <h1 class="crm-page-header__title mt-3">
        Mis <em class="baskerville-italic" style="font-weight: 400;">facturas</em>
      </h1>
      <p class="crm-page-header__meta mt-3">
        Gestiona tus facturas y pagos. Método de pago: Transferencia bancaria.
      </p>
    </div>

    <!-- Bank info -->
    <div class="crm-panel" style="max-width: 600px;">
      <p class="crm-kicker" style="margin-bottom: 1rem;">Datos para transferencia</p>
      <div class="grid md:grid-cols-2 gap-3 text-sm">
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Titular</p>
          <p class="mt-2 font-semibold" style="color: var(--gg-text);">Grande&Gordo S.L.</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Banco</p>
          <p class="mt-2 font-semibold" style="color: var(--gg-text);">Abanca</p>
        </div>
        <div class="crm-panel-soft p-4 md:col-span-2">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">IBAN</p>
          <p class="mt-2 font-semibold font-mono tracking-wide" style="color: var(--gg-text);">ESXX XXXX XXXX XXXX XXXX</p>
        </div>
        <div class="crm-panel-soft p-4">
          <p class="crm-kicker" style="font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;">Concepto</p>
          <p class="mt-2 font-semibold" style="color: var(--gg-text);">Número de factura</p>
        </div>
      </div>
    </div>

    <!-- Invoices list -->
    <div id="invoices-list">
      <div class="text-center text-crm-muted py-12">Cargando facturas...</div>
    </div>

  </div>

  <script>
    (async () => {
      const { api } = await import('../../../lib/api-client');
      const { showToast } = await import('../../../lib/crm-ui');
      const listEl = document.getElementById('invoices-list');

      const formatMoney = (cents: number) => `€${(cents / 100).toFixed(2)}`;

      const getStatusBadge = (status: string) => {
        const badges: Record<string, string> = {
          draft: 'crm-badge-default',
          issued: 'crm-badge-warning',
          sent: 'crm-badge-info',
          paid: 'crm-badge-success',
          cancelled: 'crm-badge-danger',
          overdue: 'crm-badge-danger',
        };
        const labels: Record<string, string> = {
          draft: 'Borrador',
          issued: 'Emitida',
          sent: 'Enviada',
          paid: 'Pagada',
          cancelled: 'Cancelada',
          overdue: 'Vencida',
        };
        return `<span class="crm-badge ${badges[status] || badges.draft}">${labels[status] || status}</span>`;
      };

      const loadInvoices = async () => {
        try {
          const response = await api('/api/portal/invoices');
          const { invoices } = response;

          if (!invoices || invoices.length === 0) {
            listEl!.innerHTML = `
              <div class="crm-empty">
                <p class="font-medium" style="color: var(--gg-text);">No tienes facturas todavía.</p>
                <p class="text-sm mt-2">Contacta con nosotros para más información.</p>
              </div>
            `;
            return;
          }

          listEl!.innerHTML = `
            <div class="crm-table-wrap">
              <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--gg-border);">
                <p class="crm-kicker">Historial</p>
                <h2 style="font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; margin-top: 0.35rem; color: var(--gg-text);">Tus facturas</h2>
              </div>
              <div class="overflow-x-auto">
                <table class="crm-table min-w-full text-sm">
                  <thead>
                    <tr>
                      <th>Factura</th>
                      <th>Descripción</th>
                      <th>Importe</th>
                      <th>Fecha</th>
                      <th>Estado</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    ${invoices.map((inv: any) => `
                      <tr>
                        <td><p class="font-semibold" style="color: var(--gg-text);">${inv.invoiceNumber}</p></td>
                        <td class="text-crm-muted">${inv.description || '—'}</td>
                        <td><span class="font-bold" style="color: var(--gg-text);">${formatMoney(inv.totalCents)}</span></td>
                        <td class="text-crm-muted">${new Date(inv.issueDate).toLocaleDateString('es-ES')}</td>
                        <td>${getStatusBadge(inv.status)}</td>
                        <td style="text-align: right;">
                          <div class="flex gap-2 justify-end">
                            <a href="/client/invoices/detail?id=${inv.id}" class="crm-button crm-button-secondary" style="min-height: 2.25rem; padding: 0.5rem 0.85rem; font-size: 0.8rem;">Ver detalle</a>
                            ${inv.status !== 'paid' ? `
                              <button onclick="uploadProof('${inv.id}')" class="crm-button crm-button-primary" style="min-height: 2.25rem; padding: 0.5rem 0.85rem; font-size: 0.8rem;">
                                Subir justificante
                              </button>
                            ` : ''}
                          </div>
                        </td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
            </div>
          `;
        } catch (e) {
          console.error('Failed to load invoices:', e);
          listEl!.innerHTML = `
            <div class="crm-alert crm-alert-danger">
              Error cargando facturas. Intenta de nuevo.
            </div>
          `;
        }
      };

      const uploadProof = (invoiceId: string) => {
        const proofUrl = prompt('Introduce la URL del justificante (opcional):');
        const notes = prompt('Añadir nota (opcional):');
        if (notes === null) return;

        api(`/api/portal/invoices/${invoiceId}/payment-proof`, {
          method: 'POST',
          body: JSON.stringify({
            paymentDate: new Date().toISOString(),
            notes: notes || null,
            proofUrl: proofUrl || null,
          }),
        })
          .then(() => {
            showToast('Justificante enviado. Verificaremos el pago pronto.', 'success');
            loadInvoices();
          })
          .catch((e) => {
            showToast('Error al subir justificante: ' + e.message, 'error');
          });
      };

      (window as any).uploadProof = uploadProof;
      await loadInvoices();
    })();
  </script>
</ClientLayout>
