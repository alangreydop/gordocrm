---
import ClientLayout from '../../../layouts/ClientLayout.astro';
---

<ClientLayout title="Mis Facturas">
  <div class="max-w-5xl mx-auto space-y-8" role="region" aria-label="Contenido principal">
    <section class="text-center space-y-4">
      <h1 class="text-4xl font-black tracking-tight text-crm-text">Mis Facturas</h1>
      <p class="text-crm-muted">Gestiona tus facturas y pagos. Método de pago: Transferencia bancaria.</p>
    </section>

    <!-- Bank info card -->
    <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6">
      <h2 class="text-lg font-bold text-crm-text mb-4">Datos para transferencia</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="text-crm-text-secondary">Titular:</span>
          <p class="text-crm-text font-medium">Grande & Gordo S.L.</p>
        </div>
        <div>
          <span class="text-crm-text-secondary">Banco:</span>
          <p class="text-crm-text font-medium">Abanca</p>
        </div>
        <div>
          <span class="text-crm-text-secondary">IBAN:</span>
          <p class="text-crm-text font-medium font-mono">ESXX XXXX XXXX XXXX XXXX</p>
        </div>
        <div>
          <span class="text-crm-text-secondary">Concepto:</span>
          <p class="text-crm-text font-medium">Número de factura</p>
        </div>
      </div>
    </div>

    <!-- Invoices list -->
    <div class="space-y-4" id="invoices-list">
      <div class="text-center text-crm-text-secondary py-12">Cargando facturas...</div>
    </div>
  </div>

  <script>
    (async () => {
      const { api } = await import('../../../lib/api-client');
      const listEl = document.getElementById('invoices-list');

      const formatMoney = (cents: number) => `€${(cents / 100).toFixed(2)}`;

      const getStatusBadge = (status: string) => {
        const badges: Record<string, string> = {
          draft: 'bg-crm-panel-soft text-crm-muted',
          issued: 'bg-crm-warning/20 text-crm-warning',
          sent: 'bg-crm-info/20 text-crm-info',
          paid: 'bg-crm-success/20 text-crm-success',
          cancelled: 'bg-crm-danger/20 text-crm-danger',
          overdue: 'bg-crm-danger/20 text-crm-danger',
        };
        const labels: Record<string, string> = {
          draft: 'Borrador',
          issued: 'Emitida',
          sent: 'Enviada',
          paid: 'Pagada',
          cancelled: 'Cancelada',
          overdue: 'Vencida',
        };
        return `<span class="px-3 py-1 rounded-full text-xs font-bold ${badges[status] || badges.draft}">${labels[status] || status}</span>`;
      };

      const loadInvoices = async () => {
        try {
          const response = await api('/api/portal/invoices');
          const { invoices } = response;

          if (!invoices || invoices.length === 0) {
            listEl!.innerHTML = `
              <div class="text-center text-crm-text-secondary py-12">
                <p>No tienes facturas todavía.</p>
                <p class="text-sm mt-2">Contacta con nosotros para más información.</p>
              </div>
            `;
            return;
          }

          listEl!.innerHTML = invoices
            .map(
              (inv: any) => `
            <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6 hover:border-crm-accent transition">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-lg font-bold text-crm-text">${inv.invoiceNumber}</h3>
                    ${getStatusBadge(inv.status)}
                  </div>
                  <p class="text-sm text-crm-muted">
                    Emitida: ${new Date(inv.issueDate).toLocaleDateString('es-ES')}
                    ${inv.dueDate ? `· Vence: ${new Date(inv.dueDate).toLocaleDateString('es-ES')}` : ''}
                  </p>
                  ${inv.description ? `<p class="text-sm text-crm-text-secondary mt-2">${inv.description}</p>` : ''}
                </div>
                <div class="text-right">
                  <div class="text-2xl font-bold text-crm-text">${formatMoney(inv.totalCents)}</div>
                  <div class="flex gap-2 mt-3 justify-end">
                    <a
                      href="/client/invoices/detail?id=${inv.id}"
                      class="crm-button crm-button-secondary text-sm"
                    >
                      Ver detalle
                    </a>
                    ${inv.status !== 'paid' ? `
                      <button
                        onclick="uploadProof('${inv.id}')"
                        class="crm-button crm-button-primary text-sm"
                      >
                        Subir justificante
                      </button>
                    ` : ''}
                  </div>
                </div>
              </div>
            </div>
          `,
            )
            .join('');
        } catch (e) {
          console.error('Failed to load invoices:', e);
          listEl!.innerHTML = `
            <div class="text-center text-crm-danger py-12">
              error cargando facturas. Intenta de nuevo.
            </div>
          `;
        }
      };

      const uploadProof = (invoiceId: string) => {
        const proofUrl = prompt('Introduce la URL del justificante (opcional):');
        const notes = prompt('Añadir nota (opcional):');

        if (notes === null) return;

        api(`/api/portal/invoices/${invoiceId}/payment-proof`, {
          method: 'POST',
          body: JSON.stringify({
            paymentDate: new Date().toISOString(),
            notes: notes || null,
            proofUrl: proofUrl || null,
          }),
        })
          .then(() => {
            alert('Justificante enviado. Verificaremos el pago pronto.');
            loadInvoices();
          })
          .catch((e) => {
            alert('error al subir justificante: ' + e.message);
          });
      };

      // Make uploadProof global
      (window as any).uploadProof = uploadProof;

      await loadInvoices();
    })();
  </script>
</ClientLayout>
