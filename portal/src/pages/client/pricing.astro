---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Planes y Precios">
  <div class="max-w-6xl mx-auto space-y-8" role="region" aria-label="Contenido principal">
    <section class="text-center space-y-4">
      <h1 class="text-4xl font-black tracking-tight text-crm-text">Ritmo de producción</h1>
      <p class="text-crm-muted">Elige el ritmo que mejor se adapta a tu producción visual.</p>
    </section>

    <!-- Pricing Tiers -->
    <div class="grid md:grid-cols-3 gap-6">
      <!-- E-commerce -->
      <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6 md:p-8 flex flex-col">
        <div class="mb-6">
          <h3 class="text-xl font-bold text-crm-text">E-commerce</h3>
          <p class="text-sm text-crm-muted mt-1">Para marcas que empiezan en online</p>
        </div>

        <div class="mb-4">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-black text-crm-text">€750</span>
            <span class="text-crm-text-secondary">/mes</span>
          </div>
        </div>

        <div class="flex items-baseline gap-2 mb-6 py-2 border-t border-b border-dashed border-crm-border">
          <span class="text-xs text-crm-text-secondary uppercase tracking-wide">Base visual:</span>
          <span class="text-sm font-bold text-crm-success">€1.800</span>
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">15-20 imágenes/mes</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Fondo blanco + 1-2 escenarios</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">2 rondas de revisiones</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Entrega en 5-7 días laborables</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">The Vault (biblioteca privada)</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Soporte email + Slack</span>
          </li>
        </ul>

        <a href="mailto:hola@grandeandgordo.com?subject=Interesado%20en%20plan%20E-commerce" class="crm-button crm-button-secondary w-full text-center">
          Contactar
        </a>
      </div>

      <!-- Multicanal (Most Popular) -->
      <div class="rounded-3xl border p-6 md:p-8 flex flex-col relative" style="border-color: color-mix(in srgb, var(--crm-success) 50%, transparent); background: linear-gradient(to bottom, color-mix(in srgb, var(--crm-success) 10%, transparent), var(--crm-bg-alt));">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="px-3 py-1 rounded-full text-crm-text text-xs font-bold uppercase tracking-wide" style="background: var(--crm-success);">Más elegido</span>
        </div>

        <div class="mb-6">
          <h3 class="text-xl font-bold text-crm-text">Multicanal</h3>
          <p class="text-sm text-crm-muted mt-1">Para marcas que crecen en todos los canales</p>
        </div>

        <div class="mb-4">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-black text-crm-text">€1.500</span>
            <span class="text-crm-text-secondary">/mes</span>
          </div>
        </div>

        <div class="flex items-baseline gap-2 mb-6 py-2 border-t border-b border-dashed border-crm-border">
          <span class="text-xs text-crm-text-secondary uppercase tracking-wide">Base visual:</span>
          <span class="text-sm font-bold text-crm-success">€2.800</span>
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">35-45 imágenes/mes</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Fondo blanco + 3-4 escenarios</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">3 rondas de revisiones</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Entrega en 5-7 días laborables</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">The Vault + formatos multi-plataforma</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Account manager asignado</span>
          </li>
        </ul>

        <a href="mailto:hola@grandeandgordo.com?subject=Interesado%20en%20plan%20Multicanal" class="crm-button crm-button-primary w-full text-center">
          Contactar
        </a>
      </div>

      <!-- Consolidada -->
      <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6 md:p-8 flex flex-col">
        <div class="mb-6">
          <h3 class="text-xl font-bold text-crm-text">Consolidada</h3>
          <p class="text-sm text-crm-muted mt-1">Para marcas con volumen alto y lanzamientos frecuentes</p>
        </div>

        <div class="mb-4">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-black text-crm-text">€2.750</span>
            <span class="text-crm-text-secondary">/mes</span>
          </div>
        </div>

        <div class="flex items-baseline gap-2 mb-6 py-2 border-t border-b border-dashed border-crm-border">
          <span class="text-xs text-crm-text-secondary uppercase tracking-wide">Base visual:</span>
          <span class="text-sm font-bold text-crm-success">Incluido</span>
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">80-100 imágenes/mes</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Todos los escenarios + variaciones</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Revisiones ilimitadas</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Entrega express 24-48h</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">The Vault + raw + editables</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Account manager dedicado</span>
          </li>
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-5 h-5 text-crm-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-crm-text-secondary">Revisión trimestral de estrategia</span>
          </li>
        </ul>

        <a href="mailto:hola@grandeandgordo.com?subject=Interesado%20en%20plan%20Consolidada" class="crm-button crm-button-secondary w-full text-center">
          Contactar
        </a>
      </div>
    </div>

    <!-- Commitment note -->
    <p class="text-center text-sm text-crm-text-secondary">
      Todos los planes: 3 meses mínimo, luego mes a mes sin compromiso.
    </p>

    <!-- Unit breakdown -->
    <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6 md:p-8">
      <h2 class="text-2xl font-bold text-crm-text mb-6">¿Cómo funcionan las unidades?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="rounded-2xl border border-crm-border bg-crm-panel p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-crm-panel-soft flex items-center justify-center">
              <svg class="w-5 h-5 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="font-semibold text-crm-text">Imagen simple</p>
          </div>
          <p class="text-2xl font-black text-crm-text">1 unidad</p>
          <p class="text-xs text-crm-text-secondary mt-1">Packshot, fondo blanco</p>
        </div>

        <div class="rounded-2xl border border-crm-border bg-crm-panel p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-crm-panel-soft flex items-center justify-center">
              <svg class="w-5 h-5 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="font-semibold text-crm-text">Pieza branded / PDP</p>
          </div>
          <p class="text-2xl font-black text-crm-text">2 unidades</p>
          <p class="text-xs text-crm-text-secondary mt-1">Con texto, layout</p>
        </div>

        <div class="rounded-2xl border border-crm-border bg-crm-panel p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-crm-panel-soft flex items-center justify-center">
              <svg class="w-5 h-5 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="font-semibold text-crm-text">Vídeo corto</p>
          </div>
          <p class="text-2xl font-black text-crm-text">4 unidades</p>
          <p class="text-xs text-crm-text-secondary mt-1">&lt;30 segundos</p>
        </div>

        <div class="rounded-2xl border border-crm-border bg-crm-panel p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-crm-panel-soft flex items-center justify-center">
              <svg class="w-5 h-5 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="font-semibold text-crm-text">Pieza premium</p>
          </div>
          <p class="text-2xl font-black text-crm-text">6+ unidades</p>
          <p class="text-xs text-crm-text-secondary mt-1">Campaña, hero, compleja</p>
        </div>
      </div>

      <p class="text-sm text-crm-muted mt-6">
        <strong class="text-crm-text">Nota:</strong> Antes de producir, te confirmamos el consumo estimado de unidades.
      </p>
    </div>

    <!-- What's included -->
    <div class="rounded-3xl border border-crm-border bg-crm-bg-alt p-6 md:p-8">
      <h2 class="text-2xl font-bold text-crm-text mb-6">Lo que incluye cada plan</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4 py-4 border-b border-crm-border">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Brief y estrategia</h3>
            <p class="text-sm text-crm-muted mt-1">Asistente AI para conceptualización + revisión humana del equipo</p>
          </div>
        </div>

        <div class="flex items-start gap-4 py-4 border-b border-crm-border">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Producción con IA</h3>
            <p class="text-sm text-crm-muted mt-1">Generación de assets con modelos propietarios + control de calidad</p>
          </div>
        </div>

        <div class="flex items-start gap-4 py-4 border-b border-crm-border">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Assets multi-formato</h3>
            <p class="text-sm text-crm-muted mt-1">Versiones optimizadas para cada plataforma (9:16, 1:1, 16:9, etc.)</p>
          </div>
        </div>

        <div class="flex items-start gap-4 py-4 border-b border-crm-border">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Revisiones</h3>
            <p class="text-sm text-crm-muted mt-1">Rondas de feedback dentro del scope del brief (ilimitadas en Consolidada)</p>
          </div>
        </div>

        <div class="flex items-start gap-4 py-4 border-b border-crm-border">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Descarga ilimitada</h3>
            <p class="text-sm text-crm-muted mt-1">Acceso permanente a tus assets + descarga bulk en ZIP</p>
          </div>
        </div>

        <div class="flex items-start gap-4 py-4">
          <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-crm-text">Derechos comerciales</h3>
            <p class="text-sm text-crm-muted mt-1">Tus imágenes para siempre. Sin licencias, sin renovaciones.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Guarantee -->
    <div class="rounded-3xl border p-6 md:p-8" style="border-color: color-mix(in srgb, var(--crm-success) 50%, transparent); background-color: color-mix(in srgb, var(--crm-success) 10%, transparent);">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-crm-success/20 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-crm-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
