---
import ClientLayout from '../../layouts/ClientLayout.astro';
---

<ClientLayout title="Historial">
  <div class="space-y-6">
    <!-- Header -->
    <section class="crm-panel-strong p-6 md:p-8">
      <p class="crm-kicker">Trayectoria</p>
      <h1 class="mt-3 text-3xl font-black text-white md:text-5xl">Historial de Trabajos</h1>
      <p class="mt-2 text-sm text-slate-300">Todos tus trabajos completados, entregados y en progreso</p>
    </section>

    <!-- Stats -->
    <section class="grid gap-4 md:grid-cols-4">
      <div class="crm-panel p-5">
        <p class="crm-kicker">Completados</p>
        <p id="stat-completed" class="mt-4 text-3xl font-black text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Entregados</p>
        <p id="stat-delivered" class="mt-4 text-3xl font-black text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">En Progreso</p>
        <p id="stat-progress" class="mt-4 text-3xl font-black text-white">—</p>
      </div>
      <div class="crm-panel p-5">
        <p class="crm-kicker">Total Assets</p>
        <p id="stat-assets" class="mt-4 text-3xl font-black text-white">—</p>
      </div>
    </section>

    <!-- Filters -->
    <section class="crm-panel p-4 flex flex-wrap gap-3 items-center">
      <select id="filter-status" class="crm-input text-sm max-w-xs">
        <option value="">Todos los estados</option>
        <option value="completed">Completado</option>
        <option value="delivered">Entregado</option>
        <option value="processing">En producción</option>
        <option value="pending">Pendiente</option>
      </select>
      <select id="filter-platform" class="crm-input text-sm max-w-xs">
        <option value="">Todas las plataformas</option>
        <option value="instagram">Instagram</option>
        <option value="tiktok">TikTok</option>
        <option value="amazon_pdp">Amazon PDP</option>
        <option value="paid_ads">Paid Ads</option>
      </select>
      <input
        type="text"
        id="search-brief"
        class="crm-input text-sm max-w-xs"
        placeholder="Buscar por nombre..."
      />
    </section>

    <!-- Jobs List -->
    <section class="crm-panel p-6 md:p-7">
      <div id="jobs-list" class="space-y-4">
        <div class="text-center py-12 text-slate-400">
          Cargando historial...
        </div>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const { api, escapeHtml, formatDate, jobStatusClass } = await import('../../lib/api-client');

      // State
      let allJobs = [];
      let filteredJobs = [];

      // DOM Elements
      const jobsList = document.getElementById('jobs-list');
      const filterStatus = document.getElementById('filter-status');
      const filterPlatform = document.getElementById('filter-platform');
      const searchBrief = document.getElementById('search-brief');

      // Status badges
      const statusLabels = {
        pending: 'Pendiente',
        processing: 'En producción',
        completed: 'Completado',
        delivered: 'Entregado',
        failed: 'Fallido',
      };

      // Load jobs
      async function loadJobs() {
        try {
          const { jobs } = await api('/api/portal/jobs');
          allJobs = jobs.sort((a, b) =>
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
          );
          filteredJobs = [...allJobs];
          renderJobs();
          updateStats();
        } catch (error) {
          console.error('Error loading jobs:', error);
          jobsList.innerHTML = `
            <div class="text-center py-12">
              <p class="text-slate-400">Error cargando historial</p>
              <button onclick="window.location.reload()" class="crm-button crm-button-primary mt-4">
                Recargar
              </button>
            </div>
          `;
        }
      }

      // Update stats
      function updateStats() {
        const completed = allJobs.filter(j => j.status === 'completed').length;
        const delivered = allJobs.filter(j => j.status === 'delivered').length;
        const progress = allJobs.filter(j => ['pending', 'processing'].includes(j.status)).length;

        // Count total assets
        Promise.all(allJobs.map(j => api(`/api/portal/jobs/${j.id}`))).then(results => {
          const totalAssets = results.reduce((sum, r) => sum + (r.assets?.length || 0), 0);
          document.getElementById('stat-completed').textContent = completed;
          document.getElementById('stat-delivered').textContent = delivered;
          document.getElementById('stat-progress').textContent = progress;
          document.getElementById('stat-assets').textContent = totalAssets;
        });
      }

      // Filter jobs
      function applyFilters() {
        const status = filterStatus.value;
        const platform = filterPlatform.value;
        const search = searchBrief.value.toLowerCase();

        filteredJobs = allJobs.filter(job => {
          if (status && job.status !== status) return false;
          if (platform && job.platform !== platform) return false;
          if (search && !job.briefText?.toLowerCase().includes(search)) return false;
          return true;
        });

        renderJobs();
      }

      // Render jobs
      function renderJobs() {
        if (filteredJobs.length === 0) {
          jobsList.innerHTML = `
            <div class="text-center py-12 text-slate-400">
              No hay trabajos que coincidan con los filtros
            </div>
          `;
          return;
        }

        jobsList.innerHTML = filteredJobs.map(job => `
          <article class="crm-panel-soft p-5 hover:border-slate-600 transition">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="${jobStatusClass(job.status)} px-2 py-1 rounded text-xs font-medium">
                    ${statusLabels[job.status] || job.status}
                  </span>
                  <span class="text-xs text-slate-500">${escapeHtml(job.platform || '—')}</span>
                  <span class="text-xs text-slate-500">${escapeHtml(job.type || '—')}</span>
                </div>
                <h3 class="mt-2 text-lg font-semibold text-white">
                  ${escapeHtml(job.briefText || `Trabajo ${job.id.slice(0, 8)}`)}
                </h3>
                <div class="mt-2 flex items-center gap-4 text-sm text-slate-400">
                  <span>Creado: ${formatDate(job.createdAt)}</span>
                  <span>Actualizado: ${formatDate(job.updatedAt)}</span>
                  ${job.dueAt ? `<span>Due: ${formatDate(job.dueAt)}</span>` : ''}
                </div>
                <div class="mt-3 flex items-center gap-4 text-sm">
                  <span class="text-slate-400">
                    Units: <span class="text-white font-medium">${job.unitsConsumed ?? 0} / ${job.unitsPlanned ?? 0}</span>
                  </span>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <a
                  href="/client/jobs/detail?id=${job.id}"
                  class="crm-button crm-button-primary text-sm whitespace-nowrap"
                >
                  Ver detalle
                </a>
              </div>
            </div>
          </article>
        `).join('');
      }

      // Event listeners
      filterStatus.addEventListener('change', applyFilters);
      filterPlatform.addEventListener('change', applyFilters);
      searchBrief.addEventListener('input', applyFilters);

      // Initialize
      loadJobs();
    })();
  </script>
</ClientLayout>
