---
import ClientLayout from '../../layouts/ClientLayout.astro';
import { siteLinks } from '../../lib/site-links';
---

<ClientLayout title="Centro de Cliente | Grande & Gordo">
  <div class="space-y-6">
    <section class="rounded-3xl border border-zinc-800 bg-zinc-950 p-6 md:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Centro de cliente</p>
      <h1 class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">Todo tu operativo, conectado</h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-400 md:text-base">
        Desde aquí puedes seguir todos tus trabajos, revisar entregables, enviar feedback y mantener el contexto ordenado.
      </p>
    </section>

    <!-- Estado Operativo -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
      <h2 class="text-xl font-bold text-white mb-4">Estado operativo</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Plan</p>
          <p id="hub-plan" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Dataset</p>
          <p id="hub-dataset" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Capacidad</p>
          <p id="hub-capacity" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Segmento</p>
          <p id="hub-segment" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Proxima review</p>
          <p id="hub-next-review" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Ultimo contacto</p>
          <p id="hub-last-contact" class="text-base font-semibold text-white mt-1">—</p>
        </div>
        <div class="rounded-xl border border-zinc-800 bg-black p-4 md:col-span-2">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Contacto operativo</p>
          <p id="hub-account-manager" class="text-base font-semibold text-white mt-1">hola@grandeandgordo.com</p>
        </div>
      </div>
    </section>

    <!-- Accesos Rápidos -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
      <h2 class="text-xl font-bold text-white mb-4">Accesos rápidos</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/client" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-violet-600/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Dashboard</p>
              <p class="text-xs text-zinc-500 mt-0.5">Resumen de trabajos</p>
            </div>
          </div>
        </a>

        <a href="/client/jobs" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Trabajos</p>
              <p class="text-xs text-zinc-500 mt-0.5">Todos tus jobs</p>
            </div>
          </div>
        </a>

        <a href="/client/assets" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-emerald-600/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Assets</p>
              <p class="text-xs text-zinc-500 mt-0.5">Todos tus entregables</p>
            </div>
          </div>
        </a>

        <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-amber-600/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Brief</p>
              <p class="text-xs text-zinc-500 mt-0.5">Actualizar contexto</p>
            </div>
          </div>
        </a>

        <a href="/client/onboarding" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Onboarding</p>
              <p class="text-xs text-zinc-500 mt-0.5">Checklist de sesión</p>
            </div>
          </div>
        </a>

        <a href="/client/profile" class="group rounded-xl border border-zinc-800 bg-black p-5 transition hover:border-zinc-600">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-zinc-700/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-zinc-200">Perfil</p>
              <p class="text-xs text-zinc-500 mt-0.5">Tu cuenta y datos</p>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Últimos Trabajos -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-xl font-bold text-white">Últimos trabajos</h2>
          <p class="text-sm text-zinc-400 mt-1">Sigue el estado de tus jobs y entregables</p>
        </div>
        <a href="/client/jobs" class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition">Ver todos →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-black">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Brief</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Estado</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Due</th>
              <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Units</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody id="hub-jobs-body" class="divide-y divide-zinc-800">
            <tr>
              <td colspan="5" class="px-4 py-6 text-center text-zinc-500">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Últimos Assets -->
    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-xl font-bold text-white">Últimos assets</h2>
          <p class="text-sm text-zinc-400 mt-1">Tus entregables aprobados</p>
        </div>
        <a href="/client/assets" class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition">Ver todos →</a>
      </div>
      <div id="hub-assets-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <p class="text-zinc-500">Cargando assets...</p>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const {
        api,
        datasetStatusClass,
        escapeHtml,
        formatDate,
        formatNumber,
        getSessionContext,
        jobStatusClass,
        subscriptionClass,
      } = await import('../../lib/api-client');

      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      try {
        const [session, jobsData, assetsData] = await Promise.all([
          getSessionContext(),
          api('/api/portal/jobs'),
          api('/api/portal/assets').catch(() => ({ assets: [] })),
        ]);

        const client = session?.client;
        const jobs = Array.isArray(jobsData.jobs) ? jobsData.jobs : [];
        const assets = Array.isArray(assetsData.assets) ? assetsData.assets : [];

        // Estado operativo
        if (client) {
          setText('hub-plan', client.plan ?? 'Sin plan definido');
          setText('hub-dataset', client.datasetStatus ?? 'pending_capture');
          setText('hub-capacity', `${formatNumber(client.monthlyUnitCapacity ?? 0)} unidades`);
          setText('hub-segment', `${client.segment ?? 'Sin segmento'} / ${client.marginProfile ?? 'Sin margen'}`);
          setText('hub-next-review', formatDate(client.nextReviewAt));
          setText('hub-last-contact', formatDate(client.lastContactedAt));
          setText('hub-account-manager', client.accountManager ?? 'hola@grandeandgordo.com');

          const datasetEl = document.getElementById('hub-dataset');
          if (datasetEl) {
            datasetEl.className = `text-base font-semibold mt-1 ${datasetStatusClass(client.datasetStatus ?? '')}`;
          }

          const planEl = document.getElementById('hub-plan');
          if (planEl) {
            planEl.className = `text-base font-semibold mt-1 ${subscriptionClass(client.subscriptionStatus ?? 'inactive')}`;
          }
        }

        // Últimos trabajos (top 5)
        const jobsBody = document.getElementById('hub-jobs-body');
        if (jobsBody) {
          if (jobs.length === 0) {
            jobsBody.innerHTML = `
              <tr>
                <td colspan="5" class="px-4 py-6 text-center text-zinc-500">Todavía no tienes trabajos activos.</td>
              </tr>
            `;
          } else {
            const recentJobs = jobs.slice(0, 5);
            jobsBody.innerHTML = recentJobs.map((job) => `
              <tr class="hover:bg-zinc-900 transition">
                <td class="px-4 py-3">
                  <p class="font-medium text-white">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
                  <p class="text-xs text-zinc-500 mt-0.5">${escapeHtml(job.platform ?? 'Sin plataforma')} · ${escapeHtml(job.type ?? 'Sin tipo')}</p>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                    ${escapeHtml(job.status ?? 'pending')}
                  </span>
                </td>
                <td class="px-4 py-3 text-zinc-400">${escapeHtml(formatDate(job.dueAt))}</td>
                <td class="px-4 py-3 text-zinc-400">${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}</td>
                <td class="px-4 py-3 text-right">
                  <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-white underline decoration-zinc-700 underline-offset-4 transition hover:decoration-white">Ver</a>
                </td>
              </tr>
            `).join('');
          }
        }

        // Últimos assets (top 6)
        const assetsGrid = document.getElementById('hub-assets-grid');
        if (assetsGrid) {
          if (assets.length === 0) {
            assetsGrid.innerHTML = '<p class="text-zinc-500 col-span-full">Todavía no hay assets aprobados.</p>';
          } else {
            const recentAssets = assets.slice(0, 6);
            assetsGrid.innerHTML = recentAssets.map((asset) => `
              <article class="rounded-xl border border-zinc-800 bg-black p-4">
                <p class="text-sm font-semibold text-white">${escapeHtml(asset.label ?? asset.type)}</p>
                <p class="text-xs text-zinc-500 mt-1">${escapeHtml(asset.type ?? 'asset')}</p>
                ${
                  asset.deliveryUrl
                    ? `<a href="${escapeHtml(asset.deliveryUrl)}" target="_blank" rel="noreferrer" class="inline-block mt-3 text-xs font-semibold text-violet-400 hover:text-violet-300 transition">Abrir asset →</a>`
                    : '<p class="text-xs text-zinc-500 mt-3">Disponible pronto</p>'
                }
              </article>
            `).join('');
          }
        }
      } catch (error) {
        console.error('Hub loading error:', error);
      }
    })();
  </script>
</ClientLayout>
