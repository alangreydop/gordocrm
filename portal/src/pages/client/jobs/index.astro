---
import ClientLayout from '../../../layouts/ClientLayout.astro';
---

<ClientLayout title="Mis trabajos">
  <div class="space-y-6">
    <section class="crm-page-header">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="crm-kicker">Produccion</p>
          <h1 class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">Mis trabajos</h1>
          <p class="crm-page-header__meta mt-4">
            Seguimiento de todos tus trabajos con deadline, estado y consumo de unidades.
          </p>
        </div>
        <input
          type="search"
          id="jobs-search"
          placeholder="Buscar por brief, plataforma o tipo"
          class="crm-input w-full md:w-80"
        />
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-4">
      <div class="crm-metric-card">
        <p class="crm-kicker">Total trabajos</p>
        <p id="metric-total" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">En produccion</p>
        <p id="metric-processing" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Completados</p>
        <p id="metric-completed" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="crm-metric-card">
        <p class="crm-kicker">Pendientes feedback</p>
        <p id="metric-feedback" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
    </div>

    <div class="crm-table-wrap">
      <div class="overflow-x-auto">
        <table class="crm-table min-w-full divide-y divide-gray-200 text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left">Brief</th>
              <th class="px-6 py-3 text-left">Plataforma</th>
              <th class="px-6 py-3 text-left">Tipo</th>
              <th class="px-6 py-3 text-left">Estado</th>
              <th class="px-6 py-3 text-left">Due</th>
              <th class="px-6 py-3 text-left">Unidades</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody id="jobs-body" class="divide-y divide-gray-200">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-slate-400">Cargando trabajos...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        escapeHtml,
        formatDate,
        formatNumber,
        jobStatusClass,
      } = await import('../../../lib/api-client');

      const tbody = document.getElementById('jobs-body');
      const searchInput = document.getElementById('jobs-search');
      let jobs = [];

      const setMetric = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
      };

      const isDueSoon = (value) => {
        if (!value) return false;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return false;
        const now = new Date();
        const diff = date.getTime() - now.getTime();
        return diff >= 0 && diff <= 7 * 24 * 60 * 60 * 1000;
      };

      const render = () => {
        if (!tbody) return;

        const query =
          searchInput instanceof HTMLInputElement
            ? searchInput.value.trim().toLowerCase()
            : '';

        const filtered = jobs.filter((job) => {
          if (!query) return true;
          return [
            job.briefText,
            job.platform,
            job.type,
          ]
            .filter(Boolean)
            .some((value) => String(value).toLowerCase().includes(query));
        });

        // Metricas
        setMetric('metric-total', String(jobs.length));
        setMetric('metric-processing', String(jobs.filter((job) => job.status === 'processing').length));
        setMetric('metric-completed', String(jobs.filter((job) => ['completed', 'delivered'].includes(job.status)).length));
        setMetric('metric-feedback', String(jobs.filter((job) => job.status === 'completed' && (!job.assets || job.assets.length === 0)).length));

        if (filtered.length === 0) {
          tbody.innerHTML = `
            <tr class="bg-zinc-950/50">
              <td colspan="7" class="px-6 py-16 text-center">
                <div class="flex flex-col items-center justify-center gap-3">
                  <div class="rounded-full bg-zinc-900 p-4 text-zinc-500">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  </div>
                  <p class="text-zinc-400 font-medium">No encontramos trabajos que coincidan con tu búsqueda</p>
                  <p class="text-xs text-zinc-600">Prueba con otros términos o revisa tus filtros</p>
                  <button onclick="document.getElementById('jobs-search').value=''; document.getElementById('jobs-search').dispatchEvent(new Event('input'))" class="mt-2 text-xs text-sky-400 hover:text-sky-300 transition underline">Limpiar búsqueda</button>
                </div>
              </td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = filtered.map((job) => {
          const progress = job.unitsPlanned > 0
            ? Math.round((job.unitsConsumed / job.unitsPlanned) * 100)
            : 0;
          const isProcessing = job.status === 'processing';
          const assetsCount = job.assetsCount ?? 0;

          return `
          <tr class="hover:bg-gray-50 align-top">
            <td class="px-6 py-4">
              <p class="font-medium text-white max-w-xs truncate">${escapeHtml(job.briefText ?? 'Sin brief')}</p>
              <p class="text-xs text-gray-500 mt-1">Actualizado ${escapeHtml(formatDate(job.updatedAt))}</p>
              ${assetsCount > 0 ? `
                <p class="text-xs text-emerald-400 mt-1">${assetsCount} asset${assetsCount !== 1 ? 's' : ''} completado${assetsCount !== 1 ? 's' : ''}</p>
              ` : ''}
              ${isProcessing && progress > 0 ? `
                <div class="mt-2 flex items-center gap-2">
                  <div class="flex-1 h-1.5 bg-gray-700 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-500 rounded-full transition-all" style="width: ${progress}%"></div>
                  </div>
                  <span class="text-xs text-emerald-400 font-medium">${progress}%</span>
                </div>
              ` : ''}
            </td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(job.platform ?? '—')}</td>
            <td class="px-6 py-4 text-gray-600">${escapeHtml(job.type ?? '—')}</td>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-medium ${jobStatusClass(job.status ?? '')}">
                ${escapeHtml(job.status ?? 'pending')}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-600">
              ${escapeHtml(formatDate(job.dueAt))}
              ${isDueSoon(job.dueAt) ? '<span class="ml-2 inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-rose-500/20 text-rose-200">Pronto</span>' : ''}
            </td>
            <td class="px-6 py-4 text-gray-600">
              ${escapeHtml(formatNumber(job.unitsConsumed ?? 0))} / ${escapeHtml(formatNumber(job.unitsPlanned ?? 0))}
            </td>
            <td class="px-6 py-4 text-right">
              <a href="/client/jobs/detail?id=${encodeURIComponent(job.id)}" class="font-medium text-sky-200 transition hover:text-white">
                Abrir
              </a>
            </td>
          </tr>
        `}).join('');
      };

      try {
        const data = await api('/api/portal/jobs');
        jobs = Array.isArray(data.jobs) ? data.jobs : [];
        render();
      } catch {
        if (tbody) {
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-rose-200">No se pudieron cargar los trabajos.</td>
            </tr>
          `;
        }
      }

      searchInput?.addEventListener('input', render);
    })();
  </script>
</ClientLayout>
