---
import ClientLayout from '../../../layouts/ClientLayout.astro';
import MetricCard from '../../../components/MetricCard.astro';
import { siteLinks } from '../../../lib/site-links';
---

<ClientLayout title="Detalle trabajo">
  <div class="space-y-6" role="region" aria-label="Detalle del trabajo">
    <section class="crm-panel-strong p-6 md:p-8">
      <a href="/client" class="inline-block text-sm text-crm-text-secondary transition hover:text-crm-text">&larr; Resumen</a>
      <div class="mt-5 flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
        <div class="grid gap-3">
          <p class="crm-kicker crm-kicker--accent">Detalle del trabajo</p>
          <h1 id="job-title" class="crm-page-header__title">Cargando trabajo...</h1>
          <p id="job-subtitle" class="crm-page-header__meta">
            Estamos reuniendo el estado del encargo, el historial de revisión y los assets ya aprobados.
          </p>
        </div>
        <span id="job-status-pill" class="crm-badge crm-badge-default self-start" role="status">Sin estado</span>
      </div>
    </section>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <MetricCard kicker="Plataforma">
        <p id="job-platform" class="crm-metric-card__value">—</p>
        <p class="crm-metric-card__meta">Canal principal del encargo</p>
      </MetricCard>
      <MetricCard kicker="Tipo">
        <p id="job-type" class="crm-metric-card__value">—</p>
        <p class="crm-metric-card__meta">Formato y naturaleza de la entrega</p>
      </MetricCard>
      <MetricCard kicker="Entrega prevista">
        <p id="job-due" class="crm-metric-card__value">—</p>
        <p class="crm-metric-card__meta">Fecha comprometida para la siguiente salida</p>
      </MetricCard>
      <MetricCard kicker="Consumo">
        <p id="job-units" class="crm-metric-card__value">—</p>
        <p class="crm-metric-card__meta">Unidades consumidas frente al plan</p>
      </MetricCard>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
      <section class="crm-panel p-6 md:p-7" role="region" aria-label="Assets aprobados">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div class="space-y-2">
            <p class="crm-kicker">Entregables</p>
            <h2 class="text-2xl font-bold tracking-tight text-crm-text">Assets aprobados y material de apoyo</h2>
            <p class="text-sm leading-relaxed text-crm-text-secondary">
              Aquí verás las piezas listas para descargar y también podrás subir material nuevo si el equipo necesita más contexto.
            </p>
          </div>
          <button id="download-all-btn" class="crm-button crm-button-secondary text-sm">
            Descargar todo
          </button>
        </div>

        <div id="assets-grid" class="mt-6 grid gap-4 md:grid-cols-2">
          <p class="text-crm-muted">Cargando assets...</p>
        </div>

        <div class="mt-6 border-t border-crm-border pt-6">
          <div class="space-y-2">
            <p class="crm-kicker">Subir material</p>
            <h3 class="text-lg font-semibold tracking-tight text-crm-text">Añadir contexto al trabajo</h3>
            <p class="text-sm leading-relaxed text-crm-text-secondary">
              Comparte referencias, archivos fuente o piezas del cliente para acelerar la siguiente revisión.
            </p>
          </div>
          <div id="quota-info" class="mt-4 text-xs text-crm-muted" aria-live="polite">Cargando quota...</div>
          <form id="upload-form" class="mt-4 flex flex-col gap-3">
            <input
              type="file"
              id="upload-file"
              accept="image/jpeg,image/png,image/webp,video/mp4,video/quicktime"
              class="crm-input text-sm"
            />
            <div class="flex flex-wrap items-center gap-3">
              <button type="submit" id="upload-btn" class="crm-button crm-button-primary text-sm">
                Subir archivo
              </button>
              <span id="upload-status" class="hidden text-xs" aria-live="polite"></span>
            </div>
            <p class="text-xs text-crm-muted">Máximo 20 MB. JPG, PNG, WebP.</p>
          </form>
        </div>
      </section>

      <section class="space-y-6">
        <div
          id="progress-box"
          class="hidden rounded-[1.4rem] border p-6"
          style="border-color: color-mix(in srgb, var(--crm-info) 20%, transparent); background-color: color-mix(in srgb, var(--crm-info) 10%, transparent); color: var(--crm-info);"
          role="status"
        >
          <h2 class="font-semibold text-crm-text">Trabajo en marcha</h2>
          <p class="mt-2 text-sm leading-relaxed">Seguimos trabajando. Los assets aparecerán aquí en cuanto queden revisados y aprobados.</p>
        </div>

        <div class="crm-panel p-6 md:p-7" role="region" aria-label="Timeline del trabajo">
          <p class="crm-kicker">Timeline</p>
          <h2 class="mt-3 text-xl font-bold tracking-tight text-crm-text">Dónde está ahora el trabajo</h2>
          <div id="job-timeline" class="mt-5 space-y-4" aria-live="polite">
            <div class="flex items-start gap-3">
              <div class="mt-2 h-2 w-2 rounded-full bg-crm-muted"></div>
              <div>
                <p class="text-sm font-medium text-crm-text-secondary">Cargando timeline...</p>
              </div>
            </div>
          </div>
        </div>

        <div class="crm-panel p-6 md:p-7" role="region" aria-label="Feedback del asset">
          <p class="crm-kicker">Revisión</p>
          <h2 class="mt-3 text-xl font-bold tracking-tight text-crm-text">Pide cambios con contexto claro</h2>
          <div class="mt-4 space-y-3">
            <textarea id="feedback-text" rows="4" class="crm-input text-sm" placeholder="Describe el ajuste, el motivo y la intención del cambio..."></textarea>
            <button id="send-feedback-btn" class="crm-button crm-button-primary w-full text-sm">
              Enviar feedback
            </button>
            <p class="text-xs text-crm-muted">Tu feedback entra directo en el flujo de producción del equipo.</p>
          </div>
        </div>

        <div class="crm-panel p-6 md:p-7" role="region" aria-label="Historial de feedback">
          <p class="crm-kicker">Historial</p>
          <h2 class="mt-3 text-xl font-bold tracking-tight text-crm-text">Feedback enviado</h2>
          <div id="feedback-history" class="mt-4 space-y-3" aria-live="polite">
            <p class="text-sm text-crm-muted">Cargando historial...</p>
          </div>
        </div>

        <div class="crm-panel p-6 md:p-7" role="region" aria-label="Mensajes del equipo">
          <p class="crm-kicker">Equipo</p>
          <h2 class="mt-3 text-xl font-bold tracking-tight text-crm-text">Mensajes y aclaraciones</h2>
          <div id="team-messages" class="mt-4 space-y-3" aria-live="polite">
            <p class="text-sm text-crm-muted">Cargando mensajes...</p>
          </div>
        </div>

        <div class="crm-panel p-6 md:p-7" role="region" aria-label="Soporte y contexto">
          <p class="crm-kicker">Contexto</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-crm-text">Todo alineado alrededor del encargo</h2>
          <div class="mt-4 space-y-3 text-sm text-crm-text-secondary">
            <p><span class="font-medium text-crm-text">Contacto:</span> hola@grandeandgordo.com</p>
            <p><span class="font-medium text-crm-text">Si necesitas algo urgente:</span> responde por email indicando el trabajo y el objetivo del cambio.</p>
          </div>
          <div class="mt-5 grid gap-3">
            <a href={siteLinks.brief} class="crm-button crm-button-secondary">Actualizar brief</a>
            <a href={siteLinks.onboarding} class="crm-button crm-button-secondary">Ver activación</a>
            <a href={siteLinks.portalHub} class="crm-button crm-button-secondary">Abrir centro de cliente</a>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    (async () => {
      const {
        API_BASE,
        api,
        escapeHtml,
        formatDate,
        formatNumber,
      } = await import('../../../lib/api-client');
      const { jobStatusClass, jobStatusLabel } = await import('../../../lib/ui-helpers');

      const jobId = new URLSearchParams(window.location.search).get('id');
      if (!jobId) {
        window.location.href = '/client';
        return;
      }

      const jobStatusSteps = {
        pending: { label: 'Pendiente', step: 1 },
        processing: { label: 'En producción', step: 2 },
        completed: { label: 'Completado', step: 3 },
        delivered: { label: 'Entregado', step: 4 },
      };

      const timelineSteps = [
        { step: 1, label: 'Brief recibido', description: 'El trabajo se abrió y quedó listo para producción.' },
        { step: 2, label: 'En producción', description: 'Estamos desarrollando las piezas y revisando materiales.' },
        { step: 3, label: 'QA completado', description: 'Los assets ya superaron la revisión interna.' },
        { step: 4, label: 'Entregado', description: 'Las versiones finales están listas para descarga.' },
      ];

      const assetsGrid = document.getElementById('assets-grid');
      let lightboxEl;
      let lightboxKeyHandler;

      const closeLightbox = () => {
        if (lightboxEl) {
          lightboxEl.remove();
          lightboxEl = undefined;
        }
        if (lightboxKeyHandler) {
          document.removeEventListener('keydown', lightboxKeyHandler);
          lightboxKeyHandler = undefined;
        }
      };

      const showLightbox = (url, type) => {
        closeLightbox();

        lightboxEl = document.createElement('div');
        lightboxEl.className = 'fixed inset-0 z-50 flex items-center justify-center p-4 backdrop-blur-md';
        lightboxEl.style.background = 'rgba(11, 6, 8, 0.84)';
        lightboxEl.innerHTML = `
          <button class="absolute right-4 top-4 z-10 text-[rgba(255,253,253,0.76)] transition hover:text-[rgba(255,253,253,1)]" type="button" aria-label="Cerrar preview">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
          <div class="max-h-[85vh] max-w-5xl">
            ${type === 'video'
              ? `<video src="${url}" controls class="max-h-[85vh] max-w-full rounded-2xl"></video>`
              : `<img src="${url}" alt="Asset preview" class="max-h-[85vh] max-w-full rounded-2xl object-contain" decoding="async" />`
            }
            <div class="mt-4 flex flex-wrap justify-center gap-3">
              <a href="${url}" download class="crm-button crm-button-primary">Descargar</a>
              <a href="${url}" target="_blank" rel="noreferrer" class="crm-button crm-button-secondary">Abrir aparte</a>
            </div>
          </div>
        `;

        const closeButton = lightboxEl.querySelector('button');
        closeButton?.addEventListener('click', closeLightbox);
        lightboxEl.addEventListener('click', (event) => {
          if (event.target === lightboxEl) closeLightbox();
        });

        lightboxKeyHandler = (event) => {
          if (event.key === 'Escape') closeLightbox();
        };
        document.addEventListener('keydown', lightboxKeyHandler);

        document.body.appendChild(lightboxEl);
      };

      const renderAssetsMarkup = (assets) => {
        if (!assets.length) {
          return '<div class="crm-empty md:col-span-2">Todavía no hay assets aprobados para este trabajo.</div>';
        }

        return assets.map((asset, index) => `
          <article class="crm-panel-soft cursor-pointer overflow-hidden p-4 group" data-asset-url="${escapeHtml(asset.deliveryUrl || '')}" data-asset-type="${escapeHtml(asset.type || 'image')}">
            <div class="relative mb-4 overflow-hidden rounded-[1.2rem] bg-[rgba(255,248,251,0.92)]">
              ${asset.type === 'video'
                ? `<div class="aspect-video flex items-center justify-center bg-[rgba(255,248,251,0.92)]">
                     <svg class="h-12 w-12 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0 0 10 9.87v4.263a1 1 0 0 0 1.555.832l3.197-2.132a1 1 0 0 0 0-1.664Z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                   </div>`
                : `<img src="${asset.deliveryUrl || '/placeholder-asset.jpg'}" alt="${escapeHtml(asset.label || 'Asset')}" class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" loading="lazy" decoding="async" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                   <div class="hidden aspect-video items-center justify-center bg-[rgba(255,248,251,0.92)]">
                     <svg class="h-12 w-12 text-crm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 0 1 2.828 0L16 16m-2-2 1.586-1.586a2 2 0 0 1 2.828 0L20 14m-6-6h.01M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z"/></svg>
                   </div>`
              }
              <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-3 p-3 opacity-0 transition-opacity group-hover:opacity-100" style="background: linear-gradient(180deg, rgba(11, 6, 8, 0), rgba(11, 6, 8, 0.44));">
                <span class="crm-badge ${asset.type === 'video' ? 'crm-badge-accent' : 'crm-badge-default'}">
                  ${asset.type === 'video' ? 'Video' : 'Imagen'}
                </span>
                <span class="text-xs font-medium text-[rgba(255,253,253,0.92)]">Ver preview</span>
              </div>
            </div>
            <p class="text-base font-semibold text-crm-text">${escapeHtml(asset.label ?? `Asset ${index + 1}`)}</p>
            <p class="mt-1 text-xs text-crm-muted">${escapeHtml(asset.type ?? 'asset')}</p>
            <div class="mt-4 flex gap-2">
              ${asset.deliveryUrl
                ? `<a href="${escapeHtml(asset.deliveryUrl)}" target="_blank" rel="noreferrer" class="crm-button crm-button-primary text-xs flex-1 text-center">Abrir</a>`
                : '<p class="text-xs text-crm-muted">Preparando entrega...</p>'
              }
              ${asset.deliveryUrl
                ? `<a href="${escapeHtml(asset.deliveryUrl)}" download class="crm-button crm-button-secondary text-xs">Descargar</a>`
                : ''
              }
            </div>
          </article>
        `).join('');
      };

      const bindAssetPreviews = () => {
        if (!assetsGrid) return;

        assetsGrid.querySelectorAll('[data-asset-url]').forEach((card) => {
          card.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof HTMLElement && target.closest('a')) return;

            const url = card.getAttribute('data-asset-url');
            const type = card.getAttribute('data-asset-type');
            if (!url) return;

            showLightbox(url, type);
          });
        });
      };

      const renderAssetsGrid = (assets) => {
        if (!assetsGrid) return;
        assetsGrid.innerHTML = renderAssetsMarkup(assets);
        bindAssetPreviews();
      };

      try {
        const data = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        const job = data.job;
        const assets = Array.isArray(data.assets) ? data.assets : [];

        const title = document.getElementById('job-title');
        const subtitle = document.getElementById('job-subtitle');
        const statusPill = document.getElementById('job-status-pill');
        const progressBox = document.getElementById('progress-box');
        const timelineContainer = document.getElementById('job-timeline');
        const downloadAllBtn = document.getElementById('download-all-btn');
        const sendFeedbackBtn = document.getElementById('send-feedback-btn');
        const feedbackText = document.getElementById('feedback-text');

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;
        if (subtitle) {
          const assetCount = assets.length;
          const assetText = assetCount > 0
            ? `${assetCount} asset${assetCount !== 1 ? 's' : ''} ya aprobado${assetCount !== 1 ? 's' : ''} y disponible${assetCount !== 1 ? 's' : ''} para descarga.`
            : 'Los assets aparecerán aquí cuando superen revisión.';
          subtitle.textContent = `Actualizado ${formatDate(job.updatedAt)}. ${assetText}`;
        }
        if (statusPill) {
          statusPill.textContent = jobStatusLabel(job.status ?? 'pending');
          statusPill.className = jobStatusClass(job.status ?? 'pending');
        }

        const setText = (id, value) => {
          const element = document.getElementById(id);
          if (element) element.textContent = value;
        };

        setText('job-platform', job.platform ?? '—');
        setText('job-type', job.type ?? '—');
        setText('job-due', formatDate(job.dueAt));
        setText('job-units', `${formatNumber(job.unitsConsumed ?? 0)} / ${formatNumber(job.unitsPlanned ?? 0)}`);

        if (timelineContainer) {
          const currentStep = jobStatusSteps[job.status]?.step ?? 1;
          timelineContainer.innerHTML = timelineSteps.map((step) => {
            const isCompleted = step.step <= currentStep;
            const isCurrent = step.step === currentStep;
            return `
              <div class="flex items-start gap-3">
                <div class="mt-2 h-2 w-2 rounded-full" style="background: ${isCompleted ? 'var(--crm-success)' : 'var(--crm-muted)'}"></div>
                <div class="${isCurrent ? 'opacity-100' : 'opacity-70'}">
                  <p class="text-sm font-medium ${isCompleted ? 'text-crm-text' : 'text-crm-muted'}">${escapeHtml(step.label)}</p>
                  <p class="mt-0.5 text-xs text-crm-muted">${escapeHtml(step.description)}</p>
                </div>
              </div>
            `;
          }).join('');
        }

        renderAssetsGrid(assets);

        if (downloadAllBtn && assets.length > 0) {
          downloadAllBtn.addEventListener('click', async () => {
            try {
              const JSZip = (await import('jszip')).default;
              const zip = new JSZip();
              const folder = zip.folder('assets_gordo');

              downloadAllBtn.disabled = true;
              downloadAllBtn.textContent = 'Empaquetando...';

              const downloadPromises = assets.map(async (asset, index) => {
                if (!asset.deliveryUrl) return;
                try {
                  const response = await fetch(asset.deliveryUrl);
                  if (!response.ok) throw new Error(`HTTP ${response.status}`);
                  const blob = await response.blob();
                  const filename = `${asset.label ?? `asset_${index}`}${asset.type === 'video' ? '.mp4' : '.jpg'}`;
                  folder?.file(filename, blob);
                } catch {
                  // Continue with the rest of the zip.
                }
              });

              await Promise.all(downloadPromises);

              const content = await zip.generateAsync({ type: 'blob' });
              const url = URL.createObjectURL(content);
              const link = document.createElement('a');
              link.href = url;
              link.download = `assets_trabajo_${jobId.slice(0, 8)}.zip`;
              link.click();
              URL.revokeObjectURL(url);

              downloadAllBtn.textContent = 'Descargado';
              setTimeout(() => {
                downloadAllBtn.disabled = false;
                downloadAllBtn.textContent = 'Descargar todo';
              }, 2000);
            } catch (error) {
              console.error('Bulk download failed:', error);
              downloadAllBtn.textContent = 'Error al descargar';
              setTimeout(() => {
                downloadAllBtn.disabled = false;
                downloadAllBtn.textContent = 'Descargar todo';
              }, 2000);
            }
          });
        } else if (downloadAllBtn) {
          downloadAllBtn.disabled = true;
          downloadAllBtn.classList.add('opacity-50', 'cursor-not-allowed');
        }

        if (sendFeedbackBtn && feedbackText instanceof HTMLTextAreaElement) {
          sendFeedbackBtn.addEventListener('click', async () => {
            const feedback = feedbackText.value.trim();
            if (!feedback) {
              feedbackText.focus();
              return;
            }

            sendFeedbackBtn.disabled = true;
            sendFeedbackBtn.textContent = 'Enviando...';

            try {
              await api(`/api/portal/jobs/${encodeURIComponent(jobId)}/feedback`, {
                method: 'POST',
                body: JSON.stringify({ feedback }),
              });

              feedbackText.value = '';
              sendFeedbackBtn.textContent = 'Feedback enviado';
              setTimeout(() => {
                sendFeedbackBtn.textContent = 'Enviar feedback';
                sendFeedbackBtn.disabled = false;
              }, 2000);
            } catch (error) {
              console.error('Feedback failed:', error);
              sendFeedbackBtn.textContent = 'Error al enviar';
              setTimeout(() => {
                sendFeedbackBtn.textContent = 'Enviar feedback';
                sendFeedbackBtn.disabled = false;
              }, 2000);
            }
          });
        }

        const feedbackHistoryEl = document.getElementById('feedback-history');
        if (feedbackHistoryEl) {
          const feedbackRegex = /\[Feedback ([^\]]+)\] ([^:]+): ([\s\S]*?)(?=\n\[Feedback|$)/g;
          const feedbacks = [];
          let match;

          if (job.internalNotes) {
            while ((match = feedbackRegex.exec(job.internalNotes)) !== null) {
              feedbacks.push({
                timestamp: match[1],
                author: match[2],
                text: match[3].trim(),
              });
            }
          }

          if (feedbacks.length === 0) {
            feedbackHistoryEl.innerHTML = '<p class="text-sm text-crm-muted">Aún no has enviado feedback para este trabajo.</p>';
          } else {
            feedbackHistoryEl.innerHTML = feedbacks.reverse().map((feedback) => `
              <div class="rounded-[1.1rem] border border-crm-border bg-[rgba(255,248,251,0.92)] p-4">
                <div class="mb-2 flex items-center justify-between gap-3">
                  <span class="crm-badge crm-badge-success">Enviado</span>
                  <span class="text-xs text-crm-text-secondary">${escapeHtml(feedback.timestamp)}</span>
                </div>
                <p class="text-sm whitespace-pre-wrap text-crm-text-secondary">${escapeHtml(feedback.text)}</p>
              </div>
            `).join('');
          }
        }

        const teamMessagesEl = document.getElementById('team-messages');
        if (teamMessagesEl) {
          const teamMessageRegex = /\[TeamMessage ([^\]]+)\] ([^:]+): ([\s\S]*?)(?=\n\[Feedback|\[TeamMessage|$)/g;
          const teamMessages = [];
          let match;

          if (job.internalNotes) {
            while ((match = teamMessageRegex.exec(job.internalNotes)) !== null) {
              teamMessages.push({
                timestamp: match[1],
                author: match[2],
                text: match[3].trim(),
              });
            }
          }

          if (teamMessages.length === 0) {
            teamMessagesEl.innerHTML = '<p class="text-sm text-crm-muted">Todavía no hay mensajes del equipo. Si hace falta información, aparecerá aquí.</p>';
          } else {
            teamMessagesEl.innerHTML = teamMessages.reverse().map((message) => `
              <div class="rounded-[1.1rem] border p-4" style="border-color: color-mix(in srgb, var(--crm-info) 45%, transparent); background-color: color-mix(in srgb, var(--crm-info) 12%, transparent);">
                <div class="mb-2 flex items-center justify-between gap-3">
                  <div class="flex items-center gap-2">
                    <span class="crm-badge crm-badge-info">Equipo</span>
                    <span class="text-xs text-crm-info opacity-80">${escapeHtml(message.author)}</span>
                  </div>
                  <span class="text-xs text-crm-text-secondary">${escapeHtml(message.timestamp)}</span>
                </div>
                <p class="text-sm whitespace-pre-wrap text-crm-text-secondary">${escapeHtml(message.text)}</p>
              </div>
            `).join('');
          }
        }

        if (progressBox && assets.length === 0 && job.status !== 'completed' && job.status !== 'delivered') {
          progressBox.classList.remove('hidden');
        }

        const quotaInfo = document.getElementById('quota-info');
        try {
          const quota = await api('/api/portal/upload/quota');
          if (quotaInfo) {
            const usedMB = (quota.storageUsed / (1024 * 1024)).toFixed(1);
            const maxMB = (quota.storageMax / (1024 * 1024)).toFixed(0);
            const remainingMB = (quota.storageRemaining / (1024 * 1024)).toFixed(1);
            quotaInfo.innerHTML = `<span class="text-crm-text-secondary">${quota.filesUsed}/${quota.filesMax} archivos · ${usedMB}/${maxMB} MB usados · ${remainingMB} MB libres</span>`;
          }
        } catch {
          if (quotaInfo) quotaInfo.textContent = '';
        }

        const uploadForm = document.getElementById('upload-form');
        const uploadFile = document.getElementById('upload-file');
        const uploadBtn = document.getElementById('upload-btn');
        const uploadStatus = document.getElementById('upload-status');

        uploadForm?.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!(uploadFile instanceof HTMLInputElement) || !uploadFile.files?.length) {
            uploadFile?.focus();
            return;
          }

          const file = uploadFile.files[0];
          const formData = new FormData();
          formData.append('file', file);

          if (uploadBtn instanceof HTMLButtonElement) {
            uploadBtn.disabled = true;
            uploadBtn.textContent = 'Subiendo...';
          }
          if (uploadStatus) {
            uploadStatus.className = 'text-xs text-crm-info';
            uploadStatus.textContent = 'Subiendo...';
            uploadStatus.classList.remove('hidden');
          }

          try {
            const response = await fetch(`${API_BASE}/api/portal/upload/jobs/${encodeURIComponent(jobId)}/upload`, {
              method: 'POST',
              body: formData,
              credentials: 'include',
            });

            if (!response.ok) {
              const payload = await response.json().catch(() => ({ error: 'Error desconocido' }));
              throw new Error(payload.error || 'Error al subir archivo');
            }

            uploadFile.value = '';
            if (uploadBtn instanceof HTMLButtonElement) {
              uploadBtn.disabled = false;
              uploadBtn.textContent = 'Subir archivo';
            }
            if (uploadStatus) {
              uploadStatus.className = 'text-xs text-crm-success';
              uploadStatus.textContent = 'Subido correctamente';
            }

            const refreshed = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
            const refreshedAssets = Array.isArray(refreshed.assets) ? refreshed.assets : [];
            renderAssetsGrid(refreshedAssets);
          } catch (error) {
            console.error('Upload failed:', error);
            if (uploadBtn instanceof HTMLButtonElement) {
              uploadBtn.disabled = false;
              uploadBtn.textContent = 'Subir archivo';
            }
            if (uploadStatus) {
              uploadStatus.className = 'text-xs text-crm-danger';
              uploadStatus.textContent = error instanceof Error ? error.message : 'Error al subir';
            }
          }
        });
      } catch {
        window.location.href = '/client';
      }
    })();
  </script>
</ClientLayout>
