---
import ClientLayout from '../../../layouts/ClientLayout.astro';
import { siteLinks } from '../../../lib/site-links';
---

<ClientLayout title="Detalle trabajo">
  <div class="space-y-6">
    <div>
      <a href="/client" class="text-sm text-gray-500 hover:text-gray-700 inline-block">&larr; Resumen</a>
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between mt-2">
        <div>
          <h1 id="job-title" class="text-2xl font-bold">Cargando trabajo...</h1>
          <p id="job-subtitle" class="text-gray-500 mt-1">Estamos cargando el detalle y los assets aprobados.</p>
        </div>
        <span id="job-status-pill" class="inline-flex px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-600">—</span>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Plataforma</p>
        <p id="job-platform" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Tipo</p>
        <p id="job-type" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Due</p>
        <p id="job-due" class="text-3xl font-bold mt-2">—</p>
      </div>
      <div class="bg-white rounded-lg shadow p-5">
        <p class="text-sm text-gray-500">Units</p>
        <p id="job-units" class="text-3xl font-bold mt-2">—</p>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.2fr_.8fr]">
      <section class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold mb-4">Assets aprobados</h2>
        <div id="assets-grid" class="grid gap-4 md:grid-cols-2">
          <p class="text-gray-500">Cargando assets...</p>
        </div>
      </section>

      <section class="space-y-6">
        <div id="progress-box" class="hidden bg-blue-50 rounded-lg p-6 text-blue-700">
          <h2 class="font-semibold text-blue-900">Trabajo en marcha</h2>
          <p class="mt-2">Estamos trabajando en ello. Los assets apareceran aqui en cuanto esten listos y aprobados.</p>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold">Soporte y contexto</h2>
          <div class="mt-4 space-y-3 text-sm text-gray-600">
            <p><span class="font-medium text-gray-900">Contacto:</span> hola@grandeandgordo.com</p>
            <p><span class="font-medium text-gray-900">Si necesitas algo urgente:</span> responde por email indicando el trabajo y el objetivo del cambio.</p>
          </div>
          <div class="mt-5 grid gap-3">
            <a href={siteLinks.brief} target="_blank" rel="noreferrer" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-300 hover:text-gray-900">
              Actualizar brief
            </a>
            <a href={siteLinks.onboarding} target="_blank" rel="noreferrer" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-300 hover:text-gray-900">
              Ver onboarding
            </a>
            <a href={siteLinks.portalHub} target="_blank" rel="noreferrer" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-300 hover:text-gray-900">
              Abrir centro de cliente
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    (async () => {
      const {
        api,
        escapeHtml,
        formatDate,
        formatNumber,
        jobStatusClass,
      } = await import('../../../lib/api-client');

      const jobId = new URLSearchParams(window.location.search).get('id');
      if (!jobId) {
        window.location.href = '/client';
        return;
      }

      try {
        const data = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        const job = data.job;
        const assets = Array.isArray(data.assets) ? data.assets : [];

        const title = document.getElementById('job-title');
        const subtitle = document.getElementById('job-subtitle');
        const statusPill = document.getElementById('job-status-pill');
        const assetsGrid = document.getElementById('assets-grid');
        const progressBox = document.getElementById('progress-box');

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;
        if (subtitle) {
          subtitle.textContent = `Actualizado ${formatDate(job.updatedAt)} · assets visibles solo cuando estan aprobados.`;
        }
        if (statusPill) {
          statusPill.textContent = job.status ?? 'pending';
          statusPill.className = `inline-flex px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}`;
        }

        const setText = (id, value) => {
          const element = document.getElementById(id);
          if (element) element.textContent = value;
        };

        setText('job-platform', job.platform ?? '—');
        setText('job-type', job.type ?? '—');
        setText('job-due', formatDate(job.dueAt));
        setText('job-units', `${formatNumber(job.unitsConsumed ?? 0)} / ${formatNumber(job.unitsPlanned ?? 0)}`);

        if (assetsGrid) {
          assetsGrid.innerHTML = assets.length === 0
            ? '<p class="text-gray-500">Todavia no hay assets aprobados para este trabajo.</p>'
            : assets.map((asset) => `
              <article class="border border-gray-200 rounded-lg p-4">
                <p class="font-medium text-gray-900">${escapeHtml(asset.label ?? asset.type)}</p>
                <p class="text-xs text-gray-500 mt-1">${escapeHtml(asset.type ?? 'asset')}</p>
                <p class="text-xs text-gray-500 mt-1">Aprobado para entrega</p>
                ${
                  asset.deliveryUrl
                    ? `<a href="${escapeHtml(asset.deliveryUrl)}" target="_blank" rel="noreferrer" class="inline-flex mt-4 bg-blue-900 text-white px-3 py-2 rounded-md text-sm hover:bg-blue-800">Abrir asset</a>`
                    : '<p class="text-sm text-gray-500 mt-4">Disponible en preparacion de entrega.</p>'
                }
              </article>
            `).join('');
        }

        if (
          progressBox &&
          assets.length === 0 &&
          job.status !== 'completed' &&
          job.status !== 'delivered'
        ) {
          progressBox.classList.remove('hidden');
        }
      } catch {
        window.location.href = '/client';
      }
    })();
  </script>
</ClientLayout>
