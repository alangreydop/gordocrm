---
import ClientLayout from '../../../layouts/ClientLayout.astro';
---

<ClientLayout title="Detalle trabajo">
  <a href="/client" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">&larr; Mis trabajos</a>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start mb-4">
      <h1 id="job-title" class="text-xl font-bold">Cargando trabajo...</h1>
      <span id="job-status-pill" class="inline-block px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-600">
        —
      </span>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div>
        <p class="text-gray-500">Plataforma</p>
        <p id="job-platform" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Tipo</p>
        <p id="job-type" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Creado</p>
        <p id="job-created-at" class="font-medium">—</p>
      </div>
      <div>
        <p class="text-gray-500">Actualizado</p>
        <p id="job-updated-at" class="font-medium">—</p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h2 id="assets-heading" class="text-lg font-semibold mb-3">Assets</h2>
    <div id="assets-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <p class="text-gray-500">Cargando assets...</p>
    </div>
  </div>

  <div id="progress-box" class="hidden bg-blue-50 rounded-lg p-6 text-center text-blue-700 mt-6">
    <p>Tu trabajo esta en progreso. Los assets apareceran aqui cuando esten listos.</p>
  </div>

  <script type="module">
    import {
      api,
      escapeHtml,
      formatDate,
      getQueryParam,
      jobStatusClass,
    } from '../../../lib/api-client';

    const jobId = getQueryParam('id');
    if (!jobId) {
      window.location.href = '/client';
    } else {
      try {
        const data = await api(`/api/portal/jobs/${encodeURIComponent(jobId)}`);
        const job = data.job;
        const assets = Array.isArray(data.assets) ? data.assets : [];

        const title = document.getElementById('job-title');
        const statusPill = document.getElementById('job-status-pill');
        const platform = document.getElementById('job-platform');
        const type = document.getElementById('job-type');
        const createdAt = document.getElementById('job-created-at');
        const updatedAt = document.getElementById('job-updated-at');
        const assetsHeading = document.getElementById('assets-heading');
        const assetsGrid = document.getElementById('assets-grid');
        const progressBox = document.getElementById('progress-box');

        if (title) title.textContent = job.briefText ?? `Trabajo ${job.id.slice(0, 8)}`;
        if (platform) platform.textContent = job.platform ?? '—';
        if (type) type.textContent = job.type ?? '—';
        if (createdAt) createdAt.textContent = formatDate(job.createdAt);
        if (updatedAt) updatedAt.textContent = formatDate(job.updatedAt);

        if (statusPill) {
          statusPill.textContent = job.status ?? 'pending';
          statusPill.className = `inline-block px-2 py-1 rounded text-xs font-medium ${jobStatusClass(job.status ?? '')}`;
        }

        if (assetsHeading) assetsHeading.textContent = `Assets (${assets.length})`;
        if (assetsGrid) {
          assetsGrid.innerHTML = assets.length === 0
            ? `<p class="text-gray-500">Todavia no hay assets entregados.</p>`
            : assets.map((asset) => `
              <div class="border rounded-lg p-3 text-center">
                <p class="text-sm font-medium">${escapeHtml(asset.type)}</p>
                <p class="text-xs text-gray-500 truncate mt-1">${escapeHtml(asset.r2Key)}</p>
                ${asset.qaStatus === 'approved' ? '<span class="inline-block mt-2 px-2 py-0.5 rounded text-xs bg-green-100 text-green-800">aprobado</span>' : ''}
              </div>
            `).join('');
        }

        if (
          progressBox &&
          assets.length === 0 &&
          job.status !== 'completed' &&
          job.status !== 'delivered'
        ) {
          progressBox.classList.remove('hidden');
        }
      } catch {
        window.location.href = '/client';
      }
    }
  </script>
</ClientLayout>
