---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Inicio" section="inicio">
  <div id="client-area-root">
    <div class="crm-masthead">
      <p class="crm-kicker">Tu producción</p>
      <h1 id="account-label" class="crm-masthead-title">
        <span class="inline-block w-48 h-9 rounded animate-pulse" style="background: var(--gg-border-light);"></span>
      </h1>
      <p id="account-summary" class="crm-masthead-deck">Cargando tu estado de producción.</p>
    </div>

    <div class="crm-stats-row ca-stagger" id="metrics-grid">
      <div class="crm-stat ca-metric-enter">
        <p class="crm-kicker">En producción</p>
        <p id="metric-active-projects" class="crm-stat-num mt-3">
          <span class="inline-block w-5 h-9 rounded animate-pulse" style="background: var(--gg-border-light);"></span>
        </p>
      </div>
      <div class="crm-stat ca-metric-enter">
        <p class="crm-kicker">Pendiente de revisión</p>
        <p id="metric-pending-reviews" class="crm-stat-num mt-3">
          <span class="inline-block w-5 h-9 rounded animate-pulse" style="background: var(--gg-border-light);"></span>
        </p>
      </div>
      <div class="crm-stat ca-metric-enter">
        <p class="crm-kicker">Mensajes nuevos</p>
        <p id="metric-unread-messages" class="crm-stat-num mt-3">
          <span class="inline-block w-5 h-9 rounded animate-pulse" style="background: var(--gg-border-light);"></span>
        </p>
      </div>
    </div>

    <div class="crm-section mt-8">
      <p class="crm-section-header">Actividad reciente</p>
      <div id="timeline-feed">
        {[1,2,3,4].map(() => `
          <div class="crm-row" style="border-bottom-color: oklch(92% 0.005 355);">
            <div class="flex-1">
              <div class="h-4 w-44 rounded animate-pulse" style="background: var(--gg-border-light);"></div>
              <div class="h-3 w-20 rounded animate-pulse mt-1.5" style="background: oklch(94% 0.005 355);"></div>
            </div>
          </div>
        `).join('')}
      </div>
    </div>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toInicioViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const vm = toInicioViewModel(snapshot);

      const label = document.getElementById('account-label');
      if (label) label.textContent = vm.accountLabel;

      const summary = document.getElementById('account-summary');
      if (summary) {
        const parts: string[] = [];
        if (vm.activeProjectCount > 0) parts.push(`${vm.activeProjectCount} proyecto${vm.activeProjectCount > 1 ? 's' : ''} en curso`);
        if (vm.pendingReviewCount > 0) parts.push(`${vm.pendingReviewCount} revisión${vm.pendingReviewCount > 1 ? 'es' : ''} por aprobar`);
        if (vm.unreadMessageCount > 0) parts.push(`${vm.unreadMessageCount} mensaje${vm.unreadMessageCount > 1 ? 's' : ''} sin leer`);
        summary.textContent = parts.length > 0 ? parts.join(' · ') : 'Todo al día.';
      }

      const setMetric = (id: string, value: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(value);
      };
      setMetric('metric-active-projects', vm.activeProjectCount);
      setMetric('metric-pending-reviews', vm.pendingReviewCount);
      setMetric('metric-unread-messages', vm.unreadMessageCount);

      const timelineFeed = document.getElementById('timeline-feed');
      if (timelineFeed && vm.timeline.length > 0) {
        timelineFeed.innerHTML = vm.timeline.slice(0, 10).map((item, i) => `
          <div class="crm-row ca-card-enter" style="border-bottom-color: oklch(92% 0.005 355); animation-delay: ${i * 40}ms;">
            <div class="flex-1">
              <p class="text-sm" style="color: var(--gg-text);">${item.label}</p>
              <p class="text-xs mt-0.5" style="color: oklch(55% 0.008 355);">${item.occurredAt ? new Date(item.occurredAt).toLocaleDateString('es-ES') : ''}</p>
            </div>
          </div>
        `).join('');
      } else if (timelineFeed) {
        timelineFeed.innerHTML = `
          <div class="py-10 text-center">
            <p class="crm-kicker" style="color: oklch(55% 0.008 355);">Sin actividad</p>
            <p class="text-sm mt-2" style="color: var(--gg-text-muted);">Aquí aparecerá el historial de tu producción.</p>
          </div>`;
      }
    })();
  </script>
</ClientAreaLayout>