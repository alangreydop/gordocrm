---
import ClientAreaLayout from '../layouts/ClientAreaLayout.astro';
---

<ClientAreaLayout title="Inicio" section="inicio">
  <div id="client-area-root" class="space-y-6">
    <section class="rounded-3xl border border-zinc-800 bg-zinc-950 overflow-hidden p-6 md:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Resumen</p>
      <h1 id="account-label" class="mt-4 text-3xl font-black tracking-tight text-white md:text-5xl">
        Cargando...
      </h1>
      <p id="account-summary" class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-400 md:text-base">
        Cargando tu estado de cuenta.
      </p>
    </section>

    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Proyectos activos</p>
        <p id="metric-active-projects" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Revisiones pendientes</p>
        <p id="metric-pending-reviews" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Mensajes sin leer</p>
        <p id="metric-unread-messages" class="mt-4 text-4xl font-black tracking-tight text-white">—</p>
      </div>
    </div>

    <section class="rounded-2xl border border-zinc-800 bg-zinc-950 p-6 md:p-7">
      <p class="text-xs font-bold uppercase tracking-[0.28em] text-zinc-500">Actividad reciente</p>
      <div id="timeline-feed" class="mt-5 space-y-3">
        <p class="text-sm text-zinc-400">Cargando actividad...</p>
      </div>
    </section>
  </div>

  <script>
    (async () => {
      const { bootstrapClientArea } = await import('../lib/client-area/bootstrap');
      const { toInicioViewModel } = await import('../lib/client-area/view-models');

      const snapshot = await bootstrapClientArea();
      const vm = toInicioViewModel(snapshot);

      const label = document.getElementById('account-label');
      if (label) label.textContent = vm.accountLabel;

      const summary = document.getElementById('account-summary');
      if (summary) {
        const parts: string[] = [];
        if (vm.activeProjectCount > 0) parts.push(`${vm.activeProjectCount} proyecto${vm.activeProjectCount > 1 ? 's' : ''} activo${vm.activeProjectCount > 1 ? 's' : ''}`);
        if (vm.pendingReviewCount > 0) parts.push(`${vm.pendingReviewCount} revisión${vm.pendingReviewCount > 1 ? 'es' : ''} pendiente${vm.pendingReviewCount > 1 ? 's' : ''}`);
        if (vm.unreadMessageCount > 0) parts.push(`${vm.unreadMessageCount} mensaje${vm.unreadMessageCount > 1 ? 's' : ''} sin leer`);
        summary.textContent = parts.length > 0 ? parts.join(' · ') : 'Todo al día.';
      }

      const setMetric = (id: string, value: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(value);
      };
      setMetric('metric-active-projects', vm.activeProjectCount);
      setMetric('metric-pending-reviews', vm.pendingReviewCount);
      setMetric('metric-unread-messages', vm.unreadMessageCount);

      const timelineFeed = document.getElementById('timeline-feed');
      if (timelineFeed && vm.timeline.length > 0) {
        timelineFeed.innerHTML = vm.timeline.slice(0, 10).map((item) => `
          <div class="flex items-start gap-3">
            <div class="w-2 h-2 mt-2 rounded-full bg-zinc-700 flex-shrink-0"></div>
            <div>
              <p class="text-sm text-zinc-300">${item.label}</p>
              <p class="text-xs text-zinc-500 mt-0.5">${item.occurredAt ? new Date(item.occurredAt).toLocaleDateString('es-ES') : ''}</p>
            </div>
          </div>
        `).join('');
      } else if (timelineFeed) {
        timelineFeed.innerHTML = '<p class="text-sm text-zinc-400">Sin actividad reciente.</p>';
      }
    })();
  </script>
</ClientAreaLayout>