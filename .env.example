# Server
PORT=3000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# fal.ai (LoRA training + Flux/Kling generation)
FAL_KEY=...

# OpenAI (GPT-4V for automated QA)
OPENAI_API_KEY=sk-...

# Cloudflare R2 (asset storage)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=grande-gordo-assets
R2_PUBLIC_URL=https://assets.grandegordo.com

# PostgreSQL (Supabase — CRM portal)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Airtable (client management — legacy, migrating to PostgreSQL)
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# Redis (job queues via BullMQ)
REDIS_URL=redis://localhost:6379

# Resend (transactional email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@grandegordo.com
