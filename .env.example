# Cloudflare Worker runtime
APP_ENV=development
SESSION_SECRET=replace-this-in-production
CORS_ORIGIN=http://localhost:4321
SESSION_COOKIE_DOMAIN=.grandegordo.com

# D1 (runtime binding configured in wrangler.toml)
# DB binding name: DB

# D1 remote access for Drizzle Kit and seed script
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_DATABASE_NAME=gordocrm
CLOUDFLARE_D1_TOKEN=

# Portal
API_URL=http://127.0.0.1:8787
PUBLIC_API_URL=http://127.0.0.1:8787

# Cloudflare R2 (optional — phase 4+ asset delivery)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=grande-gordo-assets
R2_PUBLIC_URL=

# Stripe (optional — phase 4+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# fal.ai (optional — phase 4+)
FAL_KEY=

# OpenAI (optional — phase 4+)
OPENAI_API_KEY=

# Airtable (legacy import/migration only)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Cloudflare Queues / Redis replacement strategy starts later.
# Keep REDIS_URL only if you temporarily run legacy queue workers elsewhere.
REDIS_URL=

# Email (optional — phase 4+)
RESEND_API_KEY=
EMAIL_FROM=noreply@grandegordo.com
